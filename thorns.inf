! ============================================================ Initialise

[ Initialise ;
  ! #IfDef Debug;
  !   <ScriptOn>;
  ! #EndIf;

  #IfNDef DEBUG;
  print
    "If you haven't played this before, you should read the help.
    ^^Would you like to read that (y/n)? ";
  if (YesOrNo()) {
    <Help>;
    print
      "^You can always re-read that with ~HELP~.
      ^^Press ENTER to continue > ";
		_ReadPlayerInput(true, true);
  }
  #EndIf;

  #IfV5;
  ClearScreen();
  #EndIf;

  #IfDef DEBUG;
  #IfDef FULL_DEBUG;
  print "^*** FULL DEBUGGING MODE^";
  #IfNot;
  print "^*** PLAYTESTING MODE^";
  #EndIf;
  #EndIf;

  ! example of using a dynamic string
  ! string DS_PRIORY_NAME "Our Lady of Thorns";
  ! print "^^Welcome to @(1)^";
  ! print "Welcome to @(DS_PRIORY_NAME)^";

  QuoteBoxSimple(quote_opening);
  SetTime(3 * 60, 1);
  lookmode = 2;  ! verbose mode by default

  move BrAelred to Dorm;
  move BrAnselm to Dorm;
  move BrHugh to Dorm;
  move BrMartin to Dorm;

  ! just so they don't all arrive at once, making a long list of text
  move BrBenedict to Necessarium;
  move BrWilfred to Necessarium;

  ! Starting other places
  move BrRemigio to LayCells;
  move BrCuthbert to BellTower;
  move BrOswald to PriorsSolar;

  print
    "Early autumn in the year of Our Lord 1346. The priory of Our Lady of Thorns
    stands on the cliffs above Ashcombe, on the northeast coast of England.^^

    You awake at 3 AM to the sound of the tower bell. It pealed once,
    calling you to Matins, the first of eight daily Divine Offices where you and
    your brethren meet in the church downstairs to sing and pray. You are lying
    in your cot, still bleary from sleep. Like your brethren, you sleep in your
    habit, so you can rise and go to Divine Office without delay.

    ^^While you've been learning a great deal from your mentor, Brother Aelred
    the Herbalist, you had hoped that after five months here, you'd be better
    acclimatised to the early rising.^^";

  #IfDef HAS_HINTS; HintReady(Hint_intro); #EndIf;

  SceneMatins.scene_start();

  move MyRobe to player;

  ! Don't print the banner at start; print it after first office
  return 2;
];

#IfDef HAS_HINTS;
Include "./game_hints.inf";
#EndIf;


