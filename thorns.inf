! PUZZLE: identifying the poison

Room Infirmary "Infirmary"                                          ! >Infirmary
  with
    description [;
      if (self hasnt visited)
        print
          "The Infirmary serves both the brothers and visiting villagers who
          seek healing. ";
      "Several narrow beds line the western wall. A workbench holds
      mortars and bowls for preparing remedies. The air
      has a sharp tang.
      ^^The Infirmary Chapel is to the south, and the Slype is to the west.";
    ],
    #IfDef HAS_HINTS;
    on_first_entry [;
       HintReady(Hint_Infirmary);
    ],
    #EndIf;
    s_to InfirmaryChapel,
    out_to Slype,
    w_to Slype,
    before [;
      Smell: if (noun == nothing)
        "The air smells of herbs, vinegar, and illness.";
    ],
    cheap_scenery
      'beds' 'cots' "They're just simple cots, with nothing on or under them."
      4 'mortars' 'mortar' 'bowls' 'bowl' [;
        Examine: "The mortars and bowls are used for grinding medicine.";
        Smell: "They don't smell of anything---perhaps they haven't been used in
          a while?";
        Taste, Search, Empty: "There's nothing in them.";
        Take, Receive: "Don't mess with Brother Benedict's work tools.";
      ]
      1 2 'work' 'workbench' 'bench' [;
        Examine: "A plain wood table holding the mortars and bowls.";
        Receive: "Don't add your stuff to Brother Benedict's work space.";
      ]
    ,
  has
    ;


Object -> Mirror "mirror"                                              ! >Mirror
  class AdjObject,
  with
    adj_name 'reflective' 'metal',
    noun_name 'mirror' 'plate',
    react_before [;
      Examine:
        if (noun == player) {
          print "(in the mirror)^";
          <<Examine Mirror>>;
        }
    ],
    initial "A polished metal mirror hangs on the wall.",
    before [;
      Examine:
        "A young face, barely requiring shaving, stares back at you. Your black
        Benedictine habit hangs loose on your thin frame. No tonsure marks your
        crown---you're still a novice, not yet bound by final vows. Brother
        Aelred used to say you had honest eyes. You hope he was right.";
      Attack:
        "Next, you'd want to cross a black cat's path? You think
        better of it.";
      Take:
        if (self hasnt moved && BrBenedict in location)
          "You dare not steal this in front of the brother.";
    ],
  has
    ;


Object -> InfirmaryCabinet "medicine cabinet"                ! >InfirmaryCabinet
  class AdjObject,
  with
    adj_name 'medicine',
    noun_name 'cabinet',
    when_closed [;
      print_ret (The) self, " sits against a wall, closed.";
    ],
    when_open [;
      print (The) self, " is open";
      PrintContents(", revealing ", self);
      ".";
    ],
    description [;
      #IfDef HAS_HINTS; HintReady(Hint_Cabinet); #EndIf;
      print
        "A wooden cabinet secured with a brass lock mechanism. Four wheels,
        each engraved with digits ~0~ through ~9~, can be rotated independently.
        Carved into the wood above the lock: ~Historia nostra, fides nostra~. ";
      if (self hasnt general && self hasnt open)
        print
          "^^You remember Brother Aelred mentioning this cabinet:
          ~Brother Benedict is trusting. He doesn't want to keep medicines
          from his brothers in need, only from the village folk we treat.
          It's set to something every brother knows---outsiders wouldn't
          think to look for it.~ ";
      give self general;
      <<Examine Wheels>>;
    ],
    check_combination [;
      ! 1152 = founding date
      if (Wheel1.setting == 1 && Wheel2.setting == 1
          && Wheel3.setting == 5 && Wheel4.setting == 2) {
        if (self hasnt open) {
          give self open;
          TaskDone(TASK_OPENED_MEDICINE_CABINET);
          "^You hear a satisfying click as the lock disengages and
          the cabinet opens.";
        }
      } else {
        give self ~open;
      }
    ],
    before [;
      if (BrBenedict in Infirmary && action ~= ##Examine or ##Take)
        "You dare not with Brother Benedict here.";
      Open:
        if (self has open) print_ret (The) self, " is already open.";
        if (~~self.check_combination()) print_ret (The) self, " is locked.";
      Search:
        if (self hasnt open) <<Open self>>;
      Examine:
        if (self has open) {
          print (The) self, " is open";
          PrintContents(", and contains ", self);
          ".";
        }
      SetTo:
        <<SetTo Wheels second>>;
    ],
  has
    static container openable ~open;


Decoction -> -> FoxgloveDecoction "foxglove decoction"      ! >FoxgloveDecoction
  with
    name 'foxglove',
    description
      "A small bottle filled with a concentrated murky yellow-brown liquid,
      labelled ~Foxglove~.
      You know from Brother Aelred that this can be miraculous for the heart
      in small quantities, but in greater quantities, it can be deadly.",
    before [;
      Smell: "It smells like grass.";
      Taste:
        "You try a small amount. It's unpleasantly bitter, with a
        strong grassy taste.";
    ],
  ;


Decoction -> -> HenbaneDecoction "henbane decoction"         ! >HenbaneDecoction
  with
    name 'henbane',
    description
      "A small bottle of a concentrated greenish-brown liquid, labelled
      ~Henbane~. You know from Brother Aelred that this is used for sedative
      purposes, though it does have disturbing side-effects. If used in excess,
      it can be fatal.
      ^^This bottle is almost entirely empty, with only a bit remaining.",
    before [;
        Smell:
          ev_hen_symptoms = true;
          "Like stale urine.";
        Taste:
          ev_hen_symptoms = true;
          "You try a small amount. It's very unpleasant,
          like licking an old chamber pot.";
    ],
    after [;
      Take:
        ev_took_poison = 1;
    ],
  has evidence ;


Decoction -> -> FeverFewDecoction "feverfew decoction"      ! >FeverfewDecoction
  with
    name 'feverfew',
    description
      "A small bottle filled with a concentrated dark yellow-green liquid,
      labelled ~Feverfew~. You know from
      Brother Aelred that this is often used to treat fevers and ague.",
    before [;
      Smell: "It's pungent, similar but not exactly like strong chamomile tea.";
      Taste:
        "You try a small amount: it's overwhelmingly bitter, with a strong
        chamomile-like flavour.";
    ],
  ;


Object -> Wheels "wheels"                                             ! >Wheels
  with
    name 'wheels',
    describe 0,
    description [;
      print
        "The four wheels currently show: ", Wheel1.setting, "-",
        Wheel2.setting, "-", Wheel3.setting, "-", Wheel4.setting;
      ".";
    ],
    before [ s ;
      if (BrBenedict in Infirmary && action ~= ##Examine)
        "You daren't mess with it in front of the brother.";
      SetTo:
        if (InfirmaryCabinet has open)
          "The wheels can't be turned while the cabinet is open.";
        if (second < 1000 || second > 9999)
          "You can only set it to a four digit combination.";
        s = second;
        Wheel1.setting = s / 1000;
        s = s - (Wheel1.setting * 1000);
        Wheel2.setting = s / 100;
        s = s - (Wheel2.setting * 100);
        Wheel3.setting = s / 10;
        Wheel4.setting = s - (Wheel3.setting * 10);
        print "You turn the wheels to ", second, ".^";
        InfirmaryCabinet.check_combination();
        rtrue;
    ]
  has static pluralname;


Class Wheel                                                             ! >Wheel
  with
    setting 0,  ! starts at I
    describe 0,
    set_me [;
        print "You turn ", (the) self, " to ", self.setting, ".^";
        InfirmaryCabinet.check_combination();
    ],
    before [;
      if (BrBenedict in Infirmary && action ~= ##Examine)
        "You daren't mess with it in front of the brother.";

      SetTo:
        if (InfirmaryCabinet has open)
          "The wheels can't be turned while the cabinet is open.";
        self.setting = second;
        self.set_me();
        rtrue;
      Turn:
        if (InfirmaryCabinet has open)
          "The wheels can't be turned while the cabinet is open.";
        self.setting++;
        if (self.setting > 9) self.setting = 0;
        self.set_me();
        rtrue;
      Examine:
        print_ret (The) self, " is currently set to ", self.setting, ".";
    ],
  has
    static;

Wheel -> Wheel1 "first wheel"                                          ! >Wheel1
  with name 'first' '1st' 'one' 'wheel';

Wheel -> Wheel2 "second wheel"                                         ! >Wheel2
  with name 'second' '2nd' 'two' 'wheel';

Wheel -> Wheel3 "third wheel"                                          ! >Wheel3
  with name 'third' '3rd' 'three' 'wheel';

Wheel -> Wheel4 "fourth wheel"                                         ! >Wheel4
  with name 'fourth' '4th' 'four' 'wheel';


! ----------------------------------------------------------- Infirmary Chapel
! The player can only entere here after the death, so we can
! write this knowing there will be a body in it, etc.

Room InfirmaryChapel "Infirmary Chapel"                       ! >InfirmaryChapel
  with
    description
        "A tiny chapel attached to the Infirmary, barely large enough for a
        priest and one or two others. A simple stone altar stands against the
        east wall. This is where the dying receive Last Rites, where the
        desperately ill make their final prayers. The air is heavy with the
        memory of fear and hope. The Infirmary lies to the north.",
    n_to Infirmary,
    out_to Infirmary,
    cheap_scenery
      ! 1 'eyes' 'face' [;
      !   ev_symptoms = true;
      !   print "His eyes are black and extremely dilated";
      !   if (task_done->TASK_MATCH_SYMPTOMS)
      !     "---a telltale sign of henbane poisoning";
      !   ".";
      ! ]
      'white' 'shroud' [;
        Examine:  "A simple and dignified white cloth.";
        Search, LookUnder:
          "There is nothing underneath it but the body of your mentor.";
        default: "Leave the shroud be, Brother.";
      ]
      15 'plague' 'sore' 'sores' 'bubo' 'bubos' 'buboes'
        "TODO MOTH"
    ,
  has ;


Altar -> InfirmaryAltar                                        ! >InfirmaryAltar
  with
  has ~enterable ~supporter ;

! PUZZLE: find the key for the restricted garden
! PUZZLE: identify the poison

Object -> -> BrAelredBody "Brother Aelred's body"                ! >BrAelredBody
  class AdjObject,
  with
    adj_name 'brother' 'aelred^s' 'earthly',
    noun_name 'body' 'corpse' 'remains' 'aelred',
    initial "On the altar are Brother Aelred's earthly remains.",
    invent "Brother Aelred's body, covered by a shroud",
    description [;
      if (self hasnt moved) {
        QuoteBoxSimple(quote_body);
        give self moved;
      }
      print
        "Your beloved mentor lies still on the altar, still dressed, covered
        with a simple white shroud. His face is visibly peaceful now, though
        you remember his agony earlier. His eyes are still open---staring
        upward as if fixed on Heaven, his hands folded across his chest";
      if (self hasnt general)
        print
          ". Something seems odd about him, though you can't quite place it";
      else if (task_done->TASK_MATCH_SYMPTOMS)
        print
          ". Now you notice: even in death, his pupils remain enormously
          dilated---a telltale sign of henbane poisoning.";
      ".";
    ],
    react_before [;
      Smell:
        if (noun == nothing)
          "There is an odd faint odour in the air.";
      Pray:
        "You whisper a small sad prayer to your dear mentor.
        You fervently hope he can hear you.";
    ],
    before [;
      Smell:
        if (self hasnt general) {
          ev_symptoms = true;
          give self general;
          "There's an odd smell about his remains---something like alcohol
          and urine in his mouth. Unusual.";
        }
        "That same odd smell lingers.";
      Kiss:
        "You reverently kiss him on the forehead---and then notice an odd
        odour about his remains.";
      Touch: "Already cold.";
      Attack, Cut, Burn: "Absolute blasphemy!";
      LookUnder:
        "Shifting the body slightly, you find nothing underneath.";
      Turn, Push, Pull:
        "You dare not disturb the dead---particularly
        not one who was so dear to you.";
      Take:
        "Moving him would be deeply inappropriate. Plus, he's much too heavy
        to carry.";
      Search:
        if (GardenGateKey hasnt moved) {
          move GardenGateKey to player;
          update_moved = true;
          "In an inner pocket of his robe, you find ", (a) GardenGateKey, ".
          You take it.";
        }
    ],
    life [;
      Give:
        "He is beyond earthly needs.";
      WakeOther:
        "You've been studying Lazarus too much.";
      default:
        "While in life, he overflowed with joyful energy---alas, no more.";
    ],
  has animate proper;


Object -> BrAelredEyes "Brother Aelred's eyes"                   ! >BrAelredEyes
  class AdjObject
  with
    article "his",
    adj_name 'aelred' 'aelred^s' 'brother' 'his',
    noun_name 'eyes' 'face' 'head',
    description [;
      ev_symptoms = true;
      "His pupils are unnaturally dilated and black.";
    ],
    before [;
      Close: "Leave such matters to Brother Benedict.";
    ],
  has static proper pluralname concealed ;


Object -> BrAelredHabit "Brother Aelred's habit"                ! >BrAelredHabit
  class AdjObject
  with
    adj_name 'aelred' 'aelred^s' 'aelreds' 'brother' 'his',
    noun_name 'habit' 'robe',
    description
      "You see nothing unusual about his habit
      and don't see the things he was picking at.",
    before [;
      Search:
        if (BrAelredDying hasnt animate) <<Search BrAelredBody>>;
    ],
    has static proper concealed ;



Statue -> RochStatue "statue of St Roch"                            ! >RochStatue
  with
    name 'st' 'roch',
    description
      "It depicts St Roch, patron saint of plague victims and the sick.
      He's depicted pointing to a plague sore on his leg."
  has ;


! ------------------------------------------------------------------- Herbarium

! PUZZLE: hints more about basil; it's the only thing not hanging here,
!   so it might help them decide to look at it in garden

Room Herbarium "Herbarium"                                          ! >Herbarium
  with
    description
      "This room still carries Brother Aelred's presence in every corner.
      Bundles of dried herbs hang from the rafters. The worktable in the centre,
      laden with materials above and below, bears the marks of much use.
      A large terracotta pot in the corner was used often to transfer plants.
      Without him here, the room feels hollow.
      ^^The Slype lies north, and the Garden---his garden---waits to the
      south.",
    n_to Slype,
    s_to Garden,
    out_to Garden,
    #IfDef HAS_HINTS;
    on_first_entry [;
      HintReady(Hint_HangingHerbs);
      HintReady(Hint_Herbarium);
    ],
    before [;
      Smell:
        if (noun == nothing)
          "Dried herbs and dust, with the faint ghost of everything Aelred
          ever handled here.";
      Listen: "It's unnaturally quiet here. Aelred was always laughing.";
    ],
    #EndIf;
    cheap_scenery
      3 'thyme' 'rosemary' 'feverfew' [;
        Examine:
          "You can just see them to recognise them, but can't reach them.";
        default:
          "They're too far out of your reach to do anything with.";
      ]
      CS_THEM 3 'rafters' 'bunches' 'herbs' [;
        Examine:
          if (parent(player) ~= HerbTable)
            "The different bunches of herbs hang from the rafters.
            From here, you can't quite make out what they are.";
          "Three different bunches hang from the rafters. They're still out of
          your grasp---Brother Aelred was much taller than you---but you
          recognise them as thyme, rosemary, and feverfew.";
        default:
          "The rafters are much too far up to do anything with.";
      ]
   has
     ;


! PUZZLE: another way to get the restricted garden key

Object -> Pot "plant pot"                                                 ! >Pot
  class AdjObject,
  with
    adj_name 'large' 'terracotta' 'plant',
    noun_name 'pot',
    describe 0,
    description "A substantial container, perfect for repotting a large plant.",
    before [;
      if (action ~= ##Examine && player in HerbTable)
        "You can't reach the pot from the table.";
      Smell: "It smells of dirt.";
      Take: "It's too large to carry about easily.";
      Turn, Pull, Push, LookUnder:
        if (GardenGateKey hasnt moved) {
          move GardenGateKey to player;
          update_moved = true;
          "Underneath the pot, you find ", (a) GardenGateKey, ".
          You take it.";
        }
        "Nothing is under the pot.";
    ],
  has
    static container open;


Object -> HerbTable "worktable"                                     ! >HerbTable
  class AdjObject,
  with
    adj_name 'work',
    noun_name 'worktable' 'table',
    react_before [;
      Go:
        if (player in self) {
          if (selected_direction == d_to) <<Exit self>>;
          "You'd have to climb down from ", (the) self, " first.";
        };
    ],
    description [;
      print
        "A large, heavy table where you and Brother Aelred did your daily work";
      PrintContents(". On it ", self, ISARE_BIT);
      ".";
    ],
    before [;
      Search, LookUnder:
        if (Basket hasnt moved) {
          give Basket ~concealed;
          "Looking below the table, you find Brother Aelred's basket,
          which he used for gathering and carrying herbs.";
        }
        "There is nothing else under the table.";
      Climb: <<Enter self>>;
    ],
    after [;
      Enter: "You climb up onto the worktable.";
      Exit: "You climb down from the worktable.";
    ],
  has
    scenery supporter enterable;


Object -> -> Jars "jars"                                                 ! >Jars
  with
    name 'jars',
    description
      "There are almost two dozen of them, each carefully labelled. You know
       these well---managing these has been your daily labour for the past
       few months. You don't see anything missing or unusual about them.",
    before [;
      if (action ~= ##Examine && player in HerbTable)
        "You can't do anything with the jars while standing on the table.";
      Take, Pull, Push, Turn:
        "Leave them be. You have more important things to do.";
    ],
  has static pluralname;



! PUZZLE: need to handle dangerous plants

Object -> -> Gloves "gloves"                                           ! >Gloves
  with
    name 'gloves',
    description "A pair of rough gloves, used by Aelred in the gardens.",
    before [;
      Smell: "They smell like dirt and herbs from the Garden.";
      Taste: "For some reason, you lick them. They taste like dirt.";
    ],
    after [;
      Wear:
        if (self hasnt general) {
          give self general;
          print
            "You pause for a second. His gloves, and now they'll pass to
            you. You hope you can honour his work in the garden.^^";
        }
    ],
  has
    clothing ok_carry pluralname;


! PUZZLE: need to identify poison

Object -> -> Herbal "Aelred's Herbal"                                  ! >Herbal
  class AdjObject,
  with
    adj_name 'aelred' 'aelred^s' 'aelreds',
    noun_name 'herbal',
    description
      "A thin volume, but very handy: it lists many herbs and other plants,
      along with descriptions of them and their uses.",
    before [  ;
      Examine:
        if (verb_word == 'read')
          "It's much too dense to read the entire thing. (You can consult it
          by looking up a plant by name, like CONSULT HERBAL ABOUT PARSLEY.)";
      Consult:
        if (location == thedark) { PrintMsg(MSG_EXAMINE_DARK); rtrue; }
        wn = consult_from;
        switch (NextWord()) {

          'rosemary':
            #Ifv5; @set_text_style 4; #EndIf;
            print
              "Rosemary: one of God's most beneficial gifts, useful for the
              digestion and for nerves. Can be made into a decoction or served
              as a tea";

          'thyme':
            #Ifv5; @set_text_style 4; #EndIf;
            print
              "Thyme: powerful for cleaning the blood and warding off the
              plague. Can be made into a decoction or served in a tea";

          'feverfew':
            #Ifv5; @set_text_style 4; #EndIf;
            print
              "Feverfew: a sovereign remedy for headaches and the agues that
              bring fever. Women take it for monthly afflictions. Chew the
              fresh leaves or make a tea, though the bitterness is formidable.
              Some claim it prevents the megrim when taken daily";

          'basil':
            #Ifv5; @set_text_style 4; #EndIf;
            print
              "Basil: difficult to grow in these northern climes, but common
              in warmer lands like southern France and especially Tuscany,
              where it is prized as both culinary herb and remedy. Effective
              for digestive troubles and inflammation of the eyes";

          'monkshood':
            #Ifv5; @set_text_style 4; #EndIf;
            print
              "Monkshood: when used with caution, can reduce inflammation or
              problems with breathing. When used without care, can result in
              a death that looks like rabies: with frothy saliva, slurred
              speech, and impaired vision. Used as a liniment or decoction";

          'foxglove':
            #Ifv5; @set_text_style 4; #EndIf;
            print
              "Foxglove: some claim it strengthens a weak heart, though its
              use is controversial and dangerous. Even small amounts can
                cause the heart to beat irregularly. Handle with great
                caution---the plant irritates the skin terribly";

          'mandrake', 'root':
            #Ifv5; @set_text_style 4; #EndIf;
            print
              "Mandrake: called the sleeping root. In small doses brings
              drowsiness and eases pain. A large root consumed or its smoke
              deeply breathed brings profound sleep---useful before surgery
              or for serious insomnia. Not dangerous to handle, but it should
              not be eaten";

          'henbane':
            #Ifv5; @set_text_style 4; #EndIf;
            ev_hen_symptoms = true;
            print
              "Henbane: can treat toothache and rheumatism. While useful, it
              can be deadly: symptoms preceding death include extremely
              dilated eyes and strange visions";

          'rose', 'roses':
            #Ifv5; @set_text_style 4; #EndIf;
            print
              "Rose: can treat headaches and eye inflammation. Flowers can
              be beaten to a paste to treat melancholy";

          'rosehip', 'rosehips', 'rose', 'hips', 'hip':
            #Ifv5; @set_text_style 4; #EndIf;
            print
              "Rosehips: as a tea, useful for warding off colds and chest
              pain";

          default: "You find no entry for that in ", (the) self;
        }

        #Ifv5; @set_text_style 0; #EndIf;
        TaskDone(TASK_USED_HERBAL);
        ".";
    ],
  has proper ok_carry;


! PUZZLE: need for carrying contraband

Object -> Basket "basket"                                              ! >Basket
  with
    name 'basket',
    capacity 20,
    description [;
      print
        "A deep flax basket---useful when harvesting herbs and carrying them
        to the Infirmary";
      PrintContents(". In it ", self, ISARE_BIT);
      ".";
    ],
    before [;
      Receive:
        if (noun == Pax) "She wouldn't find that very comfortable.";
        if (noun has light)
          "Placing a lit item in the basket would surely catch it on fire.";
    ],
    after [;
      Receive: CheckHidContraband(noun);
    ],
  has
    concealed container open ok_carry;


! --------------------------------------------------------------------- Garden


Room Garden "Garden"                                                   ! >Garden
  with
    description
      "Aelred's garden. You can still see where his hands touched
      everything---the carefully weeded beds, the path worn by his daily rounds.
      ^^You enter the Herbarium to the north. A gate west guards plants too
      dangerous for common use.",
    n_to Herbarium,
    w_to GardenGate,
    in_to Herbarium,
    time_left 0,
    #IfDef HAS_HINTS;
    on_first_entry [;
      HintReady(Hint_Garden);
    ],
    #EndIf;
    each_turn [;
      self.time_left++;
      if (self.time_left == 5) {
        print
          "^Spending time here reminds you of a conversation from spring,
          when Brother Aelred was tending a corner of the garden. ~This one's a
           challenge, my son,~ he said, gesturing at a new";
        if (BasilPlant has general || Basil has moved)
          print " basil"; else print ", small";
        " plant. ~It wants warmth and sun we can barely give it here. But
        there's a brother of ours---he came from sunnier lands, seeking refuge.
        He never complains, but I see the homesickness in his eyes.~ Aelred
        touched the leaves gently. ~If I can coax this to grow, it will remind
        him of home. A small kindness, perhaps, but sometimes those matter
        most.~ You will miss Aelred so much.";
      }
    ],
    before [;
      Smell:
        if (noun == nothing)
          "The air carries the last of the season's herbs and,
          beneath that, turned earth.";
      Dig:
        "You dare not dig or plant in his garden. Not today.";
    ],
    cheap_scenery
      1 'path' "It's just the path around the beds."
    ,
  has
    ;


Object -> Beds "beds"                                                    ! >Beds
  with
    name 'beds' 'bed' 'plants',
    description
      "Neat rows of raised beds, carefully tended and weeded. Woody rosemary
      grows tall in one corner, its leaves green against the autumn sky.
      Low-growing thyme spreads in silvery-green mats, while feverfew's white
      daisy-flowers still bloom despite the season. In the most sheltered spot,
      tender basil leaves catch what little sun reaches this northern
      garden---a small miracle that Aelred coaxed it to survive this long.",
    before [;
      Receive:
        "Soon, it will be your daily labour to plant things here---but not
        today.";
    ]
  has
    pluralname scenery container open;


Plant -> -> RosemaryPlant "rosemary plant"                      ! >RosemaryPlant
  with
    name 'rosemary',
    description
      "Several feet tall and woody-stemmed, with needle-like leaves of
      deep green.",
    before [;
      Smell: <<Smell Rosemary>>;
      Taste: <<Taste Rosemary>>;
    ],
  ;


Herb -> -> -> Rosemary "rosemary sprig"                              ! >Rosemary
  with
    name 'rosemary',
    description "A stalk of needle-like leaves.",
    before [;
      Smell: "It smells of pine sap and wood.";
      Taste:
        "You try a few needles: it tastes strongly of pine and wood.";
    ]
  ;


Plant -> -> ThymePlant "thyme plant"                               ! >ThymePlant
  with
    name 'thyme',
    description
      "A low, creeping plant with tiny grey-green leaves forming dense
      mats. Even brushing against it releases its scent.",
    before [;
      Smell: <<Smell Thyme>>;
      Taste: <<Taste Thyme>>;
    ],
  has
  ;


Herb -> -> -> Thyme "thyme sprig"                                       ! >Thyme
  with
    name 'thyme',
    description
      "A miniature forest in a sprig, with many tiny leaves shooting off in
      different directions.",
    before [;
      Smell: "Strongly earthy with a note of mint.";
      Taste: "You try a few leaves. It's warm and earthy.";
    ],
  ;


Plant -> -> FeverfewPlant "feverfew plant"                      ! >FeverfewPlant
  with
    name 'feverfew',
    description
      "A bushy plant about two feet tall, covered with small white
      flowers like tiny daisies. The leaves are deeply divided and
      yellow-green.",
    before [;
      Smell: <<Smell Feverfew>>;
      Taste: <<Taste Feverfew>>;
    ],
  ;


Herb -> -> -> Feverfew "feverfew sprig"                              ! >Feverfew
  with
    name 'feverfew',
    description
      "A cluster of stems bearing small daisy-like flowers with white
      petals and yellow centres. The leaves are feathery and aromatic.",
    before [;
      Smell:
        "Strong and bitter, almost medicinal---like chamomile but sharper.";
      Taste:
        "You try a single leaf: intensely bitter, leaving your mouth
        tingling unpleasantly.";
    ],
  ;


! general = player has observed this; the flashback about basil use the right
!   name

Plant -> -> BasilPlant "basil plant"                               ! >BasilPlant
  with
    name 'basil',
    description [;
      give self general;  ! observed
      "Less than a foot tall, with broad oval leaves of tender
      green---remarkable that it's survived this long in England's chill.
      Aelred must have sheltered it carefully. It appears to be young and
      in its first season.";
    ],
    before [;
      Smell: <<Smell Basil>>;
      Taste: <<Taste Basil>>;
    ],
    has
  ;


Herb -> -> -> Basil "basil sprig"                                       ! >Basil
  with
    name 'basil',
    description "A cluster of large green leaves with pointed tips.",
    before [;
      Smell: "It's strong and peppery, with notes of anise.";
      Taste:
        "You try a single leaf: it's sharp at first,
        then peppery and a bit like liquorice.";
    ],
  has
    ;


! -------------------------------------------------------- Restricted Garden

Object -> GardenGate "restricted garden gate"                      ! >GardenGate
  class AdjObject,
  with
    adj_name 'restricted' 'garden',
    noun_name 'gate',
    when_open "The gate for the Restricted Garden is open.",
    when_closed [;
      print "The gate for the Restricted Garden is closed";
      if (self has locked) print " and locked";
      ".";
    ],
    ! before [;
    !   Unlock:
    !     if (second == GardenGateKey) {
    !       give self ~locked;
    !       give self open;
    !       print "You unlock the gate, open it, and enter the smaller garden.^^";
    !       PlayerTo(RestrictedGarden);
    !       rtrue;
    !     }
    ! ],
    after [;
      Unlock:
        give self open;
        print "You unlock the gate, open it, and enter the smaller garden.^^";
        PlayerTo(RestrictedGarden);
        rtrue;
    ],
    description [;
      #IfDef HAS_HINTS; HintReady(Hint_GardenGate); #EndIf;
      "A wooden fence protecting access to the dangerous plants.";
    ],
    found_in RestrictedGarden Garden,
    door_dir (w_to) (e_to),
    with_key GardenGateKey
  has
    static door openable locked lockable;


Object GardenGateKey "iron key"                                 ! >GardenGateKey
  class AdjObject,
  with
    article "an",
    adj_name 'iron' 'garden' 'pitted' 'rusty',
    noun_name 'key',
    description [;
      "A heavy iron key, its surface pitted and darkened with rust from years
      hanging in the damp Herbarium. It opens the gate to the Restricted Garden
      where the dangerous herbs grow.";
    ],
    after [;
      Examine: TaskDone(TASK_GARDEN_KEY);
    ],
  has ok_carry;


Room RestrictedGarden "Restricted Garden"                    ! >RestrictedGarden
  with
    description [;
      print
        "Here is Aelred's collection of dangerous plants---those too potent for
        casual use, too deadly for error. The beds here are smaller, more
        carefully separated.";
      if (self hasnt general)
        print
          "^^Aelred brought you here only twice, making you repeat each plant's
          name, its use, its danger. ~Respect them, my son~, he said. ~In the
          right dose, they heal. In the wrong, they kill.~";
      give self general;
      "^^The only exit is through the gate to the east.";
    ],
    each_turn [;
      #IfDef HAS_HINTS; HintReady(Hint_RestGarden); #EndIf;
    ],
    before [;
      Smell:
        if (noun == nothing)
          "Something sweetish and medicinal underneath the cold air.
          Not unpleasant, exactly. But wrong, somehow.";
    ],
    e_to GardenGate,
    out_to GardenGate,
  has
    ;


Object -> RestBeds "beds"                                            ! >RestBeds
  with
    name 'beds' 'bed' 'plants',
    description [;
      print
        "Small, carefully separated beds---no risk of cross-contamination.
        You recognise monkshood by its dark leaves and hooded flowers,
        foxglove by its pink bells, henbane by its sickly-sweet smell";
      if (MandrakeRoot hasnt moved) print
        ". A small gnarled mandrake root pushes from the earth, pale and
        forked like a tiny human figure";
      ".";
    ],
    before [;
      Receive:
        "Soon, it will be your daily labuor to plant things
        here---but not yet. Not today.";
    ],
  has
    pluralname scenery container open;


Plant -> -> MonkshoodPlant "monkshood plant"                   ! >MonkshoodPlant
  with
    name 'monkshood',
    description
      "Several feet high, with spikes of helmet-shaped, deep blue flowers.",
    before [;
      Smell: <<Smell Monkshood>>;
      Taste: <<Taste Monkshood>>;
    ],
  has toxic ;


Herb -> -> -> Monkshood "monkshood sprig"                           ! >Monkshood
  with
    name 'monkshood',
    description
      "The flowers are deep blue, and in a shape like a monk's cowl, hence the
      name.",
    before [;
      Smell:
        "You cautiously sniff---barely any scent at all. The plant saves
        its power for those who consume it.";
      Taste: "You dare not. It can be lethal even in small doses.";
    ],
  has toxic ;


Plant -> -> FoxglovePlant "foxglove plant"                      ! >FoxglovePlant
  with
    name 'foxglove',
    description
      "A tall plant with distinct stems of flowers: bell-shaped and pink.",
    before [;
      Smell: <<Smell Foxglove>>;
      Taste: <<Taste Foxglove>>;
    ],
  has toxic ;


Herb -> -> -> Foxglove "foxglove sprig"                              ! >Foxglove
  with
    name 'foxglove',
    description
      "The flowers are pink and bell-shaped, dangling in a long spike---each
      bloom like a tiny glove finger, hence the name.",
    before [;
      Smell:
        "You cautiously sniff---barely any scent at all. The plant saves
        its power for those who consume it.";
      Taste: "You dare not. It can be lethal even in small doses.";
    ],
  has toxic ;


Plant -> -> HenbanePlant "henbane plant"                         ! >HenbanePlant
  with
    name 'henbane',
    description
      "A sprawling plant, with yellow and purple bell-shaped flowers.",
    before [;
      Smell: <<Smell Henbane>>;
      Taste: <<Taste Henbane>>;
    ],
  has toxic ;



! on = looked up henbane

Herb -> -> -> Henbane "henbane sprig"                                 ! >Henbane
  with
    name 'henbane',
    description "The flowers are dirty yellow and streaked with purple.",
    before [;
      Smell:
        "Reminiscent of stale urine. Very unpleasant.";
      Taste: "You wouldn't dare. You've been taught that it's very toxic.";
    ],
  has toxic ;


! PUZZLE: putting Wilfred to sleep to enter library



Object -> -> MandrakeRoot "mandrake root"                        ! >MandrakeRoot
  with
    name 'mandrake' 'root',
    description
      "A small pale, forked root twisted into a vaguely human shape.",
    before [;
      Burn:
        if (player in Scriptorium) {
          SceneLibraryMandrake.scene_start();
          "You throw ", (the) self, " into the fireplace.";
        }
      PutOn, Insert, ThrowAt:
        if (second == Fireplace) <<Burn self>>;
      Smell:
        "An unpleasant, earthy smell.";
      Taste:
        "You take a tiny nibble, and find it extremely unpleasant.";
      Eat:
        "You've already learned from Brother Aelred enough to know
        you shouldn't eat this.";
      Take, Touch: rfalse;   ! not toxic to handle
    ],
  has
    toxic ok_carry;

! ------------------------------------------------------------- Refectory

! only meal would be after None (at 3pm)
Room Refectory "Refectory"                                          ! >Refectory
  with
    description [;
      "The Refectory is a long, austere hall where the community takes its
      meals in silence while one brother reads aloud from the lectern. Two
      rows of trestle tables stretch the length of the room, their oak
      surfaces scrubbed clean. High windows along the eastern wall admit ",
      (DescribeLight) self, " that barely reaches the stone floor. The smell of
      pottage lingers faintly in the air. A doorway to the south leads to
      the Kitchen, and wide openings to the north return to the Cloister.";
    ],
    n_to CloisterS,
    s_to Kitchen,
    out_to CloisterS,
    before [;
      SitAny: <<Enter RefectoryBenches>>;
      Smell: if (noun == nothing) "The scent of pottage from previous meals.";
      Listen: "You can hear activity in the Kitchen to the south.";
    ],
    cheap_scenery
      1 'lectern' [;
        Examine: "A plain wooden stand, used for reading during meals.";
        Take, Push, Pull, Turn: "You dare not move it.";
        Search, LookUnder: "There is nothing in or under it.";
        Receive: "You dare not clutter it with your stuff.";
      ]
      'window' 'windows' "They're too high up to do anything with."
      12 'trestle' 'table' 'tables' [;
        Examine: "The tables are bare and well-washed.";
        Take, Push, Pull, Turn: "You dare not mess with the tables.";
        Search: "The tables are bare.";
        Receive: "You dare not clutter the meal tables with your stuff.";
      ]
    ,
  ;


Chair -> RefectoryBenches "benches"                          ! >RefectoryBenches
  with
    description "Plain wooden benches.",
    name 'bench' 'benches',
    article "some",
    before [;
      Turn, Pull, Push:
        "Rearranging the furniture here would irritate Brother Martin.";
    ]
  has scenery pluralname;


! ------------------------------------------------------------------ Kitchen

! general = been given fish
! on = has tried stairs

Room Kitchen "Kitchen"                                                ! >Kitchen
  with
    description
      "A large room, lit by high windows. A door leads north to the Refectory,
      and stairs descend south to the Undercroft below.
      ^^A large working table dominates the centre, scattered with implements
      and vessels. A hearth is built into the east wall, its fire warming the
      room.",
    n_to Refectory,
    out_to Refectory,
    time_left 0,
    d_to Undercroft,
    cheap_scenery
      'implements' 'various' "A collection of utensils, knives, and vessels."
      4 'utensils' 'knives' 'vessels' 'spices'
        "You needn't worry about these--Brother Martin is the Kitchener.",
    each_turn [;
      if (BrMartin in self) {
        self.time_left++;
        if (self.time_left < 4) rfalse;
        if (Fish hasnt moved) {
          move Fish to player;
          update_moved = true;
          print
            "^Brother Martin smiles broadly.
            ~Hungry, are we, Brother Novice?~ He takes a piece of smoked fish
            and presses it into your hands. ~There. Now leave us to our work.~";
        } else {
          print
            "Brother Martin says ~Out, out, Brother Aldwin. Remigio and I are
            working.~";
        }
        print " He ushers you out.^^";
        PlayerTo(Refectory);
      }
    ],
    before [;
      Search:
        if (BrMartin in Kitchen || BrRemigio hasnt general)
          "You can't just search here with another brother here.";
      Smell:
        if (noun == nothing)
          "There is a strong smell of soup from the cauldron.";
      Listen:
        print "You can hear the noise of ";
        if (BrMartin in self) print "Brother Martin and ";
        "Brother Remigio working.";
      Go:
        if (selected_direction == d_to) {
          give Kitchen on;  ! tried going down stairs
          if (BrMartin in location)
            print_ret (string) MSG_DARE_NOT_ANOTHER_BROTHER;
          if (BrRemigio hasnt general)
            "Brother Remigio stops you, apologetically. ~No, not allowed~, he s
            ays, ~Frate Hugh, he not allow go to cellars.~";
          f_found_darkness = true;
          if ((~~IndirectlyContains(player, MyCandle)) &&
                (~~IndirectlyContains(player, TallowCandle))
                && TallowCandle hasnt moved) {
            move TallowCandle to player;
            update_moved = true;
            print
              "Seeing you without a candle he produces a tallow one from his
              robe and gives it to you. ~La luce~.^";
          }
          if (TallowCandle hasnt light && MyCandle hasnt light) {
            print
              "^You're heading down to the Undercroft without a light source.
              Are you sure you want to do this? ";
            if (~~YesOrNo()) "You think better of it.";
          }
          print
            "Brother Remigio looks away slyly as you head down the stairs.^";
          ! PlayerTo(Undercroft);
        }
    ],
    after [;
      Search:
        "There are many things here, but all of them are simple
        Kitchen implements, and you find nothing unexpected or useful.";

    ]
  has
    ;


Object -> KitchenTable "table"                                   ! >KitchenTable
  with
    name 'working' 'table',
    description [;
      print
        "A long high table, big enough for two or three people to work at.
        It has a collection of utensils, knives,";
      if (Fish hasnt moved) print " a piece of smoked fish,";
      print " and vessels of spices on it";
      PrintContents(". Also on it ", self, ISARE_BIT);
      ".";
    ],
    before [;
      Enter, Climb:
        print_ret (string) MSG_DARE_NOT_ANOTHER_BROTHER;
    ],
  has scenery supporter;


Object -> -> Fish "smoked fish"                                          ! >Fish
  class AdjObject,
  with
    article "a piece of",
    adj_name 'smoked',
    noun_name 'fish' 'cod',
    description "Cod? Haddock? You're a gardener, not a fisherman.",
    before [;
      Smell: "A slight whiff of brininess and wood smoke.";
      Take:
        if (Fish hasnt moved) {
          if (BrMartin in Kitchen)
            "Brother Martin is right here. You can't just steal food.";
          if (BrRemigio hasnt general)
            "~Ladro, ladro---uh--thieves!~ Brother Remigio cries,
            and stops you from taking the fish.";
        }
    ],
    after [;
      Taste: "You try a nibble. It's delicious.";
      Eat: "You eat it. Brother Martin always makes delicious food.";
      Take:
        if (Fish hasnt moved)
          "Brother Remigio slyly looks away while you take ", (the) Fish, ".";
    ]
  has
    concealed edible ok_carry ;


Object -> Hearth "hearth"                                              ! >Hearth
  with
    name 'hearth' 'fire' 'fireplace',
    description
      "A stone block built into the wall, with a fire burning in it.
      A cauldron hangs above the fire.",
    before [;
      if (BrMartin in location && action ~= ##Search or ##Examine or ##Smell)
        print_ret (string) MSG_DARE_NOT_ANOTHER_BROTHER;

      Search: "Anything within this would certainly be burned to cinders.";
      Receive:
        if (noun == MandrakeRoot)
          "That would spoil the pottage. You think better of this.";
        remove noun;
        "You toss ", (the) noun, " into the hearth and it disappears into the
        fire.";
      Touch: "Ow, ow, ow.";
      Smell: "Burning wood and smoke.";
      Enter:
        deadflag = 1;
        print "Visions of saints burning at the stake enter your head.";
    ]
  has scenery container open;


Object -> -> Cauldron "cauldron"                                     ! >Cauldron
  with
    name 'cauldron' 'pot' 'pottage' 'soup',
    description
      "A large iron pot hanging over the fire, filled with pottage---a
      thick vegetable stew that will feed the brothers at their next meal.",
    before [;
      if (BrMartin in location && action ~= ##Search or ##Examine or ##Smell)
        print_ret (string) MSG_DARE_NOT_ANOTHER_BROTHER;

      Touch: "Ow, ow, ow.";
      Taste, Eat: "It's not mealtime yet.";
      Blow: "You can't manage to cool it.";
      Search, LookUnder: "Just pottage bubbling away.";
      Take: "It's far too hot and heavy to move.";
      Receive:
        "This is food for you and your brothers. You shouldn't tamper with it.";
    ],
  has scenery;


! ================================================ Basement


Room Undercroft "Undercroft"                                       ! >Undercroft
  with
    description [;
      print
        "Barrels crowd this vaulted space beneath the Refectory. Everything the
        priory needs to survive is here: tallow, salt, wine, mustard, grain.
        A table is against a wall.
        The cellarer's careful hand is evident in the organisation---each
        item labelled, stacked, accounted for.";
      if (self hasnt visited)
        print
          "^^As cellarer, Brother Hugh alone manages this space---organising the
          stores, counting what remains, arranging what must be purchased. No
          other brother would have reason to come here uninvited.";
      "^^Stairs lead up to the Kitchen. A wide door to the east would allow
      barrels to be rolled in and out for deliveries.";
    ],
    u_to Kitchen,
    e_to [;
      print
        "You push the door open and head east, emerging at the Passage.
        The door closes behind you.^^";
      return PassageSouth;
    ],
    after [;
      Go:
        if (SceneUndercroft hasnt general) SceneUndercroft.scene_start();
    ],
    before [;
      Listen:
        "In the dimness, you can hear rats.";
      Smell:
        if (noun == nothing)
          "Musty and filled with fragrances from the barrels, especially with
          the overpowering odour of tallow.";
    ],
    cheap_scenery
      1 'door' [;
        Examine: "It's a broad wooden door.";
        Push, Open: <<Go FAKE_E_OBJ>>;
      ]
  has
    ~light;


Object -> UndercroftTable                                     ! >UndercroftTable
  with
    name 'table',
    describe 0,
    description [;
      print "A rough wooden table";
      PrintContents(". On it ", self, ISARE_BIT);
      ".";
    ],
    before [;
      Search, LookUnder: "You find nothing unexpected under it.";
      Push, Pull, Turn:
        "You push the table a bit and find nothing unexpected.";
      Climb, Enter: "It is too rickety to stand on safely.";
    ],
  has
    static supporter ;


Object -> -> Stick "pointed stick"                                      ! >Stick
  class AdjObject,
  with
    adj_name 'long' 'pointed',
    noun_name 'stick',
    describe 0,
    description
      "A long branch from a tree. It may be used for chasing away or hitting
      rats, as there's a bit of dried blood on one end.",
    react_before [;
      Go:
        if (parent(self) == player &&
           location.(selected_direction) == WestDoor or WestGate)
          "You need to drop ", (the) self, " first.
          It's much too large and conspicuous to carry around the priory.";
    ],
    before [;
      Insert:
        if (~~second ofclass Barrel) "It wouldn't fit in that.";
    ],
    after [;
      Take:
        "It's long enough that it's awkward to carry, but you take it
         all the same.";
    ],
  has ;


Object -> -> Ledger "ledger"
  with
    name 'ledger' 'paper' 'cord',
    description
      "It's a sheaf of coarse paper, tied with a cord. It seems to record
      recent purchases and sales of goods for the priory.",
    before [;
      Examine:
        if (verb_word == 'read')
          "It's filled with Hugh's cramped hand. The most recent items listed
          are the sale of beeswax candles, a purchase of a barrel of mustard
          seeds, and the sale of sheep from the priory's fields.";
    ],
    after [;
      Take: "You're unsure how it will prove useful, but you take it.";
    ],
  has ;


Object -> Barrels "barrels"                                           ! >Barrels
  with
    name 'barrels',
    before [ b i ;
      Examine:
        print "You see five barrels: ";
        objectloop (b ofclass Barrel) {
          i++;
          print (address) b.simple_name;
          if (b has open) print " (open)";
          switch (i) {
            1,2,3: print ", ";
            4: print " and ";
            5: ".";
          }
        }
      default:
        PrintMsg(MSG_PARSER_NOT_MULTIPLE_VERB);
        rtrue;
    ],
  has scenery;


Barrel -> GrainBarrel "grain barrel"                              ! >GrainBarrel
  with
    name 'grain',
    simple_name 'grain',
    description [;
      print
        "A stout wooden barrel bearing the charcoal mark ~GRAIN~";
      if (self has open)
        print ". It is currently open, revealing dried wheat kernels";
      ".";
    ],
    before [;
      Smell:
        if (self has open)
          "A faint, dusty grain smell.";
      Taste:
        if (self has open)
          "You take a kernel and chew it---hard and chalky, as expected.";
    ],
  has edible;


Barrel -> WineBarrel "wine barrel"                                ! >WineBarrel
  with
    name 'wine',
    simple_name 'wine',
    description [;
      print
        "A stout wooden barrel bearing the charcoal mark ~WINE~";
      if (self has open)
        print ". It is currently open, revealing dark red wine within";
      ".";
    ],
    before [;
      Drink: "You wouldn't dare steal from the priory's stores.";
      Smell:
        if (self has open)
          "The sharp, fruity scent of wine fills your nostrils.";
      Taste:
        if (self has open)
          "You dip a finger and taste---sour, vinegary. Table wine, not
          sacramental quality.";
    ];

Barrel -> SaltBarrel "salt barrel"                                ! >SaltBarrel
  with
    name 'salt',
    simple_name 'salt',
    description [;
      print
        "A stout wooden barrel bearing the charcoal mark ~SALT~";
      if (self has open)
        print ". It is currently open, revealing coarse grey salt";
      ".";
    ],
    before [;
      Smell:
        if (self has open)
          "A faint mineral scent, mixed with the tang of the sea.";
      Taste:
        if (self has open)
          "You taste a few crystals---intensely salty, as expected.";
    ],
  has edible;

Barrel -> TallowBarrel "tallow barrel"                          ! >TallowBarrel
  with
    name 'tallow',
    simple_name 'tallow',
    description [;
      print
        "A stout wooden barrel bearing the charcoal mark ~TALLOW~";
      if (self has open)
        print ". It is currently open, revealing pale, waxy rendered fat";
      ".";
    ],
    before [;
      Smell:
        if (self has open)
          "A greasy, animal smell---not pleasant, but not rotten either.";
      Taste:
        if (self has open)
          "You absolutely refuse to taste rendered animal fat.";
      Take:
        if (self has open)
          "You won't. Leave that to the chandler.";
    ];

Barrel -> MustardBarrel "mustard barrel"                        ! >MustardBarrel
  with
    name 'mustard',
    simple_name 'mustard',
    description [;
      print
        "A stout wooden barrel bearing the charcoal mark ~MUSTARD~";
      if (self has open)
        print ". It is currently open, revealing yellow-brown ground mustard";
      ".";
    ],
    before [;
      Smell:
        if (self has open)
          "Sharp and pungent---the unmistakable bite of ground mustard.";
      Taste:
        if (self has open)
          "You taste a tiny amount---fiery hot and bitter. You cough.";
    ],
    after [;
      Search:
        if (self hasnt open) "You cannot, since the barrel is closed.";
        the_time = the_time + 2;
        move MustardPackage to player;
        "After digging around with the stick for several minutes, you find
        something buried deep in the mustard. You pull it free---a small
        package, its burlap stained deep yellow. You take it.";
    ],
  has edible;


Object MustardPackage "mustard-yellow package"                 ! >MustardPackage
  with
    name 'mustard' 'package',
    description
      "A small package of burlap, tied with simple cord.
      Originally dark, it has stained deep yellow from the mustard.",
    before [;
       Close: "You can't retie the package again, so it will remain open.";
    ],
    after [;
      Open:
        "You untie the cord, revealing a small illuminated psalter.";
    ]
  has
    container openable ~open evidence;


Object -> StolenPsalter "illuminated psalter"                   ! >StolenPsalter
  class AdjObject,
  with
    article "an",
    adj_name 'illuminated' 'stolen',
    noun_name 'psalter' 'manuscript',
    description
      "A small psalter, exquisitely crafted. The leather cover is tooled
      with a design of intertwined vines and lilies. Opening it, you see
      Brother Wilfred's unmistakable hand---each page a work of devotion.
      The opening initial 'B' of Psalm 1 (~Beatus vir~) is illuminated in
      brilliant azure and gold leaf, depicting a tree bearing fruit by
      streams of water. Marginal decorations show doves, wheat, and grapes.
      ^^This is clearly one of Wilfred's finest works. It should be kept in the
      Library before it is sold, not hidden here.",
    before [;
      Examine:
        if (ev_psalter == false) QuoteBoxSimple(quote_psalter);
        ev_psalter = true;
        if (verb_word == 'read')
          "The psalms are beautiful, but what strikes you most is the
          artistry---the hours Wilfred must have spent on each illumination.";
    ],
  has
    ~concealed evidence;  ! Remove concealed when player searches


! ---------------------------------------------------- FitzAlan Crypt

Object Ladder "ladder"                                                 ! >Ladder
  with
    name 'ladder',
    description [;
      if (self hasnt general) {
        QuoteBoxSimple(quote_ladder);
        give self general;
      }
      if (parent(player) ofclass Tomb)
        "You're higher now, but the ladder is still high above you.";
      if (location == FitzAlanCrypt) "The ladder is far above you.";
      print "A narrow wooden ladder leads down";
      if (~~IsLit(FitzAlanCrypt)()) print " into darkness";
      ".";
    ],
    before [;
      Take, Pull, Push:
        "The ladder is much too high to reach.";
    ]
  has scenery open;


Room FitzAlanCrypt "FitzAlan Crypt"                             ! >FitzAlanCrypt
  with
    name 'stone' 'walls',
    description
      "A small vaulted chamber, no more than ten feet across.
      The central tomb bears the effigy of a knight.
      Flanking this is a smaller undecorated tomb.

      ^^The walls here are finished stone rather than rough-hewn rock, and
      narrow recesses have been cut into the walls---likely once holding
      offerings or relics. The air is still, undisturbed for decades
      or longer. A patina of dust covers everything, unmarred by footprints
      save your own.",
    s_to [;
      if (Frame hasnt general) "You can't go that way.";
      print "You slip through the opening behind the panel, revealing...^";
      return Crypt;
    ],
    u_to "Alas, the ladder is raised up and well out of your reach.",
    #IfDef HAS_HINTS;
    on_first_entry [;
      HintReady(Hint_FACrypt);
    ],
    #EndIf;
    before [;
      Examine, Search: if (location == thedark) "But it's dark.";
    ],
    cheap_scenery
      1 'recesses'
        "There is nothing in these, and they don't respond in any way to
        manipulation."
      16 'fitzalan' 'knight' 'lion' 'arms' 'armor' 'armour' 'carvings' [;
        Examine:
          "The knight, shield, and lion are well done, but they're
          just carved into the stone.";
        Push, Pull, Take, Turn:
          "The knight and its shield and arms are carved into the stone.
          They don't respond in any way to your manipulation.";
        default:
          "There's nothing you can do with these.";
      ]
    ,
  has
    ~light;


Tomb -> FitzAlanLargeTomb "larger tomb"                     ! >FitzAlanLargeTomb
  with
    adj_name 'large' 'larger' 'central',
    description
      "Large, heavy, and sealed. The knight carved into it is in
      full armour, his hands clasped in prayer; his shield displays
      a lion, the FitzAlan arms."
    has
      ~proper;


Tomb -> FitzAlanSmallTomb "smaller tomb"                    ! >FitzAlanSmallTomb
  with
    adj_name
      'small' 'smaller' 'wive' 'wive^s' 'children' 'child'
      'wife^s' 'child^s' 'children^s',
    description
      "Probably for the FitzAlan wife or children, this is a simple
      square block, fully sealed.",
  has
    ~proper;


! open = open
Object -> FitzAlanPanel "art panel"                             ! >FitzAlanPanel
  class AdjObject,
  with
    adj_name 'wooden' 'wood' 'faded',
    noun_name 'art' 'panel' 'youths' 'corpses' 'inscription',
    initial [;
      if (self has open)
        "The panel is ajar, revealing an opening to the south.";
      if (frame has general)
        "The panel is currently closed flush against the wall.";
      "Against the southern wall hangs a faded wooden panel depicting the Three
      Living and the Three Dead, its Latin inscription barely legible in the
      gloom.";
    ],
    description [;
      if (self has open)
        "The panel is ajar from the wall, revealing an opening to the south.";
      "A large wooden painted panel set in a distinctive brass frame, it
      depicts the Three Living and the Three Dead---three noble youths
      recoiling from three crowned corpses who gesture toward them. Woven
      beneath in Gothic script: ~QUOD FUIMUS, ESTIS; QUOD SUMUS, ERITIS~
      (What we were, you are; what we are, you will be). Dampness has taken
      its toll on the ancient pigments.";
    ],
    before [;
      Take:
        "Before you even try, you realise this would be much too large to
        carry.";
      Burn:
        "Given how damp it is here, you couldn't catch it alight.";
      Search:
        "Besides your search for meaning in this memento mori, you find nothing
        unexpected in the artwork.";
      Turn: "Nothing happens when you try to rotate the panel.";
      Push:
        if (Frame hasnt general)
          "The art panel seems fixed to the distinctive brass frame.";
        if (self has open) <<Close self>>;
        "The art panel seems fixed to the distinctive brass frame";
      Pull:
        if (self has open) "The panel is already ajar.";
        "The art panel seems fixed to the distinctive brass frame.";
      LookUnder:
        if (self hasnt open)
          "The panel and frame are attached to the wall.";
      Open:
        if (Frame has general) <<Push Button>>;
      Close:
        if (self has open) {
          give self ~open;
          "You push the panel against the wall and hear a click from inside the
          frame.";
        }
        if (Frame has general)
          "The panel is already closed.";
    ],
    has
      static transparent;


! general = player has examined frame
Object -> -> Frame "brass frame"                                        ! >Frame
  class AdjObject,
  with
    adj_name 'distinctive' 'brass',
    noun_name 'frame',
    before [;
      Search, Examine:
        give self transparent;
        if (FitzAlanPanel has open)
          "The panel and frame are ajar from the wall, revealing an opening.";
        give self general;
        "The brass frame encloses the art panel. Examining it closely, you find
        a small button on the right-hand side of the panel.";
      Push:
        if (self has general) "Perhaps if you tried to do that to the button?";
        "Nothing unexpected happens.";
      LookUnder:
        <<LookUnder FitzAlanPanel>>;
      Open:
        if (self has general) <<Push Button>>;
      Close:
        <<Close FitzAlanPanel>>;
      Pull:
        <<Pull FitzAlanPanel>>;
    ],
  has
    static ~transparent;


Object -> -> -> Button "button"                                        ! >Button
  with
    name 'button',
    description "It's a small brass button on the side of the frame.",
    before [;
      Push:
        if (FitzAlanPanel hasnt open) {
          give FitzAlanPanel open;
          if (self hasnt moved) {
            give self moved;
            TaskDone(TASK_FA_PANEL);
            "You push the button and hear a faint click from inside the frame.
            The panel pops ajar from the wall, revealing an opening to the
            south.";
          }
          "Pushing the button, the panel once again swings open,
          revealing the opening to the south.";
        }
        "You push the button but hear no click. Perhaps this is because the
        panel is already open?";
    ],
  has
    static;

! ---------------------------------------------------------- Crypt


Room Crypt                                                              ! >Crypt
  with
    short_name [;
      print "Main Crypt";
      if (TombEzra has general) print " (hiding)";
      rtrue;
    ],
    description [;
      print
        "The crypt stretches dimly before you, thick stone pillars supporting
        low vaulted arches. Rows of tombs line the walls; the air is thick and
        damp.";
      if (FitzAlanPanel has open)
        print
          " An opening in the north wall reveals a passage.";
      else
        print " A section of the north wall has been covered with wood planks.";
      "^^A large bell is in a stand by the stairs heading upward, and a small
      doorway leads south.";
    ],
    u_to CryptStairs,
    n_to [;
      if (Frame hasnt general) "You can't go that way.";
      print
        "You head south through the opening behind the panel, revealing...^";
      return FitzAlanCrypt;
    ],
    s_to CryptVestry,
    time_left 0,
    #IfDef HAS_HINTS;
    each_turn [;
        HintReady(Hint_Crypt);
        if (self.time_left > 4)
          HintReady(Hint_CryptEscape);
    ],
    #EndIf;
    before [;
      Smell:
        if (noun == nothing or Crypt) "Heavy, damp, and earthy.";
    ],
    cheap_scenery
      'pillars' 'arches'
        "They're just part of the ceiling, far too high for you to do
        anything with them."
      CS_THEM 2 'crypts' 'tombs' [;
        Examine, Search:
          if (self hasnt general) {
            print "You cast your eyes over the tombs.";
            give self general;
            QuoteBoxSimple(quote_crypt);
          }
          "There are six tombs holding the earthly remains of former priors:
          Brothers Gordian, Ezra, Crispin, Dunstan, Godric, and Ambrose.";
      ]
    ,
  has
    ~light;


Object -> BlankPanel "wood panel"                                  ! >BlankPanel
  class AdjObject,
  with
    adj_name 'blank' 'wood',
    noun_name 'panel' 'planks',
    describe 0,
    description [;
      print
        "This side may have once had art on it; it's impossible to
        tell because this side has been boarded over with thick planks of oak
        (perhaps to provide insulation from the now-disused family crypt?)";
      if (FitzAlanPanel has open)
        print ".^^The panel is ajar, revealing an opening to the north";
      ".";
    ],
    before [;
      Pull, Close:
        if (FitzAlanPanel hasnt open)
          "It already is pulled shut, and you can't pry the planks off.";
        if (CryptBell hasnt general) {
          print
            "It doesn't appear that this can be opened from this side.
            Are you sure you want to do this? ";
            if (~~YesOrNo()) "You decide against this and leave it ajar.";
        }
        give FitzAlanPanel ~open;
        "You pull the panel closed and hear a click in the frame.";
      Push, Turn:
        if (FitzAlanPanel has open)
          "The panel is already ajar.";
        "Push as you may, you can't seem to open it from this side.";
      Search:
        if (FitzAlanPanel hasnt open)
          "You find nothing interesting about the panel other than your
          frustration that it doesn't open from this side.";
        "You find nothing unusual in the planks.";
      Take:
        if (FitzAlanPanel hasnt open)
          "You cannot pry the planks off the panel.";
    ],
  has static;


Tomb -> TombGordian "Brother Gordian's tomb"                      ! >TombGordian
  with
    noun_name 'gordian' 'gordian^s' 'tomb' 'crypt',
    history_text [;
      TaskDone(TASK_LEARNED_FOUNDING_DATE);
      "Gordian (1112-1192). Founder of the priory in 1152, formerly Master
      Builder to the Earl of Pembroke. A man of great skill and piety, he lived
      by three great creeds that he impressed upon the brethren drawn to
      the new priory.
      ^^Gordian designed the church and Cloister himself, from the
      great bell in the tower to the stained glass of the Nave.
      ^^It is said he built the priory as penance for worldly pride,
      each clever mechanism a reminder that God's
      mysteries surpass man's cleverness. He served as Prior from its
      founding until his death.";
    ],
    ;

Tomb -> TombEzra "Brother Ezra's tomb"                               ! >TombEzra
  with
    noun_name 'ezra' 'ezra^s' 'tomb' 'crypt',
    description
      "Brother Ezra's tomb is a stone block with a lid on which his name is
      carved. It sits in the dankest corner of the crypt, positioned between
      two thick pillars that cast deep shadows behind it.",
    react_before [;
      if (self hasnt general) rfalse;

      Listen, Smell, Examine, Wait, Pray, Insert, Eat, Think,
      Blow, Consult, Drink, Transfer, Look, Drop, SwitchOff, Extinguish,
      WaitHours, WaitMinutes, WaitMoves, WaitUntil:
        ;
      Go:
        print "You stand.^";
        give self ~general;
        if (selected_direction == u_to) rtrue;
      Exit:
        give self ~general;
        "You stand.";
      default:
        print "(To do so, you get up from crouching)^";
        give self ~general;
    ],
    before [;
      Hide:
        if (self has general) "You are already crouching down and hiding.";
        give TombEzra general;  ! hidden
        "You crouch far down on the darkest side of ", (the) self, ".";
    ],
    history_text
      "Ezra (1155-1212). Elected as the second prior in 1192 and served in this
      role for 18 years. He built out the Infirmary and the Infirmary Chapel
      and opened the priory to religious pilgrims travelling to Scotland.
      Contemporary brothers remembered him
      for his flaming orange hair and for his kindness---he always said he
      would protect his brethren from danger as well as he could.";


Tomb -> TombCrispin "Brother Crispin's tomb"                      ! >TombCrispin
  with
    noun_name 'crispin' 'crispin^s' 'tomb' 'crypt',
    history_text
      "Crispin (1180-1248). Gained renown in the Holy Land
      as a young man, then took his vows and joined the priory.
      The second-longest serving prior (1210-1248), he brought many
      benefactors and the priory saw many pilgrims pass through hoping to
      meet the man who had taken the cross with such honour.";


Tomb -> TombDunstane "Brother Dunstan's tomb"                    ! >TombDunstane
  with
    noun_name 'dunstan' 'dunstan^s' 'tomb' 'crypt',
    history_text
      "Dunstan (1210-1270). Entered the priory from a trading family in
      Pembroke. Elected prior in 1248, after the death of Prior Crispin,
      he served for 22 years until his death. The latter half of his
      time as prior was marred by the start of the Second Baron's War and a
      decline in the prestige of the priory.";


Tomb -> TombGodric "Brother Godric's tomb"                         ! >TombGodric
  with
    noun_name 'godric' 'godric^s' 'tomb' 'crypt',
    history_text
      "Godric (1230-1299). Entered the priory as a child and was raised in
      its confines. Known best for his singing voice, he was the cantor
      from his early twenties, and was elected prior at only 40.
      He served in this role for 25 years (1270-95), only a few years before his
      death.";


Tomb -> TombAmbrose "Brother Ambrose's tomb"                      ! >TombAmbrose
  with
    noun_name 'ambrose' 'ambrose^s' 'tomb' 'crypt',
    history_text
      "Ambrose (1255-1310). After losing two brothers in the civil wars,
      Ambrose took his vows at twenty. He was elected as prior and served
      1295-1310. During his administration, he emphasised the importance
      of silence, and began the tradition of total silence throughout the
      grounds except in very limited circumstances. It is said that,
      in addition to his offices, he spent several hours a day silently
      praying in memory of his lost brothers.";


! general = rung and in the sequence for rescue

Object -> CryptBell "crypt bell"                                    ! >CryptBell
  class AdjObject,
  with
    adj_name 'crypt',
    noun_name 'handbell' 'bell',
    description
      "A large bell in a stand, both made of pewter. You've heard it once
      rung during a Mass in the crypt, and it was loud enough that you
      heard it on the Cloister.",
    before [;
      Turn, Pull, Attack, Push:
        if (self has general)
          "You just rang it, and dare not do it again.";
        SceneCrypt.scene_start();
        give self general;
        "You sound it with vigour which produces an almost deafening peal
        as it echoes around the room. You feel certain someone above will
        have heard that.";
      Take: "Leave it here. It will be needed for future masses here.";
    ]
  has scenery;


! -------------------------------------------------------- Crypt Vestry

Room CryptVestry "Crypt Vestry"                                   ! >CryptVestry
  with
    description
      "A long vertical passage of rough stone. This may have originally been
      designed to be a tunnel to another crypt, but it appears to be used
      to store materials needed for masses held in the crypt, and there are
      some such things on a ledge.",
    n_to Crypt,
    out_to Crypt,
    cant_go "The only way out is north.",
    before [;
      Smell:
        if (noun == nothing) "Heavy, damp, and earthy.";
    ],
    cheap_scenery
      1 'items' "If you want to search the ledge, just say so.",
  has
    ~light;


Object -> VestryLedge "ledge"                                     ! >VestryLedge
  with
    name 'ledge' 'shelf',
    inside_description
      "From your vantage on the ledge, you see nothing further here, and
      nothing unexpected about the stone above.",
    description [;
      print
        "It's a simple wooden ledge fastened to the stone wall. It contains
        several items, likely needed for services held down here";
      PrintContents(". Standing out among the other items ", self, ISARE_BIT);
      ".";
    ],
    react_before [;
      Go:
        if (parent(player) == self && selected_direction == d_to) <<Exit self>>;
    ],
    before [;
      Climb: <<Enter self>>;
      Search:
        if (coins has concealed) {
          give coins ~concealed;
          "Searching around, you find some pewter platters, a cup, and old
          cloths. You realise these won't be useful, but then you discover a
          sack buried under the cloths.";
        }
        print "There's nothing interesting on the ledge";
        PrintContents(" except ", self);
        ".";
    ],
    after [;
      Enter: "With some difficulty you climb onto the shelf.";
      Exit: "You scramble back down from the ledge.";
    ]
  has
    scenery supporter enterable;


Object -> -> Coins "sack"                                               ! >Coins
  with
    describe 0,
    short_name [;
      print "sack";
      if (self has moved) print " of coins";
      rtrue;
    ],
    parse_name [ w1 w2 w3 w4 ;
      w1 = NextWord();

      if (self hasnt general) {
        if (w1 == 'sack') return 1; return 0;
      }

      w2 = NextWord();
      w3 = NextWord();
      w4 = NextWord();

      ! print "DEBUG coins=", (address) w1, " ", w2, "^";

      if (w1 == 'sack') {
        if (w2 == 0) return 1;
        if (w2 == 'of' && w3 == 'silver' && w4 == 'coins') return 4;
        if (w2 == 'of' && w3 == 'coin' or 'silver' or 'coins') return 3;
        return 1;
      }
      if (w1 == 'coin' && w2 == 'sack') return 2;
      if (w1 == 'coin' or 'coins' or 'silver') return 1;
      return 0;
    ],
    description [;
      print "The sack is yellow-smeared dark burlap, tied with simple cord";
      if (self hasnt general) {
        ev_coins = true;
        give self general;
        ". Opening it, your hands tremble slightly---the weight is unmistakable.
        Silver coins spill into view: groats and pennies, perhaps ten
        shillings' worth.
        ^^Your breath catches. A small fortune, enough to feed the priory for
        a season.
        Hidden here, among the dead, where no monk should have need of it.";
      }
      else
        ", heavy with silver coins.";
    ],
    before [;
      Empty:
        "The coins are evidence. Best to leave them in the sack.";
      Receive:
        "There's no room for anything else.";
      Close:
        "It's already tied closed.";
      Open:
        if (self hasnt general) <<Examine self>>;
        "You loosen the cord, check the contents---still silver---and
        tie it closed again. The sight of such wealth still unsettles you.";
      Search:
        if (self hasnt general) <<Examine self>>;
        "The sack contains only silver coins. More money than you've ever
        held.";
      Take:
        if (self in player) {
          print "You already have the sack";
          wn = verb_wordnum + 1;
          if (NextWord() == 'coin' or 'coins') print ". Leave the coins in it";
          ".";
        }
    ],
    after [;
      Take:
        if (self has general)
          "You take the sack, trying to ignore how the coins shift and clink.
          Your vow of poverty weighs heavier than the silver.";
        "You take it, noting metallic clinking as you do.";
    ]
  has evidence;


