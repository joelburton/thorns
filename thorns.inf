    description [;
      print
        "A long wooden table, big enough for two or three people to work at.
        It has a collection of utensils, knives, and vessels of spices on it";
      PrintContents(". On it ", self, ISARE_BIT);
      ".";
    ],
  has supporter;

Object -> Hearth "hearth"
  with
    name 'hearth' 'fire',
    description "A stone block built into the wall, with a fire burning in it.",
    before [;
      Search: "Anything within this would certainly be burned to cinders.";
      Receive:
        remove noun;
        "You toss ", (the) noun, " into the hearth and it disappears into the
        fire.";
      Touch: "Ow, ow, ow.";
      Smell: "Burning wood and smoke.";
      Enter:
        deadflag = 1;
        "Visions of saints burning at the stake enter your head.";
    ]
  has static container open;

