! --------------------------------------------------------- Scriptorium

Room Scriptorium "Scriptorium"                                    ! >Scriptorium
  with
    description
      "This chamber is where three of the brothers typically work, creating
      illuminated manuscripts and copying books. To the west is the Cloister;
      to the east is the Library.

      A large table is at the centre where the work is done.",
    e_to LibraryDoor,
    w_to CloisterE,
    out_to CloisterE,
    in_to LibraryDoor,
    #IfDef HAS_HINTS;
      on_first_entry [;
        HintReady(Hint_Scriptorium);
      ],
    #EndIf;
    before [;
      Smell:
        if (MandrakeRoot in Fireplace) {
          print
            "Foolishly, you deeply inhale the mandrake yourself, and
            wake to find yourself being shaken
            firmly by Brother Oswald.^^

            ~What madness, Brother Aldwin? What were you thinking?~

            You are sentenced to bread and water for a week.";
          KillOff();
        }
        "You can smell wood burning in the fireplace.";
    ],
    after [;
      Go:
        if (Pax in player && BrWilfred has awake && BrWilfred in self) {
          SceneLibraryCat.scene_start();
          rfalse;
        }
        if (BrWilfred in self && BrWilfred has awake) {
          if (f_ever_offered_confession) {
            "Brother Wilfred loop up from his work and then looks down
            with sadness.";
          } else {
            f_ever_offered_confession = true;
            "^Brother Wilfred looks up from his work and immediately sees the
            pain and confusion in your face, the weight of carrying around
            what you've discovered.

            ^^~My child~, he says, ~I can see that you carry much sorrow.
            Would you like to unburden yourself? Might I offer you confession?~

            ^^(You can do so with CONFESS TO WILFRED.)";
          }
        }
    ],
    cheap_scenery
      CS_THEM 15 'writing' 'implements' 'brushes' 'brush' 'ink' 'inks' [;
        Examine:
          "Brushes and inks needed for the work.";
        Search:
          "There's nothing hidden among them.";
        Smell:
          "They smell of the pigments used in copying.";
        default: "You shouldn't disturb these materials.";
      ]
    ,
  has
     ;


Object -> ScriptoriumTable "table"                           ! >ScriptoriumTable
  with
    name 'table' 'desk',
    description [ ;
      print
        "Large enough for four monks to work here, it is laden with
        implements for producing illuminated manuscripts. A breviary,
        presumably a current work, is open on the table";
      if (LibraryKey in BrWilfred) print ", along with a silver key";
      ".";
    ],
    before [;
      Receive:
        if (noun == LibraryKey && BrWilfred in Scriptorium) {
          move LibraryKey to BrWilfred;
          "You place the key on the table, aiming for the exact place it
          was before.";
        }
        "There are implements and the breviary on the table already.
        Don't clutter it with your stuff.";
      LookUnder: "Just the floor.";
      Climb, Enter:
        "You dare not. This is the workplace of several of your brethren.";
    ],
  has
    scenery supporter;


Object -> -> Breviary "breviary"                                 ! >Breviary
  with
    name 'breviary' 'manuscript',
    description
      "Brother Wilfred's current work---an unfinished breviary for the
      Divine Office. The Latin text flows in careful Gothic script across
      vellum pages. Several decorated initials have been illuminated with
      silver leaf and vermilion, their intricate patterns revealing the
      master's eye even as the slightly wavering lines betray his trembling
      hands. Many pages still await illumination.",
    before [;
      Examine:
        if (verb_word == 'read')
          "The breviary lies open to Psalm 23. The Latin reads: ~Dominus
          regit me, et nihil mihi deerit; in loco pascuae ibi me collocavit...~
          (The Lord is my shepherd, I shall not want; He maketh me to lie
          down in green pastures...)";
      Search: "You discover nothing but the sacred text itself.";
      LookUnder: "There is nothing beneath the breviary.";
      Take, Insert:
        "You wouldn't dare. These illuminated works are one of the main sources
        of the priory's income, and a loss of one would be a disaster.";
      default: "You shouldn't disturb the breviary.";
    ]
  has ;



Object -> Fireplace "fireplace"                                     ! >Fireplace
  with
    name 'fireplace' 'fire',
    initial
      "A fireplace is built into the south wall, and a small fire is going,
      making the room warmer and helping keep the manuscripts dry from the
      sea air.",
    description [;
      print
        "The fireplace is a stone recess in the wall with a fire going";
      PrintContents(". In it ", self, ISARE_BIT);
      ".";
    ],
    before [;
      LetGo:
        "You can't remove burning things from ", (the) self, ".";
    ],
    after [;
      Touch: "Ow, ow, ow.";
      Smell:
        "It smells of wood and smoke.";
      Receive:
        remove noun; ! other things burn instantly
        print (The) noun, " catches aflame and is destroyed.";
        if (noun == Rosemary && BrWilfred in location && BrWilfred has awake)
          print
            " Brother Wilfred smells the burning rosemary.
            ~Ah, my favorite.~";
        "";
    ],
  has
    static container open;

