Constant INITIAL_LOCATION_VALUE = MyCot;
Constant MAX_CARRIED = 3;
Constant SACK_OBJECT = Basket;


Include "globals.h";

! --------------------------------- default messages

Constant MSG_STRONG_DEFAULT "Jesus wept.";
Constant MSG_TAKE_YOURSELF "You're far too modest for that.";
Constant MSG_KISS_PLAYER "You're far too modest for that.";
Constant MSG_ATTACK_DEFAULT "Peace, Brother. Violence isn't the answer.";
Constant MSG_JUMP "You do so, feeling self-conscious the entire time.";
Constant MSG_PRAY_DEFAULT "You pray fervently, but nothing apparent happens.";
Constant MSG_BUY_DEFAULT  "The sin of avarice takes many forms.";
Constant MSG_SING_DEFAULT
  "You're a novice, not a cantor. Save your voice for the Office.";
Constant MSG_SLEEP_DEFAULT
  "Sloth is one of the seven deadly sins.
  Brother Prior would find work for idle hands.";
Constant MSG_SORRY_DEFAULT "This isn't confession.";
Constant MSG_KISS_DEFAULT
  "Such displays of affection are... inappropriate.
  And forbidden. Very forbidden.";
Constant MSG_MILD_DEFAULT "Mind your tongue, Brother.";
Constant MSG_PROMPT = 1234;  ! anything > 1000
[LibraryMessages p_msg ; ! p_arg_1 p_arg_2;
	switch(p_msg) {
    MSG_PROMPT:
      #IfDef HAS_HINTS; if (turns == 4) HintReady(hint_dragon); #EndIf;
      if (turns == 0) print "What will you do, Brother?^";
      print "> ";
	}
];


Constant TODO_AREA
  "A tiny grey tiger cat, wearing an orange safety vest, holds up a STOP sign,
  blocking your way. ~Sorry, this area is still UNDER CONSTRUCTION.~";

! ============================================================ Libraries

Include "ext_cheap_scenery.h";
Include "ext_quote_box.h";
Include "extlib/printtime.h";
Include "extlib/adjectives.h";
#IfDef HAS_HINTS;
  include "extlib/hints.h";
#EndIf;

! ==================================================== Global Attrs/Props/Vars



Global suspicion_level = 0;
! 0 = before death
! 1 = after death
! 2 = identified poison
! 3 = find coins or shortage or letters

Global f_smelled_aelred = 0;

! ============================================================= Hooks


[ DeathMessage;
  if (deadflag == 3) print "You have failed";
];

[ TimePasses ;  ! Call when # turns goes up
  SetTime(the_time + 2);
];

[ InScope ;
  ! So player can find sacristy door to open it
  if (real_location == Sacristy && location == thedark) {
    PlaceInScope(SacristyDoor);  ! so we can find door
    PlaceInScope(Sacristy);      ! so room actions, like smell, work
  }
  rfalse;
];

[ IsARoom p_obj;
  if (p_obj ofclass Room or Cloister) return 1;
  return 2;
];

Global g_been_in_dark = false;
Replace _UpdateDarkness;
! There doesn't appear to be a better way to do this; NewRoom is called for
! every room EXCEPT thedark.
[ _UpdateDarkness p_silent _ceil _old_darkness _darkness;
	if(location == thedark) _old_darkness = true;
	_ceil = ScopeCeiling(player);
	if(_LookForLightInObj(_ceil, _ceil) == false) _darkness = true;
	if(_darkness ~= _old_darkness) scope_modified = true;
	if(_darkness) {

    ! only change: quote on first darkness
    NowInDark();
    !--- end of changes

		if(_old_darkness == false && p_silent == false) PrintMsg(MSG_NOW_DARK);
		location = thedark;
	} else {
		location = real_location;
		if(_old_darkness && p_silent == false) {
			new_line;
			<Look>;
		}
	}
];



Include "puny.h";

! ================================================================ Verbs

[ HistoryScope o;
  switch (scope_stage) {
    1: rfalse;
    2: objectloop (o provides history_text) PlaceInScope(o); rtrue;
  }
];

Extend 'climb' first
  * 'on' noun                             -> Climb
  * 'down'                                -> Exit
  * 'down' noun                           -> Exit;

Extend 'consult' first
	* noun 'about'/'on' scope=HistoryScope  -> Consult;

Extend 'get' first
  * 'down'                                -> Exit;

Verb meta 'help'
  *                                       -> Help;

Extend 'jump'
  * 'on' noun                             -> Climb;

Verb 'kneel'
  * 'on' supporter                        -> Enter;

Extend 'look'
  * 'beneath' noun                        -> LookUnder
  * 'under' noun                          -> LookUnder;

Extend 'look' first
! * 'up' noun 'in' noun                   -> Consult reverse;
	* 'up' scope=HistoryScope 'in' noun     -> Consult reverse
  * 'up' topic 'in' noun                  -> Consult reverse
  * 'in' noun 'about' scope=HistoryScope  -> Consult;

Verb meta 'map'
  *                                       -> Map;

Extend 'read' first
	* 'about' scope=HistoryScope 'in' noun  -> Consult reverse
	* scope=HistoryScope 'in' noun          -> Consult reverse;

Verb 'ring' 'toll' 'peal'
  * noun                                  -> Pull;

Extend only 'sit' first
  *                                       -> SitAny;

Verb 'xyzzy' 'plug'
  *                                       -> Xyzzy;

! ========================================================= Verb Subs

[ HelpSub;
  print
    "^OUR LADY OF THORNS is written by Joel Burton <joel at joelburton.com>.

    ^^Unfamiliar with IF? See
    https://pr-if.org/doc/play-if-card/";

  #IfDef HAS_HINTS;
    print
      "^^There are hints in this game, but they'll appear only as you encounter
      those challenges (so even seeing the titles won't spoil anything.)
      You can see the available ones with the command ~HINT~.";
  #IfNot;
    print
      "^^You're playing the small-size version of this game intended for
      retro 8-bit computers. There is a separate game file with hints that will
      also run on your system.";
  #EndIf;

  "^^Playtesters and well-wishers: Melissa Higuchi, Lois Burton.

  ^^Special thanks to: Fredrik Ramsberg, andrewj, curiousdannii, Garry Francis,
  and ~Pontus I~ for answering my questions on forums.";
];

[ LookUnderSub;
  if (ObjectIsUntouchable(noun)) return;
  "You find nothing unexpected.";
];

[ MapSub helpful;
  switch (location) {

    WestPorch, Nave, Quire, HighAltarArea, StJudeChapel, LadyChapel,
    FitzAlanChantry, Sacristy:
      font off;
      print "
        ^    to Tower  to Dorm   to Crypt
        ^   +---------------------------------+
        ^   |   @@64    .    @@64    .    @@64    Fitz |
        ^   |        .         .         -----|
        ^  -   Nave  .  Quire  .  Altar  Lady |
        ^   |        .         .         -----|
        ^   |        .         .         Jude |
        ^   +-------------|-------|-- --|-----+
        ^           to Cloister   | Sac |
        ^ @@64 = Stairs      |       +-----+^";

    CloisterE, CloisterN, CloisterNE, CloisterNW, CloisterS, CloisterSE,
    CloisterSW, CloisterW, Garth, PriorsSolar, Locutory,
    ChapterHouse, Lavatorium, Refectory:
      font off;
      print "
        ^            @@92 |
        ^  - NW = N = NE -
        ^    ||   |   ||
        ^  - W -Garth- E -
        ^    ||   |   ||
        ^  - SW = S = SE ----
        ^    |    |       |^";

    Dorm, Necessarium, Dorter, LayCells:
      font off;
      print "
      ^  +----------------+
      ^  | @@64              |
      ^  |     Dorm       |
      ^  |                |
      ^  |----   ---|-----+
      ^  | @@64 Dorter   Nec |  @@64: Stairs
      ^  |----   ---|-----+
      ^  |    Lay Dorm    |
      ^  +----------------+^";

    Slype, Infirmary, InfirmaryChapel, HerbalistWorkroom, Garden:
      font off;
      print "^   NO MAP FOR THIS AREA YET XXX^";

    default: "There is no map for this area.";
  }
  font on;
  if (helpful) "^(You can see this map again by typing ~MAP~)^";
];

[ SitAnySub;
  if (location == Quire) <<Enter Stalls>>;
  "Where are you specifically trying to sit?";
];

[ XyzzySub; "You're in a monastery, not Colossal Cave."; ];


! ========================================== debugging grammar

#IfDef DEBUG;

  Verb meta 'settime'   * number number -> HourAdvance;
  Verb meta 'time'      *               -> Time;
  Verb meta 'suspicion' * number        -> SuspicionChange;
  Verb meta '_cabinet'  *               -> SolveCabinet;
  Verb meta '_lib'      *               -> SolveLib;
  Verb meta '_light'    *               -> SolveLight;
  Verb meta '_lion'     *               -> SolveLion;
  Verb meta '_office'   *               -> SolveOffice;
  Verb meta '_kill'     *               -> SolveAelredDead;

  [ SuspicionChangeSub;
    suspicion_level = noun;
    "Suspicion Level set to ", suspicion_level, ".";
  ];

  [ HourAdvanceSub ; SetTime(noun * 60 + second); <<Time>>; ];
  [ ZeroPad n; if (n < 10) print "0"; print n; ];
  [ TimeSub ;
    "Sundial: ", (SundialTime) the_time, "^",
      "Clock: ", (ZeroPad) the_time / 60, ":", (ZeroPad) the_time % 60;
  ];

  [ SolveAelredDeadSub; give BrAelred ~animate; f_smelled_aelred = 1; "You murder hobo!"; ];
  [ SolveCabinetSub; give InfirmaryCabinet open ; PlayerTo(Infirmary); ];
  [ SolveLibSub; give BrWilfred general; give LibraryDoor open; "Unlocked library."; ];
  [ SolveLightSub; move MagicLightGem to player; "You have the magic gem."; ];
  [ SolveLionSub; FitzAlanAltar.open_altar(); ];
  [ SolveOfficeSub; Service.stop_service(); "Service solved."; ];

  Object MagicLightGem "gem"
    with name 'gem', description "Glows with debugging power.",
    has light;

#EndIf;


! ================================================================ Routines

[ NowInDark ;
  if (g_been_in_dark == false) {
    QuoteBoxSimple(quote_darkness);
    g_been_in_dark = true;
  }
];

Constant CLOCK_NIGHT 1;      !
Constant CLOCK_MORNING 2;
Constant CLOCK_AFTERNOON 3;
Constant CLOCK_EVENING 4;

[ RoughTime ;
  if (the_time >= 1320 || the_time <= 360) return CLOCK_NIGHT;  ! 10p-6a
  if (the_time <= 720) return CLOCK_MORNING;                    ! 6a-noon
  if (the_time <= 1080) return CLOCK_AFTERNOON;                 ! noon-6p
  return CLOCK_EVENING;                                         ! 6p-10p
];

! Recursively check if a non-PC monk is in an obj, yes=true
[ MonkInObj loc obj;
  objectloop (obj in loc) {
    if (obj ofclass Monk)
      rtrue;
    if (MonkInObj(obj))
      rtrue;
  }
  rfalse;
];

! Is a monk in this room? (searching recursively)
[ MonkInRoom loc ;
  if (loc == 0) loc = location;
  return MonkInObj(loc);
];

[ KillOff;
  deadflag = 3;
  " By the time your penance ends, any chance of solving any mystery
    has long passed.^";
];


! ================================================================== CLASSES
! Altar, Chest, Cot, Monk, Room, Statue

Class Altar
  class AdjObject,
  with
    article "an",
    short_name "altar",
    adj_name 'stone',
    noun_name 'altar',
    react_before [;
      Go:
        if (player in self) {
          if (selected_direction == d_to) <<Exit self>>;
          "You'd have to climb down from ", (the) self, " first.";
        };
    ],
    description [;
      print "A simple stone altar, worn smooth by centuries of prayer";
      PrintContents(". On it ", self, ISARE_BIT);
      ".";
    ],
    before [;
      Climb:
        if (MonkInRoom())
          "You dare not, especially with another brother in the area.";
        <<Enter self>>;
    ],
    after [;
      Enter:
        "It feels deeply sacriligeous, but you climb onto the altar.";
      Exit:
        "You climb down from the altar.";
    ],
  has
    supporter enterable static;


Class Chest
  with
    parse_name [ w count ;
      w = NextWord();
      if (w == 'chest' or 'box') return 1;
      if (w == 'brother') {
        count++;
        w = NextWord();
      }
      if (w ~= self.amonk.&name-->0
        or self.amonk.&possess-->0
        or self.amonk.&possess-->1) return 0;
      w = Nextword();
      if (w ~= 'chest' or 'box') return 0;
      return count + 2;
    ],
    description [;
      print_ret
        (The) self,
        " is like all the others: a simple wooden box with a lid.";
    ],
    short_name [;
      print (The) self.amonk, "'s chest"; rtrue;
    ],
    before [;
      if (action ~= ##Examine && MonkInRoom())
        "You wouldn't dare with another brother in the room.";
      Examine: ;
      Take:
        "You couldn't carry that easily---and besides, how would ",
        (The) self.amonk, " store anything?";
      Push, Turn:
        "There's nothing underneath it, and it will just frustrate the
        brothers to move their chests around.";
      Open:
        if (suspicion_level == 0)
          "Searching another brother's property
          without reason just feels wrong.";
      default:
        if (suspicion_level == 0)
          "Doing anything with another brother's property
          without reason just feels wrong.";
    ],
  has
    proper container ~open openable scenery;


Class Cot
  with
    parse_name [ w count ;
      w = NextWord();
      if (w == 'cot' or 'bed' or 'mattress') return 1;
      if (w == 'brother') {
        count++;
        NextWord();
      }
      if (w ~= self.amonk.&name-->0
        or self.amonk.&possess-->0
        or self.amonk.&possess-->1) return 0;
      w = Nextword();
      if (w ~= 'cot' or 'bed' or 'mattress') return 0;
      return count + 2;
    ],
    description [;
      print_ret
        (The) self,
        " is like all the others: a simple straw mattress.";
    ],
    short_name [;
      print (The) self.amonk, "'s cot"; rtrue;
    ],
    before [;
      if (action ~= ##Examine && MonkInRoom())
        "You wouldn't dare with another brother in the room.";

      Search, LookUnder:
        "A search of ", (the) self, " finds nothing.";
      Take:
        "You couldn't carry that easily---and besides, how would ",
        (The) self.amonk, " sleep?";
      Push, Turn:
        "There's nothing underneath it, and it will just frustrate the
        brothers to move their cots around.";
    ],
  has
    proper scenery supporter enterable;

! TODO: hugh: hide letters *under* chest
! example things that could be in chest: sketch of priory, seashells, glasses

! Base class for all animated brothers (except player)
Class Monk
  with
    name 'brother',
    life [;
      Tell, Answer, Yes:
        print_ret (The) self, " isn't interested, most because he's
          NOT IMPLEMENTED YET.";
      default: "He apologizes. ~I'm NOT IMPLEMENTED YET.~";
    ],
  has
    animate proper
  ;


Class Room
  has light;  ! turn off in individual underground rooms


Class Statue
  with
    name 'statue',
    before [;
      Take:
        "The statue has stood here for many years.";
      Push, Pull, Turn:
        print "With some effort, you ";
        switch (action) {
          ##Push: print "push";
          ##Pull: print "pull";
          ##Turn: print "rotate";
        }
        " the statue a bit, revealing nothing
        unexpected. Feeling guilty about the potential sacriliege
        of this action, you reset it as it was.";
    ],
    life [;
      Attack, ShoutAt: "Perish the very idea!";
      Give:
        "You cannot offer ", (ItorThem) self, " anything but your reverence.";
      Ask, Tell, Answer, Show: "The statue remains ever-silent.";
      WakeOther: "Save the miracles for others.";
      Kiss:
        "You reverently kiss the hem of ", (ItorThem) self, " stone robe.";
      Order:
        "If anything, a statue of a saint would order you around.";
    ],
  has
    static animate proper;

Class Tincture
  with
    name 'tincture' 'tinctures//p',
    article "a bottle of",
    sniff [;
        if (self hasnt open) print "(first opening the bottle)^";
        give self open;
        print_ret "You breathe in: ", (string) self.scent;
    ],
    lick [;
        if (self hasnt open) print "(first opening the bottle)^";
        give self open;
        print_ret "You dare a tiny taste: ", (string) self.flavor;
    ],
    before [;
      Eat, Drink: "You dare not.";
      Attack:
        "You shouldn't break this---such bottles are valuable
        and communal property.";
      Empty:
        "These tinctures are used by Brother Benedict in healing.
        It would be wrong to waste them.";
      Smell: self.sniff(); rtrue;
      Taste: self.lick(); rtrue;
    ],
  has
    container openable ~open;


! ================================================= MONKS
! Aelred: herbalist
! Anselm: cantor
! Benedict: infirmarer
! Cuthbert: sacrist
! Hugh: cellarer
! Martin: kitchener
! Oswald: prior
! Remigio: servant lay monk
! Wilfred: librarian
!
! the PC, Aldwin, is not an instance of monk class.

Monk BrAelred "Brother Aelred"
  with
    name 'aelred' 'herbalist',
    description [;
      if (self hasnt animate)
        "Dead descrip XXX";
      "Your beloved mentor. In normal moments, Brother Aelred's eyes
      twinkled with kindness, a smile framing against his broad face.
      Right now, though, he looks desperately ill.
      Sweat beads on his flushed face, and his pupils are enormously
      dilated, giving his eyes a black, glassy appearance.
      His limbs are twitching in his habit, making it seem
      as though trying to remove something that isn't there.";
    ],
    possess 'aelred^s' 'aelreds',
    go_home [;
      move self to HerbalistWorkroom;
    ],
  has
      animate;  ! turn off when dead
  ! henbane symptoms = visual hallcuinations


Monk BrAnselm "Brother Anselm"
  with
    name 'anselm' 'cantor',
    description "Cantor XXX",
    possess 'anselm^s' 'anselms',
    go_home [;
      remove self;
    ],
  has
    ;

Monk BrBenedict "Brother Benedict"
  with
    name 'benedict' 'infirmarer',
    description "Infirmarer XXX",
    possess 'benedict^s' 'benedicts',
    go_home [;
      move self to Infirmary;
    ],
  has
    ;

Monk BrCuthbert "Brother Cuthbert"
  with
    name 'cuthbert' 'sacrist',
    description "Sacrist XXX",
    possess 'cuthbert^s' 'cuthberts',
    go_home [;
      remove self;
    ],
  has
  ;

Monk BrHugh "Brother Hugh"
  with
    name 'hugh' 'cellarer',
    description "Cellarer XXX",
    possess 'hugh^s' 'hughs',
    history_text
      "Left at the monastery at only 8 by his family, Brother Hugh was brought
      up here. He serves us well as our cellarer, keeping track of our goods
      and manages the trade with boats.",
    go_home [;
      move self to Undercroft;
    ],
  has
  ;

Monk BrMartin "Brother Martin"
  with
    name 'martin' 'kitchener',
    description "Kitchener XXX",
    possess 'martin^s' 'martins',
    go_home [;
      move self to Locutory;
    ],
  has
  ;

Monk BrOswald "Brother Oswald"
  with
    name 'oswald' 'prior',
    description "Oswald Prior XXX",
    go_home [;
      move self to PriorsSolar;
    ]
  ;


Monk BrRemigio "Brother Remigio"
  with
    name 'remigio',
    description "Lay monk XXX",
    possess 'remigio^s' 'remigios',
    go_home [;
      move self to Kitchen;
    ],
    life [;
      Give:
        if (noun == Basil) {
          move Basil to self;
          "Remigio's weathered face transforms. ~Basilico!~ he exclaims,
          taking the herb and breathing deeply. ~I have not smelled this
          since I left Toscana.~ His eyes glisten. ~Brother Aelred grew
          this? He was... he was a good man.~ He gestures toward the
          stairs. ~Go below if you must, Brother. I will not question you.~";
        }
    ],
  has
  ;

Monk BrWilfred "Brother Wilfred"
  with
    name 'wilfred' 'librarian',
    description
      "Brother Wilfred is the most venerated of the brethren, well
      over seventy. He's lean and wiry, with wisps of white hair shooting
      in all directions from his head. His fingers are stained with pigments,
      and his habit has bits of fluff or fur on it.",
    history_text
      "Wilfred XXXX-. Wilfred joined the monastery as a young man,
      coming from a well-educated family. From XXXX-XXXX, he served
      as the Prior, but in his old age, now acts as the master
      illuminator and librarian.",
    initial [;
      if (BrWilfred in Scriptorium)
        print "Brother Wilfred is seated at the table, close to south wall";
        if (BrWilfred has general) print ", snoring heavily";
        ".";
    ]
    possess 'wilfred^s' 'wilfreds',
    go_home [;
      move self to Scriptorium;
      move LibraryKey to ScriptoriumTable;
    ],
    each_turn [ chance ;
      if (BrWilfred has general || deadflag) return;
      chance = random(10);
      if (chance == 1)
        "^Brother Wilfred yawns sleepily.";
      if (chance == 2)
        "^Brother Wilfred rubs his temples with tiredness.";
      if (chance == 3)
        "^Brother Wilfred blinks his eyes heavily.";
    ],
  has
  ;


! aelred might call me:
! "Son" or "my son" - classic mentor address
! "Child" - affectionate, protective
! "Brother" - when being more formal/equal
! "Young friend" - warm but not patronizing

! others "Brother Novice" or "Brother Aldwin"


! ======================================================== 2.0 CHURCH
! 2.0.1 Entrance
! 2.0.2 Nave
! 2.0.3 Tower
! 2.0.4 Quire
! 2.0.5 High Altar Area
! 2.0.6 Sacristy
! 2.0.7 FitzAlan chantry
! 2.0.8 Lady Chapel
! 2.0.9 St Jude Chapel


! --------------------------------------------------- 2.0.1 Entrance
! West Porch, door

Room WestPorch "West Porch"
  class AdjObject,
  with
    adj_name 'west',
    noun_name  'porch' 'entrance',
    description
      "This covered entrance protects the west door from the
      winds that come across the sea to the east.
      Villagers used to gather here before services,
      but the number who do so have been declining for years.",
    e_to WestDoor,
    in_to WestDoor,
    cant_go
      "It is forbidden for you to leave the Priory grounds without permission
      of Brother Oswald.",
    cheap_scenery
      1 'villagers' "You certainly don't see any here now."
      1 'grounds' "The scraggly grounds extend in all directions."
  ;

Object WestDoor "west door"
  class AdjObject,
  with
    adj_name 'west',
    noun_name 'door' 'carving',
    found_in WestPorch Nave,
    door_dir (e_to) (w_to),
    when_closed "The great door is closed.",
    when_open [;
      print "The great door is open, revealing the ";
      if (location == WestPorch) "nave to the east."; "porch to the west.";
    ],
    description [;
      if (location == WestPorch && self hasnt open)
        "Carved deeply into the door's face:^
        ^  NOSTRA DOMINA SPINARUM (~Our Lady of Thorns~)^
        ^  FUNDATUM ANNO DOMINI MCXX^^
        Over two hundred years of wind and rain have worn the letters
        smooth.";
      "A large and solid oaken door.";
    ],
    after [;
      Close:
        print "You close the west door";
        if (location == WestPorch) print ", revealing a carving on the face";
        ".";
    ],
  has
    static door openable ~open;

! --------------------------------------------------- 2.0.2 Nave
! Nave and rood screen and cross

Room Nave "Nave"
  with
    name 'nave',
    description
      "The public space, where villagers stand for Mass.
      The stone floor is worn smooth by centuries of feet.
      High above, narrow windows admit pale light.
      The quire lies to the east, separated by a screen.
      A doorway in the north wall leads to the bell tower stairs.",
    e_to Quire,
    w_to WestDoor,
    out_to WestDoor,
    u_to TowerStairs,
    n_to TowerStairs,
    cheap_scenery
      'outside' 'porch' "The porch is to the west, beyond the door."
      1 'quire' "You should go east to see it better."
      1 'windows' "They're too high up to look out, but dim light comes in.",
  has ;

Object RoodScreen "rood screen"
  with
    name 'rood' 'screen',
    description
      "A wooden rood screen separates the nave from the quire, dividing the
      public space from the sacred. A simple carved cross tops the
      screen---the ~rood~ that gives it its name. The wood is dark with
      centuries of candle smoke.",
    found_in Nave Quire,
  has
    transparent  ! so can see cross "contained" in it
    scenery;

Object -> RoodCross "rood cross"
  class AdjObject,
  with
    adj_name 'rood',
    noun_name 'cross',
    description "Simply carved and without ornamentation.",
  has
    static;

!---------------------------------------------------- 2.0.3 Tower
! Tower stairs, tower, bell, and views

Room TowerStairs "Tower Stairs"
  with
    name 'stone' 'steps' 'stairs',
    description
      "A narrow spiral staircase winds upward. The stone steps
      are worn smooth and treacherously steep.
      Cold air and dim light flows down from above.",
    d_to Nave,
    s_to Nave,
    u_to BellTower,
  has ;

Room BellTower "Bell Tower"
  with
    description
      "The bell chamber. Wind whistles through the open arches on
      all four sides. The great bell hangs overhead.
      A rope from it hangs to within your reach.
      From here, you have clear views in all four directions.",
    d_to TowerStairs,
    before [;
      Examine:
        switch (selected_direction) {
          n_to:
            "To the north, you can see rough coast and cliffs,
            dotted with small farms.";
          s_to:
            "South of here, you see the cloister surrounding the garth,
            the priory's roofs, and the herb garden.
            How you've learned to love that garden.";
          w_to:
            "West lies the path to the village nestled down in the vale.
            You can also see a small path from the west door to the gate for the
            priory.";
          e_to:
            "East, you can see the infirmary and its chapel near the cliffs,
            and the dorter's small window breaking the upper story wall.";
          u_to:
            "The great bell hangs above you, dark against the sky. ";
          d_to:
            "You see the stone floor of the bell tower, and through the
            opening, the stairs descending.^^
            If you want to to look in a particular direction, do so.";
        }
    ],
  has ;

Object -> Bell "bell"
  class AdjObject,
  with
    adj_name 'great' 'bronze',
    noun_name 'bell',
    description
      "A bronze bell, green with age. Cast nearly two centuries ago,
      its surface bears the inscription: ~VOX DOMINI~",
    before [;
      Touch, Pull, Attack, Push:
        "The bell is far above you. You can only reach the rope.";
    ],
  has
    static scenery;

Object -> BellRope "bell rope"
  class AdjObject,
  with
    adj_name 'bell',
    noun_name 'rope' 'cord',
    describe 0,
    description
      "The cord reaches up to the bell, far above.
      Ringing the bell yourself would earn severe punishment.
      That duty does not belong to novices.",
    before [;
      Climb, Tie, Pull, Turn, Cut:
        StartTimer(self, 3);
        "Grabbing the cord causes the bell to toll, echoing across the priory.
        Instinctively you let go of the cord.";
    ],
    time_left,
    time_out [;
      if (location ~= BellTower or TowerStairs or Nave) {
        "You can hear footsteps in the nave, going up to the tower, and
        the returning. It seems very fortunate that you have avoided the
        wrath of the Prior, Brother Oswald.";
      }
      deadflag = 3;
      print
        "^Brother Oswald finds you here, his face dark with anger.^^
        ~What madness is this? Ringing the bells without cause?
        The entire village will think we're under attack!~^^
        You are confined to your cell with bread and water for a fortnight.";
      KillOff();
    ],
  has
    static;


!---------------------------------------------------- 2.0.4 Quire
! Quire, lectern, and stalls

! TODO: add door from quire to cloister

[ QuireDescripDuringService;
  print
    "The quire is the center of the church. Two long stalls face each other";
  if (child(Stalls) ~= nothing) {
    PrintContents(". Already seated on them ", Stalls, ISARE_BIT);
    if (BrOswald in HighAltarArea)
      print ". Brother Oswald, the Prior, is at the altar";
    ".";
  }
];

Object Service "service"
  with
    start_service [;
      move self to Quire;
      StartTimer(self, 7);
      if (BrAelred has animate) move BrAelred to Stalls;
      move BrAnselm to Stalls;
      move BrBenedict to Stalls;
      move BrCuthbert to Stalls;
      move BrHugh to Stalls;
      move BrMartin to Stalls;
      move BrOswald to HighAltarArea;
      move BrRemigio to Stalls;
      move BrWilfred to Stalls;
      Quire.old_description = Quire.description;
      Quire.description = QuireDescripDuringService;
      give Stalls concealed;
    ],

    stop_service [;
      remove self;
      give self ~general;
      StopTimer(self);
      if (BrAelred has animate) move BrAelred to HerbalistWorkroom;
      remove BrAnselm;
      move BrBenedict to Infirmary;
      remove BrCuthbert;
      move BrHugh to Undercroft;
      move BrMartin to Kitchen;
      move BrOswald to PriorsSolar;
      move BrRemigio to Kitchen;
      move BrWilfred to Scriptorium;
      print "You join the others in song.^^ - * - * -";
      Achieved(TASK_PERFORM_OFFICE);
      Quire.description = Quire.old_description;
      give Stalls ~concealed;
      "^^After a while, the office ends, and the other brothers depart.";
    ],
    add_to_scope [;
      if (BrOswald in HighAltarArea) { PlaceInScope(BrOswald); }
    ],
    time_left,
    time_out [;
      if (location == Quire)
        print
          "^Brother Anselm pauses the song: ~Why do you not join us, Brother
          Aldwin?~ The other monks look uncomfortably at you.";
      else
        print
          "^You can faintly hear the singing in the Quire. Brother Oswald
          finds you here, very frustrated. ~Why are you not with us,
          Brother Aldwin? You surely heard the bell calling you to office.~
          You follow him to the quire and join the office.";
      print
        "^^You know that you've broken a rule of the priory.
        ^^After the office, Brother Oswald reprimands you severely and
        confines you to silent penance for a week.";
      KillOff();
    ],
    react_before [;
      Sing:
        if (Service hasnt general) "But there's no service going on now.";
        if (player notin Stalls)
          "First, be seated with the others.";
        Service.stop_service();
        rtrue;
      Examine:
        if (noun == BrOswald && BrOswald in HighAltarArea)
          "Though a distance away at the altar, he has his usual
          inscrutable expression.";
      Exit:
        if (noun == Stalls) "Not during office, surely!";
    ],
    each_turn [;
      ! make a count-up timer for the service?
      if (self has general)
        "^Brother Anselm is leading the brethren in song---all except you.";
    ],
  has
    concealed;

Room Quire "Quire"
  with
    description
      "The quire is the heart of monastic worship and the center of the church.
      Two choir stalls face each other
      across the narrow gap, where the brothers gather to chant the offices.
      The stalls are plain but worn smooth by generations of use.
      The high altar rises to the
      east. The nave lies west, beyond the screen. Night stairs ascend north
      to the dormitory, and a hall leads south to the cloister.",
    old_description "",  ! gets filled with orig during service so can restore
    s_to CloisterNE,
    e_to HighAltarArea,
    w_to Nave,
    n_to NightStairs,
    u_to NightStairs,
    before [;
      Sing:
        "But there's no service going on now.";
    ],
    cheap_scenery
      'high' 'altar'
        [;
          if (BrOswald in HighAltarArea)
            "You can see the altar from here, but you should head east for a
            closer look.";
          "You can see Brother Oswald at the altar.";
        ],
  has
    ;

Object -> Stalls "stalls"
  class AdjObject,
  with
    adj_name 'wooden',
    noun_name 'stalls//p' 'stall',
    description
      "You've stood by and sat on these for months now during services.
      The carpentry is unremarkable and there is nothing these can reveal.",
    after [;
      Enter:
        if (BrAelred in self)
          "You on a stall next to your mentor, the herbalist Brother Aelred.";
        "You sit on a stall with a certain sense of familiarity.";
      Exit:
        "You get up from your stall.";
    ],
  has
    static supporter enterable pluralname;


!----------------------------------------------------- 2.0.5 High Altar Area
! HighAltar, crypt stairs

Room HighAltarArea "High Altar Area"
  with
    description [;
      print
        "A domed ceiling rises above this, the place where the Prior leads
        office.
        A chapel stands in shadow to the east.
        The sacristy lies south. Behind a";
        if (CryptGate has open) print "n open";
        else print "closed";
        if (CryptGate has locked) print ", locked";
        " gate to the north, narrow stairs descend into
          the crypt.";
    ],
    w_to Quire,
    e_to LadyChapel,
    d_to CryptGate,
    n_to CryptGate,
    s_to SacristyDoor,
    cheap_scenery
      1 'chapel'
        "From here, you can see an altar and a statue. You can go east to
         explore it.",
  has;

Altar -> HighAltar
  with
    short_name "high altar",
    article "the",
    adj_name 'high',
    ! TODO: this should mention the things on the altar
    description
      "The povery of the priory is evident in the simplicity of the altar.
      It is a simple stone structure supporting a cross and with a plain
      cloth draped on it.",
  has ;

Object -> -> AltarCloth "cloth"
  class AdjObject,
  with
    adj_name 'plain' 'altar',
    noun_name 'cloth',
    description "Coarse flax and unremarkable.",
    before [;
      Examine, Search, LookUnder, Smell, Listen: ;
      Touch: <<Examine self>>;
      Attack, Cut: "Heaven forfend.";
      default:
        "Brother Oswald would be outraged if you did anything with it.";
    ],
  has
    ;

Object -> -> AltarCross "altar cross"
  class AdjObject
  with
    article "the",
    describe 0, ! [; rtrue; ],
    adj_name 'altar',
    noun_name 'cross',
    description
      "A simple wooden cross---no gold, no jewels---firmly attached
      to the altar.",
    before [;
      Attack: "Heaven forfend.";
      Smell: "It smells like dust and faint incense.";
    ],
  has static;


! -------------------------------------------------------------

Object CryptGate "crypt gate"
  with
    name 'crypt' 'gate' 'stairs',
    description [;
      #ifDef HAS_HINTS; HintReady(Hint_gate); #EndIf;
      print
        "The gate is made of sturdy iron and has a heavy lock built into it.";
    ],
    found_in HighAltarArea CryptStairs,
    door_dir (u_to) (d_to),
  has
    scenery door locked ~open openable;

Room CryptStairs "Crypt Stairs"
  with
    name 'crypt' 'stairs',
    description [;
      print
        "At the midpoint of these stairs, you can sense the damp
        below. A thin veil of light comes from the altar area above";
      if (_LookForLightInObj(Crypt, Crypt))
        ", and weak candlelight from the crypt below.^";
      ", but the path down descends into darkness.";
    ],
    s_to CryptGate,
    u_to [;
      if (PrayerMat has general && CryptGate has locked) {
        print
          "As you approach the crypt door, you hear the soft
          click of an unseen bolt sliding back. Your prayer
          has been answered.^^";
        give CryptGate open;
        give PrayerMat hasnt general;
      }
      return CryptGate;
    ],
    d_to Crypt,
    before [;
      Smell: "Musty and damp.";
    ],
  has
    ;


! --------------------------------------------------- 2.0.6 Sacristy


Object SacristyDoor "sacristy door"
  with
    name 'sacristy' 'door',
    description "A narrow wooden door without any lock.",
    found_in HighAltarArea Sacristy,
    door_dir (n_to) (s_to),
    before [;
      Examine:
        if (location == thedark)
          "Have faith, Brother. You can't see it, but you know it's there.";
    ],
    after [;
        Open: give Sacristy light;
        Close: give Sacristy ~light;
    ],
  has
    static scenery door openable ~open;

Room Sacristy "Sacristy"
  with
    name 'sacristy' 'vestry',
    description
      "A small room where vestments and sacred vessels are kept.
      Shelves hold neatly folded linens, precious chalices, and other
      miscellaneous vestry items. The smell of beeswax and old incense lingers.
      Brother Cuthbert maintains this space with meticulous care.",
    n_to SacristyDoor,
    cheap_scenery
      1 'shelves' "The shelves are neat and tidy."
      'linen' 'linens//p'
        "The linens are worn but clean."
      4 'vessel' 'vessels//p' 'chalice' 'chalices//p'
        "The chalices are used for sacred purpose during Mass."
      1 'incense' "You can smell it faintly, but can't find any here."
      'vestry' 'items' "Some cloth, candles, and a pewter platter."
      1 'cloth' "Just scraps, really."
      2 'pewter' 'platter' "Used to hold items during Mass.",
    before [;
      Smell:
        if (location == thedark)
          "You smell wax and old incense in the darkness.";
        "Dusty and fragrant with wax and wood.";
      Go:
        if (location == thedark)
          "You shouldn't stumble around in the dark.
          You might damage something.";
    ],
  has
    ;

Object -> Candles "candles"
  class AdjObject,
  with
    adj_name 'beeswax',
    noun_name 'candles',
    describe [; rtrue; ],
    description
      "There's a few candles here, finer than the more common ones made of
      tallow. These candles are used to light the church.",
    before [;
      Burn: "Burning all of these candles would be madness.";
      Take:
        if (Candle.dont_need()) rtrue;
        "The theft of all of the candles would be quickly discovered.";
    ],
    add_to_scope Candle,
  has pluralname;

Object Candle "candle"
  class AdjObject,
  with
    adj_name 'beeswax',
    noun_name 'candle',
    describe [;
      if (self hasnt moved) rtrue;
      rfalse;
    ],
    dont_need [;
      if (FitzAlanAltar hasnt moved)
        "There's no reason for this. The monastery is lit,
        except at late night,
        and carrying one about would only raise questions.";
    ],
    description [;
      print "Good quality, made from beeswax from the priory's own bees";
      if (self has light) print ". It is currently lit.";
      ".";
    ],
    before [;
      Burn:
        if (self has light) "It's already lit.";
        if ((second == nothing && location == NightStairs)
              || second == TimeCandle) {
          give self light;
          "You light your candle using ", (the) TimeCandle, ".";
        }
        "You need something appropriate to light your candle.";
      Take:
        ! haven't solved lion/crypt: don't let them take
        if (Candle.dont_need()) rtrue;
        ! if there's already a candle in room or player, they get this one
        if (IndirectlyContains(location, self)) rfalse;
        ! if it's been removed from the game (destroyed), they get another
        if (parent(Candle) == nothing) {
          move self to player;
          if (self has moved)
            "Feeling even more guilt, you take another candle.";
          "You take a single candle, feeling the weight of this
          small theft.";
        }
        "Surely, one stolen candle must be enough.";
    ],
  has
    ;

! --------------------------------------------------- 2.0.7 FitzAlan Chantry



! TODO:
!
! candle problem: can't carry lit candle or in-hand candle:
!   in front of any monk or anywhere on cloister
! can douse with water (add water barrel on porch or in sacristry for cleaning)
! and then hide in hood or basket
! or, can throw into latrines (but cant work for undercroft darkness)
!   since can't light candle there  XXX: wouldn't there be a fire there?

Room FitzAlanChantry "FitzAlan Chantry"
  with
    name 'chantry',
    description [;
      #IfDef HAS_HINTS; HintReady(Hint_chantry); #EndIf;
      if (player in FitzAlanAltar)
        "From here you can see the arms closely.";
      print
        "The FitzAlan family chantry, endowed long ago for
        masses. But the FitzAlans are gone now---their line ended in the
        pestilence---and no masses are said here anymore";
      if (FitzAlanAltar has open)
        print " An opening in the floor reveals stairs leading down";
      ".";
    ],
    w_to HighAltarArea,
    s_to LadyChapel,
    d_to [;
      if (FitzAlanAltar has open) return FitzAlanCrypt;
    ],
    cheap_scenery
      1 'floor' "These almost look like scrapes from moving the altar."
      'gouge' 'gouges//p'
        "You're not sure what caused them---perhaps the altar was moved?"
      1 'motto' "~LEO VIAM CUSTODIT~",
  has
    ;

! open = open, can climb down. moved = ever been moved
Altar -> FitzAlanAltar
  class AdjObject,
  with
    adj_name 'stone' 'fitzalan',
    noun_name 'altar',
    describe [;
      print "^A stone altar is set against the east wall";
      PrintContents(". On it ", self, ISARE_BIT);
      ".";
    ],
    description [;
      print "A heavy-looking block of white stone";
      if (self has open)
        " that has been pushed away from the wall, revealing stairs descending
        into darkness.";
      print " on the floor. Gouges in the floor by the altar
      testify to its weight. Above the altar, carved into
      the wall, are the FitzAlan arms and motto";
      PrintContents(". On the altar ", self, ISARE_BIT);
      ".";
    ],
    after [;
      Enter:
        print "You climb onto the altar";
        if (FitzAlanLion hasnt moved)
          ". From here you can reach the carved arms above.";
        ".";
    ],
    open_altar [;
      give self open;
      give self moved;
      QuoteBoxSimple(quote_stone);
      Achieved(TASK_MOVE_ALTAR);
      "You push against the altar and it swings away from the wall,
      revealing a a set of stairs leading downward.";
    ],
    before [;
      Take:
        if (FitzAlanLion hasnt moved) rfalse;
        "Even trying, you can't lift it.";
      Search:
        "You find nothing hidden about the altar itself, but those gouges
        in the floor are intriguing.";
      Push, Turn:
        if (player in self)
          "You can't move the altar while standing on it.";
        if (self has open) {
          give self ~open;
          give FitzAlanLion ~moved;
          "You push the altar back against the wall and hear a solid click as
          it settles against the wall.";
        }
        if (FitzAlanLion has moved) { self.open_altar(); rtrue; }
        if (self has moved)
          "It no longer seems you can push it.";
        "While it seems that the altar isn't built into the floor, it
        also doesn't budge when you try to move it.";
    ],
  has
     ;

! moved = lion is pushed in
Object -> FitzAlanLion "FitzAlan arms"
  class AdjObject,
  with
    adj_name 'fitzalan' 'family' 'brass' 'rampant',
    noun_name 'lion' 'arms',
    description [;
      if (player notin FitzAlanAltar)
        "A lion, perhaps? It's a bit too far up to see clearly.";
      if (self has moved) "The lion is pressed in slightly.";
      "A finely-detailed brass rampant lion standing out from the stone.";
    ],
    before [;
      if (player notin FitzAlanAltar && action ~= ##Examine)
        "The arms are set high in the wall, well above you.";
      Push, Turn:
        if (self has moved) "Nothing new happens.";
        give self moved;
        if (self has general)
          "Again, you push against the lion, and hear the same deep click.";
        give self general;
        "You push against the lion and, surprisingly, it moves
        inward slightly. A deep click is heard in the wall.";
      Touch:
        "The lion is fine to the touch and, curiously, feels like it
        could move.";
    ],
  has
    ~moved scenery pluralname;

Object -> FitzAlanStairs "stairs"
  with
    name 'stairs',
    description "The stairs lead downward into bleak darkness.",
    before [;
      if (FitzAlanAltar hasnt open) "You can't see any such thing.";
    ],
  has
    scenery;

!---------------------------------------------------- 2.0.8 Lady Chapel
! Chapel and statue

Room LadyChapel "Lady Chapel"
  with
    name 'lady' 'chapel' 'mary' 'virgin',
    description
      "The largest of the three chapels, dedicated to
      the Blessed Virgin.
      This chapel sees more use than the others---the brothers pray here
      for the priory's patroness, Our Lady of Thorns. To the west is the
      main church. Small doorways lead north and south to smaller chapels.",
    w_to HighAltarArea,
    n_to FitzAlanChantry,
    s_to StJudeChapel,
  has
    ;

Statue -> MaryStatue "statue"
  with
    name 'mary' 'virgin' 'blessed',
    initial "A statue of Mary stands in a niche.",
    description
      "A stone statue of the Blessed Virgin Mary. Her stone hands are
      open in a gesture of welcome and mercy. Her carved face is serene.^^
      Carved on the base statue:^
      ^  BEATAE MARIAE MATRIS DEI
      ^  (Blessed Mary, Mother of God)",
    react_before [;
      Pray: "You make the sign of the cross and murmur an Ave Maria.";
    ],
  has
    female;

Altar -> MaryAltar "stone altar"
  class AdjObject,
  with
    adj_name 'stone' 'mary',
    noun_name 'altar',
  ;

! --------------------------------------------------- 2.0.9 St Jude Chapel
! Chapel, mat, statue, altar, rosehips

Room StJudeChapel "St Jude Chapel"
  with
    name 'chapel',
    description [;
      #IfDef HAS_HINTS; HintReady(hint_jude); #EndIf;
      "A small chapel dedicated to St Jude, patron of desperate causes.
      The stone floor is worn smooth---many desperate souls
      have knelt here over the centuries, praying for urgent help.
      A painted statue shows the saint.";
    ],
    n_to LadyChapel,
  has
    ;

Object -> PrayerMat "prayer mat"
  class AdjObject,
  with
    adj_name 'prayer',
    noun_name 'mat',
    description
      "A rough flax mat before the altar, worn thin by countless hours
      of kneeling. Someone has been using it recently---very recently.",
    before [;
      Take, Push: "You are deeply certain it belongs here.";
      Search, LookUnder: "Nothing below it but a worn stone floor.";
    ],
    after [;
      Enter: "You kneel on the worn mat.";
    ],
    react_before [;
      Pray:
        if (player in PrayerMat) {
          if (self hasnt general) {
            give self moved;   ! ever got a prayer
            give PrayerMat general;
            "You feel a powerful sense of hope that the Saint will help you in
            crisis.";
          }
          "You feel that the Saint has already heard your plea.";
        }
    ],
  has
    supporter enterable;

Altar -> JudeAltar "altar"
  with
    description [;
      print "A simple stone altar, worn smooth by centuries of prayer.";
      if (RoseHips hasnt moved) {
        give RoseHips ~concealed;
        " Someone has left an offering of ", (a) RoseHips, " here.";
      }
      "";
    ],
  has
    ;


! The berries are initially known only as "berries", but they become known
! as rosehips after smell/tasting them. They're initially concealed, but are
! revealed after examining the altar (otherwise, they'd get listed in the
! initial room description, and I want people to have to look at the altar
! to notice them).

Object -> -> RoseHips "small red berries"
  with
    short_name [;
      if (self has general) { print "rosehips"; rtrue; }
    ],
    invent [;
      print (a) self, " (originally left as an offering to St Jude)"; rtrue;
    ],
    parse_name [ w wn ;
      while (true) {
        w = NextWord();
        if (w == 'red' or 'berry' or 'berries') wn++;
        else if (self has general &&
            w == 'rose' or 'hip' or 'hips' or 'rosehip' or 'rosehips') wn++;
        else return wn;
      }
    ],
    description [;
      if (self hasnt general) print "Small seed pods. ";
      "Someone carefully gathered these as an offering.
      They're fresh and fragrant, picked within the last day or two.";
    ],
    recall [;
      if (self hasnt general) {
        give self general;
        Achieved(TASK_IDENTIFY_ROSEHIPS);
        QuoteBoxSimple(quote_rose);
        "This action brings back a memory from summer: Aelred in the physic
        garden, showing you a red rose in full bloom. ~Beautiful now, Brother,
        but its true gift comes later. These petals fall, and by autumn the
        hip swells with seed---tart and rich. We gather them after the first
        frost for winter cordials.~ He'd smiled. ~The rose serves us twice:
        beauty in summer, medicine in autumn.~";
      }
      ", reminiscent of roses.";
    ],
    ! XXX perhaps they have to both smell and taste before they recognize?
    before [;
      Eat:
        "You shouldn't eat an offering left to a saint.";
      Taste:
        print "You nibble at one: a sweet, tangly flavor";
        self.recall();
        rtrue;
      Smell:
        print "A faint, floral scent";
        self.recall();
        rtrue;
      Touch:
        "They're firm. Perhaps you should check their scent?";
    ],
  has
    pluralname edible concealed;

Statue -> JudeStatue "St. Jude"
  with
    name 'saint' 'st' 'jude',
    description
      "A wooden statue of St Jude, simply carved and crudely painted.
      The saint holds a staff in one hand. His painted eyes seem to
      gaze down at those who kneel before him in desperation.",
    react_before [;
      Pray: "You murmur a brief prayer to St Jude.";
    ];

! ======================================================== 2.1 CLOISTER
! NW N NE W E SW S SE Garth

class Cloister
  with
    name 'cloister' 'arcade',
    description [;
      if (CloisterNE hasnt visited) {
        print
          "You emerge to the northeast corner of the cloister walk,
          the covered stone arcade at the
          center of the priory. It's a continuous square path surrounding
          the garth, a large open yard. Various rooms and
          passageways come off of the cloister walk.^";
        MapSub(1);
      }
      print
        "Arched openings admit ";
      switch (RoughTime()) {
        CLOCK_NIGHT: print "cold night air and pale moonlight";
        CLOCK_MORNING: print "fresh morning breeze";
        CLOCK_AFTERNOON: print "slanted autumn sun";
        default: print "dim evening light";
      }
      print ".^^";
      self.cloister_detail();
    ],
    d_to
      "The Garth is only one step down from the cloister. To enter it,
      just walk in that direction through an opening.",
    before [;
      Climb:
        "You eye the effort it would take to scale the cloister
        and think better of it.";
    ],
  has
    light;

Cloister CloisterNW "Cloister (NW)"
  with
    cloister_detail
      "The wall of the nave rises imposingly to the north,
      and an imposing door lies to the west.",
    s_to CloisterW,
    e_to CloisterN,
    w_to PriorDoor;

Cloister CloisterN "Cloister (N)"
  with
    cloister_detail
      "The wall of the nave rises imposingly to the north.",
    w_to CloisterNW,
    s_to Garth,
    e_to CloisterNE;

Cloister CloisterNE "Cloister (NE)"
  with
    cloister_detail
      "An passageway to the church quire is north.
      The chapter house is to the east, and the day stairs to the upper floor
      head upward from here.",
    n_to Quire,
    e_to ChapterHouse,
    w_to CloisterN,
    u_to DayStairs,
    s_to CloisterE,
  ;

Cloister CloisterW "Cloister (W)"
  with
    cloister_detail
      "The locutory lies to the west.",
    s_to CloisterSW,
    e_to Garth,
    w_to Locutory,
    n_to CloisterNW,
  ;

Cloister CloisterE "Cloister (E)"
  with
    cloister_detail
      "To the east is the entrance to the warmining room.",
    n_to CloisterNE,
    e_to Scriptorium,
    w_to Garth,
    s_to CloisterSE,
  ;

Cloister CloisterSW "Cloister (SW)"
  with
    cloister_detail
      "The monk's gate lies to the west. A small alcove, the lavatorium,
       is to the south,
       right after the arcade turns to the east.",
    s_to Lavatorium,
    e_to CloisterS,
    w_to
      "As a novice, you are confined to the priory until you take
      your final vows.",
    n_to CloisterW,
    cheap_scenery
      3 'monk' 'monk^s' 'gate'
        "The gate is a heavy door leading to the outer world.
        It has a heavy bar on it to open the door---though you are forbidden
        to admit anyone to the priory. That is the sole duty of
        Brother Oswald.",
  ;

Cloister CloisterS "Cloister (S)"
  with
    cloister_detail
      "The refectory lies to the south.",
    n_to Garth,
    w_to CloisterSW,
    e_to CloisterSE,
    s_to Refectory,
  ;

Cloister CloisterSE "Cloister (SE)"
  with
    cloister_detail
      "The long slype lies to the east.",
    n_to CloisterE,
    e_to Slype,
    w_to CloisterS,
    cheap_scenery
      2 'long' 'slype'
        "The slype is a covered passageway to the east.",
  ;

Room Garth "Garth"
  with
    name 'garth' 'square',
    description
      "The garth---the small grass courtyard at the heart of the cloister.
      The covered cloister walk surrounds it on all sides, its arches
      framing the sky above.^^
      This is the monastery's heart, open to rain and sun, enclosed
      by the daily circuit of monastic life.",
    n_to CloisterN,
    w_to CloisterW,
    s_to CloisterS,
    e_to CloisterE,
    u_to
      "The cloister walk is raised only a single step. You're already
      at ground level. Just walk in the direction you want to enter it.",
    cheap_scenery
      'grass' 'courtyard'
        "Sparse grass and a few stubborn herbs. The garth was probably
        more carefully tended in better times."
      1 'water'
        "Presumably there's water in the well, but it's much too
        far for you to reach.",
  has
    ;

Object -> Sundial "sundial"
  class AdjObject,
  with
    adj_name 'sun',
    noun_name 'sundial' 'dial' 'clock',
    description [;
      if (the_time < 300 || the_time > 1260)
        "The sundial isn't casting a discernable shadow without sunlight.";
      "The sundial casts a shadow showing that the approximate time is ",
        (SundialTime) the_time, ".";
    ],
    has static;

Object -> GarthWell "well"
  class AdjObject,
  with
    adj_name 'stone' 'old',
    noun_name 'well',
    description
      "An old stone well, its edges worn smooth by centuries of drawing
      water.",
    before [;
      Enter, Climb:
        "The well is deep and dark. You're not that desperate.";
      Search:
        "It's too dark to see the bottom.";
      Receive:
        remove noun;
        print_ret
          (The) noun, " lands far below with a splash.
          I hope you didn't need that.";
    ],
  has
    static container open;

! ======================================================== 2.2 WEST WING
! 2.2.1 Prior's Solar
! 2.2.2 Locutory
! 2.2.3 Lavatorium

! --------------------------------------------------- 2.2.1 Prior's Solar

! this could be an interesting combination lock puzzle
Object PriorDoor "prior door"
  with
    name 'prior' 'door',
    description [;
      print "A heavy wooden door";
      if (location == CloisterNW)
        print " with a strange set of dials on it";
      print ". It is currently ";
      if (self hasnt open) "closed."; "open.";
    ],
    door_dir (e_to) (w_to),
    with_key PriorKey,
    found_in CloisterNW PriorsSolar,
  has
    static scenery door openable ~open lockable locked transparent;

Object -> PriorDials "dials"
  with
    name 'dials',
    description "NOT IMPLEMENTED YET. Use the key.",
;

Object PriorKey "fake key"
  with
    name 'fake' 'key',
    description
      "A large key stamped with the message
      FOR EMERGENCY USE SINCE THE REAL PUZZLE FOR THIS HASN'T BEEN WRITTEN.
      Use me to unlock the Prior's door.",
    found_in CloisterNW,
    initial "A large key glows in neon red on the stone floor.",
  ;

Room PriorsSolar "Prior's Solar"
  with
    name 'solar' 'room',
    description
      "Prior Oswald's private chamber. A narrow bed stands against one wall.
      A writing desk holds account books and correspondence. A wooden
      chest sits at the foot of the bed.
      The room is austere but private---a privilege of rank in a
      community that otherwise shares everything.",
    e_to PriorDoor,
  has
    ;

Object -> PriorsDesk "desk"
  with
    name 'desk' 'writing' 'table',
    description
      "A plain wooden desk covered with the Prior's work: account books,
      letters, administrative records.",
  has
    scenery static supporter;

Object -> PriorsChest "wooden chest"
  with
    name 'wooden' 'chest' 'box',
    description
      "A sturdy wooden chest bound with iron. Locked.",
  has
    scenery static container openable ~open lockable locked;

Object -> PriorsBed "narrow bed"
  class AdjObject,
  with
    adj_name 'narrow',
    noun_name 'bed',
    description
      "A simple bed---better than the straw pallets in the dormitory,
      but hardly luxurious.",
    react_before [;
      Sleep: <<Enter self>>;
    ],
    before [;
      Enter:
        "If the Prior were to catch you in his bed, you'd be expelled.
        You think better of it.";
    ],
  has
    scenery static supporter enterable;

! ---------------------------------------------------  2.2.2 Locutory

Room Locutory "Locutory"
  with
    name 'locutory' 'parlour' 'speaking' 'room',
    description [;
      if (self hasnt visited) QuoteBoxSimple(quote_locutory);
      "The locutory---the speaking room. A plain
      wooden table and a bench occupy the center. The walls are bare stone.
      This is where the Prior meets with merchants, where brothers
      discuss monastery business, where the silence of the Rule may
      be broken for practical needs.";
    ],
    e_to CloisterW,
  has
    ;

Object -> LocutoryTable "table"
  class AdjObject,
  with
    adj_name 'wooden',
    noun_name 'table',
    description
      "A plain wooden table where necessary business is conducted.",
  has
    scenery static supporter;

Object -> LocutoryBenches "benches"
  class AdjObject,
  with
    adj_name 'wooden',
    noun_name 'bench' 'benches//p',
    description
      "Simple wooden benches flanking the table.",
  has
    scenery static supporter enterable pluralname;

! --------------------------------------------------- 2.2.3 Lavatorium

Room Lavatorium "Lavatorium"
  with
    name 'lavatorium',
    description
      "A small alcove off the cloister where the brothers wash before
      entering the refectory. You can only go back the way you came.",
    n_to CloisterSW,
  has
     ;

Object -> Basin "basin"
  class AdjObject
  with
    adj_name 'large' 'stone',
    noun_name 'basin',
    initial
      "A large stone basin is built into the south wall, filled with
      water for washing.",
    description
      "The basin is worn smooth and water-stained from centuries of use
      and contains a large quantity of water.",
    before [;
      Drink:
        "This is washing-up water, and not suitable for drinking.";
      Taste:
        "You try a tiny sip and notice nothing unexpected.";
      Take:
        "The basin is built into the wall, and trying to get the water from it
        would seem impractical.";
    ],
    after [;
      Receive:
        print (The) noun, " drops into the water";
        if (noun == Candle && Candle has light)
          { give Candle ~light; print " and extinguishes"; }
        ".";
    ],
  has
    static container open transparent;

Object -> -> Water "water"
  with
    article "some",
    name 'water',
    before [;
      Drink: <<Drink Basin>>;
      Taste: <<Taste Basin>>;
      Take: <<Take Basin>>;
      Insert: <<Transfer noun Basin>>;
    ],
  has
    ;

! XXX: can take, but need to put back to exit

Object -> Towel "towel"
  with
    name 'towel',
    initial "A threadbare towel hangs on a peg by the basin.",
    description
      "It's a simple linen towel, well-worn by use.",
    before [;
      Attack, Cut:
        "Destrying communal property is a violation of the Rules.";
      Take:
        "You should leave this here. The other brothers will want of its use.";
      Touch:
        "Rough linen and damp.";
      Smell:
        "It smells damp and musty.";
    ],
  ;


! ============================================= East Wing

!---------------------------------------------------------- Chapter House

Room ChapterHouse "Chapter House"
  with
    description
      "The chapter house is a modest, rectangular room where the brothers
      gather each morning to discuss monastery business. A plain wooden table
      and benches occupy the center, and painted panels on the walls depict
      the hours of the divine office. In one corner stands a life-sized
      wooden statue.",
    w_to CloisterNE,
    cheap_scenery
      1 'scroll' "It's just a painted part of the statue.",
  has
    ;

Object -> ChapterFurniture "table and benches"
  with
    name 'table' 'tables' 'chair' 'chairs',
    describe 0,
    description "Both the table and the chairs are plainly made and wooden.",
    before [;
      Examine: ;
      Push, Pull, Turn:
        "You could move them, but for what purpose?
        They're just plain furniture.";
      Receive:
        "There would be no point cluttering this space with stuff.";
      Enter:
        "You have no reason to sit right now.";
      Take:
        "Leave the furniture be, Brother.";
    ]
  has supporter enterable pluralname;

Statue -> GordianStatue "statue"
  with
    name 'gordian' 'statue',
    describe 0,
    description
      "A wooden statue, worn and with the paint flaking in
      places. You recognize it as Brother Gordian, who you have been told
      was the founder of the priory. His face is filled with reverence and
      curiosity, and he is depicted holding a scroll reading ~INGENIUM DEI~.",
    before [;
      Kiss: "That would only give you a splinter.";
      Order: "The statue doesn't respond, naturally.";
    ],
  has
    static ~proper;

Object -> OfficeHours "painted panel"
  class AdjObject,
  with
    adj_name 'painted' 'office',
    noun_name 'panel' 'hours',
    description
      "It shows the offices:^
      ^Matins  3 AM     Sext     Noon
      ^Lauds   5 AM     None     3 PM
      ^Prime   6 AM     Vespers  6 PM
      ^Terce   9 AM     Compline 7 PM",
    before [;
      Take: "It's much too large to carry.";
      LookUnder, Search, Turn, Push, Pull:
        "It's painted onto a panel wall, and it doesn't move.";
    ]
  has
    scenery;

! --------------------------------------------------------- Scriptorium

Room Scriptorium "Scriptorium"
  with
    description
      "This chamber is where three of the brothers typically work, creating
      illuminated manuscripts and copying books. To the west is the cloister;
      to the east is the library.

      A large table is at the center where the work is done.",
    e_to LibraryDoor,
    w_to CloisterE,
    before [;
      Open, Unlock:
        if (noun == self && BrWilfred has general) {
          "You wouldn't dare try to enter the library with Brother Wilfred
          watching you!";
        }
      Smell:
        if (MandrakeRoot.burn_time) {
          print
            "Foolishly, you deeply inhale the mandrake yourself, and awaken by
            firm shaking by Brother Oswald.^^

            ~What madness, Brother Aldwin? What were you thinking?~

            You are sentenced to bread and water for a week.";
          KillOff();
        }
    ],
  has
     ;

Object -> ScriptoriumTable "table"
  with
    name 'table',
    description [;
      print
        "Large enough for four monks to work here";
      PrintContents(". On it ", self, ISARE_BIT);
      ".";
    ],
    before [;
      Search: "A search reveals nothing but the implements and manuscript.";
      LookUnder: "Just the floor.";
    ],
  has
    scenery supporter;

Object -> -> Manuscript "manuscript"
  with
    name 'manuscript',
    description
        "The manuscript is a psalter in progress, open to Psalm 23.
        The Latin text is written in a careful Gothic script, and
        someone---likely Brother Wilfred---has begun illuminating the
        initial ~D~ of ~Dominus~ with delicate gold leaf and azure.
        The shepherd's crook curves through the letter, and tiny sheep
        peek from the margins. It's beautiful work, though the hand
        that painted it must have trembled with age.",
    before [;
      Examine:
        if (verb_word == 'read')
          "The Latin reads: 'Dominus regit me, et nihil mihi deerit...'
          (The Lord is my shepherd, I shall not want...)";
        ! else will fall throw to normal examine
      Search: "You discover nothing but the text iself.";
      LookUnder: "There is nothing below the manuscript.";
      default: "You shouldn't disturb the manuscript.";
    ]
  has ;

Object -> -> WritingImplements "writing implements"
  class AdjObject,
  with
    adj_name 'writing',
    noun_name 'implements' 'brush' 'brushes//p' 'ink' 'inks//p',
    description "Brushes and inks needed for the work.",
    before [;
      Examine: ;
      Smell: "They smell of the pigments used in copying.";
      default: "You shouldn't disturb these materials.";
    ],
  has pluralname;

Object -> -> LibraryKey "silver key"
  class AdjObject,
  with
    adj_name 'library' 'silver',
    noun_name 'key',
    description
      "A simple silver key, tarnished with age. Brother Wilfred guards
      it jealously---it's his responsibility as librarian to control
      access to the priory's precious books.",
    before [;
      Take:
        if (BrWilfred in location && BrWilfred hasnt general) ! awake
          "Brother Wilfred's eyes snap up just as your hand reaches for it.
          ~Ah-ah,~ he says kindly but firmly, stifling a yawn. ~Not without
          the prior's leave, young Brother Aldwin.~";
    ],
    each_turn [;
      if (BrWilfred hasnt general
            && self notin ScriptoriumTable && ~~deadflag) {
        print
          "^Brother Wilfred discovers the missing key---you're caught.

          For violating such a serious rule of the priory, you are sentenced
          to bread and water for a week.";
        KillOff();
      }
    ]
  has ;

Object -> Fireplace "fireplace"
  with
    name 'fireplace' 'fire',
    initial
      "A fireplace is built into the south wall, and a small fire is going,
      making the room warmer and helping keep the manuscripts dry from the
      sea air.",
    description
      "A plain chamber of stone built into the wall.",
    after [;
      Touch: "Ow, ow, ow.";
      Smell:
        "It smells of wood and smoke.";
      Receive:
        print "You toss ", (the) noun, " into the fire.^";
        if (noun == MandrakeRoot) <<Burn MandrakeRoot>>;
        remove noun; ! other things burn instantly
        rtrue;
    ],
  has
    container open;

Object MandrakeRoot "mandrake root"
  with
    name 'mandrake' 'root',
    description
      "A pale, forked root twisted into a vaguely human shape.",
    burn_time 0,
    daemon [;
      self.burn_time++;
      switch (self.burn_time) {
        1:
          move self to Fireplace;
          if (player in Scriptorium)
            "^An unpleasant, acrid stench starts to fill the room.
            To be cautious, you move to the north side of the room, far from
            the fireplace.";
        2:
          give BrWilfred general;
          if (player in Scriptorium) "^Brother Wilfred starts to snore.";
        3:
          if (player in Scriptorium) "^Brother Wilfred seems deeply asleep.";
        5:
          if (player in Scriptorium)
            "^The mandrake root has burned, and the air starts to clear.";
          remove self;
        7:
          if (player in Scriptorium)
            "^Brother Wilfred begins to stir.";
        8:
          give BrWilfred ~general;
          self.burn_time = 0;
          StopDaemon(self);
          if (player in Scriptorium)
            "^Brother Wilfred seems groggily awake now.";
      }
    ],
    before [;
      Burn:
        if (player in Scriptorium) { StartDaemon(self); rtrue; }
      Smell:
        "An unpleasant, earthy smell.";
      Taste:
        "You take a tiny nibble, and find it extremely unpleasant.";
      Eat:
        "You've already learned from Brother Aelred enough to know
        you shouldn't eat this.";
    ]
  has
    ;

! ----------------------------------------------------------------------------

Object -> LibraryDoor "library door"
  with
    name 'library' 'door',
    description "A heavy wooden door with a keyhole.",
    found_in Scriptorium Library,
    door_dir (w_to) (e_to),
    door_to Library,
    with_key LibraryKey,
    each_turn [;
      if (BrWilfred hasnt general && self has open) {
        print
          "^Brother Wilfred notices the open door to the library---you're
          caught!

          For violating a serious rule of the priory, you are sentenced to
          bread and water for a week.";
          KillOff();
      }
    ],
  has
    scenery door openable ~open lockable locked;

Room Library "Library"
  with
    description
      "This is a small private room. There is a bookshelf on the north wall
      and a large map of the priory on the south wall.
      The only exit to to the west.",
    w_to Scriptorium,
    before [;
      Smell: "Ah, the smell of dusty books.";
    ],
    cheap_scenery
      'manuscript' 'manuscripts'
        "There are many, but none seem significant."
  has
    light;

Object -> BrassMap "brass map"
  class AdjObject,
  with
    adj_name 'brass',
    noun_name 'map',
    add_to_scope TwoCryptsOnMap,
    description
      "Finely etched into brass and signed by ~Brother Gordian~.
      It shows both the indoor and outdoor areas, from the dorms in the second
      floor all the way down to the two crypts below ground.",
  has
    scenery;

Object TwoCryptsOnMap "two crypts"
  with
    name 'two' 'crypts',
    description
      "Two crypts: a larger one, simply labeled ~Crypt~ and another,
      ~FitzAlan Crypt~.^^
      Now that you think of it, while you've been in the crypt before, you've
      never seen or heard of the other one.",
    after [;
      Examine:
        Achieved(TASK_DISCOVER_FA_CRYPT);
    ],
    has
      ;

Object -> Bookshelf "bookshelf"
  class AdjObject,
  with
    adj_name 'book',
    noun_name 'shelf' 'bookshelf' 'books' 'shelves',
    description [;
      print
        "The bookshelf has about fifty books, most of which are manuscripts,
        used for the work in the scriptorium";
      if (MonkGuide hasnt moved)
        print
          ". One that draws your attention is titled ~Registrum Fratrum~";
      ".";
    ],
    before [;
      Search:
        print "There are many books on the bookshelf";
        PrintContents(". Also on it ", self, ISARE_BIT);
        ".";
    ],
    add_to_scope [;
      if (MonkGuide in nothing) PlaceInScope(MonkGuide);
    ],
  has scenery supporter;

Object MonkGuide "Registrum Fratrum",
  with
    name 'register' 'registrum' 'fratrum',
    description
      "The ~Registrum Fratrum~ (~Register of the Brothers~).
      A small leather-bound book providing information on the monks who
      have served in the priory.",
    before [ i last_word end ;
      Examine:
        if (verb_word == 'read')
          "It's too long to read through, but you can look up particular
          entries by name.";
      Consult:
        if (second == nothing) {
          print "You find no entry for ~";
          last_word = consult_from + consult_words - 1;
          end = WordAddress(last_word) + WordLength(last_word);
          for (i = WordAddress(consult_from) : i < end : i++)
            print (char) i->0;
          "~ in ", (the) self, ".";
        }
        print_ret (string) second.history_text;
    ],
    after [;
      Take:
        Achieved(TASK_FINDING_GUIDE);
        "You carefully remove the Registrum Fratrum from the shelf.
        Brother Wilfred would be furious if he knew.";
    ],
  has
    proper;

Object HistGordian "Prior Gordian"
  with
    name 'prior' 'gordian',
    history_text
      "The priory was founded in 1248 by Prior Gordian, formerly Master
      Builder to the Earl of Pembroke. A man of great skill and piety, he
      designed the church and cloisters himself, incorporating his love of
      both sacred geometry and cunning devices. It is said he built the
      priory as penance for worldly pride, each mechanism a reminder that God's
      mysteries surpass man's cleverness."
  has
    ;

! ----------------------------------------------------------------- Slype

Room Slype "Slype"
  with
    description
      "A long east-west stone corridor. West is the cloister,
      east is the infirmary. A small passage heads south to the herbarium.",
    s_to HerbalistWorkroom,
    e_to Infirmary,
    w_to CloisterSE,
  has
     ;

! --------------------------------------------------------------

Room Infirmary "Infirmary"
  with
    description
      "The infirmary serves both the brothers and visiting villagers who seek
      healing. Several narrow beds line the western wall, their straw mattresses
      covered with coarse linen. A workbench holds mortars, bowls, and various
      implements for preparing remedies. The air smells of herbs, vinegar, and
      illness. A polished metal mirror hangs on the wall---unusual luxury, but
      necessary for examining patients' throats and eyes. The medicine cabinet
      stands against the north wall. A small chapel lies to the south, and
      the slype is to the west.",
    s_to InfirmaryChapel,
    w_to Slype,
    before [;
      Smell: if (noun == nothing) "A sharp, bitter smell.";
    ],
    cheap_scenery
      1 'beds' "They're just beds, with nothing on or under them."
      1 'mortars'
        "Useful for grinding medicine, but you should leave them alone."
      1 'bowels'
        "Unremarkable clay pots"
      'various' 'implements' "You don't need to worry about these.",
  has
    ;

Object -> Mirror "mirror"
  class AdjObject,
  with
    adj_name 'reflective' 'metal',
    noun_name 'mirror' 'plate',
    react_before [;
      Examine:
        if (noun == selfobj) {
          print "(in the mirror)^";
          <<Examine Mirror>>;
        }
    ],
    before [;
      Examine:
        "A young face, still beardless, stares back at you.
        Your black Benedictine habit hangs loose on your thin frame.
        No tonsure marks your crown---you're
        still a novice, not yet bound by final vows.
        Brother Aelred used to say you had honest eyes.
        You hope he was right.";
      Attack, Cut:
        "Next, you'll want to cross a black cat's path?";
    ],
  has
    ;

Object -> InfirmaryCabinet "medicine cabinet"
  with
    name 'medicine' 'cabinet',
    description [;
      print
        "A wooden cabinet secured with a brass lock mechanism. Four wheels,
        each engraved with digits ~0~ through ~9~, can be rotated
        independently. Carved into the wood above the lock:
        ~Historia nostra, fides nostra~.";
      if (self hasnt general)
        print
          "^^You remember Brother Aelred mentioning this cabinet:
          ~Brother Benedict is trusting. He doesn't want to keep medicines
          from his brothers in need, only from the village folk we treat.
          It's set to something every brother knows---outsiders wouldn't
          think to look for it.~";
      give self general;

      print
        "^^The four wheels currently show: ", Wheel1.setting, "-",
        Wheel2.setting, "-", Wheel3.setting, "-", Wheel4.setting;
      ".";
    ],
    check_combination [;
      if (Wheel1.setting == 1 && Wheel2.setting == 3
          && Wheel3.setting == 4 && Wheel4.setting == 6) {
        if (self hasnt open) {
          give self open;
          Achieved(TASK_OPEN_CABINET);
          "^You hear a satisfying click as the lock disengages and
          the cabinet opens.";
        }
      } else {
        give self ~open;
      }
    ],
    before [;
      Open:
        if (self has open) "The cabinet is already open.";
        if (~~self.check_combination()) "The cabinet remains locked.";
      Search:
        if (self hasnt open) <<Open self>>;
      Examine:
        if (self has open) <<Search self>>;
    ],
  has
    container openable ~open;

Tincture -> -> PoppySyrup "poppy syrup"
  with
    name 'poppy' 'syrup' 'opium',
    description
      "A small bottle of a red-dark, thick liquid. You know from Brother
      Aelred that this is used as a painkiller. If misused, it can be fatal.",
    scent "heady and sweet.",
    flavor "floral and sweet."
  ;

Tincture -> -> HenbaneTincture "tincture of henbane"
  with
    name 'hen' 'bane' 'henbane',
    description
      "A small bottle of a greenish-brown liquid. You know from Brother Aelred
      that this is used for sedative purposes, though it does have disturbing
      side-effects. If used in excess, it can be fatal.^^
      This bottle is almost entirely empty, with only a bit remaining.",
    scent "overtones of alcohol and urine.",
    flavor "gluey, unpleasant, and bitter.",
    identified [;
      Achieved(TASK_IDENTIFY_POISON);
      if (suspicion_level == 0) suspicion_level = 1;
      "^That's it---you now know that your dear mentor was poisoned with ",
      (the) self, ". You know you'll need to figure out who killed him and
      why.";
    ],
    before [;
      Smell:
        self.sniff();
        give self general;
        if (f_smelled_aelred) self.identified();
        rtrue;
      Taste:
        self.lick();
        give self general;
        if (f_smelled_aelred) self.identified();
    ],
  ;

Tincture -> -> Theriac "theriac"
  with
    name 'theriac',
    description
      "A small bottle of a dark brown, sticky paste. You know from Brother
      Aelred that this is often used as a restorative and antidote for
      poisons.",
    scent "complex notes of honey and exotic spices.",
    flavor "overpoweringly sweet and bitter.",
  ;

Class Wheel
  with
    setting 0,  ! starts at I
    set_me [;
        print "You turn ", (the) self, " to ", self.setting, ".^";
        InfirmaryCabinet.check_combination();
    ],
    before [;
      SetTo:
        if (InfirmaryCabinet has open)
          "The wheels can't be turned while the cabinet is open.";
        self.setting = second;
        self.set_me();
        rtrue;
      Turn:
        if (InfirmaryCabinet has open)
          "The wheels can't be turned while the cabinet is open.";
        self.setting++;
        if (self.setting > 9) self.setting = 0;
        self.set_me();
        rtrue;
      Examine:
        print_ret (The) self, " is currently set to ", self.setting, ".";
    ],
  has
    scenery;

Wheel -> Wheel1 "first wheel"
  with name 'first' '1st' 'one' 'wheel';

Wheel -> Wheel2 "second wheel"
  with name 'second' '2nd' 'two' 'wheel';

Wheel -> Wheel3 "third wheel"
  with name 'third' '3rd' 'three' 'wheel';

Wheel -> Wheel4 "fourth wheel"
  with name 'fourth' '4th' 'four' 'wheel';

