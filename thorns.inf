! ---------------------------------------------------- Night Stairs

Constant MSG_STAIRS_UP_DOWN_ONLY
  "You can go only up or or down.";

Room NightStairs "Night Stairs"                                   ! >NightStairs
  with
    description
      "Midway on the narrow stone stairway connecting the Dorm to the
      Quire. These are the Night Stairs---three times each night, monks file
      down in darkness for Matins, Lauds, and Prime. The walls are close,
      the air still.^^

      A lone candle flickers in its niche.",
    d_to Quire,
    u_to Dorm,
    cant_go MSG_STAIRS_UP_DOWN_ONLY,
  has
    ;


Candle -> TimeCandle "canonical hour candle"                       ! >TimeCandle
  with
    adj_name 'canonical' 'hour' 'time',
    describe 0,
    initial
      "A lit candle sits in a sconce built into the stone wall.",
    description [ hour ;
      hour = the_time / 60;
      print "A canonical hour candle is used by ", (The) BrCuthbert,
        " to tell the hours for offices. ";

      if (hour == 0)
        "This one is fresh, with all twenty-four marks visible
        from top to bottom.";
      if (hour == 23)
        "This one has burned nearly to the base, with only one mark remaining.";

      print "It has burned down past ", hour, " mark";
      if (hour ~= 1) print "s";
      print ", leaving ", 24 - hour, " mark";
      if (24 - hour ~= 1) print "s";
      " remaining below the flame. You estimate the time as ",
      (SundialTime) the_time, ".";
    ],
    before [;
      ! Burn: "It's already burning.";
      Pull: <<Take self>>;
      Push: "It's already firmly seated in the sconce.";
      Extinguish:
        "You'd best not extinguish the time candle---the whole community
        depends on it for keeping the hours.";
      Touch: "Ouch. Quite warm.";
      Smell: "There's an unpleasant aroma of tallow.";
      Squeeze: "Mostly firm, but softer as you get closer to the flame.";
      Take: print_ret
        (The) BrCuthbert, " would be very annoyed if this disappeared,
        and if you were suspected, you'd have heavy penance. You think better
        of this act.";
      Turn: "You turn the candle pointlessly in the sconce.";
    ]
  has
    static light;

! ---------------------------------------------------- Neccessarium

Room Necessarium "Necessarium"                                    ! >Necessarium
  with
    description
      "A narrow stone chamber extending from the Dorm. A wooden bench
      with several latrine holes runs along the east wall, each opening onto
      the dung pit far below. The smell is overpowering. Cold, foul air rises
      from the pit below.",
    w_to Dorter,
    before [;
      Smell, Taste: "In this foul place, you dare not.";
      Climb:
        if (selected_direction == d_to)
          "You wouldn't fit in a latrine hole, praise be.";
    ],
    cheap_scenery
      'dung' 'pit' "Happily, you can only barely make it out from up here."
      11 'wooden' 'bench' "It's just a bench. Leave it be."
    ,
  has
    ;


Object -> Latrines "latrines"                                        ! >Latrines
  with
    name 'latrine' 'latrines' 'hole' 'holes',
    before [;
      Enter:
        "You don't need to use the latrines just now.";
      Receive:
        if (noun has worn)
          "You'd best not discard what you're wearing.";
      Search:
        "Even if you could see anything far down in the pit,
        you wouldn't want to.";
    ],
    after [;
      Receive:
        remove noun;
        "You drop ", (the) noun, " in ", (the) self,
        ", losing it in the filth far below.";
    ]
  has
    pluralname scenery container open;


! ---------------------------------------------------- LayCells

Room LayCells "Lay Brothers' Cells"                                 ! >LayCells
  with
    description
      "This chamber was built to house the priory's lay brothers---those who
      serve without taking full vows. The walls are marked with darker patches
      where other cots once stood, and you can see the worn floorboards where
      chests were dragged back and forth over the years. Now the room holds
      only Brother Remigio's single cot and chest, pushed against the far wall.
      The priory's decline is nowhere more visible than in this emptiness,
      this quiet room that once held the sounds of simple men at their evening
      prayers.
      ^^The only exit is north to the Dorter.",
    n_to Dorter,
    cheap_scenery
      11 'darker' 'patches' "Just marks on the wall."
      11 'worn' 'floorboards' "The floorboards reveal nothing special."
    ,
  has
    light;


Chest -> ChestRemigio "Brother Remigio's chest"                  ! >ChestRemigio
  with
    description [;
      print "A simple wooden box with a lid";
      if (self has open) print ". It is open";
      ".";
    ],
    amonk BrRemigio;


Object -> -> PilgrimBadge "pilgrim badge"
  with
    name 'pilgrim' 'badge' 'pewter',
    description
      "A small pewter badge, cheaply cast but carefully kept. It depicts
      a figure in a monk's robe---St Francis of Assisi, you think, given
      the birds around him. The kind of thing sold to pilgrims at a
      shrine. How it ended up in an English priory, in the chest of a
      Tuscan lay brother, is a story you will never fully know.",
    before [;
      Smell: "It smells of nothing but old metal.";
      Taste: "Cold pewter. You feel immediately foolish.";
    ],
  has;


Object -> CotRemigio "Brother Remigio's cot"
  class AdjObject,
  with
    adj_name 'remigio' 'remigios' 'remigio^s',
    noun_name 'cot' 'mattress' 'bed',
    description
        "It's a simple straw mattress.",
    before [;
      Examine: ;
      Search, LookUnder:
        if (suspicion_level == 0)
          print_ret (string) MSG_ANOTHER_BROTHERS_PROPERTY_WRONG;
      Push, Pull, Turn:
        "You shouldn't move this. Leave it be.";
      Enter:
        "That's ", (the) self, ". You shouldn't sleep there.";
      default:
        "You shouldn't do anything with the cot.";
    ],
  has
    scenery proper;


! ================================================================= Game

Object MyRobe "your robe"                                              ! >MyRobe
  class AdjObject,
  with
    adj_name 'my',
    noun_name 'robe' 'habit',
    invent [ ;
      print "your robe (worn)";
      if (PrintContents(" (hidden in the hood ", MyHood, ISARE_BIT)) print ")";
      rtrue;
    ],
    description
      "A simple black woollen cloth, marking you as a novice of this house.
      It doesn't have pockets, but a large hood hangs at your back.",
    ! react_before [;
    !   Insert:
    !     if (second == self) <<Insert noun MyHood>>;
    ! ],
    before [;
      Disrobe: "You daren't. A monk must always be ready for office.";
      Take: "You're already wearing it.";
      Search:
        print "There's nothing in your robe";
        PrintContents(", but hidden in the hood ", self, ISARE_BIT);
        ".";
      Wear:
        "You're already wearing it. Outside a weekly washing, you're
        always wearing it.";
      LookUnder: "Just you.";
      Smell: "It's been a few days since washing day.";
    ],
  ! has container clothing transparent worn ok_carry;
  has proper clothing transparent worn ok_carry ;


! slightly-kludgy, but added always to scope in InScope
!
! trying to add it as scope of the robe is problem because it would get
! reported in inventory or otherwise act weird.

Object -> MyHood "hood"                                                ! >MyHood
  class AdjObject,
  with
    adj_name 'robe' 'my',
    noun_name 'hood',
    capacity 3,
    description [;
      print
        "A deep hood attached to your habit, large enough to pull over your
        head in foul weather";
        PrintContents(". In the hood ", self, ISARE_BIT);
        ".";
    ],
    before [;
      Receive:
        if (noun == Pax) "She wouldn't find that very comfortable.";
        if (noun has light)
          "Placing a lit item in your hood would surely catch it on fire.";
      Wear, Take:
        "It's part of your robe, which you're already wearing.";
      Search:
        if (~~PrintContents("In the hood ", self, ISARE_BIT))
          print "There is nothing in the hood";
        ".";
    ],
    after [;
      Receive: CheckHidContraband(noun);
      ! Receive:
      !   "You put ", (the) noun, " into the hood.";
    ],
  has scenery container open worn;


