    e_to Infirmary,
    w_to CloisterSE,
    n_to
      "There is an open area between here and the Infirmary,
      but you can't get to it.",
    before [;
      Smell:
        if (noun == nothing)
          "A faint sweetness lingers from the bushes, though the flowers are
          mostly gone now.";
    ],
    cheap_scenery
      1 'scriptorium'
        "It's just the wall of the Scriptorium. You don't see
        anything remarkable about it."
      12 'rose' 'bush' 'bushes' [;
        Examine:
          "These bushes were a point of pride for Aelred, given how hard it
          can be to grow roses in this climate. Given the season, the flowers
          are largely gone, replaced by only rosehips and their scent.";
        Smell: "Faint but still sweet and floral.";
        Search, LookUnder: "There is nothing in the bushes.";
        Dig, Take: "You wouldn't dare dig up one of these.";
        default: "Leave the bushes be.";
      ]
    ,
  has
     ;


Object -> RoseOrHips "roses"                                       ! >RoseOrHips
