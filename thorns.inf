! ============================================================ Initialise

[ Initialise o ;

  ! #IfDef Debug;
  !   <ScriptOn>;
  ! #EndIf;
  #IfV5;
  ClearScreen();
  #EndIf;

  ! example of using a dynamic string
  ! string DS_PRIORY_NAME "Our Lady of Thorns";
  ! print "^^Welcome to @(1)^";
  ! print "Welcome to @(DS_PRIORY_NAME)^";

  QuoteBoxSimple(quote_opening);
  SetTime(5 * 60, 2);
  lookmode = 2;  ! verbose mode by default

  objectloop (o ofclass Monk) o.go_home();

  move MyRobe to player;

  selfobj.description =
    "You're a novice in your first year, younger than all of the professed
    monks. Your black habit marks you as Benedictine, though you haven't yet
    taken your final vows. Your head remains untonsured---that will come only
    if you complete your novitiate and join the community fully.";

  print "Late Summer in the year of Our Lord 1346.
  The priory of Our Lady of Thorns stands forlornly on the cliffs above Ashcombe,
  on the northeast coast of England, where
  wind and sea have worn the stones for two hundred years.^^

  You awake at 5 AM to the sound of the great bell, calling you to
  Lauds. You are lying in your cot, still bleary from sleep.
  You've already been to two offices this morning, the first at 2 AM.
  Like your brethren, you sleep in your habit, so you're already fully dressed.

  ^^While you've been learning a great deal about healing herbs from your
  mentor, Brother Aelred, you had hoped that after five months here,
  you'd be better acclimated to the schedule.^^

  The other brothers rise from their cots.

  ^^^(If you're new to this game, type ~HELP~).^^";

  #IfDef HAS_HINTS; HintReady(Hint_intro); #EndIf;

  give Service general;  ! service
  Service.start_service();
  ! Don't print the banner at start; print it after first office
  return 2;
];

#IfDef HAS_HINTS;
Include "./game_hints.inf";
#EndIf;



! [ FinalMessages;

!   "You tell Prior Oswald everything. Hugh is taken by the sheriff within
!   days. He is tried, condemned, and hanged before the month is out. Rose
!   dies alone that winter, with no brother to tend her.

!   You kept your vows. You served truth. But standing in the herb garden
!   where Aelred died, you wonder if justice and mercy are truly the same
!   thing---or if, in choosing one, you betrayed the other.

!   Aelred's words echo: ~One life for two, my son.~ You will never know
!   if you honored his sacrifice, or squandered it.;"


!   "You tell Hugh to leave. Tonight. Before questions are asked. He flees
!   the island, and you never learn what becomes of him---or Rose.

!   You lied to the Prior. You broke your vows. But when you pray before
!   the Lady of Thorns, you remember Aelred's last words: ~One life for
!   two, my son.~ Perhaps mercy, not justice, was what he meant.

!   Still, you wonder. A murderer walks free. Does forgiveness make you
!   holy, or complicit? You will carry this question all your days.";

! ];

! “And let them first pray together, that so they may associate in peace.”

!
! You remember Aelred once quoting St. Bernard: "The church clothes her
! stones in gold and leaves her sons naked."

