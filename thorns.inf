! ------------------------------------------------------------------ Kitchen

Room Kitchen "Kitchen"
  with
    description
      "A large room, lit by high windows. A door leads north
      to the refectory, and stairs descend south to the undercroft below.
      ^^A large working table dominates the center, scattered with
      implements and vessels. A hearth is built into
      the east wall, its fire warming the room.",
    n_to Refectory,
    d_to Undercroft,
    cheap_scenery
      'implements' 'various' "A collection of utensils, knives, and vessels."
      4 'utensils' 'knives' 'vessels' 'spices'
        "You needn't worry about these--Brother Martin is the Kitchener.",
  has
    ;

Object -> KitchenTable "table"
  with
