!         if (noun == Stalls) "Not during office, surely!";
!     ],
!     each_turn [;
!       ! make a count-up timer for the service?
!       if (self has general)
!         "^Brother Anselm is leading the brethren in song---all except you.";
!     ],
!   has
!     concealed;


Room Quire "Quire"                                                      ! >Quire
  with
    description
      "The quire is the heart of monastic worship and the center of the church.
      Two choir stalls face each other
      across the narrow gap, where the brothers gather to chant the offices.
      The stalls are plain but worn smooth by generations of use.
      The high altar rises to the
      east. The nave lies west, beyond the screen. Night stairs ascend north
      to the dormitory, and a hall leads south to the cloister.",
    old_description "",  ! gets filled with orig during service so can restore
    s_to CloisterN,
    e_to HighAltarArea,
    w_to Nave,
    n_to NightStairs,
    u_to NightStairs,
    cheap_scenery
      'high' 'altar'
        [;
          if (BrOswald in HighAltarArea)
            "You can see the altar from here, but you should head east for a
            closer look.";
          "You can see Brother Oswald at the altar.";
        ],
    before [;
      Sing: "But there's no service going on right now.";
    ]
  has
    ;


Object -> Stalls "stalls"                                              ! >Stalls
  class AdjObject,
  with
    article "two",
    adj_name 'wooden',
    noun_name 'stalls//p' 'stall',
    description
      "You've stood by and sat on these for months now during services.
      The carpentry is unremarkable and there is nothing these can reveal.",
    after [;
      Enter:
        if (BrAelred in self)
          "You on a stall next to your mentor, the herbalist Brother Aelred.";
        "You sit on a stall with a certain sense of familiarity.";
      Exit:
        "You get up from your stall.";
    ],
  has
    static supporter enterable pluralname;


!----------------------------------------------------- 2.0.5 High Altar Area
! HighAltar, crypt stairs


Room HighAltarArea "High Altar Area"                            ! >HighAltarArea
  with
    description [;
      print
        "A domed ceiling rises above this, the place where the Prior leads
        office.
        A chapel stands in shadow to the east.
        The sacristy lies south. ";
        if (CryptGate hasnt open)
          "A closed gate blocks a descent on the narrow stairs to the crypt.";
        "The crypt gate is open.";
    ],
    w_to Quire,
    e_to LadyChapel,
    d_to CryptGate,
    n_to CryptGate,
    s_to SacristyDoor,
    cheap_scenery
      1 'chapel'
        "From here, you can see an altar and a statue. You can go east to
         explore it.",
  has;


Altar -> HighAltar                                                  ! >HighAltar
  with
    short_name "high altar",
    article "the",
    adj_name 'high',
    description
      "The povery of the priory is evident in the simplicity of the altar.
      It is a simple stone structure supporting a cross and with a plain
      cloth draped on it.",
  has ;


Object -> -> AltarCloth "cloth"                                    ! >AltarCloth
  class AdjObject,
  with
    adj_name 'plain' 'altar',
    noun_name 'cloth',
    description "Coarse flax and unremarkable.",
    before [;
      Examine, Search, LookUnder, Smell, Listen: ;
      Touch: <<Examine self>>;
      Attack, Cut: "Heaven forfend.";
      default:
        "Brother Cuthbert would be outraged if you did anything with it.";
    ],
  has
    ;


Object -> -> AltarCross "altar cross"                              ! >AltarCross
  class AdjObject
  with
    article "the",
    describe 0, ! [; rtrue; ],
    adj_name 'altar',
    noun_name 'cross',
    description
      "A simple wooden cross---no gold, no jewels---firmly attached
      to the altar.",
    before [;
      Attack: "Heaven forfend.";
      Smell: "It smells like dust and faint incense.";
    ],
  has static;


! -------------------------------------------------------------

! PUZZLE: how to get into the crypt?
!  It isn't the key; that's a red herring and player will never get it.
!  It can be entered throught the secret FitzAlanCrypt
! PUZZLE: how to leave the crypt?
!  - can pray to st jude for impossible help
!  - can ring the bell, hide, wait for cuthbert to search, then run
!    upstairs when he goes to crypt vestry

Object CryptGate "crypt gate"                                       ! >CryptGate
  with
    name 'crypt' 'gate' 'stairs',
    description [;
      #ifDef HAS_HINTS; HintReady(Hint_gate); #EndIf;
      "The gate is made of sturdy iron and has a heavy lock built into it.";
    ],
    found_in HighAltarArea CryptStairs,
    door_dir (u_to) (d_to),
  has
    scenery door locked ~open openable;


Room CryptStairs "Crypt Stairs"                                   ! >CryptStairs
  with
    name 'crypt' 'stairs',
    description [;
      print
        "At the midpoint of these stairs, you can sense the damp
        below. A thin veil of light comes from the altar area above";
      if (_LookForLightInObj(Crypt, Crypt))
        ", and weak candlelight from the crypt below.^";
      ", but the path down descends into darkness.";
    ],
    s_to CryptGate,
    u_to [;
      if (PrayerMat has general && CryptGate hasnt open) {
        print
          "As you approach the crypt door, you hear the soft
          click of an unseen bolt sliding back. Your prayer
          has been answered.^^";
        give CryptGate open;
        give PrayerMat hasnt general;
        Achieved(TASK_ESCAPE_CRYPT);
      }
      return CryptGate;
    ],
    d_to Crypt,
    before [;
      Smell: "Musty and damp.";
    ],
  has
    ;


! --------------------------------------------------- 2.0.6 Sacristy


Object SacristyDoor "sacristy door"                              ! >SacristyDoor
  with
    name 'sacristy' 'door',
    description "A narrow wooden door without any lock.",
    found_in HighAltarArea Sacristy,
    door_dir (n_to) (s_to),
    before [;
      Examine:
        if (location == thedark)
          "Have faith, Brother. You can't see it, but you know it's there.";
    ],
    after [;
        Open: give Sacristy light;
        Close: give Sacristy ~light;
    ],
  has
    static scenery door openable ~open;


! PUZZLE: can only get the candle if has proven it's needed
! PUZZLE: has to hide candle as its contraband

Room Sacristy "Sacristy"                                             ! >Sacristy
  with
    name 'sacristy' 'vestry',
    description
      "A small room where vestments and sacred vessels are kept.
      Shelves hold neatly folded linens, precious chalices, and other
      miscellaneous vestry items. The smell of beeswax and old incense lingers.
      Brother Cuthbert maintains this space with meticulous care.",
    n_to SacristyDoor,
    cheap_scenery
      1 'shelves' "The shelves are neat and tidy."
      'linen' 'linens//p'
        "The linens are worn but clean."
      4 'vessel' 'vessels//p' 'chalice' 'chalices//p'
        "The chalices are used for sacred purpose during Mass."
      1 'incense' "You can smell it faintly, but can't find any here."
      'vestry' 'items' "Some cloth, candles, and a pewter platter."
      1 'cloth' "Just scraps, really."
      2 'pewter' 'platter' "Used to hold items during Mass.",
    before [;
      Smell:
        if (location == thedark)
          "You smell wax and old incense in the darkness.";
        "Dusty and fragrant with wax and wood.";
      Go:
        if (location == thedark)
          "You shouldn't stumble around in the dark.
          You might damage something.";
    ],
  has
    ;


Object -> Candles "candles"                                           ! >Candles
  class AdjObject,
  with
    adj_name 'beeswax',
    noun_name 'candles',
    describe [; rtrue; ],
    description
      "There's a few candles here, finer than the more common ones made of
      tallow. These candles are used to light the church.",
    before [;
      Burn: "Burning all of these candles would be madness.";
      Take:
        if (MyCandle.dont_need()) rtrue;
        "The theft of all of the candles would be quickly discovered.";
    ],
    add_to_scope MyCandle,
  has pluralname;


Candle MyCandle "beeswax candle"                                     ! >MyCandle
  with
    adj_name 'beeswax',
    description [;
      print "Good quality, made from beeswax from the priory's own bees";
      if (self has light) print ". It is currently lit";
      ".";
    ],
    before [;
      Take:
        ! haven't solved lion/crypt: don't let them take
        if (MyCandle.dont_need()) rtrue;
        ! if there's already a candle in room or player, they get this one
        if (IndirectlyContains(location, self)) rfalse;
        ! if it's been removed from the game (destroyed), they get another
        if (parent(MyCandle) == nothing) {
          move self to player;
          if (self has moved)
            "Feeling even more guilt, you take another candle.";
          "You take a single candle, feeling the weight of this
          small theft.";
        }
        "Surely, one stolen candle must be enough.";
    ],
  has
    ;


! --------------------------------------------------- 2.0.7 FitzAlan Chantry

! PUZZLE: find hidden ladder to FA Crypt
! PUZZLE: how to get out of that area, since ladder is one-way

Room FitzAlanChantry "FitzAlan Chantry"                       ! >FitzAlanChantry
  with
    name 'chantry',
    description [;
      #IfDef HAS_HINTS; HintReady(Hint_chantry); #EndIf;
      if (player in FitzAlanAltar)
        "From here you can see the arms closely.";
      print
        "The FitzAlan family chantry, endowed long ago for
        masses. But the FitzAlans are gone now---their line ended in the
        pestilence---and no masses are said here anymore";
      if (FitzAlanAltar has open) {
        print ". An opening in the floor reveals a ladder leading down";
        if (~~FitzAlanCrypt.is_lit())
          print " into darkness";
      }
      ".";
    ],
    w_to HighAltarArea,
    s_to LadyChapel,
    d_to [;
      if (FitzAlanAltar has open) {
        if (~~(FitzAlanCrypt.is_lit() || IsCarryingLit())) {
          print "Do you want to descend into darkness? ";
          if (YesOrNo() == 0) "You decide better of it.";
          #IfDef HAS_HINTS; HintReady(Hint_FALight); #EndIf;
        }
        print
          "^You climb down the ladder. As you step off the bottom rung,
          a counterweight somewhere in the mechanism snaps the ladder
          back to the ceiling, far out of reach.^^";
        move Ladder to FitzAlanCrypt;
        return FitzAlanCrypt;
      }
    ],
    cheap_scenery
      1 'floor' "These almost look like scrapes from moving the altar."
      'gouge' 'gouges//p'
        "You're not sure what caused them---perhaps the altar was moved?"
      1 'motto' "~LEO VIAM CUSTODIT~",
  has
    ;


! open = open, can climb down
! moved = ever been opened

Altar -> FitzAlanAltar                                          ! >FitzAlanAltar
  class AdjObject,
  with
    adj_name 'stone' 'fitzalan',
    noun_name 'altar',
    describe [;
      print "^A stone altar is set against the east wall";
      PrintContents(". On it ", self, ISARE_BIT);
      ".";
    ],
    description [;
      print "A heavy-looking block of white stone";
      if (self has open)
        " that has been pushed away from the wall, revealing stairs descending
        into darkness.";
      print " on the floor. Gouges in the floor by the altar
      testify to its weight. Above the altar, carved into
      the wall, are the FitzAlan arms and motto";
      PrintContents(". On the altar ", self, ISARE_BIT);
      ".";
    ],
    after [;
      Enter:
        print "You climb onto the altar";
        if (FitzAlanLion hasnt moved)
          ". From here you can reach the carved arms above.";
        ".";
    ],
    open_altar [;
      give self open;
      give self moved;
      move Ladder to FitzAlanChantry;
      QuoteBoxSimple(quote_stone);
      Achieved(TASK_FA_CRYPT);
      print
        "You push against the altar and it swings away from the wall,
        revealing an opening in the floor with a ladder visible.^";
    ],
    before [;
      Take:
        if (FitzAlanLion hasnt moved) rfalse;
        "Even trying, you can't lift it.";
      Search:
        "You find nothing hidden about the altar itself, but those gouges
        in the floor are intriguing.";
      Push, Turn:
        if (player in self)
          "You can't move the altar while standing on it.";
        if (self has open) {
          give self ~open;
          give FitzAlanLion ~moved;
          remove Ladder;
          "You push the altar back against the wall and hear a solid click as
          it settles against the wall.";
        }
        if (FitzAlanLion has moved) { self.open_altar(); rtrue; }
        if (self has moved)
          "It no longer seems you can push it.";
        "While it seems that the altar isn't built into the floor, it
        also doesn't budge when you try to move it.";
    ],
  has
     ;


! moved = lion is pushed in now
! general = lion has ever been pushed in

Object -> FitzAlanLion "FitzAlan arms"                           ! >FitzAlanLion
  class AdjObject,
  with
    adj_name 'fitzalan' 'family' 'brass' 'rampant',
    noun_name 'lion' 'arms',
    description [;
      if (player notin FitzAlanAltar)
        "A lion, perhaps? It's a bit too far up to see clearly.";
      if (self has moved) "The lion is pressed in slightly.";
      "A finely-detailed brass rampant lion standing out from the stone.";
    ],
    before [;
      if (player notin FitzAlanAltar && action ~= ##Examine)
        "The arms are set high in the wall, well above you.";
      Push, Turn:
        if (self has moved) "Nothing new happens.";
        give self moved;
        if (self has general)
          "Again, you push against the lion, and hear the same deep click.";
        give self general;
        "You push against the lion and, surprisingly, it moves
        inward slightly. A deep click is heard in the wall.";
      Touch:
        "The lion is fine to the touch and, curiously, feels like it
        could move.";
    ],
  has
    ~moved scenery pluralname;


!---------------------------------------------------- 2.0.8 Lady Chapel
! Chapel and statue

Room LadyChapel "Lady Chapel"                                      ! >LadyChapel
  with
    name 'lady' 'chapel' 'mary' 'virgin',
    description
      "The largest of the three chapels, dedicated to
      the Blessed Virgin.
      This chapel sees more use than the others---the brothers pray here
      for the priory's patroness, Our Lady of Thorns. To the west is the
      main church. Small doorways lead north and south to smaller chapels.",
    w_to HighAltarArea,
    n_to FitzAlanChantry,
    s_to StJudeChapel,
  has
    ;


Statue -> MaryStatue "statue"                                      ! >MaryStatue
  with
    name 'mary' 'virgin' 'blessed',
    initial "A statue of Mary stands in a niche.",
    description
      "A stone statue of the Blessed Virgin Mary. Her stone hands are
      open in a gesture of welcome and mercy. Her carved face is serene.^^
      Carved on the base statue:^
      ^  BEATAE MARIAE MATRIS DEI
      ^  (Blessed Mary, Mother of God)",
    react_before [;
      Pray: "You make the sign of the cross and murmur an Ave Maria.";
    ],
  has
    female;


Altar -> MaryAltar "stone altar"                                    ! >MaryAltar
  class AdjObject,
  with
    adj_name 'stone' 'mary',
    noun_name 'altar',
  ;

! --------------------------------------------------- 2.0.9 St Jude Chapel
! Chapel, mat, statue, altar, rosehips

! PUZZLE: can pray to st jude for later help in crypt
! PUZZLE: identify the rosehips

Room StJudeChapel "St Jude Chapel"                               ! >StJudeChapel
  with
    name 'chapel',
    description [;
      #IfDef HAS_HINTS; HintReady(hint_jude); #EndIf;
      "A small chapel dedicated to St Jude, patron of desperate causes.
      The stone floor is worn smooth---many desperate souls
      have knelt here over the centuries, praying for urgent help.
      A painted statue shows the saint.";
    ],
    n_to LadyChapel,
  has
    ;


! general = has a prayer
! moved = ever had a prayer (can't get a second)

Object -> PrayerMat "prayer mat"                                    ! >PrayerMat
  class AdjObject,
  with
    adj_name 'prayer',
    noun_name 'mat',
    description
      "A rough flax mat before the altar, worn thin by countless hours
      of kneeling. Someone has been using it recently---very recently.",
    before [;
      Take, Push: "You are deeply certain it belongs here.";
      Search, LookUnder: "Nothing below it but a worn stone floor.";
    ],
    after [;
      Enter: "You kneel on the worn mat.";
    ],
    react_before [;
      Pray:
        if (player in PrayerMat) {
          if (self hasnt general) {
            give self moved;   ! ever got a prayer
            give PrayerMat general;
            "You feel a powerful sense of hope that the Saint will help you in
            crisis.";
          }
          "You feel that the Saint has already heard your plea.";
        }
    ],
  has
    supporter enterable;


Altar -> JudeAltar "altar"                                          ! >JudeAltar
  with
    description [;
      print "A simple stone altar, worn smooth by centuries of prayer.";
      if (RoseHips hasnt moved) {
        give RoseHips ~concealed;
        " Someone has left an offering of ", (a) RoseHips, " here.";
      }
      "";
    ],
  has
    ;


! The berries are initially known only as "berries", but they become known
! as rosehips after smell/tasting them. They're initially concealed, but are
! revealed after examining the altar (otherwise, they'd get listed in the
! initial room description, and I want people to have to look at the altar
! to notice them).

Object -> -> RoseHips "small red berries"                            ! >RoseHips
  with
    short_name [;
      if (self has general) { print "rosehips"; rtrue; }
    ],
    invent [;
      print (a) self, " (originally left as an offering to St Jude)"; rtrue;
    ],
    parse_name [ w wn ;
      while (true) {
        w = NextWord();
        if (w == 'red' or 'berry' or 'berries') wn++;
        else if (self has general &&
            w == 'rose' or 'hip' or 'hips' or 'rosehip' or 'rosehips') wn++;
        else return wn;
      }
    ],
    description [;
      if (self hasnt general) print "Small seed pods. ";
      "Someone carefully gathered these as an offering.
      They're fresh and fragrant, picked within the last day or two.";
    ],
    recall [;
      if (self hasnt general) {
        give self general;
        QuoteBoxSimple(quote_rose);
        "This action brings back a memory from summer: Aelred in the physic
        garden, showing you a red rose in full bloom. ~Beautiful now, Brother,
        but its true gift comes later. These petals fall, and by autumn the
        hip swells with seed---tart and rich. We gather them after the first
        frost for winter cordials.~ He'd smiled. ~The rose serves us twice:
        beauty in summer, medicine in autumn.~";
      }
      ", reminiscent of roses.";
    ],
    before [;
      Eat:
        "You shouldn't eat an offering left to a saint.";
      Taste:
        print "You nibble at one: a sweet, tangly flavor";
        self.recall();
        rtrue;
      Smell:
        print "A faint, floral scent";
        self.recall();
        rtrue;
      Touch:
        "They're firm. Perhaps you should check their scent?";
    ],
  has
    pluralname edible concealed ok_carry;


Statue -> JudeStatue "St. Jude"                                    ! >JudeStatue
  with
    name 'saint' 'st' 'jude',
    description
      "A wooden statue of St Jude, simply carved and crudely painted.
      The saint holds a staff in one hand. His painted eyes seem to
      gaze down at those who kneel before him in desperation.",
    react_before [;
      Pray: "You murmur a brief prayer to St Jude.";
    ];


! ======================================================== 2.1 CLOISTER
! NW N NE W E SW S SE Garth


class Cloister
  with
    name 'cloister' 'arcade',
    description [;
      if (CloisterN hasnt visited) {
        print
          "You emerge to the northern end of the cloister walk,
          the covered stone arcade at the
          center of the priory. It's a continuous square path surrounding
          the garth, a large open yard. Various rooms and
          passageways come off of the cloister walk.^^";
      }
      print "Arched openings admit ";
      switch (RoughTime()) {
        CLOCK_NIGHT: print "cold night air and pale moonlight";
        CLOCK_MORNING: print "fresh morning breeze";
        CLOCK_AFTERNOON: print "slanted autumn sun";
        default: print "dim evening light";
      }
      print ".^^";
      self.cloister_detail();
    ],
    d_to
      "The Garth is only one step down from the cloister. To enter it,
      just walk in that direction through an opening.",
    before [;
      Climb:
        "You eye the effort it would take to scale the cloister
        and think better of it.";
    ],
  has
    light;


Cloister CloisterNW "Cloister Northwest"                           ! >CloisterNW
  with
    cloister_detail
      "The wall of the nave rises imposingly to the north,
      and an imposing door lies to the west.",
    s_to CloisterW,
    e_to CloisterN,
    w_to PriorDoor,
    each_turn [;
      #IfDef HAS_HINTS;
        HintReady(Hint_SolarDoor); HintReady(Hint_WhatIsSolar);
      #EndIf;
    ],
    cheap_scenery
      1 'buttons' "There are seven buttons on the door. You'll have to
        specify which one you want.";


Cloister CloisterN "Cloister North"                                 ! >CloisterN
  with
    cloister_detail
      "The wall of the nave rises imposingly to the north. A passageway into
      it leads to the Quire.",
    w_to CloisterNW,
    s_to Garth,
    n_to Quire,
    e_to CloisterNE;


Cloister CloisterNE "Cloister Northeast"                           ! >CloisterNE
  with
    cloister_detail
      "The chapter house is to the east, and the day stairs to the upper floor
      head upward from here.",
    e_to ChapterHouse,
    w_to CloisterN,
    u_to DayStairs,
    s_to CloisterE,
    before [;
      Go:
        if (BrAelred has general && selected_direction ~= s_to)
          "Brother Remigio seems most intent that you should follow him south.";
    ],
    after [;
      Look: if (self hasnt visited) {
        give BrAelred general;
        move BrRemigio to self;
        give ScenePreDeath ~general;
        "^The lay monk, Brother Remigio, runs up to you, his face ashen.
        ~You!~ he cries, grabbing your sleeve. ~Come---Brother
        Aelred, l'erborista, he is---~ He cannot find the words. His
        eyes say everything. He pulls you urgently south toward the slype.";
      }
    ]
  ;


Cloister CloisterW "Cloister West"                                  ! >CloisterW
  with
    cloister_detail
      "The locutory lies to the west.",
    s_to CloisterSW,
    e_to Garth,
    w_to Locutory,
    n_to CloisterNW,
  ;


Cloister CloisterE "Cloister East"                                  ! >CloisterE
  with
    cloister_detail
      "To the east is the entrance to the scriptorium.",
    n_to CloisterNE,
    e_to Scriptorium,
    w_to Garth,
    s_to CloisterSE,
    before [;
      Go:
        if (BrAelred has general && selected_direction ~= s_to)
          "Brother Remigio seems most intent that you should follow him south.";
    ],
    after [;
      Go:
        if (BrAelred has general) {
          print
            "You follow Brother Remigio south to the eastern section of the
            cloister.^^";
          move BrRemigio to self;
          <<Look>>;
        }
    ]
  ;


Cloister CloisterSW "Cloister Southwest"                           ! >CloisterSW
  with
    cloister_detail
      "The monk's gate lies to the west. A small alcove, the lavatorium,
       is to the south,
       right after the arcade turns to the east.",
    s_to Lavatorium,
    e_to CloisterS,
    w_to
      "As a novice, you are confined to the priory until you take
      your final vows.",
    n_to CloisterW,
    cheap_scenery
      3 'monk' 'monk^s' 'gate'
        "The gate is a heavy door leading to the outer world.
        It has a heavy bar on it to open the door---though you are forbidden
        to admit anyone to the priory. That is the sole duty of
        Brother Oswald.",
  ;


Cloister CloisterS "Cloister South"                                 ! >CloisterS
  with
    cloister_detail
      "The refectory lies to the south.",
    n_to Garth,
    w_to CloisterSW,
    e_to CloisterSE,
    s_to Refectory,
  ;


Cloister CloisterSE "Cloister Southeast"                           ! >CloisterSE
  with
    cloister_detail
      "The long slype lies to the east.",
    n_to CloisterE,
    e_to Slype,
    w_to CloisterS,
    cheap_scenery
      2 'long' 'slype'
        "The slype is a covered passageway to the east.",
    before [;
      Go:
        if (BrAelred has general && selected_direction ~= e_to)
          "Brother Remigio seems most intent that you should follow him east.";
    ],
    after [;
      Go:
        if (BrAelred has general) {
          print
            "You follow Brother Remigio south to the southeastern section of the
            cloister.^^";
          move BrRemigio to self;
          <<Look>>;
        }
    ]
  ;


Room Garth "Garth"                                                      ! >Garth
  with
    name 'garth' 'square',
    description
      "The garth---the small grass courtyard at the heart of the cloister.
      The covered cloister walk surrounds it on all sides, its arches
      framing the sky above.^^
      This is the monastery's heart, open to rain and sun, enclosed
      by the daily circuit of monastic life.",
    n_to CloisterN,
    w_to CloisterW,
    s_to CloisterS,
    e_to CloisterE,
    u_to
      "The cloister walk is raised only a single step. You're already
      at ground level. Just walk in the direction you want to enter it.",
    cheap_scenery
      'grass' 'courtyard'
        "Sparse grass and a few stubborn herbs. The garth was probably
        more carefully tended in better times."
      1 'water'
        "Presumably there's water in the well, but it's much too
        far for you to reach.",
  has
    ;

Object -> Sundial "sundial"                                           ! >Sundial
  class AdjObject,
  with
    adj_name 'sun',
    noun_name 'sundial' 'dial' 'clock',
    description [;
      if (the_time < 300 || the_time > 1260)
        "The sundial isn't casting a discernable shadow without sunlight.";
      "The sundial casts a shadow showing that the approximate time is ",
        (SundialTime) the_time, ".";
    ],
    has static;


Object -> GarthWell "well"                                          ! >GarthWell
  class AdjObject,
  with
    adj_name 'stone' 'old',
    noun_name 'well',
    description
      "An old stone well, its edges worn smooth by centuries of drawing
      water.",
    before [;
      Enter, Climb:
        "The well is deep and dark. You're not that desperate.";
      Search:
        "It's too dark to see the bottom.";
      Receive:
        if (MonkInRoom(Garth) ||
          MonkInRoom(CloisterN) ||
          MonkInRoom(CloisterW) ||
          MonkInRoom(CloisterE) ||
          MonkInRoom(CloisterS))
          "You dare not, since a brother would witness this act.";
        remove noun;
        print_ret
          (The) noun, " lands far below with a splash.
          I hope you didn't need that.";
    ],
  has
    static container open;


! ======================================================== 2.2 WEST WING
! 2.2.1 Prior's Solar
! 2.2.2 Locutory
! 2.2.3 Lavatorium

! --------------------------------------------------- 2.2.1 Prior's Solar

! stained glass windows in the nave (which he designed) show these three
! symbols. The door to the solar has brass plates with various symbols, and you
! must press the three that represent Gordian's creeds.
! Possible symbols/creeds:

! Compass/Square - Sacred geometry, God's order in creation
! Open Book - Knowledge/Scripture/Learning
! Hammer/Trowel - Honest labor, building for God's glory
! Cross - Faith (maybe too obvious?)
! Key - Stewardship, responsibility
! Lamp/Candle - Light of truth
! Wheat/Grapes - God's providence

! My suggestion for three creeds:

! INGENIUM DEI (God's Ingenuity) - Compass/Square symbol
! LABOR OMNIA VINCIT (Work conquers all) - Hammer symbol
! SAPIENTIA (Wisdom) - Book/Scroll symbol

! In the nave description, add:
! Three tall stained glass windows line the south wall, their colors muted
! by age. Each depicts a symbol: a compass and square, a mason's hammer,
! and an open book. Beneath each, barely legible Latin inscriptions.


Object PriorDoor "prior door"                                       ! >PriorDoor
  with
    name 'prior' 'door',
    description [;
      print "A heavy door made of fine cedar";
      if (location == CloisterNW)
        print
          ", upon which a large brass plate
          is set. There are seven fine buttons on it, each bearing a symbol:
          a compass, a hammer, a book, a cross, a key, a lamp, and wheat. Below
          them, an inscription in elegant Latin script:
            ^^  HIS TRIBUS FUNDATA EST DOMUS MEA
             ^       --- GORDIANUS, PRIMUS PRIOR
            ^^You translate that as ~On these three my house is founded:
            Gordian, First Prior~";
      print ". The door is currently ";
      if (self hasnt open) "closed."; "open.";
    ],
    door_dir (e_to) (w_to),
    found_in CloisterNW PriorsSolar,
    pressed_count 0,
    pressed 0 0 0,
    check_combination [  obj;
      ! Check if three buttons pressed
      if (self.pressed_count ~= 3) rfalse;
      objectloop (obj ofclass DoorButton)
        give obj ~on;
      self.pressed_count = 0;

      ! Check combination: Cross (FIDES), Hammer (LABOR), Book (SAPIENTIA)
      if (self.&pressed-->0 == CrossButton
          && self.&pressed-->1 == HammerButton
          && self.&pressed-->2 == BookButton) {
        give self ~locked;
        Achieved(TASK_SOLAR_DOOR);
        "^You hear a satisfying series of clicks from within the door.
        The lock disengages.";
      } else {
        ! Wrong combination - reset all buttons
        objectloop (obj ofclass DoorButton)
          give obj ~on;
        self.pressed_count = 0;
        "^You hear a dull click from within the door. All the buttons
        spring back out. Perhaps you pressed the wrong combination?";
      }
    ],
    before [;
      Open:
        if (location == PriorsSolar) {
          give self open;
          give self ~locked;
          "You open the door.";
        }
    ],
    after [;
      Open:
        if (parent(BrOswald) == PriorsSolar) {
          if (self has general) { ! already tried once
            print
              "Brother Oswald opens the door, visibly angered.
              ~How dare you defy me?~ he bellows. You are sentenced to
              bread and water for a week.";
              KillOff();
              rtrue;
          }
          give self general;
          give self locked;
          give self ~open;
          #IfDef HAS_HINTS; HintReady(Hint_PriorGone); #EndIf;
          "Brother Oswald looks shocked as the door opens.
          ~Brother Aldwin, what are you doing trying to gain entrance
          to my private quarters?~ He closes the door on you and you
          hear the lock click.";
        }
      Close:
        give self locked;
        "You close the door and hear clicks from inside the mechanism.
        The door must have locked itself.";
    ]
  has
    static scenery door openable ~open locked transparent;


Class DoorButton                                                   ! >DoorButton
  with
    found_in CloisterNW,
    parse_name [ w1 w2;
      w1 = NextWord();
      w2 = NextWord();
      if (w1 == 'button') {
        if (w2 == 0) return 1;
        if (w2 == self.&name-->0) return 2;
      }
      if (w1 == self.&name-->0) {
        if (w2 == 0 or 'button') return 1 + (w2 ~= 0);
      }
      return 0;
    ],
    before [;
      Examine:
        print "A brass button engraved with ";
        print (string) self.symbol_desc;
        if (self has on)
          print ". It is currently pressed in";
        ".";
      Push, SwitchOn:
        if (self has on)
          "That button is already pressed in.";
        give self on;
        PriorDoor.&pressed-->PriorDoor.pressed_count = self;
        PriorDoor.pressed_count++;
        print "You press the button and feel it click into place.^";
        PriorDoor.check_combination();
        rtrue;
      Pull, SwitchOff:
        if (self hasnt on)
          "That button is not currently pressed.";
        "You cannot pull the button back out.";
    ],
  has
    scenery;


DoorButton -> CompassButton "compass button"                   ! >CompassButton
  with
    name 'compass',
    symbol_desc "a compass, labeled ~RATIO~",
  has;

DoorButton -> HammerButton "hammer button"                      ! >HammerButton
  with
    name 'hammer',
    symbol_desc "a hammer, labeled ~LABOR~",
  has;

DoorButton -> BookButton "book button"                            ! >BookButton
  with
    name 'book',
    symbol_desc "an open book, labeled ~SAPIENTIA~",
  has;

DoorButton -> CrossButton "cross button"                        ! >CrossButton
  with
    name 'cross',
    symbol_desc "a cross, labeled ~FIDES~",
  has;

DoorButton -> KeyButton "key button"                              ! >KeyButton
  with
    name 'key',
    symbol_desc "a key, labeled ~CUSTODIA~",
  has;

DoorButton -> LampButton "lamp button"                            ! >LampButton
  with
    name 'lamp',
    symbol_desc "a lamp, labeled ~LUX~",
  has;

DoorButton -> WheatButton "wheat button"                        ! >WheatButton
  with
    name 'wheat' 'sheaves',
    symbol_desc "wheat sheaves, labeled ~PROVIDENTIA~",
  has;



Room PriorsSolar "Prior's Solar"                                  ! >PriorsSolar
  with
    name 'solar' 'room',
    description
      "Prior Oswald's private chamber. A narrow bed stands against one wall.
      A writing desk sits next to it. A wooden
      chest sits at the foot of the bed.
      The room is austere but private---a privilege of rank in a
      community that otherwise shares everything.",
    e_to PriorDoor,
    each_turn [;
      #IfDef HAS_HINTS; HintReady(Hint_InSolar); #EndIf;
    ],
  has
    ;


Object -> PriorsDesk "desk"                                        ! >PriorsDesk
  with
    name 'desk' 'writing',
    description [;
      print
        "A fine wooden desk with a single drawer";
      PrintContents(". On it is ", self, ISARE_BIT);
      ".";
    ],
  has
    scenery static supporter;


Object -> -> PriorCross "cross"                                    ! >PriorCross
  class AdjObject,
  with
    adj_name 'small' 'brass',
    noun_name 'cross' 'base',
    description
      "A finely detailed cross in dark wood. The brass base bears a small
      inscription: ~CONVERTIMINI~---~Turn to me~.",
    before [;
      Take: "It seems affixed to the desk.";
      Pull: "Tugging on it does nothing.";
      Push: "Pushing down on it does nothing.";
      Turn:
        if (Chronicle hasnt moved) PronounNotice(Chronicle);
        print
          "Turning the cross on its base, you hear a click within.
          The drawer opens";
        give PriorDrawer open;
        PrintContents(". In it ", PriorDrawer, ISARE_BIT);
        ".";
    ],
  has static;


Object -> PriorDrawer "desk drawer"                               ! >PriorDrawer
  class AdjObject,
  with
    describe 0,
    adj_name 'desk',
    noun_name 'drawer',
    description [;
      print "A simple wooden drawer";
      if (self has open)
        PrintContents(". It is open, revealing ", self);
      ".";
    ],
    after [;
      Close:
        give self locked;
        "It closes and you hear a click inside when it locks.";
    ],
  has
    openable locked container;


! general = read

Object -> -> Chronicle "Chronicle"                                  ! >Chronicle
  with
    article "the",
    name 'chronicle' 'book',
    description
      "The Chronicle is the Prior's record of daily business.",
    before [;
      Examine:
        if (verb_word == 'read') {
          give self general;
          if (self has moved) Achieved(TASK_PRIORS_NOTES);
          "The Chronicle contains the Prior's notes on daily affairs.
          The recent entries:
          ^^~15 September 1346: Brother Martin reports the grain stores
          are adequate for winter, though we had to purchase an additional
          sack of flour from the village due to poor harvest. The cost
          continues to strain our resources.~
          ^^~6 August 1346: Brother Hugh informs me that the sale of our
          honey and beeswax brought less income than anticipated. Several
          benefactors who once supported us have redirected their charity
          elsewhere. Our revenues have declined steadily these past three years.~
          ^^~18 August 1346: Brother Wilfred has misplaced his latest
          work---a small psalter with illuminations of remarkable quality. He
          recalls completing the opening of Beatus vir with azure and gold, but
          cannot remember where he shelved it. At his age, such lapses grow more
          frequent---this is the second time in this season he's misplaced a
          work. This is causing a significant loss of income for us.
          ^^~1 October 1346: The roof above the refectory shows signs of damage
          from the autumn storms. Brother Anselm inspected it and says it will
          require material and builders to repair---funds we can ill afford.
          I have written to the Bishop requesting assistance, but hold
          little hope of reply.~";
        }
    ],
    after [;
      Take:
        if (self has general) Achieved(TASK_PRIORS_NOTES);
        "You're uncertain if taking the prior's property is the right thing to
        do---but you do so.";
    ],
  ;


Object -> PriorsChest "wooden chest"                              ! >PriorsChest
  with
    name 'wooden' 'chest' 'box',
    description "A sturdy wooden chest.",
    describe 0,
    before [;
      Take: "It's much too large to carry.";
    ]
  has
    static container openable ~open;


Object -> PriorsBed "narrow bed"                                    ! >PriorsBed
  class AdjObject,
  with
    adj_name 'narrow',
    noun_name 'bed',
    description
      "A simple bed---better than the straw pallets in the dormitory,
      but hardly luxurious.",
    react_before [;
      Sleep: <<Enter self>>;
    ],
    before [;
      Enter:
        "If the Prior were to catch you in his bed, you'd be expelled.
        You think better of it.";
      Search, LookUnder:
        "Nothing but dust.";
    ],
  has
    scenery supporter enterable;


! ---------------------------------------------------  2.2.2 Locutory

Room Locutory "Locutory"                                             ! >Locutory
  with
    name 'locutory' 'parlour' 'speaking' 'room',
    description [;
      if (self hasnt visited) QuoteBoxSimple(quote_locutory);
      "The locutory---the speaking room. A plain
      wooden table and a bench occupy the center. The walls are bare stone.
      This is where the prior meets with merchants, where brothers
      discuss monastery business, where the silence of the Rule may
      be broken for practical needs.";
    ],
    e_to CloisterW,
  has
    ;


Object -> LocutoryTable "table"                                 ! >LocutoryTable
  class AdjObject,
  with
    adj_name 'wooden',
    noun_name 'table',
    description
      "A plain wooden table where necessary business is conducted.",
  has
    scenery static supporter;


Object -> LocutoryBenches "benches"                           ! >LocutoryBenches
