Room FitzAlanCrypt "FitzAlan Crypt"
  with
    name 'fitzalan' 'crypt',
    description
      "A small vaulted chamber, no more than ten feet across. There are three
      stone sarcophagi, each carved with remarkable detail despite
      the cramped confines. The central tomb bears the effigy of a knight in
      full armor, his hands clasped in prayer; his shield displays a red lion:
      the FitzAlan arms. Flanking him are two smaller tombs,
      their weathered inscriptions suggesting his wives or children.

      ^^The walls here are finished stone rather than rough-hewn rock, and
      narrow recesses have been cut into the walls---likely once holding
      offerings or relics. The air is still, undisturbed for decades
      or longer. A patina of dust covers everything, unmarred by footprints
      save your own.

      ^^A doorway to the west seems blocked by heavy fabric.",
    w_to [;
      print
        "With some effort, you push against the fabric and emerge into a
        much-larger crypt.^^";
      return Crypt;
    ],
    u_to [;
      ! need to handle altar moved
      return FitzAlanChantry;
    ],
  each_turn [;
    Achieved(TASK_DISCOVER_FA_CRYPT);
  ],
  has
    ~light;

Room Crypt "Crypt"
  with
    name 'crypt',
    description
      "The crypt stretches before you, a forest of thick stone pillars
      supporting low vaulted arches. Rows of stone sarcophagi line the walls,
      their carved effigies of long-dead monks and benefactors worn smooth by
      centuries of damp air. Small alcoves between the pillars hold humbler
      tombs---stone slabs marking the resting places of lesser brethren.

      ^^The air is thick and cold, heavy with the scent of earth and stone. Water
      has seeped through cracks in the vaulting overhead, leaving dark stains
      on the pillars and pooling in shallow depressions in the uneven floor.
      An iron candelabra near the stairs holds stub ends of candles, their wax
      long since melted into grotesque shapes.

      ^^Against the eastern wall hangs a faded wooden panel depicting the Three
      Living and the Three Dead, its Latin inscription barely legible in the
      gloom.",
    u_to CryptStairs,
    e_to [;
      if (Frame hasnt general) "You can't go that way.";
      print "You slip through the opening behind the panel, revealing...^^";
      return FitzAlanCrypt;
    ],
  has
    ~light;

! not a tapestry, but wood panel
! slid, raises fitzalan stairs -- trapping player
! can they just slide panel from fa crypt? or what's the puzzle?
! a panel (just art!) but the frame (sep object, brass) has a latch

Object -> Panel "art panel"
  with
    name 'art' 'panel' 'youths' 'corpses',
    initial [;
      if (latch has open) "The panel is ajar, revealing an opening.";
      if (frame has general)
        "The panel is currently closed flush against the wall.";
      rtrue;  ! hmm, always seems to print blank line.
    ],
    description
      "A large wooden painted panel set in a brass frame, it
      depicts the Three Living and the Three Dead---three noble youths
      recoiling from three
      crowned corpses who gesture toward them. Woven beneath in Gothic script:
      ~QUOD FUIMUS, ESTIS; QUOD SUMUS, ERITIS~ (What we were, you are; what we
      are, you will be). Dampness has taken its toll on the ancient
      pigments.",
    before [;
      Take:
        "Before you even try, you realize this would be much too large to
        carry.";
      Burn:
        "Given how damp it is here, you couldn't catch it alight.";
      Search:
        "Besides your search for meaning on a memento mori, you find nothing
        unexpected in the artwork.";
      Turn, Push:
        "The art panel seems affixed to the brass frame.";
      Open:
        if (Frame has general) <<Open Latch>>;
      Close:
        if (Frame has general) <<Close Latch>>;
    ],
    has
      static;

Object -> Frame "brass frame"
  with
    name 'brass' 'frame',
    before [;
      Search, Examine:
        if (Latch has open)
          "The panel and frame are ajar from the wall, revealing an opening.";
        print "The brass frame encloses the art panel";
        if (self hasnt general)
          print
            ". Examining it closely, you find
            a small latch on the right-hand side of the panel";
        give self general;
        ".";
      Push, Turn:
        if (self has general) "Perhaps if you tried to do that to the latch?";
        "Nothing unexpected happens.";
      Open:
        if (Frame has general) <<Open Latch>>;
      Close:
        if (Frame has general) <<Close Latch>>;
    ],
  has
    scenery;

Object -> Latch "latch"
  with
    parse_name [ w ;
      ! don't recognize 'latch' until its found
      ! prevent evil player from just assuming there's a latch hidden
      ! somehwere
      if (Frame hasnt general) return 0;
      w = NextWord();
      if (w == 'latch') return 1;
      return 0;
    ],
    when_open
      "The art panel and frame are ajar.",
    description [;
      print
        "It's a small latch that seems to control something inside of the
        brass frame. It is currently ";
      if (self has open) "open."; "closed.";
    ],
    before [;
      Open:
        if (self hasnt open) {
          give self open;
          "You open the latch and feel the frame pop out a bit from the wall.";
        }
        "The latch is already opened.";
      Close:
        if (self has open) {
          give self ~open;
          "You push the frame against the wall and the latch clicks shut.";
        }
      Turn, Push:
        if (self has open) <<Close self>>; <<Open self>>;
    ],
  has
    scenery;

Object -> Sarcophagi "sarcophagi"
  with
    name 'sarcophagi//p' 'crypts' 'tombs',
    description
      "Each is carved from a single block of stone and sealed with lead along
       the edges.",
    nope "Disturbing the Christian dead is mortal sin.",
    before [;
      Enter, Attack, Turn:
        self.nope(); rtrue;
      Push, Open:
        self.nope();
        "^Besides, the lids must
        weigh several hundredweight. It would take multiple men with levers
        to shift one.";
    ],
  has
    scenery pluralname;




