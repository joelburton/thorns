Object -> LibraryDoor "library door"                              ! >LibraryDoor
  with
    name 'library' 'door',
    description [;
      print "A heavy wooden door with a lock plate in silver. It is ";
      if (self has open) print "open"; else print "closed";
      ".";
    ],
    found_in Scriptorium Library,
    door_dir (w_to) (e_to),
    door_to Library,
    with_key LibraryKey,
    when_open "The library door is open.",
    when_closed "The library door is closed.",
    react_before [;
      Open, Unlock:
        if (BrWilfred in location && BrWilfred has awake) {
          "You wouldn't dare try to enter the Library with Brother Wilfred
          watching you!";
        }
    ],
    #IfDef HAS_HINTS;
    on_first_entry [;
      HintReady(Hint_LibraryKey);
    ],
    #EndIf;
    each_turn [;
      if (BrWilfred has awake && self has open) {
        print
          "^Brother Wilfred notices the open door to the Library---you're
          caught!

          For violating a serious rule of the priory, you are sentenced to
          bread and water for a week.";
          KillOff();
      }
    ],
  has
    static door openable ~open lockable locked;


Room Library "Library"                                                ! >Library
  with
    description
      "This is a small private room. There is a bookshelf on the north wall
      and a large map of the priory on the south wall.
      The only exit is to the west.",
    w_to Scriptorium,
    out_to Scriptorium,
    before [;
      Smell: if (noun == nothing) "Ah, the smell of dusty books.";
    ],
    on_first_entry [;
      TaskDone(TASK_LIBRARY);
      #IfDef HAS_HINTS; HintReady(Hint_Library); #EndIf;
    ],
    cheap_scenery
      'manuscript' 'manuscripts'
        "There are many, but none seem significant."
      11 'two' 'crypts' [;
        print
          "Two crypts: a larger one, simply labelled ~Crypt~ and another,
          ~FitzAlan Crypt~.^";
        if (FitzAlanCrypt hasnt visited)
          "^Now that you think of it, while you've been in the crypt
          once for a service, you've never seen or heard of the other one.";
        return true;
      ]
      1 'dorms'
        "One dorm for the choir monks and one for the lay brothers, naturally."
      11 'brass' 'map'
        "Finely etched into brass and signed by ~Prior Gordian~.
        It shows both the indoor and outdoor areas, from the dorms on the
        upper floor all the way down to the two crypts below ground."
    ,
  has
    ;


Object -> Bookshelf "bookshelf"                                     ! >Bookshelf
  class AdjObject,
  with
    adj_name 'book',
    noun_name 'shelf' 'bookshelf' 'books' 'items',
    notice_fratrum [ ;
      if (MonkGuide hasnt moved) {
        print
          ". One that draws your attention because of its thin size and
          small format is titled ~Registrum Fratrum~";
      }
      PrintContents(". Also on it ", self, ISARE_BIT);
    ],
    description [;
      print
        "The bookshelf has about fifty items, most of which are manuscripts,
        used for the work in the Scriptorium";
      self.notice_fratrum();
      ".";
    ],
    before [;
      Search:
        print "There are many items on the bookshelf";
        self.notice_fratrum();
        ".";
    ],
  has scenery supporter;


Object -> -> MonkGuide "Registrum Fratrum",                         ! >MonkGuide
  with
    name 'registry' 'register' 'registrum' 'fratrum',
    description
      "The ~Registrum Fratrum~ (~Register of the Brothers~).
      A small leather-bound registry that Brother Wilfred has been keeping
      for decades, back to when he was Prior. It has notes on brothers who
      have served in the priory, even including some historical ones.",
    before [ i last_word end ;
      Examine:
        if (verb_word == 'read')
          "It's too long to read through, but you can look up particular
          entries by name.";
      Consult:
        if (location == thedark) { PrintMsg(MSG_EXAMINE_DARK); rtrue; }
        if (ImplicitGrabIfNotHeld(noun)) return;
        if (second == nothing || ~~(second provides history_text)) {
          print "You find no entry for ";
          if (second == nothing) {
            last_word = consult_from + consult_words - 1;
            end = WordAddress(last_word) + WordLength(last_word);
            for (i = WordAddress(consult_from) : i < end : i++)
              print (char) i->0;
          }
          else {
            print (name) second;
          }
          " in ", (the) self, ".";
        }
        TaskDone(TASK_USED_REGISTRUM);
        second.history_text();
        rtrue;
    ],
    after [;
      Take:
        if (self has moved) rfalse;
        "You carefully remove the Registrum Fratrum from the shelf.
        Brother Wilfred would be furious if he knew.";
    ],
  has
    concealed proper;


! ----------------------------------------------------------------- Slype

Room Slype "Slype"                                                      ! >Slype
  with
