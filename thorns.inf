!   has
!     scenery static;

Object -> DorterWindow "window"
  with
    when_closed "The opening is shuttered.",
    when_open "You can see the roof.",
    door_to Rooftop,
    door_dir w_to,
  has
    static door openable;

Object Rooftop "Rooftop"
  with
    description "",
    e_to Dorter;

Object Dorm "Dorm"
  with
    description
      "",
    e_to Reredorter,
    s_to Dorter,
    d_to NightStairs,
  has
    light;

Object NightStairs "Night Stairs"
  with
    description "",
    d_to Quire,
    u_to Dorm;

Object Reredorter "Reredorter"
  with
    description
    "",
    w_to Dorm,
  has
    light;

Object LayCells "Lay cells"
  with
    description
      "",
     n_to Dorter,
   has
     light;

! =============================================== Gamr

[ Initialise;
  TitlePage();
  location = WestPorch;
  give player light;
  "^^Murder scene here...^^^";
];

[ TitlePage i;
  @erase_window -1; print "^^^^^^^^^^^^^";
  i = 0->33; if (i > 30) i = (i-30)/2;
  style bold; font off; spaces(i);
  print " OUR LADY OF THORNS^";
  style roman; print "^^"; spaces(i);
  print "[Press SPACE to begin.]^";
  font on;
  box "Behold, how good and how pleasant it is"
      "for brethren to dwell together in unity."
      ""
      "-- Psalm 133";
  @read_char 1 -> i;
  @erase_window -1;
];

[ DeathMessage;
  if (deadflag == 1) print "You have died";
  if (deadflag == 3) print "You have failed";
];

[ LookDirSub;
  ! do i want to do this? or disable this except in certain places
  if (noun == n_obj && location.n_to ~= -1)
    "To the north, you see: ", (name) location.n_to;
];

Include "Grammar";

Extend 'look' first 
  * noun=ADirection -> LookDir;

