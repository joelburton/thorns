! --------------------------------------------------- 2.2.3 Lavatorium

Room Lavatorium "Lavatorium"                                       ! >Lavatorium
  with
    name 'lavatorium',
    description
      "A small alcove off the cloister where the brothers wash before
      entering the refectory. You can only go back the way you came.",
    n_to CloisterSW,
  has
     ;


Object -> Basin "basin"                                                 ! >Basin
  class AdjObject
  with
    adj_name 'large' 'stone',
    noun_name 'basin',
    initial
      "A large stone basin is built into the south wall, filled with
      water for washing.",
    description
      "The basin is worn smooth and water-stained from centuries of use
      and contains a large quantity of water.",
    before [;
      Drink:
        "This is washing-up water, and not suitable for drinking.";
      Taste:
        "You try a tiny sip and notice nothing unexpected.";
      Take:
        "The basin is built into the wall, and trying to get the water from it
        would seem impractical.";
    ],
    after [;
      Receive:
        print (The) noun, " drops into the water";
        if (noun ofclass Candle && noun has light)
          { noun.stop_light(); print " and extinguishes"; }
        ".";
    ],
  has
    static container open transparent;


Object -> -> Water "water"                                              ! >Water
  with
    article "some",
    name 'water',
    before [;
      Drink: <<Drink Basin>>;
      Taste: <<Taste Basin>>;
      Take: <<Take Basin>>;
      Insert: <<Transfer noun Basin>>;
    ],
  has
    ;


Object -> Towel "towel"                                                 ! >Towel
  with
    name 'towel',
    initial "A threadbare towel hangs on a peg by the basin.",
    description
      "It's a simple linen towel, well-worn by use.",
    before [;
      Attack, Cut:
        "Destrying communal property is a violation of the Rules.";
      Take:
        "You should leave this here. The other brothers will want of its use.";
      Touch:
        "Rough linen and damp.";
      Smell:
        "It smells damp and musty.";
    ],
  has
    ok_carry;



! ============================================= East Wing

!---------------------------------------------------------- Chapter House

Room ChapterHouse "Chapter House"                                ! >ChapterHouse
  with
    description
      "The chapter house is a modest, rectangular room where the brothers
      gather each morning to discuss monastery business.
      A painted panel on the wall depict
      the hours of the divine office. In one corner stands a life-sized
      wooden statue. The only exit is to the west.",
    w_to CloisterNE,
    cheap_scenery
      1 'scroll' "It's just a painted part of the statue.",
    time_left 0,
    daemon [ m ;
      self.time_left++;
      give self general;
      switch (self.time_left) {
        1:
          objectloop (m ofclass Monk)
            if (m ~= BrAelred) move m to ChapterBenches;
          PlayerTo(ChapterBenches);
          "^~Brothers,~ starts Brother Prior Oswald, ~this is a terrible day
          for our community: the loss of our herbalist, Brother Aelred.~";
        2:
          "^Brother Oswald pauses. ~Brother Aelred's passing was... sudden.
          He did have a weak heart. Let us thank God that his passing
          was quick.~";
        3:
          "^Brother Oswald continues: ~Brother Benedict has placed him in
          the infirmary chapel. You may pay visits to our dear brother there.~";
        4:
          "^Brother Oswald continues: ~Our novice~---he gestures toward
          you---~is doing adequately in his
          role, and will spend today cataloging the state of the gardens
          so that he and I can meet after the burial to decide how to proceed
          without our herbalist.~";
        5:
          "^Brother Oswald continues: ~Of course, we've missed Prime, but
          we will continue to hold the rest of our Divine Offices today.
          Given the circumstances,
          I expect many of you may need to skip offices
          today---and to this, I give my blessing.~";
        6:
          objectloop (m ofclass Monk)
            if (m ~= BrAelred) move m to self;
          the_time = the_time + 20;
          give self ~general;
          "^The meeting wraps up and the brethren stand and prepare to
          leave.";
        7:
          objectloop (m ofclass Monk) m.go_home();
          StopDaemon(self);
          "^The brothers all depart.";
      }
    ],
    before [;
      Go:
        if (self has general)
          "You shouldn't leave during the meeting.";
      Examine, Look, Listen, Wait, LookUnder, Search, Think: ;
      Ask, Tell, Show, AskFor, AskTo, Shout, ShoutAt, Sing, Wave:
        if (self has general)
          "Brother Anselm, sitting beside you, rebukes you kindly:
          ~We should listen to what our prior tells us.~";
      default:
        if (self has general)
          "You dare not disturb the meeting with any action such as this.";
    ],
  has
    ;


Object -> ChapterBenches "benches"                             ! >ChapterBenches
  with
    article "two",
    name 'bench' 'benches',
    description [;
      print "The benches are plainly made of wood";
      PrintContents(". On them ", self, ISARE_BIT);
      ".";
    ],
    initial [;
      print "Two benches are in the center of the room";
      PrintContents(". On them ", self, ISARE_BIT);
      ".";
    ],
    before [;
      Examine: ;
      Push, Pull, Turn:
        "You could move them, but for what purpose?
        They're just plain furniture.";
    ], after [;
      Enter:
        "You sit on a bench.";
      Exit:
        "You get up from your bench.";
    ]
  has static supporter enterable pluralname;


Object -> ChapterTable "table"                                   ! >ChapterTable
  with
    name 'table',
    description "A large rectangular wooden table between the benches.",
    initial [;
      print "A broad table lies between the benches";
      PrintContents(". On it ", self, ISARE_BIT);
      ".";
    ],
    before [;
      Examine: ;
      Push, Pull, Turn:
        "It's much too heavy to move.";
      Enter:
        "You have no reason to sit right now.";
      Take:
        "Leave the furniture be, Brother.";
    ]
  has static supporter;


Statue -> GordianStatue "statue"                                ! >GordianStatue
  with
    name 'gordian' 'statue',
    describe 0,
    description
      "A wooden statue, worn and with the paint flaking in
      places. You recognize it as Brother Gordian, who you have been told
      was the founder of the priory. His face is filled with reverence and
      curiosity, and he is depicted holding a scroll reading
      ~III: SAPIENTIA~, reflecting Holy Wisdom in his
      three creeds.",
    before [;
      Kiss: "That would only give you a splinter.";
      Order: "The statue doesn't respond, naturally.";
    ],
  has
    static ~proper;


Object -> OfficeHours "painted panel"                             ! >OfficeHours
  class AdjObject,
  with
    adj_name 'painted' 'office',
    noun_name 'panel' 'hours',
    description
      "It shows the offices:^
      ^Matins  3 AM     Sext     Noon
      ^Lauds   5 AM     None     3 PM
      ^Prime   6 AM     Vespers  6 PM
      ^Terce   9 AM     Compline 7 PM",
    before [;
      Take: "It's much too large to carry.";
      LookUnder, Search, Turn, Push, Pull:
        "It's painted onto a panel wall, and it doesn't move.";
    ]
  has
    scenery;


! --------------------------------------------------------- Scriptorium

Room Scriptorium "Scriptorium"                                    ! >Scriptorium
  with
    description
      "This chamber is where three of the brothers typically work, creating
      illuminated manuscripts and copying books. To the west is the cloister;
      to the east is the library.

      A large table is at the center where the work is done.",
    e_to LibraryDoor,
    w_to CloisterE,
    each_turn [;
      #IfDef HAS_HINTS; HintReady(Hint_Scriptorium); #EndIf;
    ],
    before [;
      Open, Unlock:
        if (noun == self && BrWilfred has general) {
          "You wouldn't dare try to enter the library with Brother Wilfred
          watching you!";
        }
      Smell:
        if (MandrakeRoot.burn_time) {
          print
            "Foolishly, you deeply inhale the mandrake yourself, and awaken by
            firm shaking by Brother Oswald.^^

            ~What madness, Brother Aldwin? What were you thinking?~

            You are sentenced to bread and water for a week.";
          KillOff();
        }
    ],
  has
     ;


Object -> ScriptoriumTable "table"                           ! >ScriptoriumTable
  with
    name 'table',
    description [;
      print
        "Large enough for four monks to work here";
      PrintContents(". On it ", self, ISARE_BIT);
      ".";
    ],
    before [;
      Search: "A search reveals nothing but the implements and manuscript.";
      LookUnder: "Just the floor.";
    ],
  has
    scenery supporter;


Object -> -> Manuscript "manuscript"                               ! >Manuscript
  with
    name 'manuscript',
    description
        "The manuscript is a psalter in progress, open to Psalm 23.
        The Latin text is written in a careful Gothic script, and
        someone---likely Brother Wilfred---has begun illuminating the
        initial ~D~ of ~Dominus~ with delicate gold leaf and azure.
        The shepherd's crook curves through the letter, and tiny sheep
        peek from the margins. It's beautiful work, though the hand
        that painted it must have trembled with age.",
    before [;
      Examine:
        if (verb_word == 'read')
          "The Latin reads: 'Dominus regit me, et nihil mihi deerit...'
          (The Lord is my shepherd, I shall not want...)";
        ! else will fall through to normal examine
      Search: "You discover nothing but the text iself.";
      LookUnder: "There is nothing below the manuscript.";
      default: "You shouldn't disturb the manuscript.";
    ]
  has ;


Object -> -> WritingImplements "writing implements"         ! >WritingImplements
  class AdjObject,
  with
    adj_name 'writing',
    noun_name 'implements' 'brush' 'brushes//p' 'ink' 'inks//p',
    description "Brushes and inks needed for the work.",
    before [;
      Examine: ;
      Smell: "They smell of the pigments used in copying.";
      default: "You shouldn't disturb these materials.";
    ],
  has pluralname;


Object -> -> LibraryKey "silver key"                               ! >LibraryKey
  class AdjObject,
  with
    adj_name 'library' 'silver',
    noun_name 'key',
    description
      "A simple silver key, tarnished with age. Brother Wilfred guards
      it jealously---it's his responsibility as librarian to control
      access to the priory's precious books.",
    before [;
      Take:
        if (BrWilfred in location && BrWilfred hasnt general) ! awake
          "Brother Wilfred's eyes snap up just as your hand reaches for it.
          ~Ah-ah,~ he says kindly but firmly, stifling a yawn. ~Not without
          the prior's leave, young Brother Aldwin.~";
    ],
    each_turn [;
      if (BrWilfred hasnt general
            && self notin ScriptoriumTable && ~~deadflag) {
        print
          "^Brother Wilfred discovers the missing key---you're caught.

          For violating such a serious rule of the priory, you are sentenced
          to bread and water for a week.";
        KillOff();
      }
    ]
  has ;


Object -> Fireplace "fireplace"                                     ! >Fireplace
  with
    name 'fireplace' 'fire',
    initial
      "A fireplace is built into the south wall, and a small fire is going,
      making the room warmer and helping keep the manuscripts dry from the
      sea air.",
    description
      "A plain chamber of stone built into the wall.",
    after [;
      Touch: "Ow, ow, ow.";
      Smell:
        "It smells of wood and smoke.";
      Receive:
        print "You toss ", (the) noun, " into the fire.^";
        if (noun == MandrakeRoot) <<Burn MandrakeRoot>>;
        remove noun; ! other things burn instantly
        rtrue;
    ],
  has
    container open;

! ----------------------------------------------------------------------------

Object -> LibraryDoor "library door"                              ! >LibraryDoor
  with
    name 'library' 'door',
    description "A heavy wooden door with a keyhole.",
    found_in Scriptorium Library,
    door_dir (w_to) (e_to),
    door_to Library,
    with_key LibraryKey,
    each_turn [;
      #IfDef HAS_HINTS; HintReady(Hint_LibraryKey); #EndIf;
      if (BrWilfred hasnt general && self has open) {
        print
          "^Brother Wilfred notices the open door to the library---you're
          caught!

          For violating a serious rule of the priory, you are sentenced to
          bread and water for a week.";
          KillOff();
      }
    ],
  has
    scenery door openable ~open lockable locked;


Room Library "Library"                                                ! >Library
  with
    description
      "This is a small private room. There is a bookshelf on the north wall
      and a large map of the priory on the south wall.
      The only exit to to the west.",
    w_to Scriptorium,
    before [;
      Smell: "Ah, the smell of dusty books.";
    ],
    each_turn [;
      Achieved(TASK_LIBRARY);
      #IfDef HAS_HINTS; HintReady(Hint_Library); #EndIf;
    ]
    cheap_scenery
      'manuscript' 'manuscripts'
        "There are many, but none seem significant."
  has
    ;


Object -> BrassMap "brass map"                                       ! >BrassMap
  class AdjObject,
  with
    adj_name 'brass',
    noun_name 'map',
    add_to_scope TwoCryptsOnMap,
    description
      "Finely etched into brass and signed by ~Brother Gordian~.
      It shows both the indoor and outdoor areas, from the dorms in the second
      floor all the way down to the two crypts below ground.",
  has
    scenery;


Object TwoCryptsOnMap "two crypts"                             ! >TwoCryptsOnMap
  with
    name 'two' 'crypts',
    description
      "Two crypts: a larger one, simply labeled ~Crypt~ and another,
      ~FitzAlan Crypt~.^^
      Now that you think of it, while you've been in the crypt before, you've
      never seen or heard of the other one.",
    has
      ;


Object -> Bookshelf "bookshelf"                                     ! >Bookshelf
  class AdjObject,
  with
    adj_name 'book',
    noun_name 'shelf' 'bookshelf' 'books' 'shelves',
    description [;
      print
        "The bookshelf has about fifty books, most of which are manuscripts,
        used for the work in the scriptorium";
      if (MonkGuide hasnt moved)
        print
          ". One that draws your attention because of its thin size and
          small format is titled ~Registrum Fratrum~";
      ".";
    ],
    before [;
      Search:
        print "There are many books on the bookshelf";
        PrintContents(". Also on it ", self, ISARE_BIT);
        ".";
    ],
    add_to_scope [;
      if (MonkGuide in nothing) PlaceInScope(MonkGuide);
    ],
  has scenery supporter;


Object MonkGuide "Registrum Fratrum",                               ! >MonkGuide
  class AdjObject,
  with
    noun_name 'registry' 'register' 'registrum' 'fratrum' 'book',
    description
      "The ~Registrum Fratrum~ (~Register of the Brothers~).
      A small leather-bound book providing information on the monks who
      have served in the priory. It was started decades ago, when Brother
      Wilfred became the prior, but it contains information on some of the
      monks before then, also.",
    before [ i last_word end ;
      Examine:
        if (verb_word == 'read')
          "It's too long to read through, but you can look up particular
          entries by name.";
      Consult:
        if (second == nothing || ~~(second provides history_text)) {
          print "You find no entry for ~";
          if (second == nothing) {
            last_word = consult_from + consult_words - 1;
            end = WordAddress(last_word) + WordLength(last_word);
            for (i = WordAddress(consult_from) : i < end : i++)
              print (char) i->0;
          }
        else {
          print (name) second;
        }
        "~ in ", (the) self, ".";
        }
        print_ret (string) second.history_text;
    ],
    after [;
      Take:
        if (self has moved) rfalse;
        Achieved(TASK_REGISTRUM);
        "You carefully remove the Registrum Fratrum from the shelf.
        Brother Wilfred would be furious if he knew.";
    ],
  has
    proper;


! ----------------------------------------------------------------- Slype

Room Slype "Slype"                                                      ! >Slype
  with
    description
      "A long east-west stone corridor lined with decorative bushes.
      West is the cloister, east is the infirmary. A small passage heads
      south to the herbarium.",
    s_to Herbarium,
    e_to Infirmary,
    w_to CloisterSE,
    turns_left 0,
    daemon [;     ! death scene
      self.turns_left++;
      switch (self.turns_left) {
        1:
          "^Brother Aelred is here, but clearly unwell. His body is convulsing
          and his eyes look strange and unusual.";
        2:
          "^Aelred seems gripped with delirium. ~My son...~
          he whispers. ~Gathering... he was always gathering... I wanted
          to know why...~";
        3:
          "^Aelred's hand jerks wildly, trembling, gesturing toward the
          bushes lining the slype and the scriptorium behind.
          His lips move. ~The letter... the letter told me everything...~";
        4:
          "^Aelred convulses wildly. The end of his time cannot be far.";
        5:
          "^A strange peace crosses Aelred's face. He finds your hand and
          holds it with surprising strength. ~Two lives for one, my son.~
          He smile, looking towards Heaven---and is gone.";
        6:
          StopDaemon(self);
          give BrAelred ~general;
          remove BrAelred;
          print
            "^Prior Oswald arrives and, upon seeing the wide and still
            eyes of Brother Aelred, makes the sign of the cross and whispers
            a prayer. The other brothers, having heard Remigio's cries,
            come to the slype. Brother Benedict, the infirmarer, is called upon
            to determine if Aelred is dead, and he does so.
            ^^Brothers Benedict and Anselm carry Aelred's body to the
            Infirmary to be cleaned and placed in holy repose in the
            adjoining chapel.
            ^^You find yourself in the garden without quite knowing how you got
            there, standing among Aelred's carefully tended beds.
            Your friend. Your mentor. The pangs of loneliness
            that have eaten at you on some nights reappear.
            ^^Brother Wilfred, the venerable librarian, finds you in the Garden
            and tries to offer
            tender words of consolation: ~My child~, he says, ~you will always
            have a friend in me. Brother Aelred lived a joyful and reverent
            life, and we can carry on in his spirit with your help.~ He
            gestures to the gardens that you have grown to love so much.
            ^^You are told by others that there is a meeting in the Chapter
            House. You dry your eyes and make your way there.^^";
            the_time = the_time + 20;
            give BrAelred ~animate;
            StartDaemon(ChapterHouse);
      }
    ],
    before [;
      Smell:
        "A faint sweetness lingers from the bushes, though the flowers are
        mostly gone now.";
      Go:
        if (BrAelred has general)
          "You wouldn't dare leave your mentor given his current state.";
    ],
    after [;
      Go:
        if (BrAelred has general) {
          give self general;         ! death scene
          give BrAelred concealed;   ! we'll describe him in the daemon
          StartDaemon(self);
          move BrRemigio to self;
          print
            "You arrive at the Slype, where it seems Brother Remigio was
            imploring you to come to.^^";
          <<Look>>;
        }
    ],
    cheap_scenery
      1 'scriptorium' "It's just the wall of the scriptorium.",
  has
     ;


Object -> RoseBushes "bushes"                                      ! >RoseBushes
  class AdjObject,
  with
    adj_name 'rose',
    noun_name 'bush' 'bushes',
    description
      "These bushes were a point of pride for Aelred, given how hard they can be
      to grow roses in this climate. Given the season, the flowers are largely
      gone, replaced by only rosehips and their scent.",
    before [;
      Smell: "Faint but still sweet and floral.";
      Search, LookUnder: "There is nothing in the bushes.";
      Take: "You wouldn't dare dig up one of these.";
    ],
  has
    scenery;


Object -> RoseOrHips "roses"                                       ! >RoseOrHips
  class AdjObject
  with
    describe 0,
    noun_name 'rose' 'roses' 'rosehip' 'rosehips' 'flower' 'flowers',
    description
      "The flowers are largely shriveled and dead, and rosehips
      replace them.",
    before [;
      Smell: "Still lovely.";
      Search, LookUnder: <<Search RoseBushes>>;
      Take:
        "You dare not take any of the flowers or berries. It would feel
        wrong to take anything of Aelred's pride.";
    ]
  has static;


! --------------------------------------------------------------

! PUZZLE: opening the cabinet
! PUZZLE: identifying the poison

Room Infirmary "Infirmary"                                          ! >Infirmary
  with
    description [;
      #IfDef HAS_HINTS; HintReady(Hint_Infirmary); #EndIf;
      "The infirmary serves both the brothers and visiting villagers who seek
      healing. Several narrow beds line the western wall, their straw mattresses
      covered with coarse linen. A workbench holds mortars, bowls, and various
      implements for preparing remedies. The air smells of herbs, vinegar, and
      illness. A polished metal mirror hangs on the wall---unusual luxury, but
      necessary for examining patients' throats and eyes. The medicine cabinet
      stands against the north wall. A small chapel lies to the south, and
      the slype is to the west.";
    ],
    s_to InfirmaryChapel,
    w_to Slype,
    before [;
      Smell: if (noun == nothing) "A sharp, bitter smell.";
    ],
    cheap_scenery
      1 'beds' "They're just beds, with nothing on or under them."
      1 'mortars'
        "Useful for grinding medicine, but you should leave them alone."
      1 'bowels'
        "Unremarkable clay pots"
      'various' 'implements' "You don't need to worry about these.",
  has
    ;


Object -> Mirror "mirror"                                              ! >Mirror
  class AdjObject,
  with
    adj_name 'reflective' 'metal',
    noun_name 'mirror' 'plate',
    react_before [;
      Examine:
        if (noun == player) {
          print "(in the mirror)^";
          <<Examine Mirror>>;
        }
    ],
    before [;
      Examine:
        "A young face, barely requiring shaving. stares back at you.
        Your black Benedictine habit hangs loose on your thin frame.
        No tonsure marks your crown---you're
        still a novice, not yet bound by final vows.
        Brother Aelred used to say you had honest eyes.
        You hope he was right.";
      Attack, Cut:
        "Next, you'll want to cross a black cat's path?";
      Take:
        if (BrBenedict in location)
          "You dare not steal this in front of the brother.";
    ],
  has
    ;


Object -> InfirmaryCabinet "medicine cabinet"                ! >InfirmaryCabinet
  with
    name 'medicine' 'cabinet',
    description [;
      #IfDef HAS_HINTS; HintReady(Hint_Cabinet); #EndIf;
      print
        "A wooden cabinet secured with a brass lock mechanism. Four wheels,
        each engraved with digits ~0~ through ~9~, can be rotated
        independently. Carved into the wood above the lock:
        ~Historia nostra, fides nostra~.";
      if (self hasnt general)
        print
          "^^You remember Brother Aelred mentioning this cabinet:
          ~Brother Benedict is trusting. He doesn't want to keep medicines
          from his brothers in need, only from the village folk we treat.
          It's set to something every brother knows---outsiders wouldn't
          think to look for it.~";
      give self general;

      print
        "^^The four wheels currently show: ", Wheel1.setting, "-",
        Wheel2.setting, "-", Wheel3.setting, "-", Wheel4.setting;
      ".";
    ],
    check_combination [;
      ! 1152 = founding date
      if (Wheel1.setting == 1 && Wheel2.setting == 1
          && Wheel3.setting == 5 && Wheel4.setting == 2) {
        if (self hasnt open) {
          give self open;
          Achieved(TASK_INFIRMARY_CABINET);
          "^You hear a satisfying click as the lock disengages and
          the cabinet opens.";
        }
      } else {
        give self ~open;
      }
    ],
    before [;
      if (BrBenedict in Infirmary && action ~= ##Examine)
        "You dare not with Brother Benedict here.";
      Open:
        if (self has open) "The cabinet is already open.";
        if (~~self.check_combination()) "The cabinet remains locked.";
      Search:
        if (self hasnt open) <<Open self>>;
      Examine:
        if (self has open) <<Search self>>;
    ],
  has
    container openable ~open;


Tincture -> -> FoxgloveTincture "tincture of foxglove"       ! >FoxgloveTincture
  with
    name 'poppy' 'syrup' 'opium',
    description
      "A small bottle of a murky yellow-brown liquid. You know from Brother
      Aelred that this can be miraculous for the heart in small quantities,
      but in greater quantities, it can be deadly."
    scent "bitter and earthy.",
    flavor "unpleasantly bitter with a strong grassy taste.",
  ;


Tincture -> -> HenbaneTincture "tincture of henbane"          ! >HenbaneTincture
  with
    name 'hen' 'bane' 'henbane',
    description
      "A small bottle of a greenish-brown liquid. You know from Brother Aelred
      that this is used for sedative purposes, though it does have disturbing
      side-effects. If used in excess, it can be fatal.^^
      This bottle is almost entirely empty, with only a bit remaining.",
    scent "overtones of alcohol and urine.",
    flavor "gluey, unpleasant, and bitter.",
    identified [;
      Achieved(TASK_MATCH_SYMPTOMS);
      f_identified_poison = true;
      if (suspicion_level == 0) suspicion_level = 1;
      "^That's it---you now know that your dear mentor was poisoned with ",
      (the) self, ". You know you'll need to figure out who killed him and
      why.";
    ],
    before [;
      Smell:
        "There's so little left, you can only catch a whiff of the alcohol
        used to make the tincture.";
      Taste:
        self.lick();
        give self general;
        if (f_smelled_aelred) self.identified();
      Take:
        if (f_identified_poison) Achieved(TASK_EVIDENCE_HENBANE);
    ],
  ;


Tincture -> -> Theriac "theriac"                                      ! >Theriac
  with
    name 'theriac',
    description
      "A small bottle of a dark brown, sticky paste. You know from Brother
      Aelred that this is often used as a restorative and antidote for
      poisons.",
    scent "complex notes of honey and exotic spices.",
    flavor "overpoweringly sweet and bitter.",
  ;


Class Wheel                                                             ! >Wheel
  with
    setting 0,  ! starts at I
    set_me [;
        print "You turn ", (the) self, " to ", self.setting, ".^";
        InfirmaryCabinet.check_combination();
    ],
    before [;
      if (BrBenedict in Infirmary && action ~= ##Examine)
        "You daren't mess with it in front of the brother.";

      SetTo:
        if (InfirmaryCabinet has open)
          "The wheels can't be turned while the cabinet is open.";
        self.setting = second;
        self.set_me();
        rtrue;
      Turn:
        if (InfirmaryCabinet has open)
          "The wheels can't be turned while the cabinet is open.";
        self.setting++;
        if (self.setting > 9) self.setting = 0;
        self.set_me();
        rtrue;
      Examine:
        print_ret (The) self, " is currently set to ", self.setting, ".";
    ],
  has
    scenery;

Wheel -> Wheel1 "first wheel"                                          ! >Wheel1
  with name 'first' '1st' 'one' 'wheel';

Wheel -> Wheel2 "second wheel"                                         ! >Wheel2
  with name 'second' '2nd' 'two' 'wheel';

Wheel -> Wheel3 "third wheel"                                          ! >Wheel3
  with name 'third' '3rd' 'three' 'wheel';

Wheel -> Wheel4 "fourth wheel"                                         ! >Wheel4
  with name 'fourth' '4th' 'four' 'wheel';


! ----------------------------------------------------------- Infirmary Chapel
! The player can only entere here after the death, so we can
! write this knowing there will be a body in it, etc.

Room InfirmaryChapel "Infirmary Chapel"                       ! >InfirmaryChapel
  with
    description
        "A tiny chapel attached to the infirmary, barely large enough for a
        priest and one or two others. A simple stone altar stands against the
        east wall. This is where the dying receive Last Rites, where the
        desperately ill make their final prayers. The air is heavy with the
        memory of fear and hope. The infirmary lies to the north.",
    n_to Infirmary,
    cheap_scenery
      1 'eyes' [;
        print "His eyes are wide and dilated";
        if (f_identified_poison)
          "---a telltale sign of henbane poisoning";
        ".";
      ],
  has ;


Altar -> InfirmaryAltar "altar";                               ! >InfirmaryAltar


! PUZZLE: find the key for the restricted garden
! PUZZLE: identify the poison

Object -> -> BrAelredBody "Brother Aelred's body"                ! >BrAelredBody
  class AdjObject,
  with
    adj_name 'brother' 'aelred^s' 'earthly',
    noun_name 'body' 'corpse' 'remains' 'aelred',
    initial "On the altar is Brother Aelred's earthly remains.",
    description [;
      if (self hasnt moved) {
        QuoteBoxSimple(quote_body);
        give self moved;
      }
      print
        "Your beloved mentor lies still on the altar, still dressed,
        covered with a simple
        white shroud. His face is visibly peaceful now, though you remember
        his agony earlier. His eyes are still open---staring upward as if
        fixed on Heaven, his hands folded
        across his chest";
      if (self hasnt general)
        print
          ". Something seems odd about him, though you can't quite place it";
      else if (f_identified_poison)
        print
          ". Now you notice: even in death, his pupils remain enormously
          dilated---a telltale sign of henbane poisoning.";
      ".";
    ],
    react_before [;
      Smell:
        "There is an odd faint odor in the air.";
      Pray:
        "You whisper a small sad prayer to your dear mentor.
        You fervently hope he can hear you.";
    ],
    before [;
      Smell:
        if (self hasnt general) {
          give self general;
          "There's an odd smell about his remains---something like alcohol
          and urine in his mouth. Unusual.";
        }
        "That same odd smell lingers.";
      Kiss:
        "You reverently kiss him on the forehead---and then notice an odd
        odor about his remains.";
      Touch: "Already cold.";
      Attack, Cut, Burn: "Absolute blasphemy!";
      LookUnder:
        "Shifting the body slightly, you find nothing underneath.";
      Turn, Push, Pull:
        "You dare not disturb the dead---particularly
        not one who was so dear to you.";
      Take:
        "Moving him would be deeply inappropriate. Plus, he's much too heavy
        to carry.";
      Search:
        if (GardenGateKey hasnt moved) {
          move GardenGateKey to player;
          "In an inner pocket of his robe, you find ", (a) GardenGateKey, ",
          the key to the restricted garden.";
        }
    ],
    life [;
      Give:
        "He is beyond earthly needs.";
      WakeOther:
        "You've been studying Lazarus too much.";
      default:
        "While in life, he overflowed with joyful energy---alas, no more.";
    ],
  has animate;


Object -> -> Shroud "shroud"                                           ! >Shroud
  class AdjObject,
  with
    adj_name 'white',
    noun_name 'shroud',
    description "A simple and dignified white cloth.",
    before [;
      Examine: ;
      Search: "There is nothing underneath it but the body of your mentor.";
      default: "Leave the shroud be, Brother.";
    ],
  has ;


Statue -> RochStatue "statue"                                      ! >RochStatue
  with
    name 'roch',
    description
      "It depicts St Roch, patron saint of plague victims and the sick.
      He's depicted pointing to a plague sore on his leg."
  has ;


! ------------------------------------------------------------------- Herbarium

Room Herbarium "Herbarium"                                          ! >Herbarium
  with
    description
      "This room still carries Brother Aelred's presence in every corner.
      Bundles of dried herbs hang from the rafters.
      The worktable bears the marks of his careful hands: ink-labeled jars
      in his script, worn grooves where he ground countless remedies.
      A large terracotta pot in the corner was used often to transfer plants.
      Without him here, the room feels hollow.
      ^^The slype lies north, and the garden---his garden---waits
      to the south.",
    n_to Slype,
    s_to Garden,
    out_to Garden,
    each_turn [;
      #IfDef HAS_HINTS; HintReady(Hint_HangingHerbs); #EndIf;
      #IfDef HAS_HINTS; HintReady(Hint_Herbarium); #EndIf;
    ],
    cheap_scenery
      3 'thyme' 'rosemary' 'feverfew' [;
        Examine:
          "You can just see them to recognize them, but can't reach them.";
        default:
          "They're too far out of your reach to do anything with.";
      ]
      1 'grooves' "They're just grooves in the table."
   has
     ;


! PUZZLE: another way to get the restricted garden key

Object -> Pot "plant pot"                                                 ! >Pot
  class AdjObject,
  with
    adj_name 'large' 'terracotta' 'plant',
    noun_name 'pot',
    describe 0,
    description "A substantial pot, perfect for repotting a large plant.",
    before [;
      Turn, Pull, Push, LookUnder:
        if (GardenGateKey hasnt moved) {
          move GardenGateKey to player;
          "Underneath the pot, you find ", (a) GardenGateKey, ",
          the key to the restricted garden.";
        }
    ],
  has
    container open;


Object -> Jars "jars"                                                    ! >Jars
  with
    name 'jars',
    description
      "There are almost two dozen of the them, each carefully labeled.
      You know these well---mangaging these has become your daily labor
      for the past few months. You don't see anything missing or unusual
      about them.",
    before [;
      Take: "Leave them be. You have other tasks to do.";
    ],
  has concealed pluralname;


Object -> HerbTable "worktable"                                     ! >HerbTable
  class AdjObject,
  with
    adj_name 'work',
    noun_name 'worktable' 'table',
    describe 0,
    react_before [;
      Go:
        if (player in self) {
          if (selected_direction == d_to) <<Exit self>>;
          "You'd have to climb down from ", (the) self, " first.";
        };
    ],
    description [;
      print
        "A large, heavy table where you and Brother Aelred did your
        daily work";
      PrintContents(". On it ", self, ISARE_BIT);
      ".";
    ],
    find_basket [;
      if (Basket hasnt moved) {
        give Basket ~concealed;
        "Looking below the table, you find Brother Aelred's basket,
        which he used for gathering and carrying herbs.";
      }
    ],
    before [;
      Search, LookUnder:
        if (self.find_basket()) rtrue;
      Climb: <<Enter self>>;
    ],
    after [;
      Enter: "You climb up onto the worktable.";
      Exit: "You climb down from the worktable.";
    ],
  has
    static supporter enterable;


