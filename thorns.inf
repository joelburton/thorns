! ------------------------------------------------------------------ Kitchen

! general = been given fish
! on = has tried stairs

Room Kitchen "Kitchen"                                                ! >Kitchen
  with
    description
      "A large room, lit by high windows. A door leads north
      to the refectory, and stairs descend south to the undercroft below.
      ^^A large working table dominates the center, scattered with
      implements and vessels. A hearth is built into
      the east wall, its fire warming the room.",
    n_to Refectory,
    d_to [;
      give Kitchen on;  ! tried going down stairs
      if (BrMartin in location)
        "You wouldn't dare with Brother Martin here.";
      if (BrRemigio hasnt general)
        "Brother Remigio stops you, apologetically. ~No allowed~, he says,
        ~Frate Hugh, he not allow go to cellars.~";
      if ((~~IndirectlyContains(player, MyCandle)) &&
            (~~IndirectlyContains(player, TallowCandle))
            && TallowCandle hasnt moved) {
        move TallowCandle to player;
        print
          "Seeing you without a candle
          he produces a tallow one from his robe and gives
          it to you. ~La luce~.^";
      }
      if (TallowCandle hasnt light && MyCandle hasnt light) {
        print
          "You're heading down to the Undercroft without a light source.
          Are you sure you want to do this? ";
        if (~~YesOrNo()) "You think better of it.";
      }
      print "Brother Remigio looks away slyly as you head down the stairs.^^";
      return Undercroft;
    ],
    cheap_scenery
      'implements' 'various' "A collection of utensils, knives, and vessels."
      4 'utensils' 'knives' 'vessels' 'spices'
        "You needn't worry about these--Brother Martin is the Kitchener.",
    each_turn [;
      if (parent(BrMartin) == Kitchen) {
        if (BrMartin hasnt general && Fish hasnt moved) {
          move Fish to player;
          print
            "^Brother Martin twinkles ~Here to cadge a snack, eh, young novice?~
            He takes a piece of dried fish from the table and hands it to you.
            ~Now, go, go. Remigio and I have work to do.~";
        } else {
          print
            "Brother Martin says ^~Out, out, Brother Aldwin.
            Remigio and I are working.~";
        }
        print " He ushers you out.^^";
        PlayerTo(Refectory);
      }
    ],
  has
    ;


Object -> KitchenTable "table"                                   ! >KitchenTable
  with
    name 'working' 'table',
    description [;
      print
        "A long wooden table, big enough for two or three people to work at.
        It has a collection of utensils, knives,";
      if (Fish hasnt moved) print " a piece of dried fish,";
      print " and vessels of spices on it";
      PrintContents(". Also on it ", self, ISARE_BIT);
      ".";
    ],
  has supporter;


Object -> -> Fish "dried fish"                                           ! >Fish
  class AdjObject,
  with
    article "some",
    adj_name 'dried',
    noun_name 'fish' 'cod',
    description "Cod? You're a gardener, not a fisherman.",
    before [;
      Smell: "Briny, even from a distance.";
      Take:
        if (Fish hasnt moved) {
          if (parent(BrMartin) == Kitchen)
            "Brother Martin is right here. You can't just steal food.";
          if (BrRemigio hasnt general)
            "~Ladro, ladro---uh--thiefs!~ Brother Remigio cries,
            and stops you from taking the fish.";
        }
    ],
    after [;
      Eat: "Brother Martin always makes delicious food.";
      Take:
        if (Fish hasnt moved)
          "Brother Remigio slyly looks away while you take ", (the) Fish, ".";
    ]
  has
    concealed;


Object -> Hearth "hearth"                                              ! >Hearth
  with
    name 'hearth' 'fire',
    description "A stone block built into the wall, with a fire burning in it.",
    before [;
      Search: "Anything within this would certainly be burned to cinders.";
      Receive:
        remove noun;
        "You toss ", (the) noun, " into the hearth and it disappears into the
        fire.";
      Touch: "Ow, ow, ow.";
      Smell: "Burning wood and smoke.";
      Enter:
        deadflag = 1;
        "Visions of saints burning at the stake enter your head.";
    ]
  has static container open;


Object -> -> Cauldron "cauldron"                                     ! >Cauldron
  with
    name 'cauldron' 'pot' 'pottage',
    description
      "A large iron pot hanging over the fire, filled with pottage---a
      thick vegetable stew that will feed the brothers at their next meal.",
    before [;
      Touch: "Ow, ow, ow.";
      Taste, Eat: "It's not mealtime yet.";
      Search, LookUnder: "Just pottage bubbling away.";
      Take: "It's far too hot and heavy to move.";
      Receive:
        "This is food for you and your brothers. You shouldn't tamper with it.";
    ],
  has static;


! ================================================ Basement

class Barrel
  with
    name 'barrel' 'barrels//p',
    contents_name 0,
    describe 0,
    parse_name [ w1 w2 matches;
      w1 = NextWord();

      if (w1 == self.contents_name) {
        matches = 1;
        w2 = NextWord();
        if (w2 == 'barrel') return 2;
        return 1;
      }

      if (w1 == 'barrel' or 'barrels') {
        matches = 1;
        w2 = NextWord();
        if (w2 == 'of') {
          matches++;
          w2 = NextWord();
          if (w2 == self.contents_name) return 3;
        }
        else if (w2 == self.contents_name) return 2;
        return 1;
      }

      return 0;
    ],
    description [;
      print
        "A stout wooden barrel bearing the charcoal mark
        ~", (address) self.contents_name, "~";
      if (self has open)
        print ". It is currently open, revealing the expected contents";
      ".";
    ],    before [;
      Receive:
        if (noun == Hook) <<Search self>>;
        "You shouldn't add anything to the barrels.";
      Search:
        if (parent(Hook) ~= player)
          "The barrels are much too deep to search easily.";
        print "Searching ", (the) self,
            " will take several minutes. Are you sure? ";
        if (YesOrNo() == false) "You decide better of this.";
      Take: "The barrels are too heavy, and you've no need of the contents.";
      Empty, Pull, Push, Turn: "These are so heavy they're impossible to move.";
      Smell:
        if (self hasnt open) "With it closed, you can't detect any scent.";
      Taste:
        if (self hasnt open) "You cannot, since the barrel is closed.";
      Eat:
        if (self hasnt open) "You cannot, since the barrel is closed.";
        "You might taste it if you'd like, but not eat the whole thing.";
    ],
    after [;
      Open:
        "It takes several minutes to open the tightly-sealed barrel, but
        you succeed.";
      Close: "You pound on the lid to shut it.";
      Search:
        if (self hasnt open) "You cannot, since the barrel is closed.";
        the_time = the_time + 5;
        "Digging around with the hook for a few minutes, you find
        nothing unexpected.";
    ]
  has static container openable ~open;


Room Undercroft "Undercroft"                                       ! >Undercroft
  with
    description
      "The undercroft is Brother Hugh's domain. Barrels
      crowd the vaulted space beneath the refectory. Everything the
      priory needs to survive is here: tallow, salt, wine, mustard, grain.
      A wooden hook hangs on the wall, presumably for keeping rats at bay.
      The cellarer's careful hand is evident in the organization---each
      item labeled, stacked, accounted for.
      ^^As cellarer, Brother Hugh alone manages this space---organizing the
      stores, counting what remains, arranging what must be purchased. No
      other brother would have reason to come here uninvited.
      ^^Stairs lead up to the north.",
    u_to Kitchen,
    n_to Kitchen,
  has
    ~light;

Object -> Hook "hook"                                                    ! >Hook
  with
    name 'hook',
    describe 0,
    description
      "A wooden stick ending in a hook,
      useful for pulling things out of crowded corners.",
    react_before [;
      Go:
        if (parent(self) == player)
          "You need to leave ", (the) self, " here first.
          It's much too large and conspicuous to carry around.";
    ],
    before [;
      Insert:
        if (~~second ofclass Barrel) "It wouldn't fit in that.";
    ],
    has ;



Barrel -> GrainBarrel "grain barrel"                              ! >GrainBarrel
  with
    name 'grain',
    contents_name 'grain',
    description [;
      print
        "A stout wooden barrel bearing the charcoal mark ~GRAIN~";
      if (self has open)
        print ". It is currently open, revealing dried wheat kernels";
      ".";
    ],
    before [;
      Smell:
        if (self has open)
          "A faint, dusty grain smell.";
      Taste:
        if (self has open)
          "You take a kernel and chew it---hard and chalky, as expected.";
    ],
  has edible;


Barrel -> WineBarrel "wine barrel"                                ! >WineBarrel
  with
    name 'wine',
    contents_name 'wine',
