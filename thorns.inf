! This is a sprig of any kind of plant (not technically always an herb)

Class Herb                                                               ! >Herb
  with
    name 'sprig' 'sprigs//p',
    before [;
      Eat:
        if (self has toxic) {
          deadflag = 4;
          "Foolishly, you decide to eat ", (the) self, " failing to remember
          that it's toxic. You spend several days very sick. Any chance you
          had of solving Brother Aelred's murder passed.";
        }
        "You shouldn't eat the entire sprig. If you want to just see what it
        tastes like, say so.";
      Touch, Take:
        if (self has toxic && Gloves hasnt worn)
          "You dare not. It's toxic and irritating to the touch.";
    ],
  has edible concealed;


! Base class for all animated brothers (except player)
!
! Monks may only be in:
!   - Quire
!   - HighAltarArea
!   - Night Stairs
!   - Cloister any part (not Garth)
!   - PriorsSolar (just Oswald)
!   - Locutory (just Anselm [or maybe can wave others in?])
!   - Refectory (Martin, temporarily)
!   - Kitchen (Remigio and Martin)
!   - Slype (Benedict)
!   - Crypt & CryptVestry (just Cuthbert, while investigating noise)
!   - Chapter House
!   - Scriptorium (only Wilfred)
!   - Undercroft (only Hugh)
!
! In all of those places, need to check for illegal-if-monk-here

Class Monk                                                               ! >Monk
  with
    name 'brother',
    orders [;
      "You're just a novice, and in no position to order anyone around.";
    ],
    life [;
      Tell, Answer, Yes, Ask:
        print_ret
          (The) self, " presses a finger to his lips, reminding
          you of the rule of silence toward needless conversation.";
      Give:
        print_ret
          (The) self, " looks puzzled and refuses your gift with a gesture.";

      default: "BUG HOW DID YOU GET HERE?";
    ],
  has
    animate proper
    ! In real game, you can't carry these --- but for testing purposes,
    ! I often purloin a monk to move them where I want them --- and don't
    ! want that to trigger as contraband
    ok_carry
  ;


! Base class for plants; player can't take these, but can get a sprig of
! each of these, which is an Herb (defined above)

Class Plant                                                             ! >Plant
  with
    name 'plant',
    before [ p ;
      Eat:
        if (self has toxic) {
          deadflag = 4;
          "Foolishly, you decide to eat ", (the) self, " failing to remember
          that it's toxic. You spend several days very sick. Any chance you
          had of solving Brother Aelred's murder passed.";
        }
      Touch:
        if (self has toxic && Gloves hasnt worn)
          "You dare not. It's toxic and irritating to the touch.";
      Take:
        if (self has toxic && Gloves hasnt worn)
          "You dare not. It's toxic and irritating to the touch.";
        p = child(self);
        if (p == nothing)
          "You've already taken a sprig from ", (the) self, ".";
        move p to player;
        give p ~concealed;
        PronounNotice(p);
        "Rather than trying to take the entire plant, you take a sprig of it.";
    ],
  has
    ~edible;


! Very light, just here so it's easy to distinguish room vs object
! with a ofclass check.

Class Room                                                               ! >Room
  has light;  ! turn off in individual underground rooms


! Statues found in altars and in chapel house: Mary, St Jude, Gordian

Class Statue                                                           ! >Statue
  with
    name 'statue',
    before [;
      Take:
        "The statue has stood here for many years.";
      Push, Pull, Turn:
        print "With some effort, you ";
        switch (action) {
          ##Push: print "push";
          ##Pull: print "pull";
          ##Turn: print "rotate";
        }
        " the statue a bit, revealing nothing
        unexpected. Feeling guilty about the potential sacriliege
        of this action, you reset it as it was.";
    ],
    life [;
      Attack, ShoutAt: "Perish the very idea!";
      Give:
        "You cannot offer ", (ItorThem) self, " anything but your reverence.";
      Ask, Tell, Answer, Show: "The statue remains ever-silent.";
      WakeOther: "Save the miracles for others.";
      Kiss:
        "You reverently kiss the hem of ", (ItorThem) self, " stone robe.";
      Order:
        "If anything, a statue of a saint would order you around.";
    ],
  has
    static animate proper;


! Medicines in the infirmary

Class Tincture                                                       ! >Tincture
  with
    name 'tincture' 'tinctures//p',
    article "a bottle of",
    sniff [;
        print_ret "You breathe it in: ", (string) self.scent;
    ],
    lick [;
        print_ret "You dare a tiny taste: ", (string) self.flavor;
    ],
    before [;
      Eat, Drink: "You dare not.";
      Attack:
        "You shouldn't break this---such bottles are valuable
        and communal property.";
      Empty:
        "These tinctures are used by Brother Benedict in healing.
        It would be wrong to waste them.";
      Smell: self.sniff(); rtrue;
      Taste: self.lick(); rtrue;
    ],
  has
    ok_carry;


Class Tomb                                                               ! >Tomb
  class AdjObject,
  with
    adj_name 'brother' 'prior',
    noun_name 'tomb' 'tombs//p',
    description [;
      print_ret
        (The) self, " is a stone block with a lid on which his name is carved.
        It is otherwise like all of the others in the room.";
    ],
    react_before [;
      Jump:
        if (location == FitzAlanCrypt && parent(Player) ofclass Tomb)
          "You jump, hoping to reach the ladder, but it's too high up.";
      Go:
        if (parent(player) == self && selected_direction == d_to) <<Exit self>>;
    ],
    nope "Disturbing the Christian dead is mortal sin.",
    before [;
      Attack:
        self.nope(); rtrue;
      Push, Turn, Pull, LookUnder:
        self.nope();
        "^Besides, the tomb and the lid must
        weigh several hundredweight. It would take multiple men with levers
        to shift one.";
      Climb: <<Enter self>>;
      Open: "They sealed solidly with mortar.";
    ],
    after [;
      Enter:
        "While it feels deeply sacriligeous, you climb on ", (the) self, ".";
      Exit: "You climb down from ", (the) self, ".";
    ],
  has supporter enterable scenery proper;


! =================================================================== MONKS
! NAME       ROLE         AGE  GOES_TO              SERVICE
! Aelred     herbalist    63   slype                1
! Anselm     cantor       30   locutory             all
! Benedict   infirmarer   48   infirmary,charter    1
! Cuthbert   sacrist      46   bell tower           all
! Hugh       cellarer     32   undercroft           all
! Martin     kitchener    42   kitchen,charter      all
! Oswald     prior        52   solar                all
! Remigio    servant/lay  38   kitchen              1
! Wilfred    librarian    73   scriptorium          all
! Aldwin     novice       20                        1
!
! the PC, Aldwin, is not an instance of monk class.

[ MonkMonkToService monk loc ;
  switch(loc) {
      CloisterNW: return CloisterN;
      CloisterW: return CloisterNW;
      Locutory: return CloisterW;
      PriorsSolar: return CloisterNW;
      Scriptorium: return CloisterE;
      Infirmary: return Slype;
      Slype: return CloisterSE;
      Undercroft: return Kitchen;
      Kitchen: return Refectory;
      Refectory: return CloisterS;
      CloisterS: return CloisterSE;
      CloisterSE: return CloisterE;
      CloisterE: return CloisterNE;
      CloisterNE: return CloisterN;
      CloisterN: return Quire;
      Quire: return Stalls;
      Dorm:
        ! don't have all monks run from the dorm
        if ((monk ~= player) && random(3) ==1) rfalse;
        return NightStairs;
      NightStairs: return Quire;
      Stalls: rfalse;
      HighAltarArea: rfalse;
      Necessarium: return Dorter;
      Dorter: return Dorm;
      LayCells: return Dorm;
      BellTower: return TowerStairs;
      TowerStairs: return Nave;
      Nave: return Quire;
      AllMonkCots: return NightStairs;
  }
];

! TODO: fix offices so player can skip them OR if the meet a monk,
!   they have to join them?

! TODO: perhaps soap in the lav could be tool? opens hughs theft box?

! Aelred, either normal or dying (but not dead, that's separate object)
! general = dying

Monk BrAelred "Brother Aelred"                                       ! >BrAelred
  with
    name 'aelred' 'herbalist',
    description [;
      if (self has general)
        "Your beloved mentor. In normal moments, Brother Aelred's eyes
        twinkled with kindness, a smile framing against his broad face.
        Right now, though, he looks desperately ill.
        Sweat beads on his flushed face, and his pupils are enormously
        dilated, giving his eyes a black, glassy appearance.
        His limbs grab wildly at his habit, making it seem
        as though trying to remove something that isn't there.";
      "Your beloved mentor. Brother Aelred is in his sixties, tall and
      broad-shouldered, with gentle eyes that often crinkle with quiet
      amusement. In the five months you've studied under him, his kindness has
      been matched only by his knowledge of God's healing herbs.";
    ],
    possess 'aelred^s' 'aelreds',
    go_home [;
      if (self hasnt general && parent(self) ~= nothing) move self to slype;
    ],
    history_text
      "Aelred (1284-). Entered the priory 1295 as a youth. Served as
      Herbalist. Fluent in several languages beyond English and Latin.^^
      Written below this in fresh ink in Wilfred's scratchy hand, it
      reads: ~Requiescat in pace, carus frater~.",
    add_to_scope [;
      if (self has general) {
        PlaceInScope(BrAelredEyes);
        PlaceInScope(BrAelredHabit);
      }
    ],
    life [;
      if (self has general)
        "He just mumbles something incoherent in response.";
      Ask:
        if (second == BrHugh or BrRemigio or BrWilfred) {
          print "His eyes show brotherly concern. ";
          <<Tell BrAelred nothing>>;
        }
        if (current_service has on)
          "~Hush now, child. This is no time for talking. I'll see you
          after office in the gardens.~";
        if (second == player)
          "~Son, you must learn about yourself yourself.~ He smiles.";
        if (second == self)
          "He chuckles gently. ~An old herbalist who talks to plants.~";
        "~Hush now, child. This is no time for talking. I'll see you
        after office in the gardens.~";
      Tell, Answer:
        "~Hush now, child. This is no time for talking. I'll see you
        after office in the gardens.~";
    ],
    before [;
      Smell:
        if (self has general)
          "There's something oddly distinctive about his breath:
          acrid and stale, reminding you of old chamber pots.";
    ],
  has
    animate;


Object -> BrAelredEyes "eyes"                                    ! >BrAelredEyes
  class AdjObject
  with
    article "his",
    adj_name 'aelred' 'aelred^s' 'brother',
    noun_name 'eyes',
    description "His pupils are unnaturally dilated and black.",
    before [;
      Close: "Leave such matters to Brother Benedict.";
    ],
  has ;


Object -> BrAelredHabit "habit"
  class AdjObject
  with
    article "his",
    adj_name 'alered' 'aelred^s' 'brother',
    noun_name 'habit',
    description
      "You see nothing on it or unusual about it. He seems to be in some sort
      of delirious state.",
    has ;


Monk BrAnselm "Brother Anselm"                                       ! >BrAnselm
  with
    name 'anselm' 'cantor',
    description
      "Brother Anselm, the Cantor, is barely thirty---young for his office.
      He joined the priory at a young age and was put under the tutelage of
      Brother Wilfred for many years.
      He has a clear, strong voice and an easy smile. Unlike many of the
      other brothers, he seems to enjoy conversation when the Rule permits it.",
    possess 'anselm^s' 'anselms',
    go_home [;
      move self to Locutory;
    ],
    orders [;
      "~Brother Aldwin, you forget yourself. You're just a novice.~";
    ],
    life [;
      Give:
        "~Oh, thank you, but I've no need for that.~";
      Answer:
        "~But I didn't ask you a question.~";
      Ask:
        switch(second) {
          BrAelred:
            "~He was so kind.~ Anselm's voice catches.
            ~We're all going to miss him terribly.~";
          BrAldwin:
            "He laughs happily. ~You? You're, well, you. I think you're
            doing very well here.~";
          BrAnselm:
            "He looks puzzled. ~You mean me?~";
          BrBenedict:
            "~He's so helpful. When I had quinsy last year, he took excellent
            care of me.~";
          BrCuthbert:
            "~He's very strict. He's so serious about the rule of silence
            that I've never really talked to him.~";
          BrHugh:
            "~Brother Hugh used to be so joyful when I arrived. I fear something
            has been on his mind for months.~";
          BrMartin:
            "~He's so busy in the kitchen that I almost never get to talk
            with him.~";
          BrOswald:
            "~He's extremely capable---but I never get a chance to talk
            with him.~";
          BrRemigio:
            "~Oh, our poor foreign lay brother. He seems a bit like a lost soul.
            It must be very lonely for him
            here, especially given how little English he has.~";
          BrWilfred:
            "~He is such an excellent illuminator and has such a sharp mind.~";
          TombGordian:
            "~He founded the priory, you know? I've only seen a few of his
            brass devices, but they were all very clever.";
          Pax:
            Pax.meet();
            "Oh, her? Her name is Pax. She's very friendly. Brother Wilfred
            seems especially fond of her.";
          default:
            "Anselm seems much more interested in talking about people
            than things or ideas.";
        }
    ],
    history_text
      "Anselm (1316-). Entered 1332. Studied under Brother Wilfred as a
      youth. Appointed Cantor 1344 despite his youth, owing to the
      exceptional clarity of his voice. Leads the brothers in the
      Divine Office."
  has
    ;


! general = already responded about aelred

Monk BrBenedict "Brother Benedict"                                 ! >BrBenedict
  with
    name 'benedict' 'infirmarer',
    description
      "Brother Benedict, the Infirmarer, is a heavyset man in his forties
      with gentle hands and a warmer smile than his bulk might suggest.
      He moves with the careful efficiency of one who tends the suffering
      daily.",
    possess 'benedict^s' 'benedicts',
    go_home [;
      ! will leave infirmary when PC enters & go to chapter house
      move self to Infirmary;
    ],
    life [;
      Ask:
        if (location ~= Infirmary) rfalse;
        switch(second) {
          BrAelredBody:
            if (self hasnt general) {
              give self general;
              "~Our dear Brother is in the chapel,~ he gestures south,
              ~and you may seek him there.~";
            }
            "He only gestures south to the chapel.";
          InfirmaryCabinet:
            "~The medicines are kept secure here.~";
          Mirror:
            "~Ah, the mirror serves medicine, not pride. I can check if pupils
            respond to light, examine the tongue and throat, see if jaundice
            yellows the eyes. Observation is half of healing.~";
        }
      Tell:
        consult_words = second;
        wn = consult_from;
        if (NextWordStopped() == 'body' or 'corpse' or 'poison' or 'aelred')
          "~I examined Brother Aelred carefully before preparing his body.
            His heart stopped---he was an old man, and such is God's will.
            We will lay him to rest tomorrow with proper honor.~";
          "Brother Benedict nods kindly but gestures toward his work.
          ~Forgive me, Brother, but I have much to attend to.~";
      default:
        "Brother Benedict looks at you kindly, but raises his finger to his
        lips. ~This is neither the time nor place for speech.~";
    ],
    history_text
      "Benedict (1298-). Entered 1318. Served as Infirmarer from 1328.
      Treats both brothers and villagers who seek healing. Known for his
      patience with the dying.",
  has
    ;


Monk BrCuthbert "Brother Cuthbert"                                 ! >BrCuthbert
  with
    name 'cuthbert' 'sacrist',
    description
      "Brother Cuthbert, the Sacrist, is in his late forties. Dark-haired
      and sharp-featured, he keeps the sacred vessels spotless and the
      canonical hours precise. He rarely smiles.",
    possess 'cuthbert^s' 'cuthberts',
    go_home [;
      move self to BellTower;
    ],
    history_text
      "Cuthbert (1300-). Entered 1315, son of a nobleman from the south.
      Appointed Sacrist 1325. Maintains
      the sacred vessels and vestments with meticulous care. Keeps the
      canonical hours by ringing the great bell.",
  has
  ;


Monk BrHugh "Brother Hugh"                                             ! >BrHugh
  with
    name 'hugh' 'cellarer',
    description
      "Brother Hugh, the Cellarer, is lean and blond, barely thirty but
      already worry-worn. He manages the priory's worldly goods—trade,
      stores, accounts—and the weight of it shows in his troubled expression.",
    possess 'hugh^s' 'hughs',
    history_text
      "Hugh (1314-). Brought to the priory 1322 as a child of eight, his
      family unable to feed him after failed harvests. Raised and educated
      by the brothers. Appointed Cellarer 1342. Manages stores and trade
      with exceptional diligence. Has a widowed sister in the village of Holt
      who visited once.",
    go_home [;
      move self to Undercroft;
    ],
  has
  ;


! Martin is in the kitchen, but goes to the chapter house whenever PC visits

! general = gsve player fish

Monk BrMartin "Brother Martin"                                       ! >BrMartin
  with
    name 'martin' 'kitchener',
    description
      "Brother Martin, the Kitchener, is short, round, and quick to laugh---
      unusual in this somber place. He and Brother Remigio, the lay monk,
      produce the simple meals that sustain the community.",
    possess 'martin^s' 'martins',
    go_home [;
      move self to Kitchen;
    ],
    history_text
      "Martin (1304-). Entered 1322. Appointed Kitchener 1334. Oversees
      the preparation of meals for the community, assisted by Brother
      Remigio.",
  has
  ;


Monk BrOswald "Brother Oswald"                                       ! >BrOswald
  with
    name 'oswald' 'prior',
    description
      "Brother Oswald, the Prior. Lean and grey-haired, in his early fifties,
      he governs the priory with stern discipline. You've learned to measure
      your words and deeds carefully in his presence.",
    go_home [;
      move self to PriorsSolar;
    ],
    history_text
      "Oswald (1294-). Entered 1312 from a minor noble family. Elected
      Prior 1338 upon the death of Brother Wilfred's predecessor. Governs
      with strict adherence to the Rule of St. Benedict.",
  ;


! Outside of first service, is always in the kitchen and never leaves.
!
! PUZZLE: will allow player access to undercroft & will give a candle
!   once bribed with the basil
!
! general = bribed with basil

Monk BrRemigio "Brother Remigio"                                    ! >BrRemigio
  with
    name 'remigio',
    description
      "Brother Remigio is a lay brother from Tuscany---not fully professed,
      but devoted to the work. He's in his late thirties, with sharp features
      and expressive hands. His English is poor, and he often lapses into
      his native Tuscan tongue.",
    possess 'remigio^s' 'remigios',
    go_home [;
      move self to Kitchen;
    ],
    describe [;
      if (BrAelred has general) {
        if (location ~= Slype)
          "^Brother Remigio is here, urging you toward the slype.";
        "^Brother Remigio is here, looking stricken at what he's seeing.";
      }
    ],
    life [;
      if (location == Slype)
        "Remigio looks too stunned to respond to anything.";
      if (BrAelred has general) {
        switch (random(3)) {
          1:
            "Brother Remigio speaks frantically: ~La urgenza---uh,
            fastly~ and points toward the slype.";
          2:
            "Brother Remigio just tugs at his hair in frustration.";
          3:
            "Looking frustrated, Remigio mutters something in his native
            tongue.";
        }
      }
      Tell:
        if (BrMartin in Kitchen)
          "Brother Martin cuts you off with a gesture to his lips.
          ~No idle chatter, Brother.~";
        "Brother Remigio listens politely, but doesn't understand you.";
      Ask:
        if (BrMartin in Kitchen) {
          "Brother Remigio looks down, uncomfortable answering anything
          with Brother Martin here.";
        }
        switch (second) {
          BrHugh:
            "~Frate Hugh? Good man. He work hard down there, always busy
            with...~ he gestures vaguely at the floor, ~...stores, si?~";
          BrMartin:
            "~Ah, Frate Martin! He is...~ Remigio searches for words.
            ~Very good man. Kind. We work, uh, insieme---together---in cucina,
            the kitchen. He teach me English.~ He smiles warmly.
            ~He no here now. At church.~";
          BrAelred:
            "~Such sad thing.~ He looks despondent.";
          BrBenedict:
            "~Such good eater, si? I like him.~";
          BrAnselm:
            "~Cosi bravo cantante!~ He gestures expressively. ~Uh, so good
            singer. When he sing, I feel...~ he touches his chest, ~...home.~";
          BrCuthbert:
            "~Frate Cuthbert ring the bells. Very loud!~ He rubs his ears
            with a smile. ~But is good. Prayer good.~";
          BrOswald:
            "~Frate Oswald, uh, has many rules, but he kind to me.~";
          BrWilfred:
            "~So wise and kind. I see him playing with bella gatta.~";
          BrAldwin:
            "~You? You are...~ he grins. ~Come si dice? Tadpole. Small,
            new. But you grow, si?~";
          Pax:
            "~Ah, la gatta! Frate Wilfred, he love her much.
            She good mouser. Always hungry.~";
          default: "Brother Remigio listens with a puzzled expression.";
        }
      Give:
        if (noun == Basil) {
          Achieved(TASK_BRIBE_WITH_BASIL);
          move Basil to self;
          give self general;
          print
            "Remigio's weathered face transforms. ~Basilico!~ he exclaims,
            taking the herb and breathing deeply. ~I not smell
            since Toscana.~ His eyes glisten. ~Brother Aelred grew?
            He was brav'uomo, a good man.~";
          if (Kitchen has on) { ! tried going down stairs
            print
              "^^He gestures toward the stairs,
              his voice thick. ~Grazie mille, uh, thanks you.
              Go. I not see you";
            if (parent(MyCandle) ~= player) {
              move TallowCandle to player;
              print ". He produces a tallow candle from his robe and gives
              it to you. ~La luce";
            }
            ".~";
          }
          "^^He clasps your hand warmly. ~Grazie mille, uh, thanks to you.
          You need to do something, Remigio let you. Yes?~";
        }
    ],
    history_text
      "Remigio (c.1308-). A lay brother from Tuscany, came to the priory
      1340 seeking refuge from troubles in his homeland. Works in the
      kitchen and performs manual labor. Has not taken full vows.",
  has
  ;

! TODO: give basil first, then try go down in kitchen -- he needs to nofice
! and give candle

Candle -> TallowCandle "tallow candle"                           ! >TallowCandle
  with
    adj_name 'tallow',
    description [;
      print "A poor quality candle made of tallow";
      if (self has light) print ". It is currently lit.";
      ".";
    ],
  has
    concealed;


! Always guards the library (he's excused from other services)
!
! PUZZLE: can put him to sleep with burning mandrake
!
! He'll have limited conversation w/PC in the library.

Monk BrWilfred "Brother Wilfred"                                    ! >BrWilfred
  with
    name 'wilfred' 'librarian',
    description
      "Brother Wilfred is the most venerated of the brethren, well
      over seventy. He's lean and wiry, with wisps of white hair shooting
      in all directions from his head. His fingers are stained with pigments,
      and his habit has bits of orange fluff or fur on it.",
    history_text
      "Wilfred (1273-). Entered 1290 from a scholarly family in Norwich.
      Elected Prior 1310, serving until 1338 when he stepped down due to
      age and failing sight. Now serves as Librarian and master illuminator,
      though his hands tremble with the years. The oldest brother in living
      memory, he has seen the priory through plague, famine, and decline.^^
      You note that this entry was written by Wilfred, but in his
      way, he tried to maintain a distant and truthful tone.",
    describe [;
      if (BrWilfred in Scriptorium) {
        print "^Brother Wilfred is seated at the table, close to the south wall";
        if (BrWilfred has general) print ", snoring heavily";
        if (parent(Pax) == self) print ". On his lap is Pax";
        ".";
      }
    ],
    possess 'wilfred^s' 'wilfreds',
    tired_count 0,  ! don't repeat messages
    lap_count 0,
    go_home [;
      move self to Scriptorium;
      move LibraryKey to ScriptoriumTable;
    ],
    each_turn [ chance ;
      if (parent(Pax) == self) {
        self.lap_count++;
        if (self.lap_count == 13) {
          remove Pax;
          give self ~general;
          if (location == Scriptorium)
            "^Pax leaps out of Brother Wilfred's lap, startling him fully
            awake.";
        }
      }
      if (parent(Pax) == player) {
        give self general; ! sleeping
        move Pax to self;
        self.lap_count = 0;
        "^Brother Wilfred perks up immediately as he sees you carrying ",
        (the) Pax, ". ~Pax~, he cries, ~are you making a new friend of our
        novice?~ ", (The) Pax, " hops out of your arms and sits on his lap.
        He snuggles her with such comfort that he drifts
        into a deep sleep.";
      }
      if (BrWilfred has general
          || Library has visited
          || deadflag
          || location ~= Scriptorium or ChapterHouse) rfalse;
      chance = random(10);
      if (location == Scriptorium && chance > 5) rfalse;
      else if (chance > 3) rfalse;
      self.tired_count++;
      switch (self.tired_count) {
        1: "^Brother Wilfred yawns sleepily.";
        2: "^The venerable Wilfred rubs his temples with tiredness.";
        3: "^Brother Wilfred yawns sleepily.";
        4: "^Brother Wilfred blinks his eyes heavily.";
        5: "^The venerable library stiles a yawn.";
        6: "^Brother Wilfred rubs his eyes.";
      }
    ],
    life [;
      WakeOther:
        if (self has general) {
          "You shake Brother Wilfred awake. ~Ah, young son, you'll have to
          pardon an old man his weakness.~ He blinks sleepily at you.";
        }
        "As you're about to shake Brother Wilfred, his eyes snap open.
        ~Dear child,~ he says, ~I was just resting my eyes.~";
      Ask:
        if (self has general) "Brother Wilfred is deep in sleep.";
        switch (second) {
          BrAelred:
            "~What a loss for our community. He would often bring me
            rosemary because he learned that was my mother's name.~";
          BrAnselm:
            "~Such a beautiful voice for one so young.~";
          BrAldwin:
            "~You? You're doing well, my child.~";
          BrBenedict:
            "~Brother Benedict makes me valerian tea to steady me.~
            He looks down at the small tremble in his hands.";
          BrCuthbert:
            "~Such a god-fearing man and so careful in his duties.~";
          BrHugh:
            "~A fine cellarer. In the past few months, he's helped me
            in the library.~";
          BrMartin:
            "~Brother Martin keeps us all well-fed, even in these lean times.
            A generous soul.~";
          BrOswald:
            "~He's done very well as prior. That was once my role, but---~
            He looks at you with tenderness. ~Age comes for us all, my son.~";
          BrRemigio:
            "~Brother Remigio? We speak little---his English, my Italian,
            neither sufficient.~ He chuckles. ~But we both love our little
            Pax, and that needs no words.~";
          BrWilfred:
            "~Me? I'm simply a child of God, like you, dear Aldwin.~";
          Pax:
            Pax.meet();
            "His eyes glisten a bit. ~Forgive an old Brother, but that cat
            has become very dear to me. I was the one who named her---'Pax',
            for the peace she brings to these old halls.~";
          default:
            "Brother Wilfred hushes you kindly. ~Never mind that.~";
        }
      Tell:
        if (self hasnt general)
          "Brother Wilfred listens sleepily without response.";
        "Brother Wilfred is deep in sleep.";
      default:
        if (self has general) {
          "Brother Wilfred is deep in sleep.";
        }
    ]
  has
  ;

Object BrAldwin "you"
	with
		name 'me' 'myself' 'self',
		short_name  [;
			if(caps_mode) { print "You"; rtrue; }
			print "yourself";
			rtrue;
		],
    description
      "You're a novice in your first year, younger than all of the professed
      monks. Your black habit marks you as Benedictine, though you haven't yet
      taken your final vows. Your head remains untonsured---that will come only
      if you complete your novitiate and join the community fully.",
		! before NULL,
		! after NULL,
		! life NULL,
		! each_turn NULL,
		! time_out NULL,
		! describe NULL,
		! add_to_scope 0,
		capacity MAX_CARRIED,
		! parse_name 0,
		! orders 0,
		! number 0,
    history_text
      "Aldwin (1326-). Joined us in 1346, coming from a servant family
      serving the Lord of Thornbury. Educated. Mother died young.
      Interested in gardening, so he's being mentored by Brother Aelred.",
	has concealed animate proper transparent;


! general: happy with you (you can pick up)

Object Pax "xxx"                                                          ! >Pax
  class AdjObject
  with
    article "an",
    adj_name 'orange',
    noun_name 'cat' 'pax',
    short_name "orange cat",
    meet [;
      give self proper;
      self.short_name = "Pax";
    ],
    description [;
      print "She is small and lean";
      if (self has general) print ", and purrs when she sees you";
      ".";
    ],
    orders [;
      print_ret "She only mews in response.";
    ],
    life [;
      Give:
        if (noun == Fish) {
          remove Fish;
          give self general;
          print_ret
            (The) self,
              " eats the fish hungrily then rubs against you, purring.";
        }
        if (noun has toxic) {
          "Surely you don't want to poison this innocent creature?";
        }
        "She turns up her nose at your offer.";
    ],
    before [;
      Attack:
        remove self;
        print_ret
          "She flees into the Garth at your movement toward her.";
      Kiss:
        if (self hasnt general)
          "Cats usually need to be bribed to let you near them.";
        print_ret
          "She allows a small head kiss.";
      Take:
        if (self hasnt general)
          "You dare not. She hisses as you start to try.";
        move self to player;
        "She allows you to pick her up.";
    ],
    after [;
      Drop:
        remove self;
        "She scampers away.";
    ],
    each_turn [;
      if (location == Scriptorium) rfalse;
      if (parent(self) == player) {
        if (location == Scriptorium or Garth
            || location ofclass Cloister) rfalse;
        "^", (The) self, " wriggles out of your arms and escapes.";
      }
      switch (random(12)) {
        1: "^", (The) self, " rubs against the cloister wall.";
        2: "^", (The) self, " twitches, sensing movement.";
        3: "^", (The) self, " chases after an insect.";
        4: "^", (The) self, " sits and licks her paw contentedly.";
      }
    ],
    history_text
      "In the margin, you find a note: ~Pax: She was first spotted in 1342.
      She's an excellent ratter and conversationalist.~",
  has
    female animate ok_carry;

! ======================================================== 2.0 CHURCH
! 2.0.1 Entrance
! 2.0.2 Nave
! 2.0.3 Tower
! 2.0.4 Quire
! 2.0.5 High Altar Area
! 2.0.6 Sacristy
! 2.0.7 FitzAlan chantry
! 2.0.8 Lady Chapel
! 2.0.9 St Jude Chapel


! --------------------------------------------------- 2.0.1 Entrance
! West Porch, door

Room WestPorch "West Porch"                                         ! >WestPorch
  class AdjObject,
  with
    adj_name 'west',
    noun_name  'porch' 'entrance',
    description
      "This covered entrance protects the west door from the
      winds that come across the sea to the east.
      Villagers used to gather here before services,
      but the number who do so have been declining for years.",
    e_to WestDoor,
    in_to WestDoor,
    cant_go
      "It is forbidden for you to leave the Priory grounds without permission
      of Brother Oswald.",
    cheap_scenery
      1 'villagers' "You certainly don't see any here now."
      1 'grounds' "The scraggly grounds extend in all directions."
  ;


! PUZZLE: one way to find the founding date is on the door

Object WestDoor "west door"                                          ! >WestDoor
  class AdjObject,
  with
    adj_name 'west',
    noun_name 'door' 'carving',
    found_in WestPorch Nave,
    door_dir (e_to) (w_to),
    when_closed "The great door is closed.",
    when_open [;
      print "The great door is open, revealing the ";
      if (location == WestPorch) "nave to the east."; "porch to the west.";
    ],
    description [;
      if (location == WestPorch && self hasnt open) {
        Achieved(TASK_LEARNED_FOUNDING_DATE);
        "Carved deeply into the door's face:^
        ^  NOSTRA DOMINA SPINARUM (~Our Lady of Thorns~)
        ^  FUNDATUM ANNO DOMINI MCLII^^
        Over two hundred years of wind and rain have worn the letters
        smooth.";
      }
      "A large and solid oaken door.";
    ],
    after [;
      Close:
        print "You close the west door";
        if (location == WestPorch) print ", revealing a carving on the face";
        ".";
    ],
  has
    static door openable ~open;

! --------------------------------------------------- 2.0.2 Nave
! Nave and rood screen and cross

Room Nave "Nave"                                                         ! >Nave
  with
    name 'nave',
    description
      "The public space, where villagers stand for Mass.
      The stone floor is worn smooth by centuries of feet.
      Detailed stained glass admits pale light.
      The quire lies to the east, separated by a screen.
      A doorway in the north wall leads to the bell tower stairs.",
    e_to Quire,
    w_to WestDoor,
    out_to WestDoor,
    u_to TowerStairs,
    n_to TowerStairs,
    cheap_scenery
      'outside' 'porch' "The porch is to the west, beyond the door."
      1 'quire' "You should go east to see it better."
      1 'windows' "They're too high up to look out, but dim light comes in.",
  has ;


! PUZZLE: this will reveal one of the Gordian's themes for the solar door

Object StainedGlass "stained glass"                              ! >StainedGlass
  with
    name 'stained' 'glass',
    description
      "You remember the first time you saw this glass, on the second day of
      your membership. Unlike some other things in the priory that show sign
      of decay, these still shine brightly on sunny days. The center pane,
      the largest, has a golden hammer labeled ~II: LABOR OMNIA VINCIT~
      (~Work Conquers All~), a reminder of the mission of Monks.",
  has
    scenery;


Object RoodScreen "rood screen"                                    ! >RoodScreen
  with
    name 'rood' 'screen',
    found_in Nave Quire,
    description
      "A wooden rood screen separates the nave from the quire, dividing the
      public space from the sacred. A simple carved cross tops the
      screen---the ~rood~ that gives it its name. The wood is dark with
      centuries of candle smoke.",
    before [;
      Climb, Enter: "It's far too narrow to climb on.";
    ]
  has
    transparent  ! so can see cross "contained" in it
    scenery;


Object -> RoodCross "rood cross"                                    ! >RoodCross
  class AdjObject,
  with
    adj_name 'rood',
    noun_name 'cross',
    description "Simply carved and without ornamentation.",
  has
    static;


!---------------------------------------------------- 2.0.3 Tower
! Tower stairs, tower, bell, and views


Room TowerStairs "Tower Stairs"                                   ! >TowerStairs
  with
    name 'stone' 'steps' 'stairs',
    description
      "A narrow spiral staircase winds upward. The stone steps
      are worn smooth and treacherously steep.
      Cold air and dim light flows down from above.",
    d_to Nave,
    s_to Nave,
    u_to BellTower,
  has ;


Room BellTower "Bell Tower"                                         ! >BellTower
  with
    description
      "The bell chamber. Wind whistles through the open arches on
      all four sides. The great bell hangs overhead.
      A rope from it hangs to within your reach.
      From here, you have clear views in all four directions.",
    d_to TowerStairs,
    before [;
      Examine:
        switch (selected_direction) {
          n_to:
            "To the north, you can see rough coast and cliffs,
            dotted with small farms.";
          s_to:
            "South of here, you see the cloister surrounding the garth,
            the priory's roofs, and the herb garden.
            How you've learned to love that garden.";
          w_to:
            "West lies the path to the village nestled down in the vale.
            You can also see a small path from the west door to the gate for the
            priory.";
          e_to:
            "East, you can see the infirmary and its chapel near the cliffs,
            and the dorter's small window breaking the upper story wall.";
          u_to:
            "The great bell hangs above you, dark against the sky. ";
          d_to:
            "You see the stone floor of the bell tower, and through the
            opening, the stairs descending.^^
            If you want to to look in a particular direction, do so.";
        }
    ],
  has ;


Object -> Bell "bell"                                                    ! >Bell
  class AdjObject,
  with
    adj_name 'great' 'bronze',
    noun_name 'bell',
    description
      "A bronze bell, green with age. Cast nearly two centuries ago,
      you recall Brother Cuthbert once telling you it bears the
      inscription ~I: FIDES~---a reminder that our primary task is faith.",
    before [;
      Touch, Pull, Attack, Push:
        "The bell is far above you. You can only reach the rope.";
    ],
  has
    static scenery;


Object -> BellRope "bell rope"                                       ! >BellRope
  class AdjObject,
  with
    adj_name 'bell',
    noun_name 'rope' 'cord',
    describe 0,
    description
      "The cord reaches up to the bell, far above.
      Ringing the bell yourself would earn severe punishment.
      That duty does not belong to novices.",
    before [;
      Climb, Tie, Pull, Turn, Cut:
        if (BrCuthbert in location)
          "You dare not do that with Brother Cuthbert here.";
        StartTimer(self, 3);
        "Grabbing the cord causes the bell to toll, echoing across the priory.
        Instinctively you let go of the cord.";
    ],
    time_left,
    time_out [;
      if (location ~= BellTower or TowerStairs or Nave) {
        "You can hear footsteps in the nave, going up to the tower, and
        the returning. It seems very fortunate that you have avoided the
        wrath of Brother Cuthbert.";
      }
      deadflag = 3;
      print
        "^Brother Cuthbert finds you here, his face dark with anger.^^
        ~What madness is this? Ringing the bells without cause?
        The entire village will think we're under attack!~^^
        You are confined to your cell with bread and water for a fortnight.";
      KillOff();
    ],
  has
    static;

Object -> BellTowerChest "wooden chest"                        ! >BellTowerChest
  class AdjObject,
  with
    adj_name 'wooden' 'old' 'weathered',
    noun_name 'chest' 'box',
    description [;
      print
        "An old wooden chest, weathered by years of wind and rain blowing
        through the open tower. The lid bears a carved Latin inscription:
        ~VOCA POPULUM AD PRECES~";
      if (self has open)
        PrintContents(". The chest stands open, revealing ", self);
      ".";
    ],
    before [;
      Open:
        if (BrCuthbert in location)
          "You dare not do that with Brother Cuthbert here.";
      Push, Pull, LookUnder, Search:
        if (BrCuthbert in location)
          "You dare not do that with Brother Cuthbert here.";
        if (ScribbledLetter hasnt moved) {
          give ScribbledLetter moved;
          give ScribbledLetter ~concealed;
          "Moving the chest reveals a letter that was hidden under it.";
        }
        "Nothing else is found under it.";
    ],
  has
    container openable ~open static;

Object -> -> BellTools "bell-repairing tools"
  with
    article "some",
    name 'tools' 'oil' 'wedges' 'items',
    description
        "Some maintenance items:
        a small vial of oil and some wooden wedges. All the practical
        things needed to keep the great bell ringing true.",
    before [;
      Take:
        "Leave them be---you have no need of bell-making tools, and Brother
        Cuthbert will need these left here.";
    ],
  has pluralname;

Object -> ScribbledLetter "scribbled letter"                  ! >ScribbledLetter
  class AdjObject,
  with
    adj_name 'scribbled',
    noun_name 'letter' 'letters//p',
    description
      "It's just a folded scrap of paper, written in an educated hand. It reads:
      ~The manuscript was exquisite---the illumination work exceptional. Should
      another such work become available, I remain most interested. Leave word
      at our usual place.~ It is unsigned.",
    after [;
      Take: Achieved(TASK_EVIDENCE_LETTER);
    ]
  has
    concealed ok_carry;


!---------------------------------------------------- 2.0.4 Quire
! Quire, lectern, and stalls

[ QuireDescripDuringService;
  print
    "The quire is the center of the church. Two long stalls face each other";
  if (child(Stalls) ~= nothing) {
    PrintContents(". Already seated on them ", Stalls, ISARE_BIT);
    if (BrOswald in HighAltarArea)
      print ". Brother Oswald, the Prior, is at the altar";
  }
  ".";
];


! Object to manage logic of the first-service and other ones
!
! PUZZLE: need to perform first service
! PUZZLE: if wander through area during service, will get sucked into it

!     add_to_scope [;
