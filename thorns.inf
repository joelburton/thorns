[ PrintTaskName task_number;
  switch (task_number) {
    TASK_EVIDENCE_COINS: "found the sack of coins";
    TASK_EVIDENCE_PSALTER: "found the stolen psalter";
    TASK_EVIDENCE_HENBANE: "found henbane";
    TASK_EVIDENCE_LETTER: "found the scribbled letter";
    TASK_LEARNED_FOUNDING_DATE: "learned about the priory's history";
    TASK_CAN_HIDE_CONTRABAND: "found a way to hide things and carry them";
    TASK_SOLAR_DOOR: "got into the Prior's Solar";
    TASK_FA_CRYPT: "discovered the secret of the FitzAlan Chantry";
    TASK_FA_PANEL: "learned how to get behind the art panel";
    TASK_ESCAPE_CRYPT: "escaped the Crypt without being caught";
    TASK_BRIBE_WITH_BASIL: "bribed Remigio with the basil";
    TASK_GARDEN_KEY: "found the key to the Restricted Garden";
    TASK_PRIORS_NOTES: "read the Prior's notes";
    TASK_MATCH_SYMPTOMS: "matched the symptoms of the poison";
    TASK_LIBRARY: "got into the Library";
    TASK_REGISTRUM: "looked something up in the Registrum Fratrum";
    TASK_HERBAL: "looked something up in Aelred's Herbal";
    TASK_INFIRMARY_CABINET: "opened the Infirmary cabinet";
    TASK_SOURCE_LIGHT: "discovered a source of light";
    TASK_ROSE_LETTERS: "found the letters to Rose";
  }
];

