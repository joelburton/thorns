! PUZZLE: putting Wilfred to sleep to enter library

Object -> -> MandrakeRoot "mandrake root"                        ! >MandrakeRoot
  with
    name 'mandrake' 'root',
    description
      "A small pale, forked root twisted into a vaguely human shape.",
    herb_text
      "Mandrake: called the sleeping root. In small doses brings drowsiness
      and eases pain. A large root consumed or its smoke deeply breathed
      brings profound sleep---useful before surgery or for serious
      insomnia. Not dangerous to handle, but burn with great caution.",
    burn_time 0,
    daemon [;
      self.burn_time++;
      switch (self.burn_time) {
        1:
          move self to Fireplace;
          if (player in Scriptorium)
            "^An unpleasant, acrid stench starts to fill the room.
            To be cautious, you move to the north side of the room, far from
            the fireplace.";
        2:
          give BrWilfred general;
          if (player in Scriptorium) {
            print "^Brother Wilfred starts to snore.^";
            QuoteBoxSimple(quote_sleep);
          }
        3:
          if (player in Scriptorium) "^Brother Wilfred seems deeply asleep.";
        5:
          if (player in Scriptorium)
            "^The mandrake root has burned, and the air starts to clear.";
          remove self;
        12:
          if (player in Scriptorium)
            "^Brother Wilfred begins to stir.";
        13:
          give BrWilfred ~general;
          self.burn_time = 0;
          StopDaemon(self);
          if (player in Scriptorium)
            "^Brother Wilfred seems groggily awake now.";
      }
    ],
    before [;
      Burn:
        if (player in Scriptorium) { StartDaemon(self); rtrue; }
      Smell:
        "An unpleasant, earthy smell.";
      Taste:
        "You take a tiny nibble, and find it extremely unpleasant.";
      Eat:
        "You've already learned from Brother Aelred enough to know
        you shouldn't eat this.";
      Take, Touch: rfalse;   ! not toxic to handle
      ThrowAt:
        if (second == Fireplace) <<Insert MandrakeRoot Fireplace>>;
    ]
  has
    concealed toxic ok_carry;

! ------------------------------------------------------------- Refectory

! only meal would be after None (at 3pm)
Room Refectory "Refectory"                                          ! >Refectory
  with
    description
      "The refectory is a long, austere hall where the community takes its
        meals in silence while one brother reads aloud from the lectern. Two
        rows of trestle tables stretch the length of the room, their worn oak
        surfaces scrubbed clean. High windows along the eastern wall admit thin
        shafts of light that barely reach the stone floor. The smell of
        pottage lingers faintly in the air. A doorway to the
        south leads to the kitchen, and wide openings to the north return to
        the cloister.",
    e_to CloisterSE,
    n_to CloisterN,
    s_to Kitchen,
  ;


! make these all stone so they cant be moved
! also: player can only spend one turn here? they wouldn't be able to dawdle?

! TODO: maybe just cut the lunch scene? and remove this furniture as
!   not important?

Object -> RefectoryLectern "lectern"                         ! >RefectoryLectern
  has static;
Object -> RefectoryTableA "table"                             ! >RefectoryTableA
  has static;
Object -> RefectoryTableB "table"                             ! >RefectoryTableB
  has static;
