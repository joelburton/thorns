  with
    adj_name 'wooden',
    noun_name 'bench' 'benches//p',
    description
      "Simple wooden benches flanking the table.",
    after [;
      Enter: "You sit on one of the benches.";
      Exit: "You get up from your bench.";
    ],
  has
