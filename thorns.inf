Room LayCells "Lay cells"                                            ! >LayCells
  with
    description
      "XXX",
     n_to Dorter,
   has
     ;



! ================================================================= Game

Object MyRobe "robe"                                                   ! >MyRobe
  with
    article "your",
    name 'robe' 'habit',
    description
      "A simple black woolen cloth, marking you as a novice of this house.
      It doesn't have pockets, but a large hood hangs at your back.",
    before [;
      Disrobe: "You daren't. A monk must always be ready for office.";
    ],
  has clothing worn transparent ok_carry;


! slightly-kludgy, but added always to scope in InScope
!
! trying to add it as scope of the robe is problem because it would get
! reported in inventory or otherwise act weird.

Object MyHood "hood"                                                   ! >MyHood
  class AdjObject,
  with
    adj_name 'robe' 'my',
    noun_name 'hood',
    description
      "A deep hood attached to your habit, large enough to pull over your
      head in foul weather.",
    before [;
      Receive:
        if (noun has light)
          "Placing a lit item in your hood would surely catch it on fire.";
    ],
    after [;
      Receive:
        print "You put ", (the) noun, " into the hood";
        if (self hasnt general)
          print
            "---and notice how when the hood is hanging behind you it prevents
            others from seeing things in it";
        give self general;
        ".";
    ]
  has container open worn;


