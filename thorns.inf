      "A thin volume, but very handy: it lists many herbs and other plants,
      along with descriptions of them and their uses.",
    before [ end i last_word ;
      Examine:
        if (verb_word == 'read')
          "It's much too dense to read the entire thing. You can consult it
          by looking up a plant by name.";
      Consult:
        if (second == nothing || ~~(second provides herb_text)) {
          print "You find no entry for ~";
          if (second == nothing) {
            last_word = consult_from + consult_words - 1;
            end = WordAddress(last_word) + WordLength(last_word);
            for (i = WordAddress(consult_from) : i < end : i++)
              print (char) i->0;
          }
        else {
          print (name) second;
        }
        "~ in ", (the) self, ".";
        }
        print_ret (string) second.herb_text;
