! --------------------------------------------------------------------- Garden


Room Garden "Garden"                                                   ! >Garden
  with
    description
      "Aelred's garden. You can still see where his hands touched
      everything---the carefully weeded beds, the
      path worn by his daily rounds.
      ^^You enter the herbarium to the north. A gate west guards
      plants too dangerous for common use.",
    n_to Herbarium,
    w_to GardenGate,
    in_to Herbarium,
    time_here 0,
    each_turn [;
      self.time_here++;
      if (self.time_here == 3) {
        print
          "^Spending all of this time here reminds you of a conversation
          from spring, when Aelred was tending a corner of the garden.
          ~This one's a challenge, my son,~ he said,
          gesturing at a new";
        if (BasilPlant has general || Basil has moved)
          print " basil"; else print ", small";
        " plant. ~It wants warmth and sun we can barely
        give it here. But there's a brother---he came to us from sunnier lands,
        seeking refuge. He never complains, but I see the homesickness in his
        eyes.~ Aelred touched the leaves gently. ~If I can coax this to grow,
        it will remind him of home. A small kindness, perhaps, but sometimes
        those matter most.~ You will miss Aelred so much.";
      }
    ],
    before [;
      Dig:
        "You dare not dig or plant in his garden. Not today.";
    ],
    cheap_scenery
      1 'path' "It's just the path around the beds.",
  has
    ;


Object -> Beds "beds"                                                    ! >Beds
  with
    name 'beds' 'bed',
    description
      "Neat rows of raised beds, carefully tended and weeded. Woody
      rosemary grows tall in one corner, its leaves green
      against the autumn sky. Low-growing thyme spreads in silvery-green
      mats, while feverfew's white daisy-flowers still bloom despite the
      season. In the most sheltered spot, tender basil leaves catch what
      little sun reaches this northern garden---a small miracle that Aelred
      coaxed it to survive this long.",
    before [;
      Receive:
        "Soon, it will be your daily labor to plant things
        here---but not today.";
    ]
  has
    pluralname scenery container open;


Plant -> -> RosemaryPlant "rosemary plant"                      ! >RosemaryPlant
  with
    name 'rosemary',
    description
      "Several feet tall and woody-stemmed, with needle-like leaves of
      deep green.",
    before [;
      Smell: <<Smell Rosemary>>;
      Taste: <<Taste Rosemary>>;
    ],
  ;


Herb -> -> -> Rosemary "rosemary sprig"                              ! >Rosemary
  with
    name 'rosemary',
    description "A stalk of needle-like leaves.",
    herb_text
      "Rosemary: one of God's most beneficial gifts, useful for the
      digestion and for nerves. Can be made into a tincture or served
      as a tea.",
    before [;
      Smell: "It smells of pine sap and wood.";
      Taste:
        "You try a few needles: it tastes strongly of pine and wood.";
    ]
  ;


Plant -> -> ThymePlant "thyme plant"                               ! >ThymePlant
  with
    name 'thyme',
    description
      "A low, creeping plant with tiny gray-green leaves forming dense
      mats. Even brushing against it releases its scent.",
    before [;
      Smell: <<Smell Thyme>>;
      Taste: <<Taste Thyme>>;
    ],
  has
  ;


Herb -> -> -> Thyme "thyme sprig"                                       ! >Thyme
  with
    name 'thyme',
    description
      "A miniature forest in a sprig, with many tiny leaves shooting off in
      different directions.",
    before [;
      Smell: "Strongly earthy with a note of mint.";
      Taste: "You try a few leaves. It's warm and earthy.";
    ],
    herb_text
      "Thyme: powerful for cleaning the blood and warding off the
      plague. Can be made into a tincture or served in a tea.",
  ;


Plant -> -> FeverfewPlant "feverfew plant"                      ! >FeverfewPlant
  with
    name 'feverfew',
    description
      "A bushy plant about two feet tall, covered with small white
      flowers like tiny daisies. The leaves are deeply divided and
      yellow-green.",
    before [;
      Smell: <<Smell Feverfew>>;
      Taste: <<Taste Feverfew>>;
    ],
  ;


Herb -> -> -> Feverfew "feverfew sprig"                              ! >Feverfew
  with
    name 'feverfew',
    description
      "A cluster of stems bearing small daisy-like flowers with white
      petals and yellow centers. The leaves are feathery and aromatic.",
    before [;
      Smell:
        "Strong and bitter, almost medicinal---like chamomile but sharper.";
      Taste:
        "You try a single leaf: intensely bitter, leaving your mouth
        tingling unpleasantly.";
    ],
    herb_text
      "Feverfew: a sovereign remedy for headaches and the agues that
      bring fever. Women take it for monthly afflictions. Chew the
      fresh leaves or make a tea, though the bitterness is formidable.
      Some claim it prevents the megrim when taken daily.",
  ;


! general = player has observed this; the flashback about basil use the right
!   name

Plant -> -> BasilPlant "basil plant"                               ! >BasilPlant
  with
    name 'basil',
