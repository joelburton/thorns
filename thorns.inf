! bell-ringer Cuthbert


Object -> TimeCandle "canonical hour candle"
  class AdjObject,
  with
    adj_name 'canonical' 'hour' 'time',
    noun_name 'candle',
    initial
      "A candle sits in a sconce built into the stone wall.",
    description [ hour ;
      hour = the_time / 60;
      print "A canonical hour candle is used by ", (The) BrCuthbert,
        " to tell the hours for offices. ";

      if (hour == 0)
        "This one is fresh, with all twenty-four marks visible
        from top to bottom.";
      if (hour == 23)
        "This one has burned nearly to the base, with only one mark remaining.";

      print "It has burned down past ", hour, " mark";
      if (hour ~= 1) print "s";
      print ", leaving ", 24 - hour, " mark";
      if (24 - hour ~= 1) print "s";
      " remaining below the flame.";
    ],
    before [;
      Burn: "It's already burning.";
      Pull: <<Take self>>;
      Push: "It's already firmly seated in the sconce.";
      Blow:
        "You'd best not extinguish the time candle---the whole community
        depends on it for keeping the hours.";
      Touch: "Ouch. Quite warm.";
      Smell: "There's an unpleasant aroma of tallow.";
      Squeeze: "Mostly firm, but softer as you get closer to the flame.";
      Take: print_ret
        (The) BrCuthbert, " would be very annoyed if this disappeared,
        and if you were suspected, you'd have heavy penance. You think better
        of this act.";
      Turn: "You turn the candle pointlessly in the sconce.";
    ]
  has
    scenery;

! ---------------------------------------------------- Neccessarium

Room Necessarium "Necessarium"
  with
    description
      "A narrow stone chamber extending from the dormitory. A wooden bench
      with several latrine holes runs along the east wall,
      each opening onto the dung pit far below.
      The smell is overpowering. Cold, foul air rises from the pit below.",
    w_to Dorm,
    before [;
      Smell, Taste: "You dare not.";
      Climb:
        if (selected_direction == d_to)
          "You wouldn't fit in a latrine hole, praise be.";
    ],
    cheap_scenery
      'dung' 'pit' "Happily, you can only barely make it out from up here.",
  has
    light;

Object -> Latrines "latrines"
  with
    name 'latrine' 'latrines' 'hole' 'holes',
    before [;
      Enter:
        "You're don't need to use the latrines just now.";
      Receive:
        if (noun has worn)
          "You'd best not discard what you're wearing.";
        if (noun == Candle or MonkGuide or MyHood) {
          print "Are you sure you want to dispose of ", (the) noun, "? ";
          if (YesOrNo() == false) "You reconsider.";
        }
        remove noun;
        "You drop ", (the) noun, " in ", (the) self,
        ", losing it in the filth far below.";
      Search:
        "Even if you could see anything far down in the pit,
        you wouldn't want to.";
    ],
  has
    pluralname scenery;

! ---------------------------------------------------- LayCells

Room LayCells "Lay cells"
  with
    description
      "XXX",
     n_to Dorter,
   has
     ;

! =============================================== Gamr

Object MyRobe "robe"
  with
    article "your",
    name 'robe' 'habit',
    description
      "A simple black woolen cloth, marking you as a novice of this house.
      It doesn't have pockets, but a large hood hangs at your back.",
    before [;
      Disrobe: "You daren't. A monk must always be ready for office.";
    ],
    add_to_scope MyHood,
  has clothing worn transparent;

Object MyHood "hood"
  with
    name 'hood',
    description
      "A deep hood attached to your habit, large enough to pull over your
      head in foul weather.",
    before [;
      ! XXX: this isn't right; i don't want to see hood in invetory or have
      ! "first taking the hood", etc
      Wear:
        if (noun == MyHood) {
          "You pull the hood over your head, covering much of your face.";
        }
    ],
  has clothing container open concealed;



! Constant DS_PRIORY_NAME = 1;

[ Initialise;

  ! #IfDef Debug;
  !   <ScriptOn>;
  ! #EndIf;
  ClearScreen();

  ! example of using a dynamic string
  ! string 1 "Our Lady of Thorns";
  ! print "^^Welcome to @(1)^";
  ! print "Welcome to @(DS_PRIORY_NAME)^";

  QuoteBoxSimple(quote_opening);
  SetTime(300, 2);
  lookmode = 2;  ! verbose mode by default

  move BrOswald to PriorsSolar;
  move BrCuthbert to Sacristy;
  move BrHugh to Undercroft;
  move BrBenedict to Infirmary;
  move BrWilfred to Library;
  move BrAnselm to Quire;
  move BrMartin to Kitchen;
  move BrAelred to HerbalistWorkroom;

  move BrRemigio to LayCells;

  move MyRobe to player;

  selfobj.description =
    "You're a novice in your first year, younger than all of the professed
    monks. Your black habit marks you as Benedictine, though you haven't yet
    taken your final vows. Your head remains untonsured---that will come only
    if you complete your novitiate and join the community fully.";

  print "Late Summer, 1346.
  The priory @(1) stands forlornly on the cliffs above Ashcombe,
  on the northeast coast of England, where
  wind and sea have worn the stones for two hundred years.^^

  You awake at 5 AM to the sound of the great bell, calling you to
  Lauds. You are lying in your cot, still bleary from sleep. You've already been
  to two offices this morning, the first at 2 AM. Like your brethren,
  you sleep in your habit, so you're already full dressed.
  You hoped that after five months here, you'd be better
  acclimated to the schedule.^^

  The other brothers rise from their cots.

  ^^^(If you're new to this game, type ~HELP~).^^";

  #IfDef HAS_HINTS; HintReady(Hint_intro); #EndIf;

  give Quire general;  ! service
  StartTimer(Dorm, 0);
  StartTimer(Quire, 7);
  ! Don't print the banner at start; print it after service
  return 2;
];

