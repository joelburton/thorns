    TASK_SOLAR_DOOR: "unlocked door to Prior's Solar";
    TASK_FA_CRYPT: "discovered secret of the lion";
    TASK_ESCAPE_CRYPT: "escaped the Crypt";
    TASK_LIBRARY: "got into the Library";
