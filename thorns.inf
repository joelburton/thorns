      print "
      ^ +------------------+-----------+
      ^        Slype       -           |
      ^ +--+-----  ----+---| Infirmary |
      ^    | Herbarium |   |           |
      ^ +--+----   ----+---+-----  ----+
      ^ |    |             |           |
      ^ | RG -   Garden    |  Chapel   |
      ^ |    |             |           |
      ^ +------------------+-----------+^";

    default: "There is no map for this area.";
