! ==================================================== Global Attrs/Props/Vars



Global suspicion_level = 0;
! 0 = before death
! 1 = after death
! 2 = identified poison
! 3 = find coins or shortage or letters

Global f_smelled_aelred = 0;
Global f_warned_contraband = 0;
Global f_identified_poison = 0;

! ============================================================= Hooks


[ DeathMessage;
  if (deadflag == 3) print "You have failed";
  if (deadflag == 4) print "You have fallen very ill";
];

[ NewRoom;
  ! In the garden and restricted garden, doing things with the plants
  ! will make for weird responses: EAT ROSEMARY tries to take the whole
  ! plant and we can't catch this with a before clause.
  !
  ! So only in those two rooms, we'll set no_implict_actions to true (else
  ! set to false) and it won't try stuff like "(first taking the ___)"
  no_implicit_actions = (location == Garden or RestrictedGarden);
  rfalse;
];

! Checks if player is carrying "contraband" (not ok_carry), either:
! - in the cloister
! - with a narc monk in the room (any but Remigio, Aelred, Wilfred)

[ CheckForContraband mir o caught_with ;
  mir = MonkInRoom();
  if (mir == BrRemigio or BrAelred or BrWilfred) mir = 0; ! not narcs
  ! safe to carry contraband if not observed
  if (mir==0 && ~~location ofclass Cloister) rfalse;

  ! check for contraband, first thing becomes 'caught_with':
  objectloop (o in player) {
    if (o hasnt ok_carry) {
      caught_with = o;
      break;
    }
  }

  if (caught_with == 0 && Basket in player && Basket has open) {
    objectloop (o in Basket) {
      if (o hasnt ok_carry) {
        caught_with = o;
        break;
      }
    }
  }

  ! no contraband, safe
  if (caught_with == 0) rfalse;

  if (random(3) > 1) f_warned_contraband++;

  if (mir == 0) {
    if (f_warned_contraband < 2)
      "^You should be more careful. If any brother saw you carrying ",
      (the) caught_with, " you'd face severe punishment.";
    if (f_warned_contraband == 2)
      "^Again: be careful. Carrying contraband around openly will get you in
      no end of trouble.";
  } else {
    if (f_warned_contraband < 1)
      "^Luckily, ", (the) mir, " didn't notice you openly carrying ",
      (the) caught_with, ". If he had, you'd have faced severe punishment.
      ^^You need to be more careful.";
  }

  if (mir == 0) {
    mir = BrCuthbert;
    print "^Brother Cuthbert enters and sees you. He";
  } else {
    print "^", (the) mir;
  }

  print
    " notices you openly carrying ", (the) caught_with,
    ". ~Brother Novice, why are you doing with that?
    That has nothing to do with your duties here.~^^
    For disobeying the rules of the priory, you are given penance of
    bread and water for a week.";
    KillOff();
];

[ TimePasses ;  ! Call when # turns goes up
  SetTime(the_time + 2);
  CheckForContraband();
];

[ InScope ;
  PlaceInScope(MyHood);
  ! So player can find sacristy door to open it
  if (real_location == Sacristy && location == thedark) {
    PlaceInScope(SacristyDoor);  ! so we can find door
    PlaceInScope(Sacristy);      ! so room actions, like smell, work
  }
  rfalse;
];

[ IsARoom p_obj;
  if (p_obj ofclass Room or Cloister) return 1;
  return 2;
];

Global g_been_in_dark = false;
Replace _UpdateDarkness;
! There doesn't appear to be a better way to do this; NewRoom is called for
! every room EXCEPT thedark.
[ _UpdateDarkness p_silent _ceil _old_darkness _darkness;
	if(location == thedark) _old_darkness = true;
	_ceil = ScopeCeiling(player);
	if(_LookForLightInObj(_ceil, _ceil) == false) _darkness = true;
	if(_darkness ~= _old_darkness) scope_modified = true;
	if(_darkness) {

    ! only change: quote on first darkness
    NowInDark();
    !--- end of changes

		if(_old_darkness == false && p_silent == false) PrintMsg(MSG_NOW_DARK);
		location = thedark;
	} else {
		location = real_location;
		if(_old_darkness && p_silent == false) {
			new_line;
			<Look>;
		}
	}
];



Include "puny.h";

! ================================================================ Verbs

[ ConsultScope o;
  switch (scope_stage) {
    1: rfalse;
    2:
      objectloop (o provides history_text) PlaceInScope(o);
      objectloop (o provides herb_text) PlaceInScope(o);
      rtrue;
  }
];

[ IsCandle ;
  return (noun ofclass Candle);
];

Extend 'climb' first
  * 'on' noun                             -> Climb
  * 'down'                                -> Exit
  * 'down' noun                           -> Exit;

Extend 'consult' first
	* noun 'about'/'on' scope=ConsultScope  -> Consult;

Verb 'extinguish'
  * noun=IsCandle                         -> SwitchOff;

Extend 'blow' first
  * 'out' noun=IsCandle                   -> SwitchOff;

Verb 'plant'
  * held                                  -> Dig
  *                                       -> Dig;

Extend 'dig'
  *                                       -> Dig;

Extend 'get' first
  * 'down'                                -> Exit;

Verb meta 'help'
  *                                       -> Help;

Extend 'jump'
  * 'on' noun                             -> Climb;

Verb 'kneel'
  * 'on' supporter                        -> Enter;

Extend 'look'
  * 'beneath' noun                        -> LookUnder
  * 'under' noun                          -> LookUnder;

Extend 'look' first
! * 'up' noun 'in' noun                   -> Consult reverse;
	* 'up' scope=ConsultScope 'in' noun     -> Consult reverse
  * 'up' topic 'in' noun                  -> Consult reverse
  * 'in' noun 'about' scope=ConsultScope  -> Consult;

Verb meta 'map'
  *                                       -> Map;

Extend 'read' first
	* 'about' scope=ConsultScope 'in' noun  -> Consult reverse
	* scope=ConsultScope 'in' noun          -> Consult reverse;

Verb 'ring' 'toll' 'peal'
  * noun                                  -> Pull;

Extend only 'sit' first
  *                                       -> SitAny;

Verb 'xyzzy' 'plug'
  *                                       -> Xyzzy;

! ========================================================= Verb Subs

[ HelpSub;
  print
    "^OUR LADY OF THORNS is written by Joel Burton <joel at joelburton.com>.

    ^^Unfamiliar with IF? See
    https://pr-if.org/doc/play-if-card/";

  #IfDef HAS_HINTS;
    print
      "^^There are hints in this game, but they'll appear only as you encounter
      those challenges (so even seeing the titles won't spoil anything.)
      You can see the available ones with the command ~HINT~.";
  #IfNot;
    print
      "^^You're playing the small-size version of this game intended for
      retro 8-bit computers. There is a separate game file with hints that will
      also run on your system.";
  #EndIf;

  "^^Playtesters and well-wishers: Melissa ~Moth~ Higuchi, Lois Burton.

  ^^Special thanks to: Fredrik Ramsberg, andrewj, curiousdannii, Garry Francis,
  and ~Pontus I~ for answering my questions on forums.";
];

[ LookUnderSub;
  if (ObjectIsUntouchable(noun)) return;
  "You find nothing unexpected.";
];

[ MapSub helpful;
  switch (location) {

    WestPorch, Nave, Quire, HighAltarArea, StJudeChapel, LadyChapel,
    FitzAlanChantry, Sacristy:
      font off;
      print "
        ^    to Tower  to Dorm   to Crypt
        ^   +---------------------------------+
        ^   |   @@64    .    @@64    .    @@64    Fitz |
        ^   |        .         .         -----|
        ^  -   Nave  .  Quire  .  Altar  Lady |
        ^   |        .         .         -----|
        ^   |        .         .         Jude |
        ^   +-------------|-------|-- --|-----+
        ^           to Cloister   | Sac |
        ^ @@64 = Stairs      |       +-----+^";

    CloisterE, CloisterN, CloisterNE, CloisterNW, CloisterS, CloisterSE,
    CloisterSW, CloisterW, Garth, PriorsSolar, Locutory,
    ChapterHouse, Lavatorium, Refectory:
      font off;
      print "
        ^            @@92 |
        ^  - NW = N = NE -
        ^    ||   |   ||
        ^  - W -Garth- E -
        ^    ||   |   ||
        ^  - SW = S = SE ----
        ^    |    |       |^";

    Dorm, Necessarium, Dorter, LayCells:
      font off;
      print "
      ^  +----------------+
      ^  | @@64              |
      ^  |     Dorm       |
      ^  |                |
      ^  |----   ---|-----+
      ^  | @@64 Dorter   Nec |  @@64: Stairs
      ^  |----   ---|-----+
      ^  |    Lay Dorm    |
      ^  +----------------+^";

    Slype, Infirmary, InfirmaryChapel, Herbarium, Garden:
      font off;
      print "
      ^ +----------------+-----------+
      ^       Slype      -           |
      ^ +-+-----  ----+--| Infirmary |
      ^   | Herbarium |  |           |
      ^ +-+----   ----+--+----- -----+
      ^ |                |           |
      ^ |     Garden     |  Chapel   |
      ^ |                |           |
      ^ +----------------+-----------+^";

    default: "There is no map for this area.";
  }
  font on;
  if (helpful) "^(You can see this map again by typing ~MAP~)^";
];

[ SitAnySub;
  if (location == Quire) <<Enter Stalls>>;
  if (location == Locutory) <<Enter LocutoryBenches>>;
  if (location == Refectory) <<Enter RefectoryBenches>>;
  "Where are you specifically trying to sit?";
];

[ XyzzySub; "You're in a monastery, not Colossal Cave."; ];


! ========================================== debugging grammar

#IfDef DEBUG;

  Verb meta 'settime'   * number number -> HourAdvance;
  Verb meta 'time'      *               -> Time;
  Verb meta 'suspicion' * number        -> SuspicionChange;
  Verb meta '_//'       *               -> SolveList;
  Verb meta '_cabinet'  *               -> SolveCabinet;
  Verb meta '_library'  *               -> SolveLibrary;
  Verb meta '_light'    *               -> SolveLight;
  Verb meta '_lion'     *               -> SolveLion;
  Verb meta '_office'   *               -> SolveOffice;
  Verb meta '_aelred'   *               -> SolveAelredDead;

  [ SuspicionChangeSub;
    suspicion_level = noun;
    "Suspicion Level set to ", suspicion_level, ".";
  ];

  [ HourAdvanceSub ; SetTime(noun * 60 + second); <<Time>>; ];
  [ ZeroPad n; if (n < 10) print "0"; print n; ];
  [ TimeSub ;
    "Sundial: ", (SundialTime) the_time, "^",
      "Clock: ", (ZeroPad) the_time / 60, ":", (ZeroPad) the_time % 60;
  ];

  [ SolveListSub;
     "_aelred _cabinet _library _light _lion _office";
  ];

  [ SolveAelredDeadSub;
      <SolveOffice>;
      give BrAelred ~animate;
      f_smelled_aelred = 1;
      PlayerTo(InfirmaryChapel);
      "^DEBUG: Aelred killed^";
  ];
  [ SolveCabinetSub;
    <SolveOffice>;
    give InfirmaryCabinet open ;
    PlayerTo(Infirmary);
    "^DEBUG: cabinet opened^";
  ];
  [ SolveLibrarySub;
    <SolveOffice>;
    give BrWilfred general;
    give LibraryDoor open;
    PlayerTo(Library);
  ];
  [ SolveLightSub;
    move MagicLightGem to player;
    "DEBUG: You have the magic gem.^";
  ];
  [ SolveLionSub;
    <SolveOffice>;
    PlayerTo(FitzAlanChantry);
    FitzAlanAltar.open_altar();
    "^DEBUG: Altar opened for you.^";
  ];
  [ SolveOfficeSub;
    Service.stop_service();
    "DEBUG: Service solved.^";
  ];

  Object MagicLightGem "gem"
    with name 'gem', description "Glows with debugging power.",
    has light;

#EndIf;


! ================================================================ Routines

[ IsCarryingLit obj;
    obj = child(player);
    while (obj ~= 0) {
        if (obj has light) return true;
        obj = sibling(obj);
    }
    return false;
];

[ NowInDark ;
  if (g_been_in_dark == false) {
    QuoteBoxSimple(quote_darkness);
    g_been_in_dark = true;
  }
];

Constant CLOCK_NIGHT 1;      !
Constant CLOCK_MORNING 2;
Constant CLOCK_AFTERNOON 3;
Constant CLOCK_EVENING 4;

[ RoughTime ;
  if (the_time >= 1320 || the_time <= 360) return CLOCK_NIGHT;  ! 10p-6a
  if (the_time <= 720) return CLOCK_MORNING;                    ! 6a-noon
  if (the_time <= 1080) return CLOCK_AFTERNOON;                 ! noon-6p
  return CLOCK_EVENING;                                         ! 6p-10p
];

! Recursively check if a non-PC monk is in an obj, yes=return monk
[ MonkInObj loc obj mir;
  objectloop (obj in loc) {
    if (obj ofclass Monk)
      return obj;
    mir = MonkInObj(obj);
    if (mir) return mir;
  }
  rfalse;
];

! Is a monk in this room? (searching recursively)
[ MonkInRoom loc ;
  if (loc == 0) loc = location;
  if (location == HighAltarArea or Quire) {
    return MonkInObj(HighAltarArea) || MonkInObj(Quire);
  }
  return MonkInObj(loc);
];

[ KillOff;
  deadflag = 3;
  " By the time your penance ends, any chance of solving any mystery
    has long passed.^";
];


! ================================================================== CLASSES
! Altar, Chest, Cot, Monk, Room, Statue



Class Altar                                                             ! >Altar
  class AdjObject,
  with
    article "an",
    short_name "altar",
    adj_name 'stone',
    noun_name 'altar',
    react_before [;
      Go:
        if (player in self) {
          if (selected_direction == d_to) <<Exit self>>;
          "You'd have to climb down from ", (the) self, " first.";
        };
    ],
    description [;
      print "A simple stone altar, worn smooth by centuries of prayer";
      PrintContents(". On it ", self, ISARE_BIT);
      ".";
    ],
    before [;
      Climb:
        if (MonkInRoom())
          "You dare not, especially with another brother in the area.";
        <<Enter self>>;
      Enter:
        if (MonkInRoom())
          "You dare not, especially with another brother in the area.";
    ],
    after [;
      Enter:
        "It feels deeply sacriligeous, but you climb onto the altar.";
      Exit:
        "You climb down from the altar.";
    ],
  has
    supporter enterable static;


! It's not hard to find the candle, but you can't take it until you've
! proved you need it by opening the passage to the FitzAlan Chantry or
! by visiting the kitchen to see the stairs to the Undercroft.

! TODO: should extinguishing the candle be a puzzle? can throw away
!  in latrines, well, or leave in a hidden area, like a crypt,
!  or douse in water in lav and nec (if we add a basin there)
!
! pro: decent puzzle
! con: can't one extinguish a candle with their fingers?

Class Candle                                                           ! >Candle
  class AdjObject,
  with
    noun_name 'candle',
    dont_need [;
      if (FitzAlanAltar hasnt moved && Kitchen hasnt visited)
        "There's no reason for this. The monastery is lit,
        except at late night,
        and carrying one about would only raise questions.";
    ],
    before [ helper ;
      Burn:
        ! > BURN CANDLE (in kitchen or nightstairs)
        ! > BURN CANDLE WITH HEARTH
        ! > BURN CANDLE WITH TIME CANDLE
        if (self has light) "It's already lit.";
        if (location == NightStairs) helper = TimeCandle;
        if (location == Kitchen) helper = Hearth;
        if ( (second == helper) || (second == nothing && helper) ) {
          give self light;
          "You light your candle using ", (the) helper, ".";
        }
        "You need something appropriate to light your candle.";
      Take:
        if (self.dont_need()) rtrue;
      SwitchOff:
        if (self hasnt light)
          "It isn't lit.";
        give self ~light;
        "You extinguish the candle.";
    ],
  has
    ~light;


! One for every monk; can only search them when suspicious.

Class Chest                                                             ! >Chest
  with
    parse_name [ w count ;
      w = NextWord();
      if (w == 'chest' or 'box') return 1;
      if (w == 'brother') {
        count++;
        w = NextWord();
      }
      if (w ~= self.amonk.&name-->0
        or self.amonk.&possess-->0
        or self.amonk.&possess-->1) return 0;
      w = Nextword();
      if (w ~= 'chest' or 'box') return 0;
      return count + 2;
    ],
    description [;
      print_ret
        (The) self,
        " is like all the others: a simple wooden box with a lid.";
    ],
    short_name [;
      print (The) self.amonk, "'s chest"; rtrue;
    ],
    before [;
      if (action ~= ##Examine && MonkInRoom())
        "You wouldn't dare with another brother in the room.";
      Examine: ;
      Take:
        "You couldn't carry that easily---and besides, how would ",
        (The) self.amonk, " store anything?";
      Push, Turn:
        "There's nothing underneath it, and it will just frustrate the
        brothers to move their chests around.";
      Open:
        if (suspicion_level == 0)
          "Searching another brother's property
          without reason just feels wrong.";
      default:
        if (suspicion_level == 0)
          "Doing anything with another brother's property
          without reason just feels wrong.";
    ],
  has
    proper container ~open openable scenery;



! One for every monk; can only search them when suspicious.

Class Cot                                                                 ! >Cot
  with
    parse_name [ w count ;
      w = NextWord();
      if (w == 'cot' or 'bed' or 'mattress') return 1;
      if (w == 'brother') {
        count++;
        NextWord();
      }
      if (w ~= self.amonk.&name-->0
        or self.amonk.&possess-->0
        or self.amonk.&possess-->1) return 0;
      w = Nextword();
      if (w ~= 'cot' or 'bed' or 'mattress') return 0;
      return count + 2;
    ],
    description [;
      print_ret
        (The) self,
        " is like all the others: a simple straw mattress.";
    ],
    short_name [;
      print (The) self.amonk, "'s cot"; rtrue;
    ],
    before [;
      if (action ~= ##Examine && MonkInRoom())
        "You wouldn't dare with another brother in the room.";

      Search, LookUnder:
        "A search of ", (the) self, " finds nothing.";
      Take:
        "You couldn't carry that easily---and besides, how would ",
        (The) self.amonk, " sleep?";
      Push, Turn:
        "There's nothing underneath it, and it will just frustrate the
        brothers to move their cots around.";
    ],
  has
    proper scenery supporter enterable;

! TODO: hugh: hide letters *under* chest


! This is a sprig of any kind of plant (not technically always an herb)

Class Herb                                                               ! >Herb
  with
    name 'sprig' 'sprigs//p',
    before [;
      Eat:
        if (self has toxic) {
          deadflag = 4;
          "Foolishly, you decide to eat ", (the) self, " failing to remember
          that it's toxic. You spend several days very sick. Any chance you
          had of solving Brother Aelred's murder passed.";
        }
        "You shouldn't eat the entire sprig. If you want to just see what it
        tastes like, say so.";
      Touch, Take:
        if (self has toxic && Gloves hasnt worn)
          "You dare not. It's toxic and irritating to the touch.";
    ],
  has edible concealed;


! Base class for all animated brothers (except player)
!
! Monks may only be in:
!   - Quire
!   - HighAltarArea
!   - Night Stairs
!   - Cloister any part (not Garth)
!   - PriorsSolar (just Oswald)
!   - Locutory (just Anselm [or maybe can wave others in?])
!   - Refectory (Martin, temporarily)
!   - Kitchen (Remigio and Martin)
!   - Slype (Benedict)
!   - Crypt & CryptVestry (just Cuthbert, while investigating noise)
!   - Chapter House
!   - Scriptorium (only Wilfred)
!   - Undercroft (only Hugh)
!
! In all of those places, need to check for illegal-if-monk-here

Class Monk                                                               ! >Monk
  with
    name 'brother',
    life [;
      Tell, Answer, Yes:
        print_ret (The) self, " isn't interested, most because he's
          NOT IMPLEMENTED YET.";
      default: "He apologizes. ~I'm NOT IMPLEMENTED YET.~";
    ],
  has
    animate proper
    ! In real game, you can't carry these --- but for testing purposes,
    ! I often purloin a monk to move them where I want them --- and don't
    ! want that to trigger as contraband
    ok_carry
  ;


! Base class for plants; player can't take these, but can get a sprig of
! each of these, which is an Herb (defined above)

Class Plant                                                             ! >Plant
  with
    name 'plant',
    before [ p ;
      Eat:
        if (self has toxic) {
          deadflag = 4;
          "Foolishly, you decide to eat ", (the) self, " failing to remember
          that it's toxic. You spend several days very sick. Any chance you
          had of solving Brother Aelred's murder passed.";
        }
      Touch:
        if (self has toxic && Gloves hasnt worn)
          "You dare not. It's toxic and irritating to the touch.";
      Take:
        if (self has toxic && Gloves hasnt worn)
          "You dare not. It's toxic and irritating to the touch.";
        p = child(self);
        if (p == nothing)
          "You've already taken a sprig from ", (the) self, ".";
        move p to player;
        give p ~concealed;
        PronounNotice(p);
        "Rather than trying to take the entire plant, you take a sprig of it.";
    ],
  has
    ~edible;


! Very light, just here so it's easy to distinguish room vs object
! with a ofclass check.

Class Room                                                               ! >Room
  has light;  ! turn off in individual underground rooms


! Statues found in altars and in chapel house: Mary, St Jude, Gordian

Class Statue                                                           ! >Statue
  with
    name 'statue',
    before [;
      Take:
        "The statue has stood here for many years.";
      Push, Pull, Turn:
        print "With some effort, you ";
        switch (action) {
          ##Push: print "push";
          ##Pull: print "pull";
          ##Turn: print "rotate";
        }
        " the statue a bit, revealing nothing
        unexpected. Feeling guilty about the potential sacriliege
        of this action, you reset it as it was.";
    ],
    life [;
      Attack, ShoutAt: "Perish the very idea!";
      Give:
        "You cannot offer ", (ItorThem) self, " anything but your reverence.";
      Ask, Tell, Answer, Show: "The statue remains ever-silent.";
      WakeOther: "Save the miracles for others.";
      Kiss:
        "You reverently kiss the hem of ", (ItorThem) self, " stone robe.";
      Order:
        "If anything, a statue of a saint would order you around.";
    ],
  has
    static animate proper;


! Medicines in the infirmary

Class Tincture                                                       ! >Tincture
  with
    name 'tincture' 'tinctures//p',
    article "a bottle of",
    sniff [;
        print_ret "You breathe it in: ", (string) self.scent;
    ],
    lick [;
        print_ret "You dare a tiny taste: ", (string) self.flavor;
    ],
    before [;
      Eat, Drink: "You dare not.";
      Attack:
        "You shouldn't break this---such bottles are valuable
        and communal property.";
      Empty:
        "These tinctures are used by Brother Benedict in healing.
        It would be wrong to waste them.";
      Smell: self.sniff(); rtrue;
      Taste: self.lick(); rtrue;
    ],
  has
    ok_carry;


Class Tomb                                                               ! >Tomb
  class AdjObject,
  with
    adj_name 'brother' 'prior',
    noun_name 'tomb' 'tombs//p',
    description [;
      print_ret
        (The) self, " is a stone block with a lid on which his name is carved.
        It is otherwise like all of the others in the room.";
    ],
    react_before [;
      Jump:
        if (location == FitzAlanCrypt && parent(Player) ofclass Tomb)
          "You jump, hoping to reach the ladder, but it's too high up.";
      Go:
        if (parent(player) == self && selected_direction == d_to) <<Exit self>>;
    ],
    nope "Disturbing the Christian dead is mortal sin.",
    before [;
      Attack:
        self.nope(); rtrue;
      Push, Turn, Pull, LookUnder:
        self.nope();
        "^Besides, the tomb and the lid must
        weigh several hundredweight. It would take multiple men with levers
        to shift one.";
      Climb: <<Enter self>>;
      Open: "They sealed solidly with mortar.";
    ],
    after [;
      Enter:
        "While it feels deeply sacriligeous, you climb on ", (the) self, ".";
      Exit: "You climb down from ", (the) self, ".";
    ],
  has supporter enterable scenery proper;


! =================================================================== MONKS
! NAME       ROLE         AGE  GOES_TO              SERVICE
! Aelred     herbalist    63   slype                1
! Anselm     cantor       30   locutory             all
! Benedict   infirmarer   48   infirmary,charter    1
! Cuthbert   sacrist      46   -                    all
! Hugh       cellarer     32   undercroft           all
! Martin     kitchener    42   kitchen,charter      all
! Oswald     prior        52   solar                all
! Remigio    servant/lay  38                        1
! Wilfred    librarian    73   scriptorium          all
! Aldwin     novice       20                        1
!
! the PC, Aldwin, is not an instance of monk class.


! Aelred, either normal or dying (but not dead, that's separate object)
! general = dying

Monk BrAelred "Brother Aelred"                                       ! >BrAelred
  with
    name 'aelred' 'herbalist',
    description [;
      if (self has general)
        "Your beloved mentor. In normal moments, Brother Aelred's eyes
        twinkled with kindness, a smile framing against his broad face.
        Right now, though, he looks desperately ill.
        Sweat beads on his flushed face, and his pupils are enormously
        dilated, giving his eyes a black, glassy appearance.
        His limbs are twitching in his habit, making it seem
        as though trying to remove something that isn't there.";
      "Your beloved mentor. Brother Aelred is in his sixties, tall and broad-
      shouldered, with gentle eyes that often crinkle with quiet amusement.
      In the five months you've studied under him, his kindness has been
      matched only by his knowledge of God's healing herbs.";
    ],
    possess 'aelred^s' 'aelreds',
    go_home [;
      if (self has animate) move self to slype;
    ],
    history_text
      "Aelred (1284-). Entered the priory 1295 as a youth. Served as
      Herbalist. Fluent in several languages beyond English and Latin.^^
      Written below this in fresh ink in Wilfred's scratchy hand, it
      reads: ~Requiescat in pace, carus frater~.",
    before [;
      Smell:
        if (self has general)
          "There's something oddly distinctive about his breath:
          acrid and stale, reminding you of old chamber pots.";
    ],
  has
      animate;  ! turn off when dead & remove him from slype


Monk BrAnselm "Brother Anselm"                                       ! >BrAnselm
  with
    name 'anselm' 'cantor',
    description
      "Brother Anselm, the Cantor, is barely thirty---young for his office.
      He joined the priory at a young age and was put under the tutelage of
      Brother Wilfred for many years.
      He has a clear, strong voice and an easy smile. Unlike many of the
      other brothers, he seems to enjoy conversation when the Rule permits it.",
    possess 'anselm^s' 'anselms',
    go_home [;
      move self to Locutory;
    ],
    history_text
      "Anselm (1316-). Entered 1332. Studied under Brother Wilfred in his
      youth. Appointed Cantor 1344 despite his youth, owing to the
      exceptional clarity of his voice. Leads the brothers in the
      Divine Office."
  has
    ;


Monk BrBenedict "Brother Benedict"                                 ! >BrBenedict
  with
    name 'benedict' 'infirmarer',
    description
      "Brother Benedict, the Infirmarer, is a heavyset man in his forties
      with gentle hands and a warmer smile than his bulk might suggest.
      He moves with the careful efficiency of one who tends the suffering
      daily.",
    possess 'benedict^s' 'benedicts',
    go_home [;
      ! will leave infirmary when PC enters & go to chapter house
      move self to Infirmary;
    ],
    history_text
      "Benedict (1298-). Entered 1318. Served as Infirmarer from 1328.
      Treats both brothers and villagers who seek healing. Known for his
      patience with the dying.",
  has
    ;


Monk BrCuthbert "Brother Cuthbert"                                 ! >BrCuthbert
  with
    name 'cuthbert' 'sacrist',
    description
      "Brother Cuthbert, the Sacrist, is in his late forties. Dark-haired
      and sharp-featured, he keeps the sacred vessels spotless and the
      canonical hours precise. He rarely smiles.",
    possess 'cuthbert^s' 'cuthberts',
    go_home [;
      move self to CloisterNE;
    ],
    history_text
      "Cuthbert (1300-). Entered 1315, son of a nobleman from the south.
      Appointed Sacrist 1325. Maintains
      the sacred vessels and vestments with meticulous care. Keeps the
      canonical hours by ringing the great bell.",
  has
  ;


Monk BrHugh "Brother Hugh"                                             ! >BrHugh
  with
    name 'hugh' 'cellarer',
    description
      "Brother Hugh, the Cellarer, is lean and blond, barely thirty but
      already worry-worn. He manages the priory's worldly goods—trade,
      stores, accounts—and the weight of it shows in his troubled expression.",
    possess 'hugh^s' 'hughs',
    history_text
      "Hugh (1314-). Brought to the priory 1322 as a child of eight, his
      family unable to feed him after failed harvests. Raised and educated
      by the brothers. Appointed Cellarer 1342. Manages stores and trade
      with exceptional diligence. Has a widowed sister in the village of Holt
      who visited once.",
    go_home [;
      move self to Undercroft;
    ],
  has
  ;


! Martin is in the kitchen, but goes to the chapter house whenever PC visits

Monk BrMartin "Brother Martin"                                       ! >BrMartin
  with
    name 'martin' 'kitchener',
    description
      "Brother Martin, the Kitchener, is short, round, and quick to laugh---
      unusual in this somber place. He and Brother Remigio, the lay monk,
      produce the simple meals that sustain the community.",
    possess 'martin^s' 'martins',
    go_home [;
      move self to Kitchen;
    ],
    history_text
      "Martin (1304-). Entered 1322. Appointed Kitchener 1334. Oversees
      the preparation of meals for the community, assisted by Brother
      Remigio.",
  has
  ;


Monk BrOswald "Brother Oswald"                                       ! >BrOswald
  with
    name 'oswald' 'prior',
    description
      "Brother Oswald, the Prior. Lean and grey-haired, in his early fifties,
      he governs the priory with stern discipline. You've learned to measure
      your words and deeds carefully in his presence.",
    go_home [;
      move self to PriorsSolar;
    ],
    history_text
      "Oswald (1294-). Entered 1312 from a minor noble family. Elected
      Prior 1338 upon the death of Brother Wilfred's predecessor. Governs
      with strict adherence to the Rule of St. Benedict.",
  ;


! Outside of first service, is always in the kitchen and never leaves.
!
! PUZZLE: will allow player access to undercroft & will give a candle
!   once bribed with the basil
!
! general = bribed with basil

Monk BrRemigio "Brother Remigio"                                    ! >BrRemigio
  with
    name 'remigio',
    description
      "Brother Remigio is a lay brother from Tuscany---not fully professed,
      but devoted to the work. He's in his late thirties, with sharp features
      and expressive hands. His English is poor, and he often lapses into
      his native Tuscan tongue.",
    possess 'remigio^s' 'remigios',
    go_home [;
      move self to Kitchen;
    ],
    life [;
      Give:
        if (noun == Basil) {
          move Basil to self;
          give self general;
          "Remigio's weathered face transforms. ~Basilico!~ he exclaims,
          taking the herb and breathing deeply. ~I have not smelled this
          since I left Toscana.~ His eyes glisten. ~Brother Aelred grew
          this? He was... he was a good man.~ He gestures toward the
          stairs. ~Go below if you must, Brother. I will not question you.~";
        }
    ],
    history_text
    history_text
      "Remigio (c.1308-). A lay brother from Tuscany, came to the priory
      1340 seeking refuge from troubles in his homeland. Works in the
      kitchen and performs manual labor. Has not taken full vows.",
  has
  ;

Candle -> TallowCandle "tallow candle"                           ! >TallowCandle
  with
    adj_name 'tallow',
    description [;
      print "A poor quality candle made of tallow";
      if (self has light) print ". It is currently lit.";
      ".";
    ],
  has
    concealed;


! Always guards the library (he's excused from other services)
!
! PUZZLE: can put him to sleep with burning mandrake
!
! He'll have limited conversation w/PC in the library.

Monk BrWilfred "Brother Wilfred"                                    ! >BrWilfred
  with
    name 'wilfred' 'librarian',
    description
      "Brother Wilfred is the most venerated of the brethren, well
      over seventy. He's lean and wiry, with wisps of white hair shooting
      in all directions from his head. His fingers are stained with pigments,
      and his habit has bits of fluff or fur on it.",
    history_text
      "Wilfred (1273-). Entered 1290 from a scholarly family in Norwich.
      Elected Prior 1310, serving until 1338 when he stepped down due to
      age and failing sight. Now serves as Librarian and master illuminator,
      though his hands tremble with the years. The oldest brother in living
      memory, he has seen the priory through plague, famine, and decline.^^
      You note that this entry was written by Wilfred, but in his
      way, he tried to maintain a distant and truthful tone.",
    initial [;
      if (BrWilfred in Scriptorium)
        print "Brother Wilfred is seated at the table, close to the south wall";
        if (BrWilfred has general) print ", snoring heavily";
        ".";
    ]
    possess 'wilfred^s' 'wilfreds',
    go_home [;
      move self to Scriptorium;
      move LibraryKey to ScriptoriumTable;
    ],
    ! TODO: don't repeat these, use each once
    each_turn [ chance ;
      if (BrWilfred has general || Library has visited || deadflag) return;
      chance = random(10);
      if (chance == 1)
        "^Brother Wilfred yawns sleepily.";
      if (chance == 2)
        "^The venerable Wilfred rubs his temples with tiredness.";
      if (chance == 3)
        "^Brother Wilfred blinks his eyes heavily.";
    ],
    life [;
      WakeOther:
        if (self has general) {
          "You shake Brother Wilfred awake. ~Ah, young son, you'll have to
          pardon an old man his weakness.~ He blinks sleepily at you.";
        }
        "As you're about to shake Brother Wilfred, his eyes snap open.
        ~Dear child,~ he says, ~I was just resting my eyes.~";
      default:
        if (self has general) {
          "Brother Wilfred is deep in sleep.";
        }
    ]
  has
  ;


! ======================================================== 2.0 CHURCH
! 2.0.1 Entrance
! 2.0.2 Nave
! 2.0.3 Tower
! 2.0.4 Quire
! 2.0.5 High Altar Area
! 2.0.6 Sacristy
! 2.0.7 FitzAlan chantry
! 2.0.8 Lady Chapel
! 2.0.9 St Jude Chapel


! --------------------------------------------------- 2.0.1 Entrance
! West Porch, door

Room WestPorch "West Porch"                                         ! >WestPorch
  class AdjObject,
  with
    adj_name 'west',
    noun_name  'porch' 'entrance',
    description
      "This covered entrance protects the west door from the
      winds that come across the sea to the east.
      Villagers used to gather here before services,
      but the number who do so have been declining for years.",
    e_to WestDoor,
    in_to WestDoor,
    cant_go
      "It is forbidden for you to leave the Priory grounds without permission
      of Brother Oswald.",
    cheap_scenery
      1 'villagers' "You certainly don't see any here now."
      1 'grounds' "The scraggly grounds extend in all directions."
  ;


! PUZZLE: one way to find the founding date is on the door

Object WestDoor "west door"                                          ! >WestDoor
  class AdjObject,
  with
    adj_name 'west',
    noun_name 'door' 'carving',
    found_in WestPorch Nave,
    door_dir (e_to) (w_to),
    when_closed "The great door is closed.",
    when_open [;
      print "The great door is open, revealing the ";
      if (location == WestPorch) "nave to the east."; "porch to the west.";
    ],
    description [;
      if (location == WestPorch && self hasnt open)
        "Carved deeply into the door's face:^
        ^  NOSTRA DOMINA SPINARUM (~Our Lady of Thorns~)^
        ^  FUNDATUM ANNO DOMINI MCLII^^
        Over two hundred years of wind and rain have worn the letters
        smooth.";
      "A large and solid oaken door.";
    ],
    after [;
      Close:
        print "You close the west door";
        if (location == WestPorch) print ", revealing a carving on the face";
        ".";
    ],
  has
    static door openable ~open;

! --------------------------------------------------- 2.0.2 Nave
! Nave and rood screen and cross

Room Nave "Nave"                                                         ! >Nave
  with
    name 'nave',
    description
      "The public space, where villagers stand for Mass.
      The stone floor is worn smooth by centuries of feet.
      High above, narrow windows admit pale light.
      The quire lies to the east, separated by a screen.
      A doorway in the north wall leads to the bell tower stairs.",
    e_to Quire,
    w_to WestDoor,
    out_to WestDoor,
    u_to TowerStairs,
    n_to TowerStairs,
    cheap_scenery
      'outside' 'porch' "The porch is to the west, beyond the door."
      1 'quire' "You should go east to see it better."
      1 'windows' "They're too high up to look out, but dim light comes in.",
  has ;


! TODO: needs description and reference in nave room description
! PUZZLE: this will reveal one of the Gordian's themes for the solar door

Object StainedGlass "stained glass"                              ! >StainedGlass
  with
    name 'stained' 'glass',
    description "XXX",
  has
    scenery;


Object RoodScreen "rood screen"                                    ! >RoodScreen
  with
    name 'rood' 'screen',
    found_in Nave Quire,
    description
      "A wooden rood screen separates the nave from the quire, dividing the
      public space from the sacred. A simple carved cross tops the
      screen---the ~rood~ that gives it its name. The wood is dark with
      centuries of candle smoke.",
    before [;
      Climb, Enter: "It's far too narrow to climb on.";
    ]
  has
    transparent  ! so can see cross "contained" in it
    scenery;


Object -> RoodCross "rood cross"                                    ! >RoodCross
  class AdjObject,
  with
    adj_name 'rood',
    noun_name 'cross',
    description "Simply carved and without ornamentation.",
  has
    static;


!---------------------------------------------------- 2.0.3 Tower
! Tower stairs, tower, bell, and views


Room TowerStairs "Tower Stairs"                                   ! >TowerStairs
  with
    name 'stone' 'steps' 'stairs',
    description
      "A narrow spiral staircase winds upward. The stone steps
      are worn smooth and treacherously steep.
      Cold air and dim light flows down from above.",
    d_to Nave,
    s_to Nave,
    u_to BellTower,
  has ;


Room BellTower "Bell Tower"                                         ! >BellTower
  with
    description
      "The bell chamber. Wind whistles through the open arches on
      all four sides. The great bell hangs overhead.
      A rope from it hangs to within your reach.
      From here, you have clear views in all four directions.",
    d_to TowerStairs,
    before [;
      Examine:
        switch (selected_direction) {
          n_to:
            "To the north, you can see rough coast and cliffs,
            dotted with small farms.";
          s_to:
            "South of here, you see the cloister surrounding the garth,
            the priory's roofs, and the herb garden.
            How you've learned to love that garden.";
          w_to:
            "West lies the path to the village nestled down in the vale.
            You can also see a small path from the west door to the gate for the
            priory.";
          e_to:
            "East, you can see the infirmary and its chapel near the cliffs,
            and the dorter's small window breaking the upper story wall.";
          u_to:
            "The great bell hangs above you, dark against the sky. ";
          d_to:
            "You see the stone floor of the bell tower, and through the
            opening, the stairs descending.^^
            If you want to to look in a particular direction, do so.";
        }
    ],
  has ;


Object -> Bell "bell"                                                    ! >Bell
  class AdjObject,
  with
    adj_name 'great' 'bronze',
    noun_name 'bell',
    description
      "A bronze bell, green with age. Cast nearly two centuries ago,
      its surface bears the inscription: ~VOX DOMINI~",
    before [;
      Touch, Pull, Attack, Push:
        "The bell is far above you. You can only reach the rope.";
    ],
  has
    static scenery;


Object -> BellRope "bell rope"                                       ! >BellRope
  class AdjObject,
  with
    adj_name 'bell',
    noun_name 'rope' 'cord',
    describe 0,
    description
      "The cord reaches up to the bell, far above.
      Ringing the bell yourself would earn severe punishment.
      That duty does not belong to novices.",
    before [;
      Climb, Tie, Pull, Turn, Cut:
        StartTimer(self, 3);
        "Grabbing the cord causes the bell to toll, echoing across the priory.
        Instinctively you let go of the cord.";
    ],
    time_left,
    time_out [;
      if (location ~= BellTower or TowerStairs or Nave) {
        "You can hear footsteps in the nave, going up to the tower, and
        the returning. It seems very fortunate that you have avoided the
        wrath of the Prior, Brother Oswald.";
      }
      deadflag = 3;
      print
        "^Brother Oswald finds you here, his face dark with anger.^^
        ~What madness is this? Ringing the bells without cause?
        The entire village will think we're under attack!~^^
        You are confined to your cell with bread and water for a fortnight.";
      KillOff();
    ],
  has
    static;


!---------------------------------------------------- 2.0.4 Quire
! Quire, lectern, and stalls

! TODO: add door from quire to cloister

[ QuireDescripDuringService;
  print
    "The quire is the center of the church. Two long stalls face each other";
  if (child(Stalls) ~= nothing) {
    PrintContents(". Already seated on them ", Stalls, ISARE_BIT);
    if (BrOswald in HighAltarArea)
      print ". Brother Oswald, the Prior, is at the altar";
    ".";
  }
];


! Object to manage logic of the first-service and other ones
!
! PUZZLE: need to perform first service
! PUZZLE: if wander through area during service, will get sucked into it

Object Service "service"                                              ! >Service
  with
    start_service [;
      move self to Quire;
      StartTimer(self, 7);
      if (BrAelred has animate) move BrAelred to Stalls;
      move BrAnselm to Stalls;
      move BrBenedict to Stalls;
      move BrCuthbert to Stalls;
      move BrHugh to Stalls;
      move BrMartin to Stalls;
      move BrOswald to HighAltarArea;
      move BrRemigio to Stalls;
      move BrWilfred to Stalls;
      Quire.old_description = Quire.description;
      Quire.description = QuireDescripDuringService;
      give Stalls concealed;
    ],

    stop_service [;
      remove self;
      give self ~general;
      StopTimer(self);
      if (BrAelred has animate) {
        move BrAelred to Slype;
        give BrAelred general; ! dying
      }
      move BrBenedict to Infirmary;
      remove BrCuthbert;
      move BrHugh to Undercroft;
      move BrMartin to Kitchen;
      move BrOswald to PriorsSolar;
      move BrRemigio to Kitchen;
      move BrWilfred to Scriptorium;
      print "You join the others in song.^^ - * - * -";
      QuoteBoxSimple(quote_song);
      Achieved(TASK_PERFORM_OFFICE);
      Quire.description = Quire.old_description;
      give Stalls ~concealed;
      print
        "^^After a while, the office ends, and the other brothers depart,
        leaving you in the Quire.^^";
      Banner();
    ],
    add_to_scope [;
      if (BrOswald in HighAltarArea) { PlaceInScope(BrOswald); }
    ],
    time_left,
    time_out [;
      if (location == Quire)
        print
          "^Brother Anselm pauses the song: ~Why do you not join us, Brother
          Aldwin?~ The other monks look uncomfortably at you.";
      else
        print
          "^You can faintly hear the singing in the Quire. Brother Oswald
          finds you here, very frustrated. ~Why are you not with us,
          Brother Aldwin? You surely heard the bell calling you to office.~
          You follow him to the quire and join the office.";
      print
        "^^You know that you've broken a rule of the priory.
        ^^After the office, Brother Oswald reprimands you severely and
        confines you to silent penance for a week.";
      KillOff();
    ],
    react_before [;
      Sing:
        if (Service hasnt general) "But there's no service going on now.";
        if (player notin Stalls)
          "First, be seated with the others.";
        Service.stop_service();
        rtrue;
      Examine:
        if (noun == BrOswald && BrOswald in HighAltarArea)
          "Though a distance away at the altar, he has his usual
          inscrutable expression.";
      Exit:
        if (noun == Stalls) "Not during office, surely!";
    ],
    each_turn [;
      ! make a count-up timer for the service?
      if (self has general)
        "^Brother Anselm is leading the brethren in song---all except you.";
    ],
  has
    concealed;


Room Quire "Quire"                                                      ! >Quire
  with
    description
      "The quire is the heart of monastic worship and the center of the church.
      Two choir stalls face each other
      across the narrow gap, where the brothers gather to chant the offices.
      The stalls are plain but worn smooth by generations of use.
      The high altar rises to the
      east. The nave lies west, beyond the screen. Night stairs ascend north
      to the dormitory, and a hall leads south to the cloister.",
    old_description "",  ! gets filled with orig during service so can restore
    s_to CloisterNE,
    e_to HighAltarArea,
    w_to Nave,
    n_to NightStairs,
    u_to NightStairs,
    before [;
      Sing:
        "But there's no service going on now.";
    ],
    cheap_scenery
      'high' 'altar'
        [;
          if (BrOswald in HighAltarArea)
            "You can see the altar from here, but you should head east for a
            closer look.";
          "You can see Brother Oswald at the altar.";
        ],
  has
    ;


Object -> Stalls "stalls"                                              ! >Stalls
  class AdjObject,
  with
    adj_name 'wooden',
    noun_name 'stalls//p' 'stall',
    description
      "You've stood by and sat on these for months now during services.
      The carpentry is unremarkable and there is nothing these can reveal.",
    after [;
      Enter:
        if (BrAelred in self)
          "You on a stall next to your mentor, the herbalist Brother Aelred.";
        "You sit on a stall with a certain sense of familiarity.";
      Exit:
        "You get up from your stall.";
    ],
  has
    static supporter enterable pluralname;


!----------------------------------------------------- 2.0.5 High Altar Area
! HighAltar, crypt stairs


Room HighAltarArea "High Altar Area"                            ! >HighAltarArea
  with
    description [;
      print
        "A domed ceiling rises above this, the place where the Prior leads
        office.
        A chapel stands in shadow to the east.
        The sacristy lies south. Behind a";
        if (CryptGate has open) print "n open";
        else print "closed";
        if (CryptGate has locked) print ", locked";
        " gate to the north, narrow stairs descend into
          the crypt.";
    ],
    w_to Quire,
    e_to LadyChapel,
    d_to CryptGate,
    n_to CryptGate,
    s_to SacristyDoor,
    cheap_scenery
      1 'chapel'
        "From here, you can see an altar and a statue. You can go east to
         explore it.",
  has;

! TODO: can do this will people around
! > enter altar
! It feels deeply sacriligeous, but you climb onto the altar.


Altar -> HighAltar                                                  ! >HighAltar
  with
    short_name "high altar",
    article "the",
    adj_name 'high',
    description
      "The povery of the priory is evident in the simplicity of the altar.
      It is a simple stone structure supporting a cross and with a plain
      cloth draped on it.",
  has ;


Object -> -> AltarCloth "cloth"                                    ! >AltarCloth
  class AdjObject,
  with
    adj_name 'plain' 'altar',
    noun_name 'cloth',
    description "Coarse flax and unremarkable.",
    before [;
      Examine, Search, LookUnder, Smell, Listen: ;
      Touch: <<Examine self>>;
      Attack, Cut: "Heaven forfend.";
      default:
        "Brother Cuthbert would be outraged if you did anything with it.";
    ],
  has
    ;


Object -> -> AltarCross "altar cross"                              ! >AltarCross
  class AdjObject
  with
    article "the",
    describe 0, ! [; rtrue; ],
    adj_name 'altar',
    noun_name 'cross',
    description
      "A simple wooden cross---no gold, no jewels---firmly attached
      to the altar.",
    before [;
      Attack: "Heaven forfend.";
      Smell: "It smells like dust and faint incense.";
    ],
  has static;


! -------------------------------------------------------------

! PUZZLE: how to get into the crypt?
!  It isn't the key; that's a red herring and player will never get it.
!  It can be entered throught the secret FitzAlanCrypt
! PUZZLE: how to leave the crypt?
!  - can pray to st jude for impossible help
!  - can ring the bell, hide, wait for cuthbert to search, then run
!    upstairs when he goes to crypt vestry

Object CryptGate "crypt gate"                                       ! >CryptGate
  with
    name 'crypt' 'gate' 'stairs',
    description [;
      #ifDef HAS_HINTS; HintReady(Hint_gate); #EndIf;
      print
        "The gate is made of sturdy iron and has a heavy lock built into it.";
    ],
    found_in HighAltarArea CryptStairs,
    door_dir (u_to) (d_to),
  has
    scenery door locked ~open openable;


Room CryptStairs "Crypt Stairs"                                   ! >CryptStairs
  with
    name 'crypt' 'stairs',
    description [;
      print
        "At the midpoint of these stairs, you can sense the damp
        below. A thin veil of light comes from the altar area above";
      if (_LookForLightInObj(Crypt, Crypt))
        ", and weak candlelight from the crypt below.^";
      ", but the path down descends into darkness.";
    ],
    s_to CryptGate,
    u_to [;
      if (PrayerMat has general && CryptGate has locked) {
        print
          "As you approach the crypt door, you hear the soft
          click of an unseen bolt sliding back. Your prayer
          has been answered.^^";
        give CryptGate open;
        give PrayerMat hasnt general;
      }
      return CryptGate;
    ],
    d_to Crypt,
    before [;
      Smell: "Musty and damp.";
    ],
  has
    ;


! --------------------------------------------------- 2.0.6 Sacristy


Object SacristyDoor "sacristy door"                              ! >SacristyDoor
  with
    name 'sacristy' 'door',
    description "A narrow wooden door without any lock.",
    found_in HighAltarArea Sacristy,
    door_dir (n_to) (s_to),
    before [;
      Examine:
        if (location == thedark)
          "Have faith, Brother. You can't see it, but you know it's there.";
    ],
    after [;
        Open: give Sacristy light;
        Close: give Sacristy ~light;
    ],
  has
    static scenery door openable ~open;


! PUZZLE: can only get the candle if has proven it's needed
! PUZZLE: has to hide candle as its contraband

Room Sacristy "Sacristy"                                             ! >Sacristy
  with
    name 'sacristy' 'vestry',
    description
      "A small room where vestments and sacred vessels are kept.
      Shelves hold neatly folded linens, precious chalices, and other
      miscellaneous vestry items. The smell of beeswax and old incense lingers.
      Brother Cuthbert maintains this space with meticulous care.",
    n_to SacristyDoor,
    cheap_scenery
      1 'shelves' "The shelves are neat and tidy."
      'linen' 'linens//p'
        "The linens are worn but clean."
      4 'vessel' 'vessels//p' 'chalice' 'chalices//p'
        "The chalices are used for sacred purpose during Mass."
      1 'incense' "You can smell it faintly, but can't find any here."
      'vestry' 'items' "Some cloth, candles, and a pewter platter."
      1 'cloth' "Just scraps, really."
      2 'pewter' 'platter' "Used to hold items during Mass.",
    before [;
      Smell:
        if (location == thedark)
          "You smell wax and old incense in the darkness.";
        "Dusty and fragrant with wax and wood.";
      Go:
        if (location == thedark)
          "You shouldn't stumble around in the dark.
          You might damage something.";
    ],
  has
    ;


Object -> Candles "candles"                                           ! >Candles
  class AdjObject,
  with
    adj_name 'beeswax',
    noun_name 'candles',
    describe [; rtrue; ],
    description
      "There's a few candles here, finer than the more common ones made of
      tallow. These candles are used to light the church.",
    before [;
      Burn: "Burning all of these candles would be madness.";
      Take:
        if (MyCandle.dont_need()) rtrue;
        "The theft of all of the candles would be quickly discovered.";
    ],
    add_to_scope MyCandle,
  has pluralname;


Candle MyCandle "beeswax candle"
  with
    adj_name 'beeswax',
    description [;
      print "Good quality, made from beeswax from the priory's own bees";
      if (self has light) print ". It is currently lit.";
      ".";
    ],
    before [;
      Take:
        ! haven't solved lion/crypt: don't let them take
        if (MyCandle.dont_need()) rtrue;
        ! if there's already a candle in room or player, they get this one
        if (IndirectlyContains(location, self)) rfalse;
        ! if it's been removed from the game (destroyed), they get another
        if (parent(MyCandle) == nothing) {
          move self to player;
          if (self has moved)
            "Feeling even more guilt, you take another candle.";
          "You take a single candle, feeling the weight of this
          small theft.";
        }
        "Surely, one stolen candle must be enough.";
    ],
  has
    ;


! --------------------------------------------------- 2.0.7 FitzAlan Chantry

! PUZZLE: find hidden ladder to FA Crypt
! PUZZLE: how to get out of that area, since ladder is one-way

Room FitzAlanChantry "FitzAlan Chantry"                       ! >FitzAlanChantry
  with
    name 'chantry',
    description [;
      #IfDef HAS_HINTS; HintReady(Hint_chantry); #EndIf;
      if (player in FitzAlanAltar)
        "From here you can see the arms closely.";
      print
        "The FitzAlan family chantry, endowed long ago for
        masses. But the FitzAlans are gone now---their line ended in the
        pestilence---and no masses are said here anymore";
      if (FitzAlanAltar has open) {
        print ". An opening in the floor reveals a ladder leading down";
        if (~~FitzAlanCrypt.is_lit())
          print " into darkness";
      }
      ".";
    ],
    w_to HighAltarArea,
    s_to LadyChapel,
    d_to [;
      if (FitzAlanAltar has open) {
        if (~~(FitzAlanCrypt.is_lit() || IsCarryingLit())) {
          print "Do you want to descend into darkness? ";
          if (YesOrNo() == 0) "You decide better of it.";
        }
        print
          "^You climb down the ladder. As you step off the bottom rung,
          a counterweight somewhere in the mechanism snaps the ladder
          back to the ceiling, far out of reach.^^";
        move Ladder to FitzAlanCrypt;
        return FitzAlanCrypt;
      }
    ],
    cheap_scenery
      1 'floor' "These almost look like scrapes from moving the altar."
      'gouge' 'gouges//p'
        "You're not sure what caused them---perhaps the altar was moved?"
      1 'motto' "~LEO VIAM CUSTODIT~",
  has
    ;


! open = open, can climb down
! moved = ever been opened

Altar -> FitzAlanAltar                                          ! >FitzAlanAltar
  class AdjObject,
  with
    adj_name 'stone' 'fitzalan',
    noun_name 'altar',
    describe [;
      print "^A stone altar is set against the east wall";
      PrintContents(". On it ", self, ISARE_BIT);
      ".";
    ],
    description [;
      print "A heavy-looking block of white stone";
      if (self has open)
        " that has been pushed away from the wall, revealing stairs descending
        into darkness.";
      print " on the floor. Gouges in the floor by the altar
      testify to its weight. Above the altar, carved into
      the wall, are the FitzAlan arms and motto";
      PrintContents(". On the altar ", self, ISARE_BIT);
      ".";
    ],
    after [;
      Enter:
        print "You climb onto the altar";
        if (FitzAlanLion hasnt moved)
          ". From here you can reach the carved arms above.";
        ".";
    ],
    open_altar [;
      give self open;
      give self moved;
      move Ladder to FitzAlanChantry;
      QuoteBoxSimple(quote_stone);
      Achieved(TASK_MOVE_ALTAR);
      print
        "You push against the altar and it swings away from the wall,
        revealing an opening in the floor with a ladder visible.^";
    ],
    before [;
      Take:
        if (FitzAlanLion hasnt moved) rfalse;
        "Even trying, you can't lift it.";
      Search:
        "You find nothing hidden about the altar itself, but those gouges
        in the floor are intriguing.";
      Push, Turn:
        if (player in self)
          "You can't move the altar while standing on it.";
        if (self has open) {
          give self ~open;
          give FitzAlanLion ~moved;
          remove Ladder;
          "You push the altar back against the wall and hear a solid click as
          it settles against the wall.";
        }
        if (FitzAlanLion has moved) { self.open_altar(); rtrue; }
        if (self has moved)
          "It no longer seems you can push it.";
        "While it seems that the altar isn't built into the floor, it
        also doesn't budge when you try to move it.";
    ],
  has
     ;


! moved = lion is pushed in now
! general = lion has ever been pushed in

Object -> FitzAlanLion "FitzAlan arms"                           ! >FitzAlanLion
  class AdjObject,
  with
    adj_name 'fitzalan' 'family' 'brass' 'rampant',
    noun_name 'lion' 'arms',
    description [;
      if (player notin FitzAlanAltar)
        "A lion, perhaps? It's a bit too far up to see clearly.";
      if (self has moved) "The lion is pressed in slightly.";
      "A finely-detailed brass rampant lion standing out from the stone.";
    ],
    before [;
      if (player notin FitzAlanAltar && action ~= ##Examine)
        "The arms are set high in the wall, well above you.";
      Push, Turn:
        if (self has moved) "Nothing new happens.";
        give self moved;
        if (self has general)
          "Again, you push against the lion, and hear the same deep click.";
        give self general;
        "You push against the lion and, surprisingly, it moves
        inward slightly. A deep click is heard in the wall.";
      Touch:
        "The lion is fine to the touch and, curiously, feels like it
        could move.";
    ],
  has
    ~moved scenery pluralname;


!---------------------------------------------------- 2.0.8 Lady Chapel
! Chapel and statue

Room LadyChapel "Lady Chapel"                                      ! >LadyChapel
  with
    name 'lady' 'chapel' 'mary' 'virgin',
    description
      "The largest of the three chapels, dedicated to
      the Blessed Virgin.
      This chapel sees more use than the others---the brothers pray here
      for the priory's patroness, Our Lady of Thorns. To the west is the
      main church. Small doorways lead north and south to smaller chapels.",
    w_to HighAltarArea,
    n_to FitzAlanChantry,
    s_to StJudeChapel,
  has
    ;


Statue -> MaryStatue "statue"                                      ! >MaryStatue
  with
    name 'mary' 'virgin' 'blessed',
    initial "A statue of Mary stands in a niche.",
    description
      "A stone statue of the Blessed Virgin Mary. Her stone hands are
      open in a gesture of welcome and mercy. Her carved face is serene.^^
      Carved on the base statue:^
      ^  BEATAE MARIAE MATRIS DEI
      ^  (Blessed Mary, Mother of God)",
    react_before [;
      Pray: "You make the sign of the cross and murmur an Ave Maria.";
    ],
  has
    female;


Altar -> MaryAltar "stone altar"                                    ! >MaryAltar
  class AdjObject,
  with
    adj_name 'stone' 'mary',
    noun_name 'altar',
  ;

! --------------------------------------------------- 2.0.9 St Jude Chapel
! Chapel, mat, statue, altar, rosehips

! PUZZLE: can pray to st jude for later help in crypt
! PUZZLE: identify the rosehips

Room StJudeChapel "St Jude Chapel"                               ! >StJudeChapel
  with
    name 'chapel',
    description [;
      #IfDef HAS_HINTS; HintReady(hint_jude); #EndIf;
      "A small chapel dedicated to St Jude, patron of desperate causes.
      The stone floor is worn smooth---many desperate souls
      have knelt here over the centuries, praying for urgent help.
      A painted statue shows the saint.";
    ],
    n_to LadyChapel,
  has
    ;


! general = has a prayer
! moved = ever had a prayer (can't get a second)

Object -> PrayerMat "prayer mat"                                    ! >PrayerMat
  class AdjObject,
  with
    adj_name 'prayer',
    noun_name 'mat',
    description
      "A rough flax mat before the altar, worn thin by countless hours
      of kneeling. Someone has been using it recently---very recently.",
    before [;
      Take, Push: "You are deeply certain it belongs here.";
      Search, LookUnder: "Nothing below it but a worn stone floor.";
    ],
    after [;
      Enter: "You kneel on the worn mat.";
    ],
    react_before [;
      Pray:
        if (player in PrayerMat) {
          if (self hasnt general) {
            give self moved;   ! ever got a prayer
            give PrayerMat general;
            "You feel a powerful sense of hope that the Saint will help you in
            crisis.";
          }
          "You feel that the Saint has already heard your plea.";
        }
    ],
  has
    supporter enterable;


Altar -> JudeAltar "altar"                                          ! >JudeAltar
  with
    description [;
      print "A simple stone altar, worn smooth by centuries of prayer.";
      if (RoseHips hasnt moved) {
        give RoseHips ~concealed;
        " Someone has left an offering of ", (a) RoseHips, " here.";
      }
      "";
    ],
  has
    ;


! The berries are initially known only as "berries", but they become known
! as rosehips after smell/tasting them. They're initially concealed, but are
! revealed after examining the altar (otherwise, they'd get listed in the
! initial room description, and I want people to have to look at the altar
! to notice them).

Object -> -> RoseHips "small red berries"                            ! >RoseHips
  with
    short_name [;
      if (self has general) { print "rosehips"; rtrue; }
    ],
    invent [;
      print (a) self, " (originally left as an offering to St Jude)"; rtrue;
    ],
    parse_name [ w wn ;
      while (true) {
        w = NextWord();
        if (w == 'red' or 'berry' or 'berries') wn++;
        else if (self has general &&
            w == 'rose' or 'hip' or 'hips' or 'rosehip' or 'rosehips') wn++;
        else return wn;
      }
    ],
    description [;
      if (self hasnt general) print "Small seed pods. ";
      "Someone carefully gathered these as an offering.
      They're fresh and fragrant, picked within the last day or two.";
    ],
    recall [;
      if (self hasnt general) {
        give self general;
        Achieved(TASK_IDENTIFY_ROSEHIPS);
        QuoteBoxSimple(quote_rose);
        "This action brings back a memory from summer: Aelred in the physic
        garden, showing you a red rose in full bloom. ~Beautiful now, Brother,
        but its true gift comes later. These petals fall, and by autumn the
        hip swells with seed---tart and rich. We gather them after the first
        frost for winter cordials.~ He'd smiled. ~The rose serves us twice:
        beauty in summer, medicine in autumn.~";
      }
      ", reminiscent of roses.";
    ],
    before [;
      Eat:
        "You shouldn't eat an offering left to a saint.";
      Taste:
        print "You nibble at one: a sweet, tangly flavor";
        self.recall();
        rtrue;
      Smell:
        print "A faint, floral scent";
        self.recall();
        rtrue;
      Touch:
        "They're firm. Perhaps you should check their scent?";
    ],
  has
    pluralname edible concealed ok_carry;


Statue -> JudeStatue "St. Jude"                                    ! >JudeStatue
  with
    name 'saint' 'st' 'jude',
    description
      "A wooden statue of St Jude, simply carved and crudely painted.
      The saint holds a staff in one hand. His painted eyes seem to
      gaze down at those who kneel before him in desperation.",
    react_before [;
      Pray: "You murmur a brief prayer to St Jude.";
    ];


! ======================================================== 2.1 CLOISTER
! NW N NE W E SW S SE Garth


class Cloister
  with
    name 'cloister' 'arcade',
    description [;
      if (CloisterNE hasnt visited) {
        print
          "You emerge to the northeast corner of the cloister walk,
          the covered stone arcade at the
          center of the priory. It's a continuous square path surrounding
          the garth, a large open yard. Various rooms and
          passageways come off of the cloister walk.^";
      }
      print "Arched openings admit ";
      switch (RoughTime()) {
        CLOCK_NIGHT: print "cold night air and pale moonlight";
        CLOCK_MORNING: print "fresh morning breeze";
        CLOCK_AFTERNOON: print "slanted autumn sun";
        default: print "dim evening light";
      }
      print ".^^";
      self.cloister_detail();
    ],
    d_to
      "The Garth is only one step down from the cloister. To enter it,
      just walk in that direction through an opening.",
    before [;
      Climb:
        "You eye the effort it would take to scale the cloister
        and think better of it.";
    ],
  has
    light;


Cloister CloisterNW "Cloister Northwest"                           ! >CloisterNW
  with
    cloister_detail
      "The wall of the nave rises imposingly to the north,
      and an imposing door lies to the west.",
    s_to CloisterW,
    e_to CloisterN,
    w_to PriorDoor;


Cloister CloisterN "Cloister North"                                 ! >CloisterN
  with
    cloister_detail
      "The wall of the nave rises imposingly to the north.",
    w_to CloisterNW,
    s_to Garth,
    e_to CloisterNE;


Cloister CloisterNE "Cloister Northeast"                           ! >CloisterNE
  with
    cloister_detail
      "An passageway to the church quire is north.
      The chapter house is to the east, and the day stairs to the upper floor
      head upward from here.",
    n_to Quire,
    e_to ChapterHouse,
    w_to CloisterN,
    u_to DayStairs,
    s_to CloisterE,
  ;


Cloister CloisterW "Cloister West"                                  ! >CloisterW
  with
    cloister_detail
      "The locutory lies to the west.",
    s_to CloisterSW,
    e_to Garth,
    w_to Locutory,
    n_to CloisterNW,
  ;


Cloister CloisterE "Cloister East"                                  ! >CloisterE
  with
    cloister_detail
      "To the east is the entrance to the warmining room.",
    n_to CloisterNE,
    e_to Scriptorium,
    w_to Garth,
    s_to CloisterSE,
  ;


Cloister CloisterSW "Cloister Southwest"                           ! >CloisterSW
  with
    cloister_detail
      "The monk's gate lies to the west. A small alcove, the lavatorium,
       is to the south,
       right after the arcade turns to the east.",
    s_to Lavatorium,
    e_to CloisterS,
    w_to
      "As a novice, you are confined to the priory until you take
      your final vows.",
    n_to CloisterW,
    cheap_scenery
      3 'monk' 'monk^s' 'gate'
        "The gate is a heavy door leading to the outer world.
        It has a heavy bar on it to open the door---though you are forbidden
        to admit anyone to the priory. That is the sole duty of
        Brother Oswald.",
  ;


Cloister CloisterS "Cloister South"                                 ! >CloisterS
  with
    cloister_detail
      "The refectory lies to the south.",
    n_to Garth,
    w_to CloisterSW,
    e_to CloisterSE,
    s_to Refectory,
  ;


Cloister CloisterSE "Cloister Southeast"                           ! >CloisterSE
  with
    cloister_detail
      "The long slype lies to the east.",
    n_to CloisterE,
    e_to Slype,
    w_to CloisterS,
    cheap_scenery
      2 'long' 'slype'
        "The slype is a covered passageway to the east.",
  ;


Room Garth "Garth"                                                      ! >Garth
  with
    name 'garth' 'square',
    description
      "The garth---the small grass courtyard at the heart of the cloister.
      The covered cloister walk surrounds it on all sides, its arches
      framing the sky above.^^
      This is the monastery's heart, open to rain and sun, enclosed
      by the daily circuit of monastic life.",
    n_to CloisterN,
    w_to CloisterW,
    s_to CloisterS,
    e_to CloisterE,
    u_to
      "The cloister walk is raised only a single step. You're already
      at ground level. Just walk in the direction you want to enter it.",
    cheap_scenery
      'grass' 'courtyard'
        "Sparse grass and a few stubborn herbs. The garth was probably
        more carefully tended in better times."
      1 'water'
        "Presumably there's water in the well, but it's much too
        far for you to reach.",
  has
    ;

Object -> Sundial "sundial"                                           ! >Sundial
  class AdjObject,
  with
    adj_name 'sun',
    noun_name 'sundial' 'dial' 'clock',
    description [;
      if (the_time < 300 || the_time > 1260)
        "The sundial isn't casting a discernable shadow without sunlight.";
      "The sundial casts a shadow showing that the approximate time is ",
        (SundialTime) the_time, ".";
    ],
    has static;


Object -> GarthWell "well"                                          ! >GarthWell
  class AdjObject,
  with
    adj_name 'stone' 'old',
    noun_name 'well',
    description
      "An old stone well, its edges worn smooth by centuries of drawing
      water.",
    before [;
      Enter, Climb:
        "The well is deep and dark. You're not that desperate.";
      Search:
        "It's too dark to see the bottom.";
      Receive:
        if (MonkInRoom(Garth) ||
          MonkInRoom(CloisterN) ||
          MonkInRoom(CloisterW) ||
          MonkInRoom(CloisterE) ||
          MonkInRoom(CloisterS))
          "You dare not, since a brother would witness this act.";
        remove noun;
        print_ret
          (The) noun, " lands far below with a splash.
          I hope you didn't need that.";
    ],
  has
    static container open;


! ======================================================== 2.2 WEST WING
! 2.2.1 Prior's Solar
! 2.2.2 Locutory
! 2.2.3 Lavatorium

! --------------------------------------------------- 2.2.1 Prior's Solar

! stained glass windows in the nave (which he designed) show these three
! symbols. The door to the solar has brass plates with various symbols, and you
! must press the three that represent Gordian's creeds.
! Possible symbols/creeds:

! Compass/Square - Sacred geometry, God's order in creation
! Open Book - Knowledge/Scripture/Learning
! Hammer/Trowel - Honest labor, building for God's glory
! Cross - Faith (maybe too obvious?)
! Key - Stewardship, responsibility
! Lamp/Candle - Light of truth
! Wheat/Grapes - God's providence

! My suggestion for three creeds:

! INGENIUM DEI (God's Ingenuity) - Compass/Square symbol
! LABOR OMNIA VINCIT (Work conquers all) - Hammer symbol
! SAPIENTIA (Wisdom) - Book/Scroll symbol

! In the nave description, add:
! Three tall stained glass windows line the south wall, their colors muted
! by age. Each depicts a symbol: a compass and square, a mason's hammer,
! and an open book. Beneath each, barely legible Latin inscriptions.


Object PriorDoor "prior door"                                       ! >PriorDoor
  with
    name 'prior' 'door',
    description [;
      print "A heavy wooden door";
      if (location == CloisterNW)
        print " with a strange set of dials on it";
      print ". It is currently ";
      if (self hasnt open) "closed."; "open.";
    ],
    door_dir (e_to) (w_to),
    with_key PriorKey,
    found_in CloisterNW PriorsSolar,
  has
    static scenery door openable ~open lockable locked transparent;


Object -> PriorDials "dials"                                       ! >PriorDials
  with
    name 'dials',
    description "NOT IMPLEMENTED YET. Use the key for noe.",
;

Object PriorKey "magic key"                                          ! >PriorKey
  with
    name 'magic' 'key',
    description
      "A large key stamped with the message
      FOR EMERGENCY USE SINCE THE REAL PUZZLE FOR THIS HASN'T BEEN WRITTEN.
      Use me to unlock the Prior's door.",
    found_in CloisterNW,
    initial "A large key glows in neon red on the stone floor.",
  has
    ok_carry
  ;


Room PriorsSolar "Prior's Solar"                                  ! >PriorsSolar
  with
    name 'solar' 'room',
    description
      "Prior Oswald's private chamber. A narrow bed stands against one wall.
      A writing desk holds account books and correspondence. A wooden
      chest sits at the foot of the bed.
      The room is austere but private---a privilege of rank in a
      community that otherwise shares everything.",
    e_to PriorDoor,
    every_turn [;
      Achieved(TASK_OPEN_SOLAR);
    ],
  has
    ;


Object -> PriorsDesk "desk"                                        ! >PriorsDesk
  with
    name 'desk' 'writing' 'table',
    description
      "A plain wooden desk covered with the Prior's work: account books,
      letters, administrative records.",
  has
    scenery static supporter;


Object -> PriorsChest "wooden chest"                              ! >PriorsChest
  with
    name 'wooden' 'chest' 'box',
    description
      "A sturdy wooden chest bound with iron. Locked.",
  has
    scenery static container openable ~open lockable locked;


Object -> PriorsBed "narrow bed"                                    ! >PriorsBed
  class AdjObject,
  with
    adj_name 'narrow',
    noun_name 'bed',
    description
      "A simple bed---better than the straw pallets in the dormitory,
      but hardly luxurious.",
    react_before [;
      Sleep: <<Enter self>>;
    ],
    before [;
      Enter:
        "If the Prior were to catch you in his bed, you'd be expelled.
        You think better of it.";
    ],
  has
    scenery static supporter enterable;


! ---------------------------------------------------  2.2.2 Locutory

Room Locutory "Locutory"                                             ! >Locutory
  with
    name 'locutory' 'parlour' 'speaking' 'room',
    description [;
      if (self hasnt visited) QuoteBoxSimple(quote_locutory);
      "The locutory---the speaking room. A plain
      wooden table and a bench occupy the center. The walls are bare stone.
      This is where the prior meets with merchants, where brothers
      discuss monastery business, where the silence of the Rule may
      be broken for practical needs.";
    ],
    e_to CloisterW,
  has
    ;


Object -> LocutoryTable "table"                                 ! >LocutoryTable
  class AdjObject,
  with
    adj_name 'wooden',
    noun_name 'table',
    description
      "A plain wooden table where necessary business is conducted.",
  has
    scenery static supporter;


Object -> LocutoryBenches "benches"                           ! >LocutoryBenches
  class AdjObject,
  with
    adj_name 'wooden',
    noun_name 'bench' 'benches//p',
    description
      "Simple wooden benches flanking the table.",
    after [;
      Enter: "You sit on one of the benches.";
      Exit: "You get up from your bench.";
    ],
  has
    scenery static supporter enterable pluralname;


! --------------------------------------------------- 2.2.3 Lavatorium

Room Lavatorium "Lavatorium"                                       ! >Lavatorium
  with
    name 'lavatorium',
    description
      "A small alcove off the cloister where the brothers wash before
      entering the refectory. You can only go back the way you came.",
    n_to CloisterSW,
  has
     ;


Object -> Basin "basin"                                                 ! >Basin
  class AdjObject
  with
    adj_name 'large' 'stone',
    noun_name 'basin',
    initial
      "A large stone basin is built into the south wall, filled with
      water for washing.",
    description
      "The basin is worn smooth and water-stained from centuries of use
      and contains a large quantity of water.",
    before [;
      Drink:
        "This is washing-up water, and not suitable for drinking.";
      Taste:
        "You try a tiny sip and notice nothing unexpected.";
      Take:
        "The basin is built into the wall, and trying to get the water from it
        would seem impractical.";
    ],
    after [;
      Receive:
        print (The) noun, " drops into the water";
        if (noun == MyCandle && MyCandle has light)
          { give MyCandle ~light; print " and extinguishes"; }
        ".";
    ],
  has
    static container open transparent;


Object -> -> Water "water"                                              ! >Water
  with
    article "some",
    name 'water',
    before [;
      Drink: <<Drink Basin>>;
      Taste: <<Taste Basin>>;
      Take: <<Take Basin>>;
      Insert: <<Transfer noun Basin>>;
    ],
  has
    ;


Object -> Towel "towel"                                                 ! >Towel
  with
    name 'towel',
    initial "A threadbare towel hangs on a peg by the basin.",
    description
      "It's a simple linen towel, well-worn by use.",
    before [;
      Attack, Cut:
        "Destrying communal property is a violation of the Rules.";
      Take:
        "You should leave this here. The other brothers will want of its use.";
      Touch:
        "Rough linen and damp.";
      Smell:
        "It smells damp and musty.";
    ],
  has
    ok_carry;



! ============================================= East Wing

!---------------------------------------------------------- Chapter House

Room ChapterHouse "Chapter House"                                ! >ChapterHouse
  with
    description
      "The chapter house is a modest, rectangular room where the brothers
      gather each morning to discuss monastery business. A plain wooden table
      and benches occupy the center, and painted panels on the walls depict
      the hours of the divine office. In one corner stands a life-sized
      wooden statue.",
    w_to CloisterNE,
    cheap_scenery
      1 'scroll' "It's just a painted part of the statue.",
  has
    ;


Object -> ChapterFurniture "table and benches"               ! >ChapterFurniture
  with
    name 'table' 'tables' 'chair' 'chairs',
    describe 0,
    description "Both the table and the chairs are plainly made and wooden.",
    before [;
      Examine: ;
      Push, Pull, Turn:
        "You could move them, but for what purpose?
        They're just plain furniture.";
      Receive:
        "There would be no point cluttering this space with stuff.";
      Enter:
        "You have no reason to sit right now.";
      Take:
        "Leave the furniture be, Brother.";
    ]
  has supporter enterable pluralname;


Statue -> GordianStatue "statue"                                ! >GordianStatue
  with
    name 'gordian' 'statue',
    describe 0,
    description
      "A wooden statue, worn and with the paint flaking in
      places. You recognize it as Brother Gordian, who you have been told
      was the founder of the priory. His face is filled with reverence and
      curiosity, and he is depicted holding a scroll reading ~INGENIUM DEI~.",
    before [;
      Kiss: "That would only give you a splinter.";
      Order: "The statue doesn't respond, naturally.";
    ],
  has
    static ~proper;


Object -> OfficeHours "painted panel"                             ! >OfficeHours
  class AdjObject,
  with
    adj_name 'painted' 'office',
    noun_name 'panel' 'hours',
    description
      "It shows the offices:^
      ^Matins  3 AM     Sext     Noon
      ^Lauds   5 AM     None     3 PM
      ^Prime   6 AM     Vespers  6 PM
      ^Terce   9 AM     Compline 7 PM",
    before [;
      Take: "It's much too large to carry.";
      LookUnder, Search, Turn, Push, Pull:
        "It's painted onto a panel wall, and it doesn't move.";
    ]
  has
    scenery;


! --------------------------------------------------------- Scriptorium

Room Scriptorium "Scriptorium"                                    ! >Scriptorium
  with
    description
      "This chamber is where three of the brothers typically work, creating
      illuminated manuscripts and copying books. To the west is the cloister;
      to the east is the library.

      A large table is at the center where the work is done.",
    e_to LibraryDoor,
    w_to CloisterE,
    before [;
      Open, Unlock:
        if (noun == self && BrWilfred has general) {
          "You wouldn't dare try to enter the library with Brother Wilfred
          watching you!";
        }
      Smell:
        if (MandrakeRoot.burn_time) {
          print
            "Foolishly, you deeply inhale the mandrake yourself, and awaken by
            firm shaking by Brother Oswald.^^

            ~What madness, Brother Aldwin? What were you thinking?~

            You are sentenced to bread and water for a week.";
          KillOff();
        }
    ],
  has
     ;


Object -> ScriptoriumTable "table"                           ! >ScriptoriumTable
  with
    name 'table',
    description [;
      print
        "Large enough for four monks to work here";
      PrintContents(". On it ", self, ISARE_BIT);
      ".";
    ],
    before [;
      Search: "A search reveals nothing but the implements and manuscript.";
      LookUnder: "Just the floor.";
    ],
  has
    scenery supporter;


Object -> -> Manuscript "manuscript"                               ! >Manuscript
  with
    name 'manuscript',
    description
        "The manuscript is a psalter in progress, open to Psalm 23.
        The Latin text is written in a careful Gothic script, and
        someone---likely Brother Wilfred---has begun illuminating the
        initial ~D~ of ~Dominus~ with delicate gold leaf and azure.
        The shepherd's crook curves through the letter, and tiny sheep
        peek from the margins. It's beautiful work, though the hand
        that painted it must have trembled with age.",
    before [;
      Examine:
        if (verb_word == 'read')
          "The Latin reads: 'Dominus regit me, et nihil mihi deerit...'
          (The Lord is my shepherd, I shall not want...)";
        ! else will fall through to normal examine
      Search: "You discover nothing but the text iself.";
      LookUnder: "There is nothing below the manuscript.";
      default: "You shouldn't disturb the manuscript.";
    ]
  has ;


Object -> -> WritingImplements "writing implements"         ! >WritingImplements
  class AdjObject,
  with
    adj_name 'writing',
    noun_name 'implements' 'brush' 'brushes//p' 'ink' 'inks//p',
    description "Brushes and inks needed for the work.",
    before [;
      Examine: ;
      Smell: "They smell of the pigments used in copying.";
      default: "You shouldn't disturb these materials.";
    ],
  has pluralname;


Object -> -> LibraryKey "silver key"                               ! >LibraryKey
  class AdjObject,
  with
    adj_name 'library' 'silver',
    noun_name 'key',
    description
      "A simple silver key, tarnished with age. Brother Wilfred guards
      it jealously---it's his responsibility as librarian to control
      access to the priory's precious books.",
    before [;
      Take:
        if (BrWilfred in location && BrWilfred hasnt general) ! awake
          "Brother Wilfred's eyes snap up just as your hand reaches for it.
          ~Ah-ah,~ he says kindly but firmly, stifling a yawn. ~Not without
          the prior's leave, young Brother Aldwin.~";
    ],
    each_turn [;
      if (BrWilfred hasnt general
            && self notin ScriptoriumTable && ~~deadflag) {
        print
          "^Brother Wilfred discovers the missing key---you're caught.

          For violating such a serious rule of the priory, you are sentenced
          to bread and water for a week.";
        KillOff();
      }
    ]
  has ;


Object -> Fireplace "fireplace"                                     ! >Fireplace
  with
    name 'fireplace' 'fire',
    initial
      "A fireplace is built into the south wall, and a small fire is going,
      making the room warmer and helping keep the manuscripts dry from the
      sea air.",
    description
      "A plain chamber of stone built into the wall.",
    after [;
      Touch: "Ow, ow, ow.";
      Smell:
        "It smells of wood and smoke.";
      Receive:
        print "You toss ", (the) noun, " into the fire.^";
        if (noun == MandrakeRoot) <<Burn MandrakeRoot>>;
        remove noun; ! other things burn instantly
        rtrue;
    ],
  has
    container open;

! ----------------------------------------------------------------------------

Object -> LibraryDoor "library door"                              ! >LibraryDoor
  with
    name 'library' 'door',
    description "A heavy wooden door with a keyhole.",
    found_in Scriptorium Library,
    door_dir (w_to) (e_to),
    door_to Library,
    with_key LibraryKey,
    each_turn [;
      if (BrWilfred hasnt general && self has open) {
        print
          "^Brother Wilfred notices the open door to the library---you're
          caught!

          For violating a serious rule of the priory, you are sentenced to
          bread and water for a week.";
          KillOff();
      }
    ],
  has
    scenery door openable ~open lockable locked;


Room Library "Library"                                                ! >Library
  with
    description
      "This is a small private room. There is a bookshelf on the north wall
      and a large map of the priory on the south wall.
      The only exit to to the west.",
    w_to Scriptorium,
    before [;
      Smell: "Ah, the smell of dusty books.";
    ],
    cheap_scenery
      'manuscript' 'manuscripts'
        "There are many, but none seem significant."
  has
    light;


Object -> BrassMap "brass map"                                       ! >BrassMap
  class AdjObject,
  with
    adj_name 'brass',
    noun_name 'map',
    add_to_scope TwoCryptsOnMap,
    description
      "Finely etched into brass and signed by ~Brother Gordian~.
      It shows both the indoor and outdoor areas, from the dorms in the second
      floor all the way down to the two crypts below ground.",
  has
    scenery;


Object TwoCryptsOnMap "two crypts"                             ! >TwoCryptsOnMap
  with
    name 'two' 'crypts',
    description
      "Two crypts: a larger one, simply labeled ~Crypt~ and another,
      ~FitzAlan Crypt~.^^
      Now that you think of it, while you've been in the crypt before, you've
      never seen or heard of the other one.",
    after [;
      Examine:
        Achieved(TASK_DISCOVER_FA_CRYPT);
    ],
    has
      ;


Object -> Bookshelf "bookshelf"                                     ! >Bookshelf
  class AdjObject,
  with
    adj_name 'book',
    noun_name 'shelf' 'bookshelf' 'books' 'shelves',
    description [;
      print
        "The bookshelf has about fifty books, most of which are manuscripts,
        used for the work in the scriptorium";
      if (MonkGuide hasnt moved)
        print
          ". One that draws your attention is titled ~Registrum Fratrum~";
      ".";
    ],
    before [;
      Search:
        print "There are many books on the bookshelf";
        PrintContents(". Also on it ", self, ISARE_BIT);
        ".";
    ],
    add_to_scope [;
      if (MonkGuide in nothing) PlaceInScope(MonkGuide);
    ],
  has scenery supporter;


Object MonkGuide "Registrum Fratrum",                               ! >MonkGuide
  with
    name 'register' 'registrum' 'fratrum' 'book',
    description
      "The ~Registrum Fratrum~ (~Register of the Brothers~).
      A small leather-bound book providing information on the monks who
      have served in the priory.",
    before [ i last_word end ;
      Examine:
        if (verb_word == 'read')
          "It's too long to read through, but you can look up particular
          entries by name.";
      Consult:
        if (second == nothing || ~~(second provides history_text)) {
          print "You find no entry for ~";
          if (second == nothing) {
            last_word = consult_from + consult_words - 1;
            end = WordAddress(last_word) + WordLength(last_word);
            for (i = WordAddress(consult_from) : i < end : i++)
              print (char) i->0;
          }
        else {
          print (name) second;
        }
        "~ in ", (the) self, ".";
        }
        print_ret (string) second.history_text;
    ],
    after [;
      Take:
        Achieved(TASK_FINDING_GUIDE);
        "You carefully remove the Registrum Fratrum from the shelf.
        Brother Wilfred would be furious if he knew.";
    ],
  has
    proper;


! ----------------------------------------------------------------- Slype

Room Slype "Slype"                                                      ! >Slype
  with
    description
      "A long east-west stone corridor. West is the cloister,
      east is the infirmary. A small passage heads south to the herbarium.",
    s_to Herbarium,
    e_to Infirmary,
    w_to CloisterSE,
  has
     ;

! --------------------------------------------------------------

! PUZZLE: opening the cabinet
! PUZZLE: identifying the poison

Room Infirmary "Infirmary"                                          ! >Infirmary
  with
    description
      "The infirmary serves both the brothers and visiting villagers who seek
      healing. Several narrow beds line the western wall, their straw mattresses
      covered with coarse linen. A workbench holds mortars, bowls, and various
      implements for preparing remedies. The air smells of herbs, vinegar, and
      illness. A polished metal mirror hangs on the wall---unusual luxury, but
      necessary for examining patients' throats and eyes. The medicine cabinet
      stands against the north wall. A small chapel lies to the south, and
      the slype is to the west.",
    s_to InfirmaryChapel,
    w_to Slype,
    before [;
      Smell: if (noun == nothing) "A sharp, bitter smell.";
    ],
    cheap_scenery
      1 'beds' "They're just beds, with nothing on or under them."
      1 'mortars'
        "Useful for grinding medicine, but you should leave them alone."
      1 'bowels'
        "Unremarkable clay pots"
      'various' 'implements' "You don't need to worry about these.",
  has
    ;


Object -> Mirror "mirror"                                              ! >Mirror
  class AdjObject,
  with
    adj_name 'reflective' 'metal',
    noun_name 'mirror' 'plate',
    react_before [;
      Examine:
        if (noun == selfobj) {
          print "(in the mirror)^";
          <<Examine Mirror>>;
        }
    ],
    before [;
      Examine:
        "A young face, barely requiring shaving. stares back at you.
        Your black Benedictine habit hangs loose on your thin frame.
        No tonsure marks your crown---you're
        still a novice, not yet bound by final vows.
        Brother Aelred used to say you had honest eyes.
        You hope he was right.";
      Attack, Cut:
        "Next, you'll want to cross a black cat's path?";
    ],
  has
    ;


Object -> InfirmaryCabinet "medicine cabinet"                ! >InfirmaryCabinet
  with
    name 'medicine' 'cabinet',
    description [;
      print
        "A wooden cabinet secured with a brass lock mechanism. Four wheels,
        each engraved with digits ~0~ through ~9~, can be rotated
        independently. Carved into the wood above the lock:
        ~Historia nostra, fides nostra~.";
      if (self hasnt general)
        print
          "^^You remember Brother Aelred mentioning this cabinet:
          ~Brother Benedict is trusting. He doesn't want to keep medicines
          from his brothers in need, only from the village folk we treat.
          It's set to something every brother knows---outsiders wouldn't
          think to look for it.~";
      give self general;

      print
        "^^The four wheels currently show: ", Wheel1.setting, "-",
        Wheel2.setting, "-", Wheel3.setting, "-", Wheel4.setting;
      ".";
    ],
    check_combination [;
      ! 1152 = founding date
      if (Wheel1.setting == 1 && Wheel2.setting == 1
          && Wheel3.setting == 5 && Wheel4.setting == 2) {
        if (self hasnt open) {
          give self open;
          Achieved(TASK_OPEN_CABINET);
          "^You hear a satisfying click as the lock disengages and
          the cabinet opens.";
        }
      } else {
        give self ~open;
      }
    ],
    before [;
      Open:
        if (self has open) "The cabinet is already open.";
        if (~~self.check_combination()) "The cabinet remains locked.";
      Search:
        if (self hasnt open) <<Open self>>;
      Examine:
        if (self has open) <<Search self>>;
    ],
  has
    container openable ~open;


Tincture -> -> FoxgloveTincture "tincture of foxglove"       ! >FoxgloveTincture
  with
    name 'poppy' 'syrup' 'opium',
    description
      "A small bottle of a murky yellow-brown liquid. You know from Brother
      Aelred that this can be miraculous for the heart in small quantities,
      but in greater quantities, it can be deadly."
    scent "bitter and earthy.",
    flavor "unpleasantly bitter with a strong grassy taste.",
  ;


Tincture -> -> HenbaneTincture "tincture of henbane"          ! >HenbaneTincture
  with
    name 'hen' 'bane' 'henbane',
    description
      "A small bottle of a greenish-brown liquid. You know from Brother Aelred
      that this is used for sedative purposes, though it does have disturbing
      side-effects. If used in excess, it can be fatal.^^
      This bottle is almost entirely empty, with only a bit remaining.",
    scent "overtones of alcohol and urine.",
    flavor "gluey, unpleasant, and bitter.",
    identified [;
      Achieved(TASK_IDENTIFY_POISON);
      f_identified_poison = true;
      if (suspicion_level == 0) suspicion_level = 1;
      "^That's it---you now know that your dear mentor was poisoned with ",
      (the) self, ". You know you'll need to figure out who killed him and
      why.";
    ],
    before [;
      Smell:
        "There's so little left, you can only catch a whiff of the alcohol
        used to make the tincture.";
      Taste:
        self.lick();
        give self general;
        if (f_smelled_aelred) self.identified();
    ],
  ;


Tincture -> -> Theriac "theriac"                                      ! >Theriac
  with
    name 'theriac',
    description
      "A small bottle of a dark brown, sticky paste. You know from Brother
      Aelred that this is often used as a restorative and antidote for
      poisons.",
    scent "complex notes of honey and exotic spices.",
    flavor "overpoweringly sweet and bitter.",
  ;


Class Wheel                                                             ! >Wheel
  with
    setting 0,  ! starts at I
    set_me [;
        print "You turn ", (the) self, " to ", self.setting, ".^";
        InfirmaryCabinet.check_combination();
    ],
    before [;
      SetTo:
        if (InfirmaryCabinet has open)
          "The wheels can't be turned while the cabinet is open.";
        self.setting = second;
        self.set_me();
        rtrue;
      Turn:
        if (InfirmaryCabinet has open)
          "The wheels can't be turned while the cabinet is open.";
        self.setting++;
        if (self.setting > 9) self.setting = 0;
        self.set_me();
        rtrue;
      Examine:
        print_ret (The) self, " is currently set to ", self.setting, ".";
    ],
  has
    scenery;

Wheel -> Wheel1 "first wheel"                                          ! >Wheel1
  with name 'first' '1st' 'one' 'wheel';

Wheel -> Wheel2 "second wheel"                                         ! >Wheel2
  with name 'second' '2nd' 'two' 'wheel';

Wheel -> Wheel3 "third wheel"                                          ! >Wheel3
  with name 'third' '3rd' 'three' 'wheel';

Wheel -> Wheel4 "fourth wheel"                                         ! >Wheel4
  with name 'fourth' '4th' 'four' 'wheel';


! ----------------------------------------------------------- Infirmary Chapel
! The player can only entere here after the death, so we can
! write this knowing there will be a body in it, etc.

Room InfirmaryChapel "Infirmary Chapel"                       ! >InfirmaryChapel
  with
    description
        "A tiny chapel attached to the infirmary, barely large enough for a
        priest and one or two others. A simple stone altar stands against the
        east wall. This is where the dying receive Last Rites, where the
        desperately ill make their final prayers. The air is heavy with the
        memory of fear and hope. The infirmary lies to the north.",
    n_to Infirmary,
    cheap_scenery
      1 'eyes' [;
        print "His eyes are wide and dilated";
        if (f_identified_poison)
          "---a telltale sign of henbane poisoning";
        ".";
      ],
  has ;


Altar -> InfirmaryAltar "altar";                               ! >InfirmaryAltar


! PUZZLE: find the key for the restricted garden
! PUZZLE: identify the poison

Object -> -> BrAelredBody "Brother Aelred's body"                ! >BrAelredBody
  class AdjObject,
  with
    adj_name 'brother' 'aelred^s' 'earthly',
    noun_name 'body' 'corpse' 'remains' 'aelred',
    initial "On the altar is Brother Aelred's earthly remains.",
    description [;
      if (self hasnt moved) {
        QuoteBoxSimple(quote_body);
        give self moved;
      }
      print
        "Your beloved mentor lies still on the altar, still dressed,
        covered with a simple
        white shroud. His face is visibly peaceful now, though you remember
        his agony earlier. His eyes are still open---staring upward as if
        fixed on Heaven, his hands folded
        across his chest";
      if (self hasnt general)
        print
          ". Something seems odd about him, though you can't quite place it";
      else if (f_identified_poison)
        print
          ". Now you notice: even in death, his pupils remain enormously
          dilated---a telltale sign of henbane poisoning.";
      ".";
    ],
    react_before [;
      Smell:
        "There is an odd faint odor in the air.";
      Pray:
        "You whisper a small sad prayer to your dear mentor.
        You fervently hope he can hear you.";
    ],
    before [;
      Smell:
        if (self hasnt general) {
          give self general;
          "There's an odd smell about his remains---something like alcohol
          and urine in his mouth. Unusual.";
        }
        "That same odd smell lingers.";
      Kiss:
        "You reverently kiss him on the forehead---and then notice an odd
        odor about his remains.";
      Touch: "Already cold.";
      Attack, Cut, Burn: "Absolute blasphemy!";
      LookUnder:
        "Shifting the body slightly, you find nothing underneath.";
      Turn, Push, Pull:
        "You dare not disturb the dead---particularly
        not one who was so dear to you.";
      Take:
        "Moving him would be deeply inappropriate. Plus, he's much too heavy
        to carry.";
      Search:
        if (GardenGateKey hasnt moved) {
          move GardenGateKey to player;
          "In an inner pocket of his robe, you find ", (a) GardenGateKey, ",
          the key to the restricted garden.";
        }
    ],
    life [;
      Give:
        "He is beyond earthly needs.";
      WakeOther:
        "You've been studying Lazarus too much.";
      default:
        "While in life, he overflowed with joyful energy---alas, no more.";
    ],
  has animate;


Object -> -> Shroud "shroud"                                           ! >Shroud
  class AdjObject,
  with
    adj_name 'white',
    noun_name 'shroud',
    description "A simple and dignified white cloth.",
    before [;
      Examine: ;
      Search: "There is nothing underneath it but the body of your mentor.";
      default: "Leave the shroud be, Brother.";
    ],
  has ;


Statue -> RochStatue "statue"                                      ! >RochStatue
  with
    name 'roch',
    description
      "It depicts St Roch, patron saint of plague victims and the sick.
      He's depicted pointing to a plague sore on his leg."
  has ;


! ------------------------------------------------------------------- Herbarium

Room Herbarium "Herbarium"                                          ! >Herbarium
  with
    description
      "This room still carries Brother Aelred's presence in every corner.
      Bundles of dried herbs hang from the rafters.
      The worktable bears the marks of his careful hands: ink-labeled jars
      in his script, worn grooves where he ground countless remedies.
      A large terracotta pot in the corner was used often to transfer plants.
      Without him here, the room feels hollow.
      ^^The slype lies north, and the garden---his garden---waits
      to the south.",
    n_to Slype,
    s_to Garden,
    out_to Garden,
    cheap_scenery
      3 'thyme' 'rosemary' 'feverfew' [;
        Examine:
          "You can just see them to recognize them, but can't reach them.";
        default:
          "They're too far out of your reach to do anything with.";
      ]
      1 'grooves' "They're just grooves in the table."
   has
     ;


! PUZZLE: another way to get the restricted garden key

Object -> Pot "plant pot"                                                 ! >Pot
  class AdjObject,
  with
    adj_name 'large' 'terracotta' 'plant',
    noun_name 'pot',
    describe 0,
    description "A substantial pot, perfect for repotting a large plant.",
    before [;
      Turn, Pull, Push, LookUnder:
        if (GardenGateKey hasnt moved) {
          move GardenGateKey to player;
          "Underneath the pot, you find ", (a) GardenGateKey, ",
          the key to the restricted garden.";
        }
    ],
  has
    container open;


Object -> Jars "jars"                                                    ! >Jars
  with
    name 'jars',
    description
      "There are almost two dozen of the them, each carefully labeled.
      You know these well---mangaging these has become your daily labor
      for the past few months. You don't see anything missing or unusual
      about them.",
    before [;
      Take: "Leave them be. You have other tasks to do.";
    ],
  has concealed pluralname;


Object -> HerbTable "worktable"                                     ! >HerbTable
  class AdjObject,
  with
    adj_name 'work',
    noun_name 'worktable' 'table',
    describe 0,
    react_before [;
      Go:
        if (player in self) {
          if (selected_direction == d_to) <<Exit self>>;
          "You'd have to climb down from ", (the) self, " first.";
        };
    ],
    description [;
      print
        "A large, heavy table where you and Brother Aelred did your
        daily work";
      PrintContents(". On it ", self, ISARE_BIT);
      ".";
    ],
    find_basket [;
      if (Basket hasnt moved) {
        give Basket ~concealed;
        "Looking below the table, you find Brother Aelred's basket,
        which he used for gathering and carrying herbs.";
      }
    ],
    before [;
      Search, LookUnder:
        if (self.find_basket()) rtrue;
      Climb: <<Enter self>>;
    ],
    after [;
      Enter: "You climb up onto the worktable.";
      Exit: "You climb down from the worktable.";
    ],
  has
    static supporter enterable;


! PUZZLE: need to handle dangerous plants

Object -> -> Gloves "gloves"                                           ! >Gloves
  with
    name 'gloves',
    description "A pair of rough gloves, used by Aelred in the gardens.",
    after [;
      Wear: "They fit perfectly.";
    ],
  has
    clothing pluralname;


! PUZZLE: need to identify poison

Object -> -> Herbal "Aelred's Herbal"                                  ! >Herbal
  class AdjObject,
  with
    adj_name 'aelred' 'aelred^s',
    noun_name 'herbal' 'book',
    description
      "A thin volume, but very handy: it lists many herbs and other plants,
      along with descriptions of them and their uses.",
    before [ end i last_word ;
      Examine:
        if (verb_word == 'read')
          "It's much too dense to read the entire thing. You can consult it
          by looking up a plant by name.";
      Consult:
        if (second == nothing || ~~(second provides herb_text)) {
          print "You find no entry for ~";
          if (second == nothing) {
            last_word = consult_from + consult_words - 1;
            end = WordAddress(last_word) + WordLength(last_word);
            for (i = WordAddress(consult_from) : i < end : i++)
              print (char) i->0;
          }
        else {
          print (name) second;
        }
        "~ in ", (the) self, ".";
        }
        print_ret (string) second.herb_text;
    ],
  has proper;


! PUZZLE: need for carrying contraband

Object -> Basket "basket"                                              ! >Basket
  with
    name 'basket',
    description [;
      print
        "A deep flax basket with a closable lid---useful when
        harvesting herbs and carrying them to the infirmary";
      PrintContents(". In it ", self, ISARE_BIT);
      ".";
    ],
    before [;
      Receive:
        if (noun has light)
          "Placing a lit item in the basket would surely catch it on fire.";
    ],
  has
    concealed container open openable ok_carry;


! PUZZLE: hints more about basil; it's the only thing not hanging here,
!   so it might help them decide to look at it in garden

Object -> Rafters "rafters"                                           ! >Rafters
  with
    name 'rafters' 'bunches' 'herbs',
    description [;
      if (parent(player) ~= HerbTable)
        "The different bunches of herbs hang from the rafters.
        From here, you can't quite make out what they are.";
      "Three different bunches hang from the rafters.
      They're still out of your grasp---Brother Aelred
      was much taller than you---but recognize them as
      thyme, rosemary, and feverfew.";
