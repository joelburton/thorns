[ ChooseObjects obj code ;
  ! When in these locations, bump up odds player is referring to right key

  ! help out with "burn (candle) with (candle)"
  if (obj == MyCandle or TallowCandle && action == ##Burn
      && location == NightStairs && noun == nothing) return 9;
  if (obj == TimeCandle && action == ##Burn && noun) return 9;

  if (location == Scriptorium && obj == LibraryKey && code == 2) {
    return 9;
  }
  if (location == Garden && obj == GardenGateKey && code == 2) {
    return 9;
  }

  ! important to keep this; otherwise, tries to get EVERYTHING
  rfalse;
];

[ DarkToDark ;
  ! During the crypt escape, can move dark-to-dark
  if (CryptBell has general) rfalse;
  print
    "You've always heard dark tales of demons lurking in lightless places, and
    these have haunted you since childhood.
    ^^After several minutes fumbling and failing to get your bearings, terror
    takes you and you begin screaming.
    ^^Soon, Brother Cuthbert arrives bearing a candle. ~Brother Aldwin?~
    he demands, ~What on earth are you doing here?~
    ^^When he hears of this, Brother Oswald sentences you to a week of bread
    and water.";
  KillOff();
];


Constant DEAD_FAILED 3;
Constant DEAD_ILL 4;
Constant DEAD_UNSOLVED 6;
Constant DEAD_JUSTICE 7;
Constant DEAD_MERCY 8;
Constant DEAD_INACTION 9;

[ DeathMessage;
  switch(deadflag) {
    ! no "won" or "died" possible
    DEAD_FAILED: print "You have failed";
    DEAD_ILL: print "You have fallen very ill";
    DEAD_UNSOLVED: print "You failed to solve the mystery";
    DEAD_JUSTICE: print "You chose justice";
    DEAD_MERCY: print "You chose mercy";
    DEAD_INACTION: print "You chose inaction";
  }
];


[ NewRoom i ;
  i = 0;  ! prevent warning if unused

  if (location provides on_first_entry && location hasnt visited) {
    location.on_first_entry();
  }

  ! Move Pax into cloister area:
  ! - not during important scenes; it's distrating
  ! - don't remove him from player
  ! - don't need to worry about removing from Wilfred, since Scriptorium
  !   isn't a closter space
  if (SceneFollowRemigio has general || SceneWandering has general) rfalse;
  if (location ofclass Cloister
      && parent(Pax) ~= player && random(6) == 1) move Pax to location;
];


[ CheckHidContraband o ;
  if (o hasnt ok_carry && ~~task_done->TASK_HID_CONTRABAND) {
    TaskDone(TASK_HID_CONTRABAND);
    print
      "You found a way to carry illicit things around without others
      noticing. ";
  }
];


[ CheckForContraband mir o caught_with mloc ;

  ! TODO: should think on this. is this too generous?
  ! but don't want them dying going to the last service with the psalter,
  ! either
  if (enough_evidence) rfalse;

  ! Don't do this during the crypt rescue since there's so much darkness and
  ! hiding and such
  if (SceneCrypt has general) rfalse;

  ! check for contraband, first thing becomes 'caught_with':
  objectloop (o in player) {
    if (o hasnt ok_carry) {
      caught_with = o;
      break;
    }
  }

  ! no contraband, safe
  if (caught_with == 0) rfalse;

  mir = NarcInRoom();
  if (mir == 0) rfalse;

  if (MyCandle has light || TallowCandle has light) {
    print "^", (The) mir,
      " catches you carrying the lit candle.
      ~Where did you get that? Candles aren't to be wasted by novices.~
      ^^For disobeying the rules of the priory, you are given penance of
      bread and water for a week.";
      KillOff();
      rtrue;
  }

  f_warned_contraband++;
  switch (f_warned_contraband) {
    1: rfalse;
    2:
      print "^You should be more careful. If ", (the) mir, " had noticed";
      " you openly carrying ", (the) caught_with,
      ", you'd have faced severe punishment.";
    3:
      "^Again: be careful! Openly carrying contraband, like ",
      (the) caught_with, ", will get you in trouble.";
    4 to 100:
      print "^", (The) mir, " ", ;
      mloc = parent(mir);
      if (parent(mloc) ~= nothing) mloc = parent(mloc);
      if (mloc ~= location) print "enters the area. He ";
      print
        "notices you openly carrying ", (the) caught_with,
        ". ~Brother Novice, what are you doing with that? That has nothing
        to do with your duties here.~
        ^^For disobeying the rules of the priory, you are given penance of
        bread and water for a week.";
      #IfDef DEBUG;
        "^^*** DEBUG: not actually killing you so we can debug this well.^";
      #IfNot;
        KillOff();
      #EndIF;
  }
];


[ CalculateEvidence
        _coins _psalter _henbane _note _chron _letters _hugh_attempt _total;
  ! *need* to know it's a suspicious death, and have a reason to blame hugh
  _coins = task_done->TASK_EVIDENCE_COINS * 5;
  _psalter = task_done->TASK_EVIDENCE_PSALTER * 5;
  _henbane = task_done->TASK_EVIDENCE_HENBANE_DECOCT * 5;
  _note = task_done->TASK_EVIDENCE_LETTER * 5;
  _chron = task_done->TASK_READ_CHRONICLE * 2;
  _letters = task_done->TASK_ROSE_LETTERS * 3;
  _hugh_attempt = ev_hugh_attempt * 5; ! hugh attempted to kill us!

  ! don't even know it's a death
  if (~~suspicion_level) rfalse;

  ! no crime proved
  if (~~(_coins || _psalter || _note)) rfalse;

  ! preponderance of evidence
  _total = (_coins + _psalter + _henbane + _note + _chron + _letters
      + _hugh_attempt + suspicion_level);
  #IfDef DEBUG;
    ! print "*** ev_total = ", _total, "^";
  #EndIf;

  return _total;
];

Global waittime_waiting = false;

[ TimePasses o contraband ;
  ! Called at end of turn when # moves goes up
  SetTime(the_time + 1);
  if (CheckCareless()) rfalse;

  if (~~f_noted_having_contraband_first_time) {
    objectloop (o in player) {
      if (o hasnt ok_carry) {
        contraband = true;
        continue;
      }
    }
    if (contraband) {
      print
        "^Remember: the Prior would be upset if he saw you openly carrying items
        not related to your tasks here. You should find a way to hide these.^";
      f_noted_having_contraband_first_time = true;
    }
  }

  if (~~waittime_waiting) {
    CheckEvidence();
    CheckForContraband();
    if (deadflag) rfalse;
    evidence_count = CalculateEvidence();
    if (enough_evidence == 0 && evidence_count >= 18) {
      enough_evidence = true;
      #Ifv5; @set_text_style 2; #EndIf;
      print "^^Note: ";
      #Ifv5; @set_text_style 0; #EndIf;
      "You feel like you've learned enough to solve the crime---but you can
      gather more if you'd like to better understand the crime.
      ^^If you want to make your accusation public, you can do so at the
      next Divine Office. If you'd like to talk with a sympathetic Brother
      first, you can do so.";
    }
  }

  ! If a service should be starting, start it
  objectloop (o ofclass SceneService)
    if (the_time >= o.time_start - 2 && o hasnt visited && o hasnt active) {
      o.scene_start();
      if (waittime_waiting) {
        waittime_waiting = false;
        print "^(stopped before time since a service is starting)";
      }

      ! optimization --- only on service can happen at a time, so stop checking
      continue;
    }
];


[ InScope ;
  ! if we do this, it doesn't put scenes in scope
  if (scope_reason ~= PARSING_REASON) rfalse;
  ! print "*** InScope^";

  ! Player should have access to certain objects when in the dark
  if (location == thedark) {
    if (real_location == Sacristy) {
      PlaceInScope(SacristyDoor);  ! so we can find door
      PlaceInScope(Sacristy);      ! so room actions, like smell, work
    }
    else if (real_location == Crypt) {
      ! Otherwise, player can't turn-off-light and then hide or ring bell.
      PlaceInScope(CryptBell);
      PlaceInScope(TombEzra);
      PlaceInScope(BlankPanel);
    }
    else if (real_location == FitzAlanCrypt) {
      PlaceInScope(FitzAlanPanel);
      PlaceInScope(Frame);
      PlaceInScope(Button);
    }
  }

  ! Place active scene(s) in scope, so they can have each_turn, react_before
  !objectloop(s ofclass Scene)
  !  if (s has active) PlaceInScope(s);

  rfalse;   ! required, otherwise doesn't add room stuff to scope!
];


! Is this a room?
[ IsARoom p_obj;
  #Ifv5;
    #IfDef DEBUG;
      if (action == ##Places or ##Rooms or ##GoTo or ##Purloin) {
    #IfNot;
      if (action == ##Places) {
    #EndIf;
        ! just list real rooms for "PLACES", "GOTO" and "ROOMS"
        if (p_obj ofclass Room or Cloister) return 1;
        return 2;
      } else if (action == ##Objects) {
        if (p_obj ofclass Room or Cloister or Scene) return 1;
        return 2;
      }
  #EndIf;
  if (p_obj ofclass Room or Cloister) return 1;
  return 2;
  ];


[ DisallowTakeAnimate p_object;
    if (p_object == Pax) rfalse;
];



Include "puny.h";


! Thanks to Garry Francis (Warrigal) for this code.

[ LockSub k;
  if (ObjectIsUntouchable(noun))
    rtrue;
  if (noun hasnt lockable)
  {
    PrintMsg(MSG_LOCK_NOT_A_LOCK, 'lock');
    rtrue;
  }
  if (noun has locked)
  {
    PrintMsg(MSG_LOCK_ALREADY_LOCKED);
    rtrue;
  }
  if (noun has open)
  {
    PrintMsg(MSG_LOCK_CLOSE_FIRST);
    rtrue;
  }
  k = RunRoutines(noun, with_key);
  if (k == nothing)
    "You can't see how to lock ", (ItOrThem)noun, ".";
  if (second == nothing && k ~= nothing && IndirectlyContains(player, k))
  {
    second = k;
    print "(with ", (the)second, ")^";
  }
  if (second == nothing)
    "You don't have the key.";
  if (second ~= k)
  {
    PrintMsg(MSG_LOCK_KEY_DOESNT_FIT);
    rtrue;
  }
  give noun locked;
  run_after_routines_msg = MSG_LOCK_DEFAULT;
  run_after_routines_arg_1 = 'lock';
];

[ UnlockSub k;
  if (ObjectIsUntouchable(noun))
    rtrue;
  if (noun hasnt lockable)
  {
    PrintMsg(MSG_UNLOCK_NOT_A_LOCK, 'unlock');
    rtrue;
  }
  if (noun hasnt locked)
  {
    PrintMsg(MSG_UNLOCK_ALREADY_UNLOCKED, 'unlock');
    rtrue;
  }
  k = RunRoutines(noun, with_key);
  if (k == nothing)
    "You can't see how to unlock ", (ItOrThem)noun, ".";
  if (second == nothing && k ~= nothing && IndirectlyContains(player, k))
  {
    second = k;
    print "(with ", (the)second, ")^";
  }
  if (second == nothing)
    "You don't have the key.";
  if (second ~= k)
  {
    PrintMsg(MSG_UNLOCK_KEY_DOESNT_FIT);
    rtrue;
  }
  give noun ~locked;
  run_after_routines_msg = MSG_UNLOCK_DEFAULT;
  run_after_routines_arg_1 = 'unlock';
];



! need to declare this library *after* puny, unlike others
Include "extlib/my_waittime.h";


! Have to put replacement here, after library

[ ImplicitGrabIfNotHeld arg1 arg2 sprig;
    if (arg1 == MyHood or MyRobe) rfalse;
    if (arg1 ofclass Plant) {
      ! Prevents "first taking the basil plant" with "> EAT BASIL"
      sprig = child(arg1);
      if (sprig == nothing)
        "You've already picked a sprig from ", (the) arg1,
        ". You should do this with that.";
      print "(first taking just a sprig from ", (the) arg1, ")^";
      ! move sprig to player;
      move sprig to location;
      give sprig moved;
      noun = sprig;
      TryToTakeNoun(sprig);
      rfalse;
    }
    return OriginalImplicitGrab(arg1, arg2);
];


[ _GuessMissingNoun p_type p_prep p_nounphrase_num _i _noun ;
  ! If the player doesn't have a key, don't guess for lock/unlock
  !  otherwise, made really strange choices like your robe
  if (action == ##Unlock or ##Lock) {
	  for(_i = 0: _i < scope_objects: _i++) {
      _noun = scope-->_i;
      if (_noun == LibraryKey or GardenGateKey)
        return Original_GuessMissingNoun(p_type, p_prep, p_nounphrase_num);
    }
    return 0;
  }
  return Original_GuessMissingNoun(p_type, p_prep, p_nounphrase_num);
];

! Use on objects that have listing_together as a routine; this should print
! a shorter name, so "spring of basil" becomes just "basil", so it does things
! like "You are carrying several sprigs (basil and rosemary)"

[ _PrintObjName p_obj p_form;
	if (listing_together) {
		print (address) p_obj.&name-->0;
		return;
	}
  Original_PrintObjName(p_obj, p_form);
];


! This allows the PLACES verb, but not OBJECTS
!   because it gets cluttered up with everything scope, like scenes.
! [ ObjectsSub;
!   print_ret (string) MSG_PARSER_UNKNOWN_VERB;
! ];

! ================================================================ Verbs

! "LOOK UP FOO IN BOOK" scope --- rather than using topics, I use objects as
! the things that can be looked up (this allows the normal parsing to find
! things, so stuff like "LOOK UP HUGH IN BOOK" and "LOOK UP BROTHER HUGH IN
! BOOK" both work because the BrHugh handles that itself)
[ ConsultScope o ;
  switch (scope_stage) {
    1: rfalse;
    2:
      objectloop (o provides history_text) PlaceInScope(o);
    3:
      "I don't know the resource you're trying to use.";
  }
];


[ AskScope o;
  switch (scope_stage) {
    1: rfalse;
    2:
      if (location == Infirmary) {
        ScopeWithin(InfirmaryCabinet);
        PlaceInScope(InfirmaryCabinet);
        PlaceInScope(Mirror);
      } else if (location == Scriptorium) {
        PlaceInScope(Breviary);
        if (ev_psalter || ev_chronicle)
          PlaceInScope(StolenPsalter);
      }

      objectloop (o provides history_text) PlaceInScope(o);
      rtrue;
    3: "*** PLEASE REPORT BUG: AskScope";
  }
];

Extend 'ask' first
  * creature 'about' scope=AskScope       -> Ask;

Extend 'blow' first
  * 'on' noun                             -> Blow;

Extend 'climb' first
  * 'on' noun                             -> Climb
  * 'up' 'on' noun                        -> Climb
  * 'down'                                -> Exit
  * 'down' noun                           -> Exit
  * 'in' container                        -> Enter ;

Extend 'consult' first
	* held 'about'/'on' scope=ConsultScope  -> Consult;

Verb 'extinguish'
  * noun                                  -> Extinguish
  * 'light'                               -> Extinguish;

Extend 'light' first
  * noun 'using' noun                          -> Burn
  * noun 'from' noun                           -> Burn;

Extend 'put' first
  * 'out' noun                            -> Extinguish;

Extend 'blow' first
  * 'out'/'on' noun                       -> Extinguish;

Verb 'hide'
  * 'by'/'behind' noun                    -> Hide
  *                                       -> Hide;

Verb 'pet'
  * creature                              -> Kiss;

Verb 'plant'
  * held                                  -> Dig
  *                                       -> Dig;

Extend 'dig'
  *                                       -> Dig;

Extend 'get' first
  * 'down'                                -> Exit;

Verb meta 'help'
  *                                       -> Help;

Extend 'jump'
  * 'on' noun                             -> Climb;

Verb 'kneel'
  * 'on' supporter                        -> Enter;

Extend 'look'
  * 'beneath'/'under'/'behind' noun       -> LookUnder;

Extend 'look' first
	* 'up' scope=ConsultScope 'in' held     -> Consult reverse
  * 'up' topic 'in' held                  -> Consult reverse
  * 'in' held 'about' scope=ConsultScope  -> Consult;

Verb meta 'map'
  *                                       -> Map;

Extend 'read' first
	* 'about' scope=ConsultScope 'in' held  -> Consult reverse
	* scope=ConsultScope 'in' held          -> Consult reverse;

Verb 'ring' 'toll' 'peal'
  * noun                                  -> Pull;

Extend only 'sit' first
  * 'down'                                -> SitAny
  *                                       -> SitAny;

Extend 'turn' first
  * noun 'to' number                      -> SetTo;

Verb 'xyzzy' 'plugh'
  *                                       -> Xyzzy;

Verb meta 'offices'
  *                                       -> Offices;

Verb meta 'time'
  *                                       -> Time;

Extend 'lock' first
  * noun                                  -> Lock;

Extend 'unlock' first
  * noun                                  -> Unlock;

Verb 'confess'
  * 'to' creature                         -> Confess;

Verb 'knock'
  * 'on' noun                             -> Knock;

! So crypt gate can say you don't have right key
Object DummyKey ;

! ========================================================= Verb Subs

[ KnockSub ;
  if (noun hasnt door) "This action results in nothing.";
  "There is no reply.";
];

