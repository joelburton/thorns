Constant Story "Our Lady of Thorns";
Constant Headline "^An interactive mystery^";

Include "Parser";
Include "VerbLib";

Verb 'ring' 'toll' 'peal'
  * noun -> Pull;

! ========================================== church

! ---------------------- entrance

Object WestPorch "West Porch"
  with
    name 'west' 'porch' 'entrance',
    description 
      "This small covered entrance protects the west door from the
      winds that come across the great cliffs. 
      Villagers used to gather here before services, 
      but the number who do so have been declining for years.",
    e_to WestDoor,
    cant_go 
      "It is forbidden for you to leave the Priory grounds without permission
      of Brother Prior.",
  has
    light;

Object -> WestDoor "west door"
  with
    name 'west' 'door' 'sign' 'stone' 'inscription',
    description [;
        if (self has open)
          "The great door is open, revealing the Nave within.";
        "The great oaken door is closed. Carved deeply into its face:^^
        @@32@@32NOSTRA DOMINA SPINARUM (~Our Lady of Thorns~)^
        @@32@@32FUNDATUM ANNO DOMINI MCCXLVII.^^
        Nearly two hundred years of wind and rain have worn the letters smooth.";
    ],
    door_dir e_to,
    door_to Nave
  has 
    scenery static door openable open ~lockable ~locked;

! ------------------------------ church

Object Nave "Nave"
  with
    description
      "The public space of the church, where villagers stand for Mass. 
      The stone floor is worn smooth by centuries of feet. 
      High above, narrow windows admit pale light.
      The quire lies to the east, separated by a rood screen. 
      A narrow doorway in the north wall leads to the bell tower stairs.",
    e_to Quire,
    w_to WestPorch,
    u_to TowerStairs,
    n_to TowerStairs,
  has
    light;

Object RoodScreen "rood screen"
  with
    name 'rood' 'screen' 'wooden',
    description
      "A wooden screen separates the nave from the quire, dividing the 
      public space from the sacred. A simple carved cross tops the 
      screen--the rood that gives it its name. The wood is dark with age and 
      centuries of candle smoke.",
    found_in Nave Quire,
  has
    scenery static;

Object RoodCross "rood cross"
  with
    name 'cross' 'rood',
    description "Simply carved and without ornamentation.",
    found_in Nave Quire,
  has
    scenery static;

Object TowerStairs "Tower Stairs"
  with
    name 'stone' 'stairs', 
    description 
      "A narrow spiral staircase winds upward. The stone steps 
      are worn smooth and treacherously steep - centuries of bell-ringers 
      have climbed this way. Cold air and dim light flows down from above.",
    d_to Nave,
    s_to Nave,
    u_to BellTower,
  has
    light;

Object BellTower "Bell Tower"
  with
    description 
      "The bell chamber. Wind whistles through the open arches on all four sides. 
      The great bronze bell hangs overhead. 
      From here, you have clear views in all four directions.",
    d_to TowerStairs,
    before [;
      LookDir: 
        if (noun == n_obj)
          "To the north, you can see rough coast and cliffs, dotted with small farms.";
        if (noun == s_obj)
          "South of here, you see the cloister surrounding the garth,
          the priory's roofs, and the herb garden.
          How you've learned to love that garden.";
        if (noun == w_obj) 
          "West lies the path that to the small village nestled far down in the vale.";
        if (noun == e_obj)
          "East, you can make out the infirmary and its chapel near the cliffs,
          and the dorter's small winow breaking the upper story wall.";
        if (noun == u_obj)
          "The great bell hangs above you, dark against the sky.";
        if (noun == d_obj)
          print "The stone floor of the bell chamber, and through the 
      opening, the stairs descending.^^";
        "You can look in any of the four compass directions.";
    ],
  has
    light;

Object -> Bell "bell"
  with
    name 'bell' 'bronze' 'great',
    description 
      "A bronze bell, green with age. Cast nearly two centuries ago, 
      its surface bears a Latin inscription: ~VOX DOMINI~",
    before [;
      Touch, Push, Pull:
        <<Pull BellRope>>;
      Take:
        "The bell weighs more than you do.";
    ],
  has
    static scenery;

Object -> BellRope "bell rope"
  with
    name 'bell' 'rope' 'cord',
    description 
      "The cord reaches up to the bell, far above. Ringing the bell yourself
      would earn severe punishment. That duty belongs to the bell-ringer, not to novices.",
    before [;
      Climb, Tie: 
        StartTimer(self, 3);
        "As you pull the cord to do that, the bell tolls, echoing across the priory.
        Instinctively you let go of the cord.";
      Pull:
        StartTimer(self, 3);
        "Pulling the cord emits a great peal that echoes for miles.";
    ],
    time_left,
    time_out [;
      deadflag = 3;
      "^Prior Oswald appears, his face dark with anger.^^
      ~What madness is this? Ringing the bells without cause? 
      The entire village thinks we're under attack!~^^
      You are confined to your cell with bread and water for a month. 
      By the time your penance ends, any chance of solving Brother Aelred's 
      murder has long passed.^^";
    ],
  has 
    static;

Object Quire "Quire"
  with
    description
      "The heart of monastic worship. Wooden choir stalls face each other 
      across the narrow space, where the brothers gather 
      to chant the offices. The stalls are plain but worn smooth by generations 
      of use. The lectern stands ready for the cantor.
      The high altar rises to the east. The nave lies west, beyond the screen. 
      Night stairs ascend to the dormitory, and a passage leads south to the cloister.",
    s_to NECloister,
    e_to HighAltar,
    w_to Nave,
    u_to NightStairs,
  has
     light;

Object -> Stalls "stalls"
  with
    name 'wooden' 'stalls',
    description 
      "You've stood by and sat on these for months now during services. 
      The carpentry is unremarkable and there is nothing these can reveal.",
    has
      static scenery;

Object -> Lectern "lectern"
  with
    name 'lectern',
  has
    static scenery supporter;

Object HighAltar "High Altar"
  with
    description
      "The altar stands on a raised platform of worn stone. A simple wooden 
      cross rises above it--no gold, no jewels.^^
      Behind the altar, three small chantry chapels stand in shadow. 
      Behind a locked gate, narrow stair descends into darkness--the 
      entrance to the crypt.",
    w_to Quire,
    ne_to ChapelA,
    e_to ChapelB,
    se_to ChapelC,
    d_to CryptStairs,
  has
    light;

! These stairs will never be unlocked, so there's no need for a key
! or dynamic descriptions.

Object -> CryptStairs "crypt stairs"
  with
    name 'crypt' 'gate' 'stairs',
    description "The gate is a sturdy iron gate with a large lock on it.",
    door_dir d_to,
    door_to Crypt,
  has
    scenery static door locked ~open;

Object -> Altar "altar"
  with
    name 'altar' 'platform' 'stone',
    description 
      "The povery of the priory is evident in the simplicity of the altar.
      It is a simple stone structure with a plain cloth draped on it.",
  has scenery static;

Object -> AltarCloth "cloth"
  with
    name 'plain' 'cloth',
    description "Coarse flax and unremarkable.",
    before [;
      Examine: ;
      default: 
        "There is nothing interesting about the cloth, 
        and Brother Prior would be outraged if you even touched it.";
    ],
  has
    static scenery;

Object ChapelA "Chapel A"
  with
    description
      "",
    sw_to HighAltar,
  has
    light;

Object ChapelB "Chapel B"
  with
    description
      "",
    w_to HighAltar,
  has
    light;

Object ChapelC "Chapel C"
  with
    description
      "",
    nw_to HighAltar,
  has
     light;


! ================================================ West Wing

Object NWCloister "NW Cloister"
  with
    description
      "",
    s_to WCloister,
    e_to Garth,
    w_to PriorDoor
  has
    light;

Object -> PriorDoor "prior door"
  with
    name 'prior' 'door',
    description "",
    door_dir w_to,
    door_to PriorsSolar,
    with_key PriorKey
  has
    static door openable ~open lockable locked;

Object -> PriorKey "prior key"
  with
    name 'silver' 'key',
    description "";

Object PriorsSolar "Prior's Solar"
  with
    description
      "",
    e_to NWCloister,
   has
     light;

Object Locutory "Locutory"
  with
    description
      "",
    e_to WCloister,
  has
    light;

Object Garth "Garth"
  with
    description
      "",
    ne_to NECloister,
    e_to ECloister,
    se_to SECloister,
    nw_to NWCloister,
    w_to WCloister,
    sw_to SWCloister,
  has
     light;

Object WCloister "W Cloister"
  with
    description
      "",
    s_to SWCloister,
    e_to Garth,
    w_to Locutory,
    n_to NWCloister,
  has
    light;

Object SWCloister "SW Cloister"
  with
    description
      "",
    s_to Laver,
    e_to Garth,
    w_to Gate,
    n_to WCloister,
    se_to Refectory,
  has
     light;

Object Gate "Gate"
  with
    description
      "",
    e_to SWCloister,
    w_to "Message",
  has
     light;

Object Laver "Laver"
  with
    description
      "",
    n_to SWCloister,
    e_to Refectory,
  has
     light;

Object Refectory "Refectory"
  with
    description
      "",
    e_to SECloister,
    w_to Laver,
    nw_to SWCloister,
    s_to Kitchen,
  has
    light;

Object Kitchen "Kitchen"
  with
    description
      "",
    n_to Refectory,
    d_to Undercroft,
  has
    light;

! ============================================= East Wing

Object NECloister "NE Cloister"
  with
    description
      "",
    n_to Quire,
    e_to ChapterHouse,
    w_to Garth,
    u_to Dorm,
    s_to ECloister,
  has
     light;

Object ECloister "E Cloister"
  with
    description
      "",
    n_to NECloister,
    e_to WarmingRoom,
    w_to Garth,
    s_to SECloister,
  has
    light;

Object SECloister "SE Cloister"
  with
    description
      "",
    n_to ECloister,
    e_to Slype,
    w_to Refectory,
  has
     light;

Object ChapterHouse "Chapter House"
  with
    description
      "",
    w_to NECloister,
  has
    light;

Object WarmingRoom "Warming Room"
  with
    description
      "",
    w_to ECloister,
    e_to Scriptorium,
  has
    light;

Object Scriptorium "Scriptorium"
  with
    description
      "",
    n_to LibraryDoor,
    w_to WarmingRoom,
  has
     light;

Object -> LibraryDoor "library door"
  with
    name 'library' 'door',
    description "",
    door_dir n_to,
    door_to Library,
    with_key LibraryKey
  has
    static door openable ~open lockable locked;

Object Library "Library"
  with
    description
      "",
    s_to Scriptorium,
    d_to SecretStairs,
  has
    light;

Object LibraryKey "library key"
  with name 'heavy' 'key';

Object SecretStairs "Secret Stairs"
  with
    description "",
    w_to Crypt,
    u_to Library,
  has
    light;

Object Slype "Slype"
  with
    description
      "",
    s_to HerbalistWorkroom,
    e_to Infirmary,
    w_to SECloister,
  has
     light;

Object Infirmary "Infirmary"
  with
    description
      "",
    s_to InfirmaryChapel,
    w_to Slype,
  has
    light;

Object InfirmaryChapel "Infirmary Chapel"
  with
    description
      "",
    n_to Infirmary,
  has
    light;

Object HerbalistWorkroom "Herbalist Workroom"
  with
    description
      "",
    n_to Slype,
    s_to Garden,
   has
     light;

Object Garden "Garden"
  with
    description
      "",
    n_to HerbalistWorkroom,
   has
     light;

Object -> GardenGate "garden gate"
  with
    description "",
    door_dir s_to,
    door_to RestrictedGarden,
    with_key GardenGateKey
  has
    static door openable locked lockable;

Object GardenGateKey "garden gate key";

Object RestrictedGarden "Restricted Garden"
  with
    description "",
    n_to Garden
  has
    light;

! ================================================ Basement

Object CellarerChamber "Cellarer Chamber"
  with
    description
      "",
    s_to Undercroft,
  has
     light;

Object Undercroft "Undercroft"
  with
    description
      "",
    n_to CellarerChamber,
    u_to Kitchen,
  has
     light;

Object Crypt "Crypt"
  with
    description
      "",
    u_to HighAltar,
    e_to SecretStairs,
  has
    light;

! ============================================== Second Floor

Object Dorter "Dorter"
  with
    description
      "A plain corridor connecting the sleeping chambers. 
      Wooden floorboards creak underfoot.",
    n_to Dorm,
    s_to LayCells,
    d_to NECloister,
    w_to DorterWindow
  has
    light;

! Object -> DorterWindows "windows"
!   with
!     name 'window' 'windows' 'opening' 'openings' 'unglazed',
!     description
!       "Simple unglazed openings in the outer wall. Wooden shutters 
!       hang beside them, currently open. Cold air flows through freely.",
!     before [;
!       Enter, Climb, JumpOver:
!         if (shutters_open) {  ! Or some condition
!           "The opening is wide enough. You could climb through 
!           onto the roof... though it would be dangerous.";
!         }
!         "The shutters are closed.";
