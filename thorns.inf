Barrel -> MustardBarrel "mustard barrel"                        ! >MustardBarrel
  with
    name 'mustard',
    contents_name 'mustard',
    description [;
      print
        "A stout wooden barrel bearing the charcoal mark ~MUSTARD~";
      if (self has open)
        print ". It is currently open, revealing yellow-brown ground mustard";
      ".";
    ],
    before [;
      Smell:
        if (self has open)
          "Sharp and pungent---the unmistakable bite of ground mustard.";
      Taste:
        if (self has open)
          "You taste a tiny amount---fiery hot and bitter. You cough.";
    ],
    after [;
      Search:
        if (self hasnt open) "You cannot, since the barrel is closed.";
        the_time = the_time + 5;
        move MustardPackage to player;
        "After digging around with the hook for several minutes, you find
        a package buried deep in the mustard. You pull it free---a small
        sack, its burlap stained deep yellow. You take it.";
    ],
  has edible;


Object MustardPackage "mustard-yellow sack"
  with
    name 'mustard' 'sack',
    description
      "A small sack of burlap, tied with simple cord.
      Originally dark, it has stained deep yellow from the mustard.",
    before [;
       Close: "You can't retie the package again, so it will remain open.";
    ],
    after [;
      Open:
        "You untie the cord, revealing a small illuminated book.";
    ]
  has
    container openable ~open;


Object -> StolenPsalter "illuminated psalter"                   ! >StolenPsalter
  class AdjObject,
  with
    article "an",
    adj_name 'illuminated' 'stolen',
    noun_name 'psalter' 'manuscript' 'book',
    description
      "A small psalter, exquisitely crafted. The leather cover is tooled
      with a design of intertwined vines and lilies. Opening it, you see
      Brother Wilfred's unmistakable hand---each page a work of devotion.
      The opening initial 'B' of Psalm 1 (~Beatus vir~) is illuminated in
      brilliant azure and gold leaf, depicting a tree bearing fruit by
      streams of water. Marginal decorations show doves, wheat, and grapes.
      ^^This is clearly one of Wilfred's finest works. It should be in the
      library before it is sold, not hidden here.",
    before [;
      Take:
        QuoteBoxSimple(quote_psalter);
        Achieved(TASK_EVIDENCE_PSALTER);
      Examine:
        if (verb_word == 'read')
          "The psalms are beautiful, but what strikes you most is the
          artistry---the hours Wilfred must have spent on each illumination.";
    ],
  has
    ~concealed;  ! Remove concealed when player searches the hiding spot


! ---------------------------------------------------- FitzAlan Crypt

Object Ladder "ladder"                                                 ! >Ladder
  with
    name 'ladder',
    describe 0,
    description [;
      if (self hasnt general) {
        QuoteBoxSimple(quote_ladder);
        give self general;
      }
      if (parent(player) ofclass Tomb)
        "You're higher now, but the ladder is still high above you.";
      if (location == FitzAlanCrypt) "The ladder is far above you.";
      print "A narrow wooden ladder leads down";
      if (~~FitzAlanCrypt.is_lit()) print " into darkness";
      ".";
    ],
    before [;
      Take, Pull, Push:
        "The ladder is much too high to reach.";
    ]
  has static open;


Room FitzAlanCrypt "FitzAlan Crypt"                             ! >FitzAlanCrypt
  with
    name 'stone' 'walls',
    description
      "A small vaulted chamber, no more than ten feet across.
      The central tomb bears the effigy of a knight.
      Flanking this is a smaller undecorated tomb.

      ^^The walls here are finished stone rather than rough-hewn rock, and
      narrow recesses have been cut into the walls---likely once holding
      offerings or relics. The air is still, undisturbed for decades
      or longer. A patina of dust covers everything, unmarred by footprints
      save your own.",
    s_to [;
      if (Frame hasnt general) "You can't go that way.";
      print "You slip through the opening behind the panel, revealing...^^";
      return Crypt;
    ],
    u_to "Alas, the ladder is raised up and well out of your reach.",
    is_lit [;
      return _LookForLightInObj(self, self);
    ],
  each_turn [;
    #IfDef HAS_HINTS; HintReady(Hint_FACrypt); #EndIf;
  ],
  cheap_scenery
    1 'recesses'
      "There is nothing in these, and they don't respond in any way to
      manipulation.",
  has
    ~light;


Tomb -> FitzAlanLargeTomb "larger tomb"                     ! >FitzAlanLargeTomb
  with
    adj_name 'large' 'larger' 'central',
    description
      "Large, heavy, and sealed. The knight carved into it is in
      full armour, his hands clasped in prayer; his shield displays
      a lion, the FitzAlan arms."
    has
      ~proper;


Object -> -> FitzAlanKnight "carvings"                         ! >FitzAlanKnight
  class AdjObject,
  with
    adj_name 'fitzalan',
    noun_name 'knight' 'lion' 'arms' 'armor' 'armour' 'carvings',
    description
      "The knight, shield, and lion are well done, but they're
      just carved into the stone.",
    before [;
      Push, Pull, Take, Turn:
        "The knight and it's shield and arms are carved into the stone.
        They don't respond in any way to your manipulation.";
    ],
    has scenery;


Tomb -> FitzAlanSmallTomb "smaller tomb"                    ! >FitzAlanSmallTomb
  with
    adj_name
      'small' 'smaller' 'wive' 'wive^s' 'children' 'child'
      'wife^s' 'child^s' 'children^s',
    description
      "Probably for the FitzAlan wives or children, this is a simple
      square block, fully sealed.",
  has
    ~proper;


! open = open
Object -> FitzAlanPanel "art panel"                             ! >FitzAlanPanel
  class AdjObject,
  with
    adj_name 'wooden' 'wood' 'faded',
    noun_name 'art' 'panel' 'youths' 'corpses' 'inscription',
    initial [;
      if (self has open)
        "The panel is ajar, revealing an opening to the south.";
      if (frame has general)
        "The panel is currently closed flush against the wall.";
      "Against the southern wall hangs a faded wooden panel depicting the Three
      Living and the Three Dead, its Latin inscription barely legible in the
      gloom.";
    ],
    description [;
      if (self has open)
        "The panel is ajar from the wall, revealing an opening to the south.";
      "A large wooden painted panel set in a distinctive brass frame, it
      depicts the Three Living and the Three Dead---three noble youths
      recoiling from three crowned corpses who gesture toward them. Woven
      beneath in Gothic script: ~QUOD FUIMUS, ESTIS; QUOD SUMUS, ERITIS~
      (What we were, you are; what we are, you will be). Dampness has taken
      its toll on the ancient pigments.";
    ],
    before [;
      Take:
        "Before you even try, you realize this would be much too large to
        carry.";
      Burn:
        "Given how damp it is here, you couldn't catch it alight.";
      Search:
        "Besides your search for meaning on a memento mori, you find nothing
        unexpected in the artwork.";
      Turn: "Nothing happens when you try to rotate the panel.";
      Push:
        if (Frame hasnt general)
          "The art panel seems fixed to the distinctive brass frame.";
        if (self has open) <<Close self>>;
        "The art panel seems fixed to the distinctive brass frame";
      Pull:
        if (self has open) "The panel is already ajar.";
        "The art panel seems fixed to the distinctive brass frame.";
      Open:
        if (Frame has general) <<Push Button>>;
      Close:
        if (self has open) {
          give self ~open;
          "You push the panel against the wall and hear a click from inside the
          frame.";
        }
        if (Frame has general)
          "The panel is already closed.";
    ],
    has
      static transparent;


! general = player has examined frame
Object -> -> Frame "brass frame"                                        ! >Frame
  class AdjObject,
  with
    adj_name 'distinctive' 'brass',
    noun_name 'frame',
    before [;
      Search, Examine:
        give self transparent;
        if (FitzAlanPanel has open)
          "The panel and frame are ajar from the wall, revealing an opening.";
        give self general;
        "The brass frame encloses the art panel. Examining it closely, you find
        a small button on the right-hand side of the panel";
      Push:
        if (self has general) "Perhaps if you tried to do that to the button?";
        "Nothing unexpected happens.";
      Open:
        if (self has general) <<Push Button>>;
      Close:
        <<Close FitzAlanPanel>>;
      Pull:
        <<Pull FitzAlanPanel>>;
    ],
  has
    static ~transparent;


Object -> -> -> Button "button"                                        ! >Button
  with
    name 'button',
     description "It's a small brass button on the side of the frame.",
    before [;
      Push:
        if (FitzAlanPanel hasnt open) {
          give FitzAlanPanel open;
          if (self hasnt moved) {
            give self moved;
            Achieved(TASK_FA_PANEL);
            "You push the button and hear click from inside the frame.
            The panel pops ajar from the wall, revealing an opening to the
            south.";
          }
          "Pushing the button, the panel once again swings open,
          revealing the opening to the south.";
        }
        "You push the button but hear no click. Perhaps this is because the
        panel is already opened?";
    ],
  has
    scenery;

! ---------------------------------------------------------- Crypt


Room Crypt "Crypt"                                                      ! >Crypt
  with
    name 'crypt',
    description [;
      print
        "The crypt stretches dimly before you, thick stone pillars
        supporting low vaulted arches. Rows of tombs line the walls;
        the air is thick and damp. ";
      if (FitzAlanPanel has open)
        print
          "Part of the apparent wall to the north is open, revealing a
          passage.";
      else
        print "A section of the north wall has been covered with wood planks.";
      "^^A large bell is in a stand by the stairs heading upward, and a small
      doorway leads south.";
    ],
    u_to CryptStairs,
    n_to [;
      if (Frame hasnt general) "You can't go that way.";
      print "You slip through the opening behind the panel, revealing...^^";
      return FitzAlanCrypt;
    ],
    s_to CryptVestry,
    each_turn [;
      #IfDef HAS_HINTS;
        HintReady(Hint_Crypt);
        HintReady(Hint_CryptEscape);
      #EndIf;
    ],
    before [;
      Smell: "Heavy, damp, and earthy.";
    ],
  has
    ~light;


Object -> BlankPanel "wood panel"                                     ! >BlankPanel
  class AdjObject,
  with
    adj_name 'blank' 'wood',
    noun_name 'panel' 'planks',
    describe 0,
    description [;
      print
        "This side may have once had art on it; it's impossible to
        tell because this side has been boarded over with thick planks of oak
        (perhaps to provide insulatation from the now-disused family crypt?)";
      if (FitzAlanPanel has open)
        print ".^^The panel is ajar, revealing an opening to the north";
      ".";
    ],
    before [;
      Pull, Close:
        if (FitzAlanPanel hasnt open)
          "It already is pulled shut, and you can't pry the planks off.";
        if (CryptBell hasnt general) {
          print
            "It doesn't appear that this can be opened from this side.
            Are you sure you want to do this? ";
            if (~~YesOrNo()) "You decide against this and leave it ajar.";
        }
        give FitzAlanPanel ~open;
        "You pull the panel closed and hear a click in the frame.";
      Push, Turn:
        if (FitzAlanPanel has open)
          "The panel is already ajar.";
        "Push as you may, you can't seem to open it from this side.";
      Search:
        if (FitzAlanPanel hasnt open)
          "You find nothing interesting about the panel other than your
          frustration that it doesn't open from this side.";
        "You find nothing unusual in the planks.";
      Take:
        if (FitzAlanPanel hasnt open)
          "You cannot pry the planks off the panel.";
    ],
  has static;


Object -> Tombs "tombs"                                                 ! >Tombs
  with
    name 'tombs',
    description
      "There are six tombs holding the earthly remains of former priors:
      Brothers Gordian, Ezra, Crispin, Dunstan, Godric, and Ambrose.",
    before [;
      Examine:
        if (self hasnt general) {
          give self general;
          QuoteBoxSimple(quote_crypt);
        }
      Search: <<Examine self>>;
    ]
  has
    scenery pluralname;


Tomb -> TombGordian "Brother Gordian's tomb"                      ! >TombGordian
  with
    noun_name 'gordian' 'gordian^s' 'tomb',
    history_text [;
      Achieved(TASK_LEARNED_FOUNDING_DATE);
      "Gordian (1112-1192). Founder of the priory in 1152, formerly Master
      Builder to the Earl of Pembroke. A man of great skill and piety, he lived
      by three great creeds that he impressed about the brethren drawn to
      the new priory.
      ^^Gordian designed the church and cloisters himself, down to
      the great bell in the tower to the stained glass of the nave.
      ^^It is said he built the priory as penance for worldly pride,
      each clever mechanism a reminder that God's
      mysteries surpass man's cleverness. He served as Prior from its
      founding until his death.";
    ],
    ;

Tomb -> TombEzra "Brother Ezra's tomb"                               ! >TombEzra
  with
    noun_name 'ezra' 'ezra^s' 'tomb',
    description
      "Brother Ezra's tomb is a stone block with a lid on which his name is
      carved. It sits in the dankest corner of the crypt, positioned between
      two thick pillars that cast deep shadows behind it.",
    react_before [;
      if (self hasnt general) rfalse;
      Listen, Smell, Examine, Wait, Pray, Insert, Eat, SwitchOff,
      Blow, Consult, Drink, Transfer, Look, Drop:
        ;
      default:
        print "(To do so, you get up from crouching)^";
        give self ~general;
    ],
    history_text
      "Ezra (1155-1212). Elected as the second prior in 1192 and served in this
      role for 18 years. He built out the infirmary and the infirmary chapel
      and opened the priory to religious pilgrims traveling to Scotland.
      Contemporary brothers of him remembered him
      for his flaming orange hair and for his kindness---he always said he
      would protect his brethren from danger as well as he could.";


Tomb -> TombCrispin "Brother Crispin's tomb"                      ! >TombCrispin
  with
    noun_name 'crispin' 'crispin^s' 'tomb',
    history_text
      "Crispin (1180-1248). Gained renown in the Holy Land
      as a young man, then took his vows and joined the priory.
      The second-longest serving prior (1210-1248), he brought many
      benefactors and the priory saw many pilgrims pass through hoping to
      meet the man who had taken the cross with such honor.";


Tomb -> TombDunstane "Brother Dunstan's tomb"                    ! >TombDunstane
  with
    noun_name 'dunstan' 'dunstan^s' 'tomb',
    history_text
      "Dunstan (1210-1270). Entered the priory from a trading family in
      Pembroke. Elected prior in 1248, after the death of Prior Crispin,
      he served for 22 years until his death. The latter half of his
      time as prior was marred by the start of the Second Baron's War and a
      decline in the prestige of the priory.";


Tomb -> TombGodric "Brother Godric's tomb"                         ! >TombGodric
  with
    noun_name 'godric' 'godric^s' 'tomb',
    history_text
      "Godric (1230-1299). Entered the priory as a child and was raised in
      its confines. Known best for his singing voice, he was the cantor
      from his early twenties, and was elected prior at only 40.
      He served in this role for 25 years (1270-95), only a few years before his
      death.";


Tomb -> TombAmbrose "Brother Ambrose's tomb"                      ! >TombAmbrose
  with
    noun_name 'ambrose' 'ambrose^s' 'tomb',
    history_text
      "Ambrose (1255-1310). After losing two brothers in the civil wars,
      Ambrose took his vows at twenty. He was elected as prior and served
      1295-1310. During his administration, he emphasized the importance
      of silence, and began the tradition of total silence throughout the
      grounds except in very limited circumstances. It is said that,
      in addition to his offices, he spent several hours a day silently
      praying in memory of his lost brothers.";


! general = rung and in the sequence for rescue

Object -> CryptBell "crypt bell"                                    ! >CryptBell
  class AdjObject,
  with
    adj_name 'crypt',
    noun_name 'handbell' 'bell',
    describe 0,
    description
      "A large bell in a stand, both made of pewter. You've heard it once
      rung during a Mass in the crypt, and it was loud enough that you
      heard it on the cloister.",
    timer_left 0,
    check [ how ;
        ! print "tomb hide=", TombEzra has general, "^";
        if (self hasnt general) rfalse;
        else if (location == parent(BrCuthbert) && TombEzra hasnt general)
          how = 1;
        else if (parent(BrCuthbert) == Crypt && FitzAlanPanel has open)
          how = 3;
        else if (real_location == FitzAlanCrypt) how = 0;
        else if (parent(BrCuthbert) == Crypt or CryptVestry && IsCarryingLit())
          how = 2;
        switch (how) {
          0: rfalse;
          1:
            print
              "Brother Cuthbert stops short. ~Brother Aldwin? What brings you to
              the crypt at this hour?~";
          2:
            print
              "~Who's there?~ Brother Cuthbert calls out, spotting your light.
              ~Brother Aldwin? You shouldn't be down here alone.~";
          3:
            print
              "~An open panel? Someone must have been robbing that old family
              crypt?~";
        }
        print
          "^^When this is reported to Brother Oswald, you are summoned
          before him. ~Why would you be wandering the crypt?~ he asks unkindly.
          You are sentenced to confined prayer for a week.";
        KillOff();
        rtrue;
    ],
    noises [ ;
      if (real_location ~= FitzAlanCrypt or Crypt or CryptVestry
          or CryptStairs or HighAltarArea) rfalse;  ! far away, can't hear
      print "^";
      if (real_location == FitzAlanCrypt) {
        if (FitzAlanPanel has open) print "Through the opening,";
        else print "Behind the panel,";
      }
      else if (real_location == parent(BrCuthbert)) print "Very close,";
      else if (real_location == CryptStairs or HighAltarArea)
        print "Faintly below,";
      else if (BrCuthbert in CryptStairs or Nave or HighAltarArea)
        print "Above,";
      else if (BrCuthbert in Crypt) print "To the north,";
      else if (BrCuthbert in CryptVestry) print "To the south,";
      else print "BUG REPORT ME";
      print " you hear ";
      rtrue;
    ],
    daemon [ ;
      self.timer_left++;


      ! check for discovery (may also do again after moving cuthbert below)
      if (self.check()) return;

      switch (self.timer_left) {
        1:
        2:
          move BrCuthbert to Nave;
          give CryptGate open;
          if (self.check()) return;
          "^You can hear a key turning in the gate above.
          If you get caught here, you'll be in serious trouble.";
        3:
          move BrCuthbert to CryptStairs;
          if (self.check()) return;
          "^You can hear footsteps coming down the crypt stairs.";
        4:
          give Crypt light;
          give CryptVestry light;
          if (self.check()) return;
          if (real_location == Crypt or CryptVestry)
            "^The footsteps are closer, and you can see some light coming
            from the stairs.";
          "^The footsteps sound closer.";
        5:
          move BrCuthbert to Crypt;
          if (self.check()) return;
          if (real_location == Crypt or CryptVestry)
            "^Someone has entered the crypt bearing a light.";
          "^You can hear someone in the crypt.";
        6:
          if (self.noises())
            "~Is someone down here?~. You recognize the voice as
            Brother Cuthbert's.";
        7:
          if (self.noises())
            "~Helloooo?~";
        8:
          move BrCuthbert to CryptVestry;
          if (self.check()) return;
          if (real_location == Crypt) {
            print
              "^The light moves to the south and you sense Brother Cuthbert
              is now searching ";
            if (CryptVestry has visited) print "the crypt vestry";
            else print "the room south of the crypt";
            ".";
          }
          if (self.noises())
            "footsteps going south, away from the crypt stairs.";
        9:
          if (self.noises()) "~Is someone in the vestry?~";
        10:
          if (self.noises()) "~Helloooo?~";
        11:
          if (self.noises()) "rustling noises.";
        12:
          if (self.noises())
            "~Must have been a draft from the church above.~ (You hear him
            muttering a brief prayer.)";
        13:
          move BrCuthbert to Crypt;
          if (self.check()) return;
          if (real_location == Crypt)
            "^The light becomes stronger here and your hear footsteps walking
            back to the stairs.";
          if (self.noises()) "the footsteps now walking back to the stairs.";
        14:
          give CryptVestry ~light;
          give Crypt ~light;
          move BrCuthbert to CryptStairs;
          if (self.check()) return;
          if (real_location == Crypt)
            "^The light dims as you hear footsteps on the stairs.";
        15:
          give self ~general;
          give CryptGate locked;
          move BrCuthbert to HighAltarArea;
          if (self.check()) return;
          if (location == HighAltarArea)
            "^You see Brother Cuthbert at the gate and see him shut the gate.";
          if (self.noises()) "the gate being shut.";
        16:
          StopDaemon(self);
          move BrCuthbert to CloisterNE;
          if (real_location == Crypt or FitzAlanCrypt or CryptVestry)
            "^You managed to avoid detection, but you're still stuck here.
            Now how will you get out?";
          Achieved(TASK_ESCAPE_CRYPT);
          "^It appears the danger has passed, and you escaped the crypt
          without being discovered.";
      }
    ],
    react_before [;
      Go:
        if (location == CryptStairs && selected_direction == u_to) {
          StopDaemon(self);
          give self ~general;
          give Crypt ~light;
          give CryptVestry ~light;
          "You slip through the open gate and complete your escape.";
        }
    ],
    before [;
      Turn, Pull, Attack, Push:
        if (self has general)
          "You just rung it, and dare not do it again.";
        StartDaemon(self);
        give self general;
        "You sound it with vigor which produces an almost deafening peal
        as it echoes around the room. You feel certain someone above will
        have heard that.";
      Take: "Leave it here. It will be needed for future masses here.";
    ]
  has static;


! -------------------------------------------------------- Crypt Vestry

Room CryptVestry "Crypt Vestry"                                   ! >CryptVestry
  with
    description "A long vertical passage of rough stone.
    This may have originally been
    designed to be a tunnel to another crypt, but it appears to be used
    to store materials needed for masses held in the crypt, and there are
    some such things on a wooden ledge.",
    n_to Crypt,
    out_to Crypt,
    before [;
      Smell: <<Smell Crypt>>;
    ],
    cheap_scenery
      1 'items' "If you want to search the ledge, just say so.",
  has
    ~light;


Object -> VestryLedge "ledge"                                     ! >VestryLedge
  with
    name 'ledge' 'shelf',
    describe 0,
    inside_description
      "From your vantage on the ledge, you see nothing further here, and
      nothing unexpected about the stone above.",
    description [;
      print
        "It's a simple wooden ledge fastened to the stone wall. It contains
        several items, likely needed for services held down here";
      PrintContents(". Standing out among the other items ", self, ISARE_BIT);
      ".";
    ],
    react_before [;
      Go:
        if (parent(player) == self && selected_direction == d_to) <<Exit self>>;
    ],
    before [;
      Climb: <<Enter self>>;
      Search:
        if (coins has concealed) {
          give coins ~concealed;
          "Searching around, you find some pewter platters, a cup, and old
          cloths. You realize these won't be useful, but then you discover a
          sack buried under the cloths.";
        }
        print "There's nothing interesting on the ledge";
        PrintContents(" except ", self);
        ".";
    ],
    after [;
      Enter: "With some difficultly you climb onto the shelf.";
      Exit: "You scramble back down from the ledge.";
    ]
  has
    supporter enterable;


Object -> -> Coins "sack of coins"                                      ! >Coins
  class AdjObject,
  with
    short_name [;
      print "sack";
      if (self has moved) print " of coins";
      rtrue;
    ],
    parse_name [ w1 w2 w3 ;
      if (self hasnt general) {
        if (NextWord() == 'sack') return 1; return 0;
      }

      w1 = NextWord();
      w2 = NextWord();
      w3 = NextWord();

      if (w1 == 'sack' && w2 == 0) return 1;
      if (w1 == 'sack' && w2 == 'of' && w3 == 'coin' or 'silver' or 'coins')
        return 3;
      if (w1 == 'coin' && w2 == 'sack') return 2;
      if (w1 == 'coin' or 'coins' or 'silver') return 1;
      return 0;
    ],
    description [;
      print "A small sack of yellow-smeared dark burlap, tied with simple cord";
      if (self hasnt general) {
        give self general;
        ". Opening it, your hands tremble slightly---the weight is unmistakable.
        Silver coins spill into view: groats and pennies, perhaps ten
        shillings' worth.
        ^^Your breath catches. A small fortune, enough to feed the priory for
        a season.
        Hidden here, among the dead, where no monk should have need of it.";
      }
      else
        ", heavy with silver coins.";
    ],
    before [;
      Empty:
        "The coins are evidence. Best to leave them in the sack.";
      Insert, Fill:
        "There's no room for anything else.";
      Close:
        "It's already tied closed.";
      Open:
        if (self hasnt general) <<Examine self>>;
        "You loosen the cord, check the contents---still silver---and
        tie it closed again. The sight of such wealth still unsettles you.";
      Search:
        if (self hasnt general) <<Examine self>>;
        "The sack contains only silver coins.
        More money than you've ever held.";
      Take:
        Achieved(TASK_EVIDENCE_COINS);
        if (IndirectlyContains(player, self)) {
          print "You already have the sack";
          wn = verb_wordnum + 1;
          if (NextWord() == 'coin' or 'coins') print ". Leave the coins in it";
          ".";
        }
    ],
    after [;
      Take:
        if (self has general)
          "You take the sack, trying to ignore how the coins shift and clink.
          Your vow of poverty weighs heavier than the silver.";
        "You take it, noting metallic clinking as you do.";
    ]
  has concealed;


! ============================================== Second Floor

Room DayStairs "Day Stairs"                                         ! >DayStairs
  with
    name 'day' 'stairs',
    description
      "Broad stone steps connect the upper living areas to the cloister walk
      below. These are the day stairs, connecting the dorter to the cloister.
      The steps are worn smooth in the center by generations of sandaled feet.",
    d_to CloisterNE,
    u_to Dorter,
  has
    ;

! ---------------------------------------------------- Dorter

Room Dorter "Dorter"                                                   ! >Dorter
  with
    description
      "A plain corridor connecting the sleeping chambers.
      Wooden floorboards creak underfoot. There are passages to the north
      and south, and broad stairs descend to the east.",
    n_to Dorm,
    s_to LayCells,
    d_to DayStairs,
    e_to DayStairs,
  has
    ;


! --------------------------------------------------- Dorm

Room Dorm "Dorm"                                                         ! >Dorm
  with
    ! we wake up here, and won't initially show the room name and description
    ! short_name [;
    !   if (turns == -1) rtrue;
    ! ],
    description [;
      if (turns == -1) rtrue;
      "This great room is used by all the choir monks except Brother Prior.
      It could easily provide rest for twenty brothers, but there are only eight
      cots in here now. Each cot has a chest at its foot for the any possessions
      the brother has.
      ^^Dim light filters in from an window high up, reflecting lightly on
      the wood floor.
      ^^Doorways lead south to the dorter and east to the necessarium.
      Narrow stairs descend down to the church.";
    ],
    e_to Necessarium,
    s_to Dorter,
    d_to NightStairs,
  has
    ;


Object -> AllMonkCots "monk's cot"                                  ! >AllMonkCots
  with
    parsed_monk 0,
    parse_name [ w found_monk words_consumed;
      ! words_consumed = 0;
      w = NextWord();
      words_consumed++;

      ! Check for "my" cot
      if (w == 'my') {
        self.parsed_monk = player;
        w = NextWord();
        if (w == 0) return 0;
        if (w == 'cot' or 'bed') return 2;
        return 0;
      }

      ! Check for generic "cot" or "cots" or "bed"
      if (w == 'cot' or 'cots' or 'bed' or 'beds') {
        if (NextWord() == 0) {
          self.parsed_monk = 0;
          return 1;
        }
      }

      ! Check for "Brother"
      if (w == 'brother') {
        w = NextWord();
        words_consumed++;
        if (w == 0) return 0;
      }

      ! Match monk name
      if (w == 'aelred' or 'aelreds' or 'aelred^s')
          found_monk = BrAelred;
      else if (w == 'hugh' or 'hughs' or 'hugh^s')
          found_monk = BrHugh;
      else if (w == 'martin' or 'martins' or 'martin^s')
          found_monk = BrMartin;
      else if (w == 'benedict' or 'benedicts' or 'benedict^s')
          found_monk = BrBenedict;
      else if (w == 'cuthbert' or 'cuthberts' or 'cuthbert^s')
          found_monk = BrCuthbert;
      else if (w == 'anselm' or 'anselms' or 'anselm^s')
          found_monk = BrAnselm;
      else if (w == 'wilfred' or 'wilfreds' or 'wilfred^s')
          found_monk = BrWilfred;
      else return 0;

      self.parsed_monk = found_monk;

      ! Check for what comes next---must be noun like "cot" or "bed"
      w = NextWord();
      if (w == 0) return 0;

      words_consumed++;
      if (w == 'cot' or 'bed') return words_consumed;

      return 0;
    ],
    react_before [;
      Go:
        if (parent(player) == self && self.parsed_monk == player) {
          print "(first getting up from your cot)^^";
          move player to location;
        }
    ],
    short_name [;
      if (self.parsed_monk == player || self.parsed_monk == 0) {
        if (caps_mode) print "Y";
        else print "y";
        print "our ";
      }
      else print (the) self.parsed_monk, "'s ";
      print "cot";
      rtrue;
    ],
    description [;
      if (self.parsed_monk == 0)
        "The cots are simple straw mattresses on wooden frames,
        all identical. You'd need to specify which monk's cot.";
      print
        (The) self, " is like all the others---a simple straw
          mattress";
      if (self.parsed_monk == BrAelred)
        print ". A faint scent of rosemary lingers";
      ".";
    ],
    before [;
      if (action ~= ##Examine && self.parsed_monk == 0)
        "Which monk's cot do you mean?";
      Smell:
        if (self.parsed_monk == BrAelred)
            "Definitely rosemary. The master's favourite.";
      Push, Pull, Turn:
        "You shouldn't rearrange the cots here. Leave them be.";
      Enter:
        if (self.parsed_monk == player)
          "The Rule discourages sloth. You've already risen for the day.";
        "That's ", (the) self, ". You shouldn't sleep there.";
    ],
    after [;
      Exit: "You leave your cot.";
    ]
  has
    scenery supporter enterable proper;


