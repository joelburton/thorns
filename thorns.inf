Barrel -> TallowBarrel "tallow barrel"                          ! >TallowBarrel
  with
    name 'tallow',
    contents_name 'tallow',
    description [;
      print
        "A stout wooden barrel bearing the charcoal mark ~TALLOW~";
      if (self has open)
        print ". It is currently open, revealing pale, waxy rendered fat";
      ".";
    ],
