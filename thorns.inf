! ==================================================== Global Attrs/Props/Vars



Global suspicion_level = 0;
! 0 = before death
! 1 = after death
! 2 = identified poison
! 3 = find coins or shortage or letters

Global f_smelled_aelred = 0;
Global f_warned_contraband = 0;
Global f_identified_poison = 0;
Global current_service = 0;

! ============================================================= Hooks

[ DarkToDark ;
  ! During the crypt escape, can move dark-to-dark
  if (CryptBell has general) rfalse;
  print
    "You've always been a bit scared of the dark, having heard tales of
    careless men being attacked by demons where there is no light.
    ^^After a few minutes trying to grope around and failing to get your
    bearings, you lose all hope and begin screaming.
    ^^After a few minutes, you are rescued by Brother Cuthbert, bearing a
    candle. ~What on earth are you doing here, Brother Novice?~
    ^^When he hears of this, Brother Oswald sentences you to a week of bread
    and water.";
  KillOff();
];

[ DeathMessage;
  if (deadflag == 3) print "You have failed";
  if (deadflag == 4) print "You have fallen very ill";
];

[ NewRoom;
  ! In the garden and restricted garden, doing things with the plants
  ! will make for weird responses: EAT ROSEMARY tries to take the whole
  ! plant and we can't catch this with a before clause.
  !
  ! So only in those two rooms, we'll set no_implict_actions to true (else
  ! set to false) and it won't try stuff like "(first taking the ___)"
  if (location ofclass Cloister
      && parent(Pax) ~= player && random(6) == 1) move Pax to location;
  no_implicit_actions = (location == Garden or RestrictedGarden);
  rfalse;
];

! Checks if player is carrying "contraband" (not ok_carry), either:
! - in the cloister
! - with a narc monk in the room (any but Remigio, Aelred, Wilfred)

[ CheckForContraband mir o caught_with ;
  ! Don't do this during the crypt rescue
  if (CryptBell has general) rfalse;

  mir = MonkInRoom();
  if (mir == BrRemigio or BrAelred) mir = 0; ! not narcs

  ! safe to carry contraband if not observed
  if (mir==0 && ~~location ofclass Cloister) rfalse;

  ! check for contraband, first thing becomes 'caught_with':
  objectloop (o in player) {
    if (o hasnt ok_carry) {
      caught_with = o;
      break;
    }
  }

  ! TODO: check logic -- can also be hidden in hood
  if (caught_with == 0 && Basket in player && Basket has open) {
    objectloop (o in Basket) {
      if (o hasnt ok_carry) {
        caught_with = o;
        break;
      }
    }
  }

  ! no contraband, safe
  if (caught_with == 0) rfalse;

  if (random(3) > 1) f_warned_contraband++;

  if (mir == 0) {
    if (f_warned_contraband < 2)
      "^You should be more careful. If any brother saw you carrying ",
      (the) caught_with, " you'd face severe punishment.";
    if (f_warned_contraband == 2)
      "^Again: be careful. Carrying contraband around openly will get you in
      no end of trouble.";
  } else {
    if (f_warned_contraband < 1)
      "^Luckily, ", (the) mir, " didn't notice you openly carrying ",
      (the) caught_with, ". If he had, you'd have faced severe punishment.
      ^^You need to be more careful.";
  }

  if (mir == 0) {
    mir = BrCuthbert;
    print "^Brother Cuthbert enters and sees you. He";
  } else {
    print "^", (the) mir;
  }

  print
    " notices you openly carrying ", (the) caught_with,
    ". ~Brother Novice, what are you doing with that?
    That has nothing to do with your duties here.~^^
    For disobeying the rules of the priory, you are given penance of
    bread and water for a week.";
    KillOff();
];

[ TimePasses o ;  ! Call when # turns goes up
  SetTime(the_time + 2);
  CheckForContraband();

  ! If a service should be starting, start it
  objectloop (o ofclass SceneService)
    if (the_time >= o.time_start - 2 && o hasnt visited && o hasnt general) {
      o.start_service();
      continue;
    }
];

[ InScope ;
  PlaceInScope(MyHood);

  if (current_service) {
    PlaceInScope(current_service);
    if (parent(BrOswald) == HighAltarArea)
      PlaceInScope(BrOswald);
  }

  ! Player should have access to certain objects when in the dark
  if (location == thedark) {
    if (real_location == Sacristy) {
      PlaceInScope(SacristyDoor);  ! so we can find door
      PlaceInScope(Sacristy);      ! so room actions, like smell, work
    }
    else if (real_location == Crypt) {
      PlaceInScope(CryptBell);
      PlaceInScope(TombEzra);
      PlaceInScope(BlankPanel);
    }
    else if (real_location == FitzAlanCrypt && Frame has general) {
      PlaceInScope(FitzAlanPanel);
      PlaceInScope(Frame);
      PlaceInScope(Button);
    }
  }

  if (ScenePreDeath has general) PlaceInScope(ScenePreDeath);

  rfalse;
];

[ IsARoom p_obj;
  if (p_obj ofclass Room or Cloister) return 1;
  return 2;
];

Global g_been_in_dark = false;
Replace _UpdateDarkness;
! There doesn't appear to be a better way to do this; NewRoom is called for
! every room EXCEPT thedark.
[ _UpdateDarkness p_silent _ceil _old_darkness _darkness;
	if(location == thedark) _old_darkness = true;
	_ceil = ScopeCeiling(player);
	if(_LookForLightInObj(_ceil, _ceil) == false) _darkness = true;
	if(_darkness ~= _old_darkness) scope_modified = true;
	if(_darkness) {

    ! only change: quote on first darkness
    NowInDark();
    !--- end of changes

		if(_old_darkness == false && p_silent == false) PrintMsg(MSG_NOW_DARK);
		location = thedark;
	} else {
		location = real_location;
		if(_old_darkness && p_silent == false) {
			new_line;
			<Look>;
		}
	}
];



Include "puny.h";

! ================================================================ Verbs

[ ConsultScope o;
  switch (scope_stage) {
    1: rfalse;
    2:
      objectloop (o provides history_text) PlaceInScope(o);
      objectloop (o provides herb_text) PlaceInScope(o);
      rtrue;
  }
];

[ IsCandle ;
  return (noun ofclass Candle);
];

[ AskScope o;
  switch (scope_stage) {
    1: rfalse;
    2:
      if (location == Infirmary) {
        PlaceInScope(InfirmaryCabinet);
        PlaceInScope(BrAelredBody);
        PlaceInScope(Mirror);
        rtrue;
      }

      objectloop (o provides history_text) PlaceInScope(o);
      rtrue;
  }
];

Extend 'ask' first
  * creature 'about' scope=AskScope       -> Ask;

Extend 'climb' first
  * 'on' noun                             -> Climb
  * 'down'                                -> Exit
  * 'down' noun                           -> Exit;

Extend 'consult' first
	* noun 'about'/'on' scope=ConsultScope  -> Consult;

Verb 'extinguish'
  * noun=IsCandle                         -> SwitchOff;

Extend 'blow' first
  * 'out' noun=IsCandle                   -> SwitchOff;

Verb 'hide'
  * 'by'/'behind' noun                    -> Hide
  *                                       -> Hide;

Verb 'pet'
  * creature                              -> Kiss;

Verb 'plant'
  * held                                  -> Dig
  *                                       -> Dig;

Extend 'dig'
  *                                       -> Dig;

Extend 'get' first
  * 'down'                                -> Exit;

Verb meta 'help'
  *                                       -> Help;

Extend 'jump'
  * 'on' noun                             -> Climb;

Verb 'kneel'
  * 'on' supporter                        -> Enter;

Extend 'look'
  * 'beneath' noun                        -> LookUnder
  * 'under' noun                          -> LookUnder;

Extend 'look' first
! * 'up' noun 'in' noun                   -> Consult reverse;
	* 'up' scope=ConsultScope 'in' noun     -> Consult reverse
  * 'up' topic 'in' noun                  -> Consult reverse
  * 'in' noun 'about' scope=ConsultScope  -> Consult;

Verb meta 'map'
  *                                       -> Map;

Extend 'read' first
	* 'about' scope=ConsultScope 'in' noun  -> Consult reverse
	* scope=ConsultScope 'in' noun          -> Consult reverse;

Verb 'ring' 'toll' 'peal'
  * noun                                  -> Pull;

Extend only 'sit' first
  *                                       -> SitAny;

Verb 'xyzzy' 'plug'
  *                                       -> Xyzzy;

! ========================================================= Verb Subs

[ HelpSub;
  print
    "^OUR LADY OF THORNS is written by Joel Burton <joel at joelburton.com>.

    ^^Unfamiliar with IF? See
    https://pr-if.org/doc/play-if-card/";

  #IfDef HAS_HINTS;
    print
      "^^There are hints in this game, but they'll appear only as you encounter
      those challenges (so even seeing the titles won't spoil anything.)
      You can see the available ones with the command ~HINT~.";
  #IfNot;
    print
      "^^You're playing the small-size version of this game intended for
      retro 8-bit computers. There is a separate game file with hints that will
      also run on your system.";
  #EndIf;

  "^^For public areas the priory, you can see a map with MAP.

  ^^This is a game with subtle descriptions. Read things
  closely and don't be afraid to try other senses.

  ^^Playtesters and well-wishers: Melissa ~Moth~ Higuchi, Lois Burton.

  ^^Special thanks to: Fredrik Ramsberg, andrewj, curiousdannii, Garry Francis,
  and ~Pontus I~ for answering my questions on forums.";
];

[ HideSub ;
  if (noun == nothing) "Hide behind what, exactly?";
  if (noun ~= TombEzra)
    "You try, but you realize you could still be easily seen.";
  if (TombEzra has general)
    "You are already crouching down and hiding.";
  give TombEzra general;  ! hidden
  "You crouch far down on the darkest side of ", (the) TombEzra, ".";
];

[ LookUnderSub;
  if (ObjectIsUntouchable(noun)) return;
  "You find nothing unexpected.";
];

[ MapSub helpful;
  switch (location) {

    WestPorch, Nave, Quire, HighAltarArea, StJudeChapel, LadyChapel,
    FitzAlanChantry, Sacristy:
      font off;
      print "
        ^    to Tower  to Dorm   to Crypt
        ^   +---------------------------------+
        ^   |   @@64    .    @@64    .    @@64    Fitz |
        ^   |        .         .         -----|
        ^  -   Nave  .  Quire  .  Altar  Lady |
        ^   |        .         .         -----|
        ^   |        .         .         Jude |
        ^   +-------------|-------|-- --|-----+
        ^           to Cloister   | Sac |
        ^ @@64 = Stairs      |       +-----+^";

    CloisterE, CloisterN, CloisterNE, CloisterNW, CloisterS, CloisterSE,
    CloisterSW, CloisterW, Garth, PriorsSolar, Locutory,
    ChapterHouse, Lavatorium, Refectory:
      font off;
      print "
        ^     to Quire        Day Stairs
        ^        |          @@64
        ^ Solar--NW = N = NE--Chapter House
        ^        ||   |   ||
        ^ Locut--W -Garth- E--Scriptorium
        ^        ||   |   ||
        ^  Gate--SW = S = SE--Slype--Infirmary
        ^        |    |         |
        ^      Lav  Refect  to Gardens^";


    Dorm, Necessarium, Dorter, LayCells:
      font off;
      print "
      ^  +----------------+
      ^  | @@64              |
      ^  |     Dorm       |
      ^  |                |
      ^  |----   ---|-----+
      ^  | @@64 Dorter   Nec |  @@64: Stairs
      ^  |----   ---|-----+
      ^  |    Lay Dorm    |
      ^  +----------------+^";

    Slype, Infirmary, InfirmaryChapel, Herbarium, Garden:
      font off;
      print "
      ^ +----------------+-----------+
      ^       Slype      -           |
      ^ +-+-----  ----+--| Infirmary |
      ^   | Herbarium |  |           |
      ^ +-+----   ----+--+----- -----+
      ^ |                |           |
      ^ |     Garden     |  Chapel   |
      ^ |                |           |
      ^ +----------------+-----------+^";

    default: "There is no map for this area.";
  }
  font on;
  if (helpful) "^(You can see this map again by typing ~MAP~)^";
];

[ SitAnySub;
  if (location == Quire) <<Enter Stalls>>;
  if (location == Locutory) <<Enter LocutoryBenches>>;
  if (location == Refectory) <<Enter RefectoryBenches>>;
  "Where are you specifically trying to sit?";
];

[ XyzzySub; "You're in a monastery, not Colossal Cave."; ];


! ========================================== debugging grammar

#IfDef DEBUG;

  [ ServiceScope o ;
    switch (scope_stage) {
      1: rfalse;
      2:

        objectloop (o ofclass SceneService) PlaceInScope(o);
        rtrue;
    }
  ];

  Verb meta 'settime'   * number number        -> HourAdvance;
  Verb meta 'time'      *                      -> Time;
  Verb meta 'suspicion' * number               -> SuspicionChange;
  Verb meta '_//'       *                      -> SolveList;
  Verb '_cabinet'       *                      -> SolveCabinet;
  Verb '_library'       *                      -> SolveLibrary;
  Verb '_light'         *                      -> SolveLight;
  Verb '_lion'          *                      -> SolveLion;
  Verb '_dead'          *                      -> SolveAelredDead;
  Verb '_crypt'         *                      -> SolveCrypt;
  Verb '_solar'         *                      -> SolveSolar;
  Verb '_undercroft'    *                      -> SolveUndercroft;
  Verb '_service'       * scope=ServiceScope   -> StartService
                        *                      -> StartService;
  Verb '_stop'          *                      -> StopService;
  Verb meta 'showmonks' *                      -> ShowMonks;

  [ SuspicionChangeSub;
    suspicion_level = noun;
    "Suspicion Level set to ", suspicion_level, ".";
  ];

  [ HourAdvanceSub ; SetTime(noun * 60 + second); <<Time>>; ];
  [ ZeroPad n; if (n < 10) print "0"; print n; ];
  [ TimeSub ;
    "Sundial: ", (SundialTime) the_time, "^",
      "Clock: ", (ZeroPad) the_time / 60, ":", (ZeroPad) the_time % 60;
  ];

  [ SolveListSub;
     "_aelred _cabinet _library _light _lion _office";
  ];

  [ SolveAelredDeadSub;
      ! TODO: move logic of the end of the death scene into a function
      ! callable by places like this, and also move as much logic as possible
      ! from the Slype and other locations into the scene.
      give BrAelred ~animate;
      give BrAelred ~general;
      give ScenePreDeath ~general;
      remove BrAelred;
      f_smelled_aelred = 1;
      PlayerTo(InfirmaryChapel);
      "^DEBUG: Aelred killed^";
  ];
  [ SolveCabinetSub;
    give InfirmaryCabinet open ;
    PlayerTo(Infirmary);
    "^DEBUG: cabinet opened^";
  ];
  [ SolveLibrarySub;
    give BrWilfred general;
    give LibraryDoor open;
    PlayerTo(Library);
  ];
  [ SolveLightSub;
    move MyCandle to player;
    MyCandle.start_light();
    "DEBUG: You have the beeswax candle.^";
  ];
  [ SolveLionSub;
    PlayerTo(FitzAlanChantry);
    FitzAlanAltar.open_altar();
    "^DEBUG: Altar opened for you.^";
  ];
  ! [ SolveOfficeSub;
  !   ! Service.stop_service();
  !   PlayerTo(Quire);
  !   "DEBUG: Service solved.^";
  ! ];
  [ SolveCryptSub;
    <SolveLight>;
    <SolveLion>;
    <Go FAKE_D_OBJ>;
    <Examine Frame>;
    <Push Button>;
    <Go FAKE_S_OBJ>;
  ];
  [ SolveSolarSub ;
    give PriorDoor open;
    remove BrOswald;
    PlayerTo(PriorsSolar);
  ];
  [ SolveUndercroftSub o ;
    objectloop (o ofclass SceneService) {
      give o visited;
      if (o has general) o.stop_service();
    }
    give Undercroft light;
    remove BrHugh;
    PlayerTo(Undercroft);
  ];
  [ ShowMonksSub m ;
    objectloop (m ofclass Monk) {
      print (The) m, ": ", (name) parent(m), "^";
    }
  ];
  [ StartServiceSub o ;
    if (noun == nothing) {
      print "Options are:^";
      objectloop (o ofclass SceneService)
        print (the) o, "^";
      return;
    }
    the_time = noun.time_start;
    StartDaemon(noun);
    "^Starting ", (the) noun;
  ];

  [ StopServiceSub o ;
    print "Stopping";
    objectloop (o ofclass SceneService) {
      give o visited;
      if (o has general) o.stop_service();
    }
  ];

  Object MagicLightGem "gem"
    with name 'gem', description "Glows with debugging power.",
    has light;

#EndIf;


! ================================================================ Routines

[ IsCarryingLit obj;
    obj = child(player);
    while (obj ~= 0) {
        if (obj has light) return true;
        obj = sibling(obj);
    }
    return false;
];

[ NowInDark ;
  if (g_been_in_dark == false) {
    QuoteBoxSimple(quote_darkness);
    g_been_in_dark = true;
  }
];

Constant CLOCK_NIGHT 1;      !
Constant CLOCK_MORNING 2;
Constant CLOCK_AFTERNOON 3;
Constant CLOCK_EVENING 4;

[ RoughTime ;
  if (the_time >= 1320 || the_time <= 360) return CLOCK_NIGHT;  ! 10p-6a
  if (the_time <= 720) return CLOCK_MORNING;                    ! 6a-noon
  if (the_time <= 1080) return CLOCK_AFTERNOON;                 ! noon-6p
  return CLOCK_EVENING;                                         ! 6p-10p
];

! Recursively check if a non-PC monk is in an obj, yes=return monk
[ MonkInObj loc obj mir;
  objectloop (obj in loc) {
    if (obj ofclass Monk) {
      if (obj == BrWilfred && BrWilfred has general) continue;
      return obj;
    }
    mir = MonkInObj(obj);
    if (mir) return mir;
  }
  rfalse;
];

! Is a monk in this room? (searching recursively)
[ MonkInRoom loc ;
  if (loc == 0) loc = location;
  if (location == HighAltarArea or Quire) {
    return MonkInObj(HighAltarArea) || MonkInObj(Quire);
  }
  return MonkInObj(loc);
];

[ KillOff;
  deadflag = 3;
  " By the time your penance ends, any chance of solving any mystery
    has long passed.^";
];


! ================================================================== CLASSES
! Altar, Chest, Cot, Monk, Room, Statue



Class Altar                                                             ! >Altar
  class AdjObject,
  with
    article "an",
    short_name "altar",
    adj_name 'stone',
    noun_name 'altar',
    react_before [;
      Go:
        if (player in self) {
          if (selected_direction == d_to) <<Exit self>>;
          "You'd have to climb down from ", (the) self, " first.";
        };
    ],
    description [;
      print "A simple stone altar, worn smooth by centuries of prayer";
      PrintContents(". On it ", self, ISARE_BIT);
      ".";
    ],
    before [;
      Climb:
        if (MonkInRoom())
          "You dare not, especially with another brother in the area.";
        <<Enter self>>;
      Enter:
        if (MonkInRoom())
          "You dare not, especially with another brother in the area.";
    ],
    after [;
      Enter:
        "It feels deeply sacriligeous, but you climb onto the altar.";
      Exit:
        "You climb down from the altar.";
    ],
  has
    supporter enterable static;


! It's not hard to find the candle, but you can't take it until you've
! proved you need it by opening the passage to the FitzAlan Chantry or
! by visiting the kitchen to see the stairs to the Undercroft.

Class Candle                                                           ! >Candle
  class AdjObject,
  with
    noun_name 'candle' 'light',
    dont_need [;
      if (FitzAlanAltar hasnt moved && Kitchen hasnt visited)
        "There's no reason for this. The monastery is lit,
        except at late night,
        and carrying one about would only raise questions.";
    ],
    after [;
      Drop:
        self.stop_light();
        "You drop the candle and, in doing so, extinguish it.";
    ],
    start_light [;
      give self light;
    ],
    stop_light [;
      give self ~light;
    ],
    before [ helper ;
      Burn:
        ! > BURN CANDLE (in kitchen or nightstairs)
        ! > BURN CANDLE WITH HEARTH
        ! > BURN CANDLE WITH TIME CANDLE
        if (self has light) "It's already lit.";
        if (location == NightStairs) helper = TimeCandle;
        if (location == Kitchen) helper = Hearth;
        if ( (second == helper) || (second == nothing && helper) ) {
          self.start_light();
          "You light your candle using ", (the) helper, ".";
        }
        "You need something appropriate to light your candle.";
      Take:
        if (self.dont_need()) rtrue;
      SwitchOff:
        if (self hasnt light)
          "It isn't lit.";
        self.stop_light();
        "You extinguish the candle.";
    ],
  has
    ~light;


! One for every monk; can only search them when suspicious.

Class Chest                                                             ! >Chest
  with
    parse_name [ w count ;
      w = NextWord();
      if (w == 'chest' or 'box') return 1;
      if (w == 'brother') {
        count++;
        w = NextWord();
      }
      if (w ~= self.amonk.&name-->0
        or self.amonk.&possess-->0
        or self.amonk.&possess-->1) return 0;
      w = Nextword();
      if (w ~= 'chest' or 'box') return 0;
      return count + 2;
    ],
    description [;
      print_ret
        (The) self,
        " is like all the others: a simple wooden box with a lid.";
    ],
    short_name [;
      print (The) self.amonk, "'s chest"; rtrue;
    ],
    before [;
      if (action ~= ##Examine && MonkInRoom())
        "You wouldn't dare with another brother in the room.";
      Examine: ;
      Take:
        "You couldn't carry that easily---and besides, how would ",
        (The) self.amonk, " store anything?";
      Push, Turn:
        "There's nothing underneath it, and it will just frustrate the
        brothers to move their chests around.";
      Open:
        if (suspicion_level == 0)
          "Searching another brother's property
          without reason just feels wrong.";
      default:
        if (suspicion_level == 0)
          "Doing anything with another brother's property
          without reason just feels wrong.";
    ],
  has
    proper container ~open openable scenery;



