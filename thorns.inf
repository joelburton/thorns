! =============================================== Gamr

[ Initialise;
  TitlePage();
  location = WestPorch;
  give player light;
  "^^Murder scene here...^^^";
];

[ TitlePage i;
  @erase_window -1; print "^^^^^^^^^^^^^";
  i = 0->33; if (i > 30) i = (i-30)/2;
  style bold; font off; spaces(i);
  print " OUR LADY OF THORNS^";
  style roman; print "^^"; spaces(i);
  print "[Press SPACE to begin.]^";
  font on;
  box "Behold, how good and how pleasant it is"
      "for brethren to dwell together in unity."
      ""
      "-- Psalm 133";
  @read_char 1 -> i;
  @erase_window -1;
];

[ DeathMessage;
  if (deadflag == 1) print "You have died";
  if (deadflag == 3) print "You have failed";
];

[ LookDirSub;
  ! do i want to do this? or disable this except in certain places
  if (noun == n_obj && location.n_to ~= -1)
    "To the north, you see: ", (name) location.n_to;
];

Include "Grammar";

Extend 'look' first 
  * noun=ADirection -> LookDir;

