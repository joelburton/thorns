! ============================================================ Initialise

[ Initialise ;

  ! #IfDef Debug;
  !   <ScriptOn>;
  ! #EndIf;
  #IfV5;
  ClearScreen();
  #EndIf;

  ! example of using a dynamic string
  ! string DS_PRIORY_NAME "Our Lady of Thorns";
  ! print "^^Welcome to @(1)^";
  ! print "Welcome to @(DS_PRIORY_NAME)^";

  QuoteBoxSimple(quote_opening);
  SetTime(5 * 60, 2);
  lookmode = 2;  ! verbose mode by default

  ! objectloop (o ofclass Monk) o.go_home();
  move BrAelred to Dorm;
  move BrAnselm to Dorm;
  move BrBenedict to Necessarium;
  move BrHugh to Dorm;
  move BrMartin to Dorm;
  move BrRemigio to LayCells;
  move BrCuthbert to BellTower;
  move BrOswald to PriorsSolar;
  move BrWilfred to Necessarium;

  move MyRobe to player;

  print "Late Summer in the year of Our Lord 1346.
  The priory of Our Lady of Thorns stands forlornly on the cliffs above Ashcombe,
  on the northeast coast of England, where
  wind and sea have worn the stones for two hundred years.^^

  You awake at 5 AM to the sound of the great bell, calling you to
  Lauds. You are lying in your cot, still bleary from sleep.
  You've already been to two offices this morning, the first at 2 AM.
  Like your brethren, you sleep in your habit, so you're already fully dressed.

  ^^While you've been learning a great deal about healing herbs from your
  mentor, Brother Aelred, you had hoped that after five months here,
  you'd be better acclimated to the schedule and the interrupted sleep.^^

  ^^^(There are commands specific to this game. If you haven't played it
  before, type ~HELP~).^^";

  #IfDef HAS_HINTS; HintReady(Hint_intro); #EndIf;

  SceneLauds.start_service();

  ! Don't print the banner at start; print it after first office
  return 2;
];

#IfDef HAS_HINTS;
Include "./game_hints.inf";
#EndIf;

! TODO: one scene: for forced march to aelred AND for dying scene

Object ScenePreDeath "pre-death"                                ! >ScenePreDeath
  with
    react_before [ dest;
      Go:
        dest = location.(selected_direction);
        if (dest == 0) rfalse;
        if (dest == Nave or Quire or HighAltarArea or LadyChapel
              or CloisterNE or CloisterN)
          rfalse;
        "While you enjoy exploring the church, you should go to the
        Garden and begin your daily labors with Brother Aelred.";
    ],
  has ;

! Aelred     herbalist    63   slype                1
! Anselm     cantor       30   locutory             all
! Benedict   infirmarer   48   infirmary,charter    1
! Cuthbert   sacrist      46   cloisters            all
! Hugh       cellarer     32   undercroft           all
! Martin     kitchener    42   kitchen,charter      all
! Oswald     prior        52   solar                all
! Remigio    servant/lay  38   kitchen              1
! Wilfred    librarian    73   scriptorium          all
! Aldwin     novice       20                        1

! general = active (adds to scope, is equal to daemon-active)
! visited = has already happened
! on = service is underway (ie, PC should be sat and singing)

Class SceneService
  with
    name 'service',
    num_present 0,
    req_monks BrAnselm BrCuthbert BrHugh BrMartin BrOswald BrWilfred BrBenedict,
    time_left 0,
    service_order 0,
    start_service [;
      ! start the daemon, set to general (active), simplify quire description.
      ! if this isn't the first service (the bell happens just pre-game),
      ! note that the hear the bell.
      StartDaemon(self);
      give self general;
      current_service = self;
      Quire.old_description = Quire.description;
      Quire.description = QuireDescripDuringService;
      give Stalls concealed;
      if (self.service_order)
        print
            "^You hear the bell ring ", (LanguageNumber) self.service_order,
            " times to call the Brothers to ", (the) self, ".^";
    ],
    stop_service [ o ;
      StopDaemon(self);
      Quire.description = Quire.old_description;
      give Stalls ~concealed;
      ! Only say this if Aldwin in the quire
      if (location == Quire)
        print
          "^  - * - * -^^The office ends and the other brothers depart,
          leaving you in the Quire.^";
      objectloop(o ofclass Monk) {
        ! when he's dead, aelread will be nowhere
        if (parent(o) ~= nothing) o.go_home();
      }
      ! the first service is special; it leads immediately to corralling
      ! the player to the slype, and it's after this service that the
      ! game "starts"
      if (self.service_order == 0) {
        print
          "^You spend a few minutes reflecting on your life
          now: ritual, timing, prayer, silence. It feels both comforting and
          confining. You're not sure which feeling will win.^";
        give ScenePreDeath general;
        Banner();
      }
      give self ~general; ! no longer active
      give self visited;  ! never do this service again; it's 100% done
      give self ~on;      ! actual singing is done
      current_service = 0;
      the_time = self.time_start + (self.service_length * 4); ! takes time
      ! but don't change the "moves", this wasn't a player choice
    ],
    has_sung false,    ! has player sung during the actual service?
    service_rounds 0,  ! what "round" of the active-singing is this?
    service_length 6,  ! how many turns do they get?
    aldwin_joining false,   ! is aldwin joining in?
      ! if so, he has to do the right things
      ! he'll be auto-joined for the first one (Lauds), but not for the others

    react_before [ dest going ;
      ! if aldwin isn't joining this service, he skips the consequences
      if (self.aldwin_joining == false) rfalse;

      Sing:
        if (player notin Stalls)
          "You should sing from the stalls. Seat yourself.";
        if (self hasnt on)
          "The service hasn't started yet.";
        if (self.has_sung)
          "You're already singing and will continue to do so throughout the
          service. If you'd like to perform other allowed actions during
          the service, you may.";
        self.has_sung = 1;
        print "You join the others in song.^";
        if (self.service_order == 0) QuoteBoxSimple(quote_song);
        rtrue;
      Go:
        going = location.(selected_direction);
        if (going == 0) rfalse;
        dest = MonkMonkToService(player, location);
        if (going ~= dest) {
          "Going to ", (the) going,
          " isn't the right direction for the Divine Office.
          You want to head to ", (the) dest, ".";
        }
      Exit:
        if (noun == Stalls) "Not during office, surely!";
      Ask, Tell, Give, AskFor, AskTo, Shout, ShoutAt:
        if (noun == BrAelred) rfalse;
        "Absolute silence is the rule when called to Divine Office.";
      Wait:
        if (self.has_sung)
          self.service_rounds = 100;  ! they're bored, end service
    ],
    daemon [ i monk now_at going_to newline num_ready ;
      self.time_left++;

      if (self hasnt on) {
        ! Service hasn't started yet; move monks to sitting in quire
        for (i = 0: i < self.#req_monks / 2: i++) {
          monk = self.&req_monks-->i;
          now_at = parent(monk);
          going_to = MonkMonkToService(monk, now_at);
          if (going_to == 0) { num_ready++; continue; }
          if (now_at ~= Quire && parent(monk) == location) {
            print "^", (the) monk, " leaves, heading to Divine Office.";
            newline = true;
          }
          move monk to going_to;
          if (going_to == location) {
            print "^", (the) monk, " arrives.";
            newline = true;
          }
          else if (going_to == Stalls && location == Quire) {
            print "^", (the) monk, " sits in the stalls.";
            newline = true;
          }
        }
        if (newline) print "^";

        if (num_ready == self.#req_monks / 2) {
          give self on;  ! all the monks are in the right place now
        }
        ! Don't check singing until service starts
        return;
      }

      if (self.service_rounds == 0) {
        if (location == Quire)
          print "^Brother Anselm begins to lead the brethren in song.^";
        else if (location ==
            Crypt or CryptStairs or LadyChapel or StJudeChapel
            or FitzAlanChantry or NightStairs or Nave or HighAltarArea
            or CloisterNE or DayStairs)
          print "^In the distance, you can hear singing as the office starts.^";
      }

      ! service is underway
      self.service_rounds++;

      if (self.aldwin_joining && location ~= Quire) {
        print
          "^Brother Cuthbert finds you, exasperated. ~Why aren't you
          singing with the other brothers in the quire?~^";
        self.failed();
        return;
      }

      if (parent(player) == Quire) {
        if (self.service_rounds == 1)
          print
            "^The other monks look at you, puzzled. Why aren't you
            seated with them?^";
        if (self.service_rounds > 1) {
          self.failed();
          return;
        }
      }

      if (self.aldwin_joining) {
        if (self.has_sung == false) {
          if (self.service_rounds > 1) {
            print
              "^Brother Anselm looks at you pointedly.
              Why aren't you singing?^";
          }
          else if (self.service_rounds > 2) {
            self.failed();
            return;
          }
        } else {
          print "^You continue to sing with the others.^";
        }
      }

      if (self.service_rounds >= self.service_length) {
        self.stop_service();
      }
    ],
    failed [;
      print
        "^   - * - * -^^
        After the service, Brother Oswald confronts you about your
        behavior. ~Where was your mind, Brother Aldwin? Part of being
        a monk is joining in song.~ You are confined to silent prayer
        for three days.";
      KillOff();
      return;
    ],
  has concealed;


