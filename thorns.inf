[ SitAnySub;
  "Where, specifically, are you trying to sit?";
];

! IDEA: flag bored on scenes; "z" will move forward in other places
!  waiting for service to start, etc

! Wrapper for Achived; allows for debugging
[ TaskDone t ;
  #IfDef FULL_DEBUG;
  if (task_done->t == 0)
    print "^*** DEBUG: task completed: ", (PrintTaskName) t;
  #EndIf;
  Achieved(t);
];


[ XyzzySub; "You're in a monastery, not Colossal Cave."; ];


! ========================================== debugging grammar

#IfDef DEBUG;

  [ SceneScope o ;
    switch (scope_stage) {
      1: rfalse;
      2:
        objectloop (o ofclass Scene) PlaceInScope(o);
        rtrue;
    }
  ];

  Verb meta 'settime'   * number number        -> SetTime;
  Verb meta 'realtime'  *                      -> RealTime;
  Verb meta 'suspicion' * number               -> SuspicionChange;
  Verb meta 'evidence'  * number               -> Evidence
                        *                      -> Evidence;
  Verb meta '_//'       *                      -> SolveList;
  Verb '_cabinet'       *                      -> SolveCabinet;
  Verb '_library'       *                      -> SolveLibrary;
  Verb '_light'         *                      -> SolveLight;
  Verb '_crypt'         *                      -> SolveCrypt;
  Verb '_solar'         *                      -> SolveSolar;
  Verb '_undercroft'    *                      -> SolveUndercroft;
  Verb '_start'         * scope=SceneScope     -> StartScene
                        *                      -> StartScene;
  Verb meta '_stop'     *                      -> StopScenes;
  Verb meta 'showmonks' *                      -> ShowMonks;
  Verb meta 'quotes'    *                      -> TestQuotes;
  Verb meta '!//'       * topic                -> Comment;
  Verb '_ending'        * number               -> Ending;

  [ EvidenceSub ;
    if (noun == nothing) print_ret CalculateEvidence();
    enough_evidence = noun;
  ];

  [CommentSub i ;
    if (active_timers) {
      print "*** DEBUG DAEMONS:";
      for (i = 0 : i < active_timers : i++)
        print " ", (name) (the_timers-->(i) & ~WORD_HIGHBIT);
      new_line;
    }
    print "*** CHECK EVIDENCE:^";
    font off;
    print
      "  ", ev_symptoms, " symptoms      ",
          ev_hen_symptoms, " hen_symptoms     ",
          ev_took_poison, " took_poison
      ^  ", ev_coins, " coins         ",
          ev_rose_letters, " rose_letters     ",
          ev_note, " note
      ^  ", ev_chronicle, " chronicle     ",
          ev_psalter, " psalter          ",
          ev_rosehips, " rosehips
      ^  ", suspicion_level, " suspicion^";
    font on;
    print "*** SCOPE^";
    <Scope>;
    print "*** SCORE";
    <FullScore>;
    print "*** INVENTORY: ";
    <Inv>;
    new_line;
    if (transcript_mode) {
      PrintMsg(MSG_COMMENT_TRANSCRIPT);
    }
    else PrintMsg(MSG_COMMENT_NO_TRANSCRIPT);
  ];

  [ SuspicionChangeSub;
    suspicion_level = noun;
    "Suspicion Level set to ", suspicion_level, ".";
  ];

  [ SetTimeSub ; SetTime(noun * 60 + second); <<Time>>; ];

  [ ZeroPad n; if (n < 10) print "0"; print n; ];

  [ RealTimeSub ;
      print_ret the_time / 60, ":", (ZeroPad) the_time % 60;
  ];

  [ SolveListSub;
     "_cabinet _library _light _crypt _solar _undercroft _start _stop";
  ];

  [ SolveCabinetSub;
    give InfirmaryCabinet open ;
    PlayerTo(Infirmary);
    "^DEBUG: cabinet opened^";
  ];

  [ SolveLibrarySub;
    give BrWilfred general;
    give LibraryDoor open;
    PlayerTo(Library);
    "^DEBUG: Wilfred asleep and library opened^";
  ];

  [ SolveLightSub;
    move MyCandle to player;
    MyCandle.start_light();
    "DEBUG: You have the beeswax candle.^";
  ];

  [ SolveCryptSub;
    <SolveLight>;
    give Frame general;
    give FitzAlanPanel open;
    PlayerTo(Crypt);
  ];

  [ SolveSolarSub ;
    give PriorDoor open;
    remove BrOswald;
    PlayerTo(PriorsSolar);
    "^DEBUG: Solar door opeend and Oswald moved.^";
  ];

  [ SolveUndercroftSub ;
    <StopScenes>;
    give Undercroft light;
    remove BrHugh;
    PlayerTo(Undercroft);
    "^DEBUG: Moved to undercroft and removed Hugh^";
  ];

  [ ShowMonksSub m ;
    objectloop (m ofclass Monk) {
      print (The) m, ": ", (name) parent(m), "^";
    }
  ];

  [ StartSceneSub o ;
    if (noun == nothing) {
      print "^";
      objectloop (o ofclass Scene)
        print (address) o.&name-->0, ": ", (The) o, "^";
      return;
    }

    <StopScenes>;
    if (o ofclass SceneService) the_time = noun.time_start;
    noun.scene_start();
    print "^DEBUG: ", (The) noun, " started^";
  ];

  [ StopScenesSub o ;
    objectloop (o ofclass Scene) {
      if (o has general) {
        o.scene_stop();
        print "^DEBUG: ", (The) o, " stopped.^";
      }
    }
  ];

  [ TestQuotesSub i quote_array ;
    for (i = 1 : i <= test_quotes-->0 : i++) {
      quote_array = test_quotes-->i;
      QuoteBoxSimple(quote_array);
    }
  ];

  [ EndingSub ;
    Ending(noun);
  ];

  Object SmellySock "smelly sock"
    with
      name 'smelly' 'sock',
      description "Yeck.",
      before [;
        Smell: "It smells like feet.";
      ],
    has ok_carry;

  Object MagicLightGem "gem"
    with
      name 'gem',
      description "Glowing with debugging power.",
    has light ok_carry;

#EndIf;


! ================================================================ Routines

[ IsLit loc;
  return _LookForLightInObj(loc, loc);
];


[ Ending choice ;
  deadflag = choice;

  switch(choice) {
    DEAD_JUSTICE:
      print
        "^You tell Prior Oswald everything. Hugh is taken by the sheriff within
        days. He is tried, condemned, and hanged before the month is out. Rose
        dies alone that winter, with no brother to tend her.

        ^^You kept your vows. You served truth. But standing in the herb garden
        where Brother Aelred died, you wonder if justice and mercy are truly
        the same thing---or if, in choosing one, you betrayed the other.

        ^^Brother Aelred's words echo: ~One life for two, my son.~ You will never know
        if you honoured his sacrifice, or squandered it.";

    DEAD_MERCY:
      print
        "^You tell Brother Hugh to leave. Tonight. Before questions are asked.
        He takes flight, and you never learn what becomes of him---or Rose.

        ^^You lied to the Prior. You broke your vows. But when you pray before
        the Lady of Thorns, you remember Brother Aelred's last words: ~One life
        for two, my son.~ Perhaps mercy, not justice, was what he meant.

        ^^Still, you wonder. A murderer walks free. Does forgiveness make you
        holy, or complicit? You will carry this question all your days.";

    DEAD_INACTION:
      print
        "^Brother Hugh fled in the night, never to be seen again.

        ^^In the weeks that followed, Brother Wilfred grew silent and withdrawn.
        He stopped eating, stopped illuminating. One morning, he simply didn't
        wake. Whether from grief for Brother Aelred or despair at the priory's
        decline, he had lost his will to live.

        ^^Three brothers lost. The Rule continues, but the light grows dimmer.";

    DEAD_UNSOLVED:
      print
        "^Brother Aelred was buried the next day in the priory graveyard,
        marked only by a simple wooden cross.

        ^^On warm days, you bring him rosemary and lay it next to his cross.

        ^^You can't shake the feeling that you failed him---that the last thing
        you could have done for your mentor, you left undone. You'll carry
        that feeling for all your days.";
  }
];


[ StoryPause;
  "^     ------------- && -------------";
];

[ IsCarryingLit obj;
    ! don't need to recurse, since hood and basket can't contain anything lit
    obj = child(player);
    while (obj ~= 0) {
        if (obj has light) return true;
        obj = sibling(obj);
    }
    return false;
];


! Called because entered
! dark room or room become dark (ie, Sacristy door closed)

[ NowInDark ;
  if (f_been_in_dark == false) {
    QuoteBoxSimple(quote_darkness);
    f_been_in_dark = true;
  }
];


! Used for things like reprting the lighting conditions

Constant CLOCK_NIGHT 1;      !
Constant CLOCK_MORNING 2;
Constant CLOCK_AFTERNOON 3;
Constant CLOCK_EVENING 4;

[ RoughTime ;
  if (the_time >= 1320 || the_time <= 360) return CLOCK_NIGHT;  ! 10p-6a
  if (the_time <= 720) return CLOCK_MORNING;                    ! 6a-noon
  if (the_time <= 1080) return CLOCK_AFTERNOON;                 ! noon-6p
  return CLOCK_EVENING;                                         ! 6p-10p
];

[ DescribeLight ;
  switch (RoughTime()) {
    CLOCK_NIGHT: print "pale moonlight";
    CLOCK_MORNING: print "cool morning light";
    CLOCK_AFTERNOON: print "bright afternoon light";
    CLOCK_EVENING: print "slanted evening light";
  }
];


! Recursively check if a non-PC monk is in an obj, yes=return monk
!  non-narcs are sleeping wilfred, aelred, remigio

[ NarcInObj loc m mloc;
  objectloop (m ofclass Monk) {
    if (m == BrWilfred && BrWilfred hasnt awake) continue;
    if (m == BrAelred or BrRemigio) continue;
    mloc = parent(m);
    if (parent(mloc) ~= nothing) mloc = parent(mloc);
    if (mloc == loc) return m;
  }
  rfalse;
];


! Is a non-narc monk in this area? (searching recursively)
!  non-narcs are sleeping wilfred, aelred, remigio

[ NarcInRoom loc res;
  if (loc == 0) loc = location;

  switch (loc) {
    HighAltarArea:
      res = NarcInObj(loc); if (res) return res;
      res = NarcInObj(Quire); if (res) return res;
      rfalse;
    Quire:
      res = NarcInObj(loc); if (res) return res;
      res = NarcInObj(HighAltarArea); if (res) return res;
      rfalse;
    Garth:
      res = NarcInObj(CloisterN); if (res) return res;
      res = NarcInObj(CloisterW); if (res) return res;
      res = NarcInObj(Garth);     if (res) return res;
      res = NarcInObj(CloisterE); if (res) return res;
      res = NarcInObj(CloisterS); if (res) return res;
      rfalse;
    CloisterNW:
      res = NarcInObj(CloisterW);  if (res) return res;
      res = NarcInObj(CloisterNW); if (res) return res;
      res = NarcInObj(CloisterN);  if (res) return res;
      rfalse;
    CloisterN:
      res = NarcInObj(CloisterNW); if (res) return res;
      res = NarcInObj(CloisterN);  if (res) return res;
      res = NarcInObj(CloisterNE); if (res) return res;
      rfalse;
    CloisterNE:
      res = NarcInObj(CloisterN);  if (res) return res;
      res = NarcInObj(CloisterNE); if (res) return res;
      res = NarcInObj(CloisterE);  if (res) return res;
      rfalse;
    CloisterW:
      res = NarcInObj(CloisterSW); if (res) return res;
      res = NarcInObj(CloisterW);  if (res) return res;
      res = NarcInObj(CloisterNW); if (res) return res;
      rfalse;
    CloisterE:
      res = NarcInObj(CloisterNE); if (res) return res;
      res = NarcInObj(CloisterE);  if (res) return res;
      res = NarcInObj(CloisterSE); if (res) return res;
      rfalse;
    CloisterSW:
      res = NarcInObj(CloisterW);  if (res) return res;
      res = NarcInObj(CloisterSW); if (res) return res;
      res = NarcInObj(CloisterS);  if (res) return res;
      rfalse;
    CloisterS:
      res = NarcInObj(CloisterSW); if (res) return res;
      res = NarcInObj(CloisterS);  if (res) return res;
      res = NarcInObj(CloisterSE); if (res) return res;
      rfalse;
    CloisterSE:
      res = NarcInObj(CloisterS);  if (res) return res;
      res = NarcInObj(CloisterSE); if (res) return res;
      res = NarcInObj(CloisterE);  if (res) return res;
      rfalse;
    default:
      return NarcInObj(loc);
  }
];


[ KillOff;
  deadflag = DEAD_FAILED;
  print
    " By the time your penance ends, any chance of solving any mystery
    has long passed.";
];


! ================================================================== CLASSES
! Altar, Chest, Cot, Monk, Room, Statue

Constant MSG_DARE_NOT_ANOTHER_BROTHER
  "You dare not, especially with another brother in the area.";

Class Altar                                                             ! >Altar
  class AdjObject,
  with
    article "an",
    short_name "altar",
    adj_name 'stone',
    noun_name 'altar',
    react_before [;
      Go:
        if (player in self) {
          if (selected_direction == d_to) <<Exit self>>;
          "You'd have to climb down from ", (the) self, " first.";
        };
    ],
    description [;
      print "A simple stone altar, worn by generations of prayer";
      PrintContents(". On it ", self, ISARE_BIT);
      ".";
    ],
    before [;
      Receive:
        if (self hasnt supporter)
          "You dare not place your things on this sacred space.";
      Climb, Enter:
        if (self hasnt enterable) "You dare not climb on this.";
        if (NarcInRoom()) print_ret (string) MSG_DARE_NOT_ANOTHER_BROTHER;
        if (action == ##Climb) <<Enter self>>;
    ],
    after [;
      Enter:
        "It feels deeply sacrilegious, but you climb onto the altar.";
      Exit:
        "You climb down from the altar.";
    ],
  has
    supporter enterable static;



Class Barrel                                                           ! >Barrel
  with
    name 'barrel' 'barrels//p',
    simple_name 0,
    describe 0,
    parse_name [ w1 w2 matches;
      w1 = NextWord();

      if (w1 == self.simple_name) {
        matches = 1;
        w2 = NextWord();
        if (w2 == 'barrel') return 2;
        return 1;
      }

      if (w1 == 'barrel') {
        matches = 1;
        w2 = NextWord();
        if (w2 == 'of') {
          matches++;
          w2 = NextWord();
          if (w2 == self.simple_name) return 3;
        }
        else if (w2 == self.simple_name) return 2;
        return 1;
      }

      return 0;
    ],
    description [;
      print
        "A stout wooden barrel bearing the charcoal mark
        ~", (address) self.simple_name, "~";
      if (self has open)
        print ". It is currently open, revealing the expected contents";
      ".";
    ],    before [;
      Receive:
        if (noun == Stick) <<Search self>>;
        "You shouldn't add anything to the barrels.";
      Search:
        if (self hasnt open) "You cannot, since the barrel is closed.";
        if (parent(Stick) ~= player)
          "The barrels are much too deep to poke around in easily.";
        if (~~f_warned_about_barrel_search_time) {
          f_warned_about_barrel_search_time = true;
          print "Searching ", (the) self,
              " will take several minutes. Are you sure? ";
          if (YesOrNo() == false) "You think better of it.";
          new_line;
        }
      Take: "The barrels are too heavy, and you've no need of the contents.";
      Empty, Pull, Push, Turn:
        "These are so heavy they're impossible for you to move.
        Brother Hugh is much stronger than you.";
      Smell:
        if (self hasnt open) "With it closed, you can't detect any scent.";
      Taste:
        if (self hasnt open) "You cannot, since the barrel is closed.";
      Eat:
        if (self hasnt open) "You cannot, since the barrel is closed.";
        "You might taste it if you'd like, but not eat the whole thing.";
      Open:
        if (~~f_warned_about_barrel_open_time) {
          f_warned_about_barrel_open_time = true;
          print "Openining the sealed ", (name) self,
              " will take several minutes. Are you sure? ";
          if (YesOrNo() == false) "You think better of it.";
          new_line;
        }
    ],
    after [;
      Open:
        the_time = the_time + 2;
        "With some effort, you succeed.";
      Close: "You pound on the lid to shut it.";
      Search:
        the_time = the_time + 2;
        "Digging around with the stick, you find nothing unexpected.";
    ]
  has static container openable ~open;



! It's not hard to find the candle, but you can't take it until you've
! proved you need it by opening the passage to the FitzAlan Chantry or
! by visiting the kitchen to see the stairs to the Undercroft.

Class Candle                                                           ! >Candle
  class AdjObject,
  with
    noun_name 'candle',
    dont_need [;
      if (~~f_found_darkness)
        "There's no reason for this. The monastery gets natural light, except
        at late night, and carrying one about would only raise questions.";
    ],
    list_together "candles",
    after [;
      Drop:
        self.stop_light();
        "You drop the candle and, in doing so, extinguish it.";
    ],
    start_light [;
      give self light;
      TaskDone(TASK_SOURCE_LIGHT);
      scope_modified = true;
    ],
    stop_light [;
      give self ~light;
      scope_modified = true;
    ],
    each_turn [ c;
      if (location == WestPorch or Passage or PassageSouth) {
        objectloop (c ofclass Candle) {
          if (c in player && c has light) {
            c.stop_light();
            print "^", (The) c, " blows out in the breeze.^";
          }
        }
      }
    ],
    before [ helper ;
      Burn:
        if (self has light) print_ret (The) self, " is already lit.";
        if (NarcInRoom())
          print_ret (string) MSG_DARE_NOT_ANOTHER_BROTHER;
        if (self notin player)
          "You need to be holding ", (the) self, " to do that.";
        ! > BURN CANDLE (in kitchen or nightstairs)
        ! > BURN CANDLE WITH HEARTH
        ! > BURN CANDLE WITH TIME CANDLE
        helper = -1;
        if (location == NightStairs) helper = TimeCandle;
        else if (location == Kitchen) helper = Hearth;
        else if (location == Scriptorium) helper = Fireplace;
        if ( (second == helper) || (second == nothing && helper ~= -1) ) {
          self.start_light();
          "You light ", (the) self, " using ", (the) helper, ".";
        }
        "You need something appropriate to light the candle.";
      Take:
        if (self.dont_need()) rtrue;
      Extinguish, SwitchOff:
        if (self hasnt light) print_ret (The) self, " isn't lit.";
        self.stop_light();
        "You extinguish ", (the) self, ".";
    ],
  has
    ~light;


Class Chair                                                             ! >Chair
  class AdjObject,
  with
    react_before [ ks ;
      Go:
        if (player in self) {
          if (selected_direction == u_to) <<Exit self>>;
          print "(first getting up from ", (the) self, ")^";
          ks = keep_silent;
          keep_silent = true;
          <Exit self>;
          keep_silent = ks;
        };
    ],
    before [;
      Push, Pull, Turn:
        "You move ", (the) self, " and find nothing unexpected.
        You set ", (ItOrThem) self, " back in place.";
      Take:
        print_ret (CObjIs) self, " much too large to carry.";
      Receive:
        print_ret (CObjIs) self, " for sitting, not cluttering with stuff.";
    ],
    after [;
      Enter:
        "You sit on ", (the) self, ".";
      Exit:
        if (keep_silent) rtrue;
        "You stand up from ", (the) self, ".";
    ],
  has
    supporter enterable static;


! One for every monk; can only search them when suspicious.

Constant MSG_ANOTHER_BROTHERS_PROPERTY_WRONG
  "another brother's property without reason just feels wrong.";

Class Chest                                                             ! >Chest
  with
    parse_name [ w count ;
      w = NextWord();
      if (w == 'chest' or 'box') return 1;
      if (w == 'brother') {
        count++;
        w = NextWord();
      }
      if (w ~= self.amonk.&name-->0
        or self.amonk.&possess-->0
        or self.amonk.&possess-->1) return 0;
      w = Nextword();
      if (w ~= 'chest' or 'box') return 0;
      return count + 2;
    ],
    description [;
      print
        (The) self,
        " is like all the others: a simple wooden box with a lid";
      if (self has open) print ". It is open";
      ".";
    ],
    short_name [;
      print (The) self.amonk, "'s chest"; rtrue;
    ],
    before [;
      if (action ~= ##Examine && NarcInRoom())
        print_ret (string) MSG_DARE_NOT_ANOTHER_BROTHER;
      Examine: ;
      Smell: "Just dusty.";
      Take:
        "You couldn't carry that easily---and besides, how would ",
        (The) self.amonk, " store anything?";
      Push, Turn, Pull:
        "There's nothing underneath it, and it will just frustrate the
        brothers to move their chests around.";
      Open:
        if (suspicion_level == 0)
          "Searching ", (string) MSG_ANOTHER_BROTHERS_PROPERTY_WRONG;
      Lock, Unlock:
        "The chests have no locks.";
      default:
        if (suspicion_level == 0)
          "Doing anything with ", (string) MSG_ANOTHER_BROTHERS_PROPERTY_WRONG;
    ],
  has
    proper container ~open openable scenery;


[ DieIfToxic ate ;
  if (self hasnt toxic) rfalse;
  deadflag = 4;
  "Foolishly, you decide to eat ", (the) ate, ", failing to remember
  that it's toxic. You spend several days very sick. Any chance you
  had of solving Brother Aelred's murder passed.";
];

Constant MSG_DARE_NOT_TOXIC
  "You dare not. It's toxic and irritating to the touch.";



Class Herb                                                               ! >Herb
  with
    name 'sprig' 'sprigs//p',
    list_together [ ;
			if (inventory_stage == 1) { print "some sprigs ("; }
      else if (inventory_stage == 2) { print ")"; }
		],
    before [;
      Eat:
        if (DieIfToxic(self)) rtrue;
        "You shouldn't eat the entire sprig. If you want to just see what it
        tastes like, say so.";
      Touch, Take:
        if (self has toxic && Gloves hasnt worn)
          print_ret (string) MSG_DARE_NOT_TOXIC;
    ],
    after [;
      Drop: "You drop the delicate sprig.";
    ],
  has edible ok_carry ;


! Base class for all animated brothers (except player)
!
! Monks may only be in:
!   - Quire
!   - HighAltarArea
!   - Night Stairs
!   - Cloister any part (not Garth)
!   - PriorsSolar (just Oswald)
!   - Locutory (just Anselm [or maybe can wave others in?])
!   - Refectory (Martin, temporarily)
!   - Kitchen (Remigio and Martin)
!   - Slype (Benedict)
!   - Crypt & CryptVestry (just Cuthbert, while investigating noise)
!   - Chapter House
!   - Scriptorium (only Wilfred)
!   - Undercroft (only Hugh)
!   - Bell Tower
!   - Tower Stairs
!   - Nave


Class Monk                                                               ! >Monk
  with
    name 'brother' 'monk',
    orders [;
      "You're just a novice, and in no position to order anyone around.";
    ],
    describe [;
      ! we use the bulleted list in the quire to help w/sat-not-sat
      if (location == Quire) rtrue;
    ],
    list_together "monks",
    walk_start 0,
    service_location 0,   ! where did they get to in last service?
    life [;
      Tell, Answer, Yes, Ask, Show:
        print_ret
          (The) self, " presses a finger to his lips, reminding
          you of the rule of silence toward needless conversation.";
      Give:
        print_ret
          (The) self, " looks puzzled and refuses your gift with a gesture.";
      Kiss: ;
      default: "BUG HOW DID YOU GET HERE?";
    ],
  has
    animate proper
    awake
    ! In real game, you can't carry these --- but for testing purposes,
    ! I often purloin a monk to move them where I want them --- and don't
    ! want that to trigger as contraband
    ok_carry
  ;

Verb meta 'who' * -> Who ;

[ WhoSub during_look m count p;
  objectloop (m ofclass Monk) {
    p = parent(m);
    if (p && location == p or parent(p))
      count++;
  }
  if (count == 0) {
    if (~~during_look) "There are no brothers here.";
    rtrue;
  }
  if (during_look) print "^";
  print "Brothers here:";
  objectloop (m ofclass Monk) {
    p = parent(m);
    if (p && location == p or parent(p)) {
      print "^- ", (string) m.simple_name, ", the ", (string) m.job_title;
      if (p ~= location) print " (seated)";
    }
  }
  "";
];

! Base class for plants; player can't take these, but can get a sprig of
! each of these, which is an Herb (defined above)

Class Plant                                                             ! >Plant
  with
    name 'plant',
    before [  p ; ! p ks ;
      Eat:
        if (DieIfToxic(self)) rtrue;
      Touch:
        if (self has toxic && Gloves hasnt worn)
          print_ret (string) MSG_DARE_NOT_TOXIC;
      Take:
        if (self has toxic && Gloves hasnt worn)
          print_ret (string) MSG_DARE_NOT_TOXIC;
        p = child(self);
        if (p == nothing)
          "You've already taken a sprig from ", (the) self, ".";
        move p to location;
        ! give p ~concealed;
        noun = p;
        if (TryToTakeNoun(true) ~= 1) {
          PronounNotice(p);
          print
            "Rather than trying to take the entire plant, you take a sprig
            of it.^";
          } else {
            move p to self;
          }
        rtrue;
    ],
  has
    ~edible scenery ;


! Very light, just here so it's easy to distinguish room vs object
! with a ofclass check.

Class Room                                                               ! >Room
  with
  has light;  ! turn off in individual underground rooms


! Statues found in altars and in chapel house: Mary, St Jude, Gordian

Class Statue                                                           ! >Statue
  with
    name 'statue',
    before [;
      Take:
        "The statue has stood here for many years.";
      Push, Pull, Turn:
        print "With some effort, you ";
        switch (action) {
          ##Push: print "push";
          ##Pull: print "pull";
          ##Turn: print "rotate";
        }
        " the statue a bit, revealing nothing unexpected. Feeling guilty about
        the potential sacrilege of this action, you reset it as it was.";
      LookUnder:
        "You can't lift the statue to search under it.";
    ],
    life [;
      Attack, ShoutAt: "Perish the very idea!";
      Give:
        "You cannot offer ", (ItorThem) self, " anything but your reverence.";
      Ask, Tell, Answer, Show: "The statue remains ever-silent.";
      WakeOther: "Save the miracles for others.";
      Kiss:
        "You reverently kiss the hem of ", (ItorThem) self, " robe.";
      Order:
        "If anything, a statue of a saint would order you around.";
    ],
  has
    static animate proper;


! Medicines in the infirmary

Class Decoction                                                     ! >Decoction
  with
    name 'decoction' 'decoctions//p',
    list_together [ ;
			if (inventory_stage == 1) { print "some decoctions ("; }
      else if (inventory_stage == 2) { print ")"; }
		],
    before [;
      Eat, Drink: "You dare not.";
      Attack:
        "You shouldn't break this---such bottles are valuable
        and communal property.";
      Empty:
        "These decoctions are used by Brother Benedict in healing.
        It would be wrong to waste them.";
    ],
  has
    ok_carry proper;


Constant MSG_DISTURBING_DEAD "Disturbing the Christian dead is a mortal sin.";


Class Tomb                                                               ! >Tomb
  class AdjObject,
  with
    adj_name 'brother' 'prior',
    description [;
      print_ret
        (The) self, " is a stone block with a lid on which his name is carved.
        It is otherwise like all of the others in the room.";
    ],
    react_before [;
      Jump:
        if (location == FitzAlanCrypt && parent(Player) ofclass Tomb)
          "You jump, hoping to reach the ladder, but it's too high up.";
      Go:
        if (player in self && selected_direction == d_to) <<Exit self>>;
    ],
    before [;
      Attack:
        print_ret (string) MSG_DISTURBING_DEAD;
      Push, Turn, Pull, LookUnder:
        print (string) MSG_DISTURBING_DEAD;
        "^Besides, the tomb and the lid must weigh several hundredweight.
        It would take multiple men with levers to shift one.";
      Climb: <<Enter self>>;
      Open: "They are sealed solidly with mortar.";
    ],
    after [;
      Enter:
        "While it feels deeply sacrilegious, you climb on ", (the) self, ".";
      Exit: "You climb down from ", (the) self, ".";
    ],
  has supporter enterable scenery proper;


! =================================================================== MONKS
! NAME       ROLE         AGE  GOES_TO              SERVICE
! Aelred     herbalist    63   slype                1
! Anselm     cantor       30   locutory             all
! Benedict   infirmarer   48   infirmary,charter    1
! Cuthbert   sacrist      46   bell tower           all
! Hugh       cellarer     32   undercroft           all
! Martin     kitchener    42   kitchen,charter      all
! Oswald     prior        52   solar                all
! Remigio    servant/lay  38   kitchen              1
! Wilfred    librarian    73   scriptorium          all
! Aldwin     novice       20                        1
!
! the PC, Aldwin, is not an instance of monk class.


! Move monk to service -- returns either direction or a location

[ MoveMonkToService monk loc ;
  if (monk == BrWilfred) {
    if (BrWilfred hasnt awake) rfalse;
    ! He'll take the key with him
    ! if (LibraryKey in Scriptorium) remove LibraryKey;
  }
  switch(loc) {
      CloisterNW: return e_to;
      CloisterW: return n_to;
      Locutory: return e_to;
      PriorsSolar: return CloisterNW;
      Scriptorium: return w_to;
      Infirmary: return w_to;
      Slype: return w_to;
      Undercroft: return u_to;
      Kitchen: return n_to;
      Refectory: return n_to;
      CloisterS: return n_to;
      Garth: return n_to;
      CloisterSE: return n_to;
      CloisterE: return n_to;
      CloisterNE: return w_to;
      CloisterN: return n_to;
      Quire: return Stalls;
      Dorm:
        ! don't have all monks run from the dorm
        if ((monk ~= player) && random(3) == 1) rfalse;  ! pause
        return d_to;
      NightStairs: return d_to;
      Necessarium: return w_to;
      ! They're only in the upper floor for Matins, so they'll take the
      ! night stairs, not the day stairs. No one will notice me, but it makes
      ! me happy to do this.
      Dorter: return n_to;
      LayCells: return n_to;
      BellTower: return d_to;
      TowerStairs: return d_to;
      Nave: return e_to;
      Quire: return Stalls;
      Stalls: return -1;
      default: rfalse;  ! should only happen when using debugging-goto
  }
];

! TODO: fix offices so player can skip them OR if the meet a monk,
!   they have to join them?

! Aelred, either normal or dying (but not dead, that's separate object)
! general = dying

! TODO: pax should follow player after fed


Monk BrAelred "Brother Aelred"                                       ! >BrAelred
  with
    name 'aelred' 'herbalist',
    simple_name "Aelred",
    job_title "Herbalist",
    description
      "Your beloved mentor. Brother Aelred is in his sixties, tall and
      broad-shouldered, with gentle eyes that often crinkle with quiet
      amusement. In the five months you've studied under him, his kindness has
      been matched only by his knowledge of God's healing herbs.",
    possess 'aelred^s' 'aelreds',
    home nothing,
    history_text
      "Aelred (1284-). Entered the priory 1295 as a youth. Served as
      Herbalist. Fluent in several languages beyond English and Latin.^^
      Written below this, in fresh ink in Wilfred's scratchy hand, it
      reads: ~Requiescat in pace, carus frater~.",
    aelred_wont_talk [;
      f_aelred_mentioned_meeting = true;
      "~Hush now, child. This is no time for talking. I'll see you
      after office in the gardens.~";
    ],
    before [;
      Smell: print_ret (The) self, " always smells a bit like herbs and dirt.";
    ],
    life [ ;
      Ask:
        if (second == BrHugh or BrRemigio or BrWilfred) {
          print "His eyes show brotherly concern. ";
          return self.aelred_wont_talk();
        }
        if (current_service has on)
          return self.aelred_wont_talk();

        switch (second) {
          BrAldwin:
            "~Son, you must learn to know yourself.~ He smiles.";
          BrAelred:
            "He chuckles gently. ~An old herbalist who talks to plants.~";
        }
        wn = consult_from;
        switch (NextWord()) {
          'himself': <<Ask BrAelred BrAelred>>;
        }
        return self.aelred_wont_talk();
      Tell, Answer:
        return self.aelred_wont_talk();
    ],
  has
    animate;


Object BrAelredDying "Brother Aelred"                           ! >BrAelredDying
  with
    name 'brother' 'monk' 'aelred' 'body',
    description [;
      if (self has animate)
        "Your beloved mentor. In normal moments, Brother Aelred's eyes
        twinkled with kindness, a smile set against his broad face.
        Right now, though, he looks desperately ill. Sweat beads on his
        flushed face, and his pupils are enormously dilated, giving his
        eyes a black, glassy appearance. His limbs grab wildly at his
        habit, making it seem as though he is trying to remove something that
        isn't there.";
      "Brother Aelred lies dead on the stone floor.
      You pray he is at peace.";
    ],
    before [;
      Kiss:
        "You kiss his forehead.";
      Smell:
        ev_symptoms = true;
        "There's something oddly distinctive about his breath:
        acrid and stale, reminding you of old chamber pots.";
      Confess:
        "He cannot help you now.";
    ],
    life [ ;
      Ask:
        wn = consult_from;
        switch (NextWord()) {
          'letters', 'letter': "Again, he points north. ~They're not alive.~";
          'poison': "He points to his throat, sputtering.";
        }
        "He just mumbles something incoherent in response.";
      default: "He just looks at you in response with those strange eyes.";
    ],
  has animate proper ;


[ DirName dir ;
  if (dir == n_to) print "north";
  else if (dir == s_to) print "south";
  else if (dir == e_to) print "east";
  else if (dir == w_to) print "west";
  else if (dir == u_to) print "up";
  else if (dir == d_to) print "down";
  #IfDef DEBUG;
  else print "*** DirName REPORT BUG";
  #EndIf;
];

[ OppDirName dir ;
  if (dir == s_to) print "the north";
  else if (dir == n_to) print "the south";
  else if (dir == w_to) print "the east";
  else if (dir == e_to) print "the west";
  else if (dir == d_to) print "upstairs";
  else if (dir == u_to) print "downstairs";
  #IfDef DEBUG;
  else print "*** OppDirName REPORT BUG";
  #EndIf;
];


Monk BrAnselm "Brother Anselm"                                       ! >BrAnselm
  with
    name 'anselm' 'cantor',
    simple_name "Anselm",
    job_title "Cantor",
    description
      "Brother Anselm, the Cantor, is barely thirty---young for his office. He
      joined the priory at a young age and was put under the tutelage of Brother
      Wilfred for many years. He has a clear, strong voice and an easy smile.
      You've learned that unlike many of the other brothers, he seems to enjoy
      conversation where the Rule permits it.",
    possess 'anselm^s' 'anselms',
    home Locutory,
    walk_home Quire (s_to) (w_to) (s_to) (w_to),
    orders [;
      "~Brother Aldwin, you forget yourself. You're just a novice.~";
    ],
    life [;
      Give:
        "~Oh, thank you, but I've no need for that.~";
      Answer:
        "~But I didn't ask you a question.~";
      Tell, Show:
        "Brother Anselm is more interested in answering questions
         about Brothers.";
      Ask:
        switch(second) {
          BrAelred:
            "~He was so kind.~ Anselm's voice catches.
            ~We're all going to miss him terribly.~";
          BrAldwin:
            "He laughs happily. ~You? You're, well, you. I think you're
            doing very well here.~";
          BrAnselm:
            "He looks puzzled. ~We've talked many times, Aldwin.~";
          BrBenedict:
            "~He's so helpful. When I had quinsy last year, he took excellent
            care of me.~";
          BrCuthbert:
            "~He's very strict. He's so serious about the rule of silence
            that I've never really talked to him.~";
          BrHugh:
            "~Brother Hugh used to be so joyful when I arrived. I fear something
            has been on his mind for months.~";
          BrMartin:
            "~He's so busy in the Kitchen that I almost never get to talk
            with him.~";
          BrOswald:
            "~He's extremely capable---but I never get a chance to talk
            with him.~";
          BrRemigio:
            "~Oh, our poor foreign lay brother. He seems a bit like a lost soul.
            It must be very lonely for him here, especially given how little
            English he has.~";
          BrWilfred:
            "~He is such an excellent illuminator and has such a sharp mind.~";
          TombGordian:
            "~He founded the priory, you know? I've only seen a few of his
            brass devices, but they were all very clever.~";
          Pax:
            Pax.meet();
            "Oh, her? Her name is Pax. She's very friendly. Brother Wilfred
            seems especially fond of her.";
        }

        wn = consult_from;
        switch (NextWord()) {
          'himself': <<Ask self self>>;
          'poison', 'murder': "~Do you really think so?~";
        }

        "Anselm seems much more interested in talking about people
        than things or ideas.";
    ],
    history_text
      "Anselm (1316-). Entered 1332. Studied under Brother Wilfred as a
      youth. Appointed Cantor 1344 despite his youth, owing to the
      exceptional clarity of his voice. Leads the brothers in the
      Divine Office."
  has
    ;


! general = already responded about aelred

Constant BENEDICT_ON_MURDER
  "~I examined Brother Aelred carefully before preparing his body.
  His heart stopped---he was an old man, and such is God's will.
  We will lay him to rest tomorrow with proper honour.~";

Monk BrBenedict "Brother Benedict"                                 ! >BrBenedict
  with
    name 'benedict' 'infirmarer',
    simple_name "Benedict",
    job_title "Infirmarer",
    walk_home Quire (s_to) (e_to) (s_to) (s_to) (e_to) (e_to),
    description
      "Brother Benedict, the Infirmarer, is a heavyset man in his forties
      with gentle hands and a warmer smile than his bulk might suggest.
      He moves with the careful efficiency of one who tends the suffering
      daily.",
    possess 'benedict^s' 'benedicts',
    home Infirmary,
    life [;
      Ask:
        if (location ~= Infirmary) rfalse;
        switch(second) {
          Pax:
            "~Dear brother, I have no time for such stray animals.~";
          BrHugh:
            "~Brother Hugh is always very helpful.~";
          BrWilfred:
            "~His hands may tremble and he can drift off---but his mind is as
            sharp as ever, praise be.~";
          BrRemigio:
            "~How horrible it must have been for him to find Brother Aelred
            like that.~";
          BrAnselm:
            "~Brother Anselm was very helpful earlier today with the body.~";
          BrAelred:
            if (self hasnt general) {
              give self general;
              "~Our dear Brother is in the chapel,~---he gestures south---~and
              you may seek him there.~";
            }
            "He only gestures south to the chapel.";
          BrBenedict:
            "~You know me, Brother. I care for the unwell.~";
          InfirmaryCabinet:
            "~The medicines are kept secure here.~";
          FeverFewDecoction, FoxgloveDecoction, HenbaneDecoction:
            print "~I keep that here for medicine.~";
            if (second == HenbaneDecoction)
              print
                " He pauses. ~I thought we had more, though. I rarely use it.~";
            "";
          Mirror:
            "~Ah, the mirror serves medicine, not pride. I can check if pupils
            respond to light, examine the tongue and throat, see if jaundice
            yellows the eyes. Observation is half of healing.~";
        }

        wn = consult_from;
        switch (NextWord()) {
          'himself': <<Ask self self>>;
          'poison', 'murder', 'smell':
            print_ret (string) BENEDICT_ON_MURDER;
        }

      Tell:
        consult_words = second;
        wn = consult_from;
        if (NextWordStopped() ==
            'body' or 'corpse' or 'poison' or 'aelred' or 'smell')
          print_ret (string) BENEDICT_ON_MURDER;
          if (location == Infirmary)
            "Brother Benedict nods kindly but gestures toward his work.
            ~Forgive me, Brother Novice, but I have much to attend to.~";

      Show:
        if (noun == Basil) "~I don't know what that plant is.~";
        if (noun ofclass Herb)
          "~Ah, yes. Brother Aelred grew that
          in the garden for my use here.~";
        if (noun ofclass Decoction) {
          print "~What are you doing with one of my decoctions? I should be
          dispensing those.~^";
          if (noun == HenbaneDecoction)
            "^~Also, why is it so empty?~ He looks suspiciously at you.";
          rtrue;
        }
      default:
        "Brother Benedict looks at you kindly, but raises his finger to his
        lips. ~This is neither the time nor place for speech.~";
    ],
    history_text
      "Benedict (1298-). Entered 1318. Served as Infirmarer from 1328.
      Treats both brothers and villagers who seek healing. Known for his
      patience with the dying.",
  has
    ;


Monk BrCuthbert "Brother Cuthbert"                                 ! >BrCuthbert
  with
    name 'cuthbert' 'sacrist',
    simple_name "Cuthbert",
    job_title "Sacrist",
    walk_home Quire (w_to) (u_to) (u_to),
    description
      "Brother Cuthbert, the Sacrist, is in his late forties. Dark-haired
      and sharp-featured, he keeps the sacred vessels spotless and the
      canonical hours precise. He rarely smiles.",
    possess 'cuthbert^s' 'cuthberts',
    home BellTower,
    history_text
      "Cuthbert (1300-). Entered 1315, son of a nobleman from the south.
      Appointed Sacrist 1325. Maintains the sacred vessels and vestments
      with meticulous care. Keeps the canonical hours by ringing the great
      bell.",
  has
  ;


Monk BrHugh "Brother Hugh"                                             ! >BrHugh
  with
    name 'hugh' 'cellarer',
    simple_name "Hugh",
    job_title "Cellarer",
    home Undercroft,
    walk_home Quire (s_to) (w_to) (s_to) (s_to) (e_to) (s_to) (s_to) Undercroft,
    description
      "Brother Hugh, the Cellarer, is lean and blond, barely thirty but
      already worry-worn. He manages the priory's worldly goods---trade, stores,
      accounts---and the weight of it shows in his troubled expression.",
    possess 'hugh^s' 'hughs',
    history_text
      "Hugh (1314-). Brought to the priory 1322 as a child of eight, his
      family unable to feed him after failed harvests. Raised and educated
      by the brothers. Appointed Cellarer 1342. Manages stores and trade
      with exceptional diligence. Has a widowed sister in the village of Holt
      who visited once.",
  has
  ;


Monk BrMartin "Brother Martin"                                       ! >BrMartin
  with
    name 'martin' 'kitchener',
    simple_name "Martin",
    job_title "Kitchener",
    home Kitchen,
    walk_home Quire (s_to) (w_to) (s_to) (s_to) (e_to) (s_to) (s_to),
    description
      "Brother Martin, the Kitchener, is short, round, and quick to
      laugh---unusual in this sombre place. He and Brother Remigio, the lay
      monk, produce the simple meals that sustain the community.",
    possess 'martin^s' 'martins',
    before [;
      Smell: print_ret (The) self,
        " always smells a bit like the fire in the Kitchen.";
    ],
    history_text
      "Martin (1304-). Entered 1322. Born and raised in Wales by a prominent
      family. Appointed Kitchener 1334. Oversees the preparation of meals for
      the community, assisted by Brother Remigio.",
  has
  ;


Monk BrOswald "Brother Oswald"                                       ! >BrOswald
  with
    name 'oswald' 'prior',
    simple_name "Oswald",
    job_title "Prior",
    description
      "Brother Oswald, the Prior. Lean and grey-haired, in his early fifties,
      he governs the priory with stern discipline. You've learned to measure
      your words and deeds carefully in his presence.",
    home PriorsSolar,
    walk_home Quire (s_to) (w_to) 0 PriorsSolar,
    history_text
      "Oswald (1294-). Entered 1312 from a minor noble family. Elected
      Prior 1338 upon the retirement of Brother Wilfred. Governs
      with strict adherence to the Rule of St Benedict.",
  ;


! Outside of first service, is always in the kitchen and never leaves.
!
! PUZZLE: will allow player access to undercroft & will give a candle
!   once bribed with the basil
!
! general = bribed with basil

Monk BrRemigio "Brother Remigio"                                    ! >BrRemigio
  with
    name 'remigio',
    simple_name "Remigio",
    job_title "Lay Kitchen Assistant",
    description [;
      if (SceneFollowRemigio has general)
        "Brother Remigio looks panicked. He keeps gesturing toward the Slype
        and saying ~Frate Aelred~.";
      if (SceneDeathInSlype has general)
        "Brother Remigio looks absolutely panicked.";
      "Brother Remigio is a lay brother from Tuscany---not fully professed, but
       devoted to the work. He's in his late thirties, with sharp features and
       expressive hands. His English is poor, and he often lapses into his
       native Tuscan tongue.";
    ],
    possess 'remigio^s' 'remigios',
    home Kitchen,
    life [;
      if (SceneDeathInSlype has general) {
        if (second == BrAelred)
          "~I come here, and I see him on ground. I try to help, but he---~
          Remigio's voice breaks. ~He cannot speak right. I run to find you.~";
        "Remigio looks too stunned to respond to anything.";
      }
      Tell:
        if (BrMartin in Kitchen)
          "Brother Martin cuts you off with a gesture to his lips.
          ~No idle chatter, Brother.~";
        "Brother Remigio listens politely, but doesn't understand you.";
      Ask:
        if (BrMartin in Kitchen) {
          "Brother Remigio looks down, uncomfortable answering anything
          with Brother Martin here.";
        }
        switch (second) {
          BrHugh:
            "~Frate Hugh? Good man. He work hard down there, always busy
            with...~ he gestures vaguely at the floor, ~...stores, si?~";
          BrMartin:
            "~Ah, Frate Martin! He is...~ Remigio searches for words. ~Very
            good man. Kind. We work, uh, insieme---together---in cucina, the
            Kitchen. He teach me English.~ He smiles warmly. ~He no here now.
            At church.~";
          BrAelred:
            "~Such sad thing.~ He looks despondent.";
          BrBenedict:
            "~Such good eater, si? I like him.~";
          BrAnselm:
            "~Cosi bravo cantante!~ He gestures expressively. ~Uh, so good
            singer. When he sing, I feel...~ he touches his chest, ~...home.~";
          BrCuthbert:
            "~Frate Cuthbert ring the bells. Very loud!~ He rubs his ears
            with a smile. ~But is good. Prayer good.~";
          BrOswald:
            "~Frate Oswald, uh, has many rules, but he kind to me.~";
          BrWilfred:
            "~So wise and kind. I see him playing with bella gatta.~";
          BrAldwin:
            "~You? You are...~ he grins. ~Come si dice? Tadpole. Small,
            new. But you grow, si?~";
          BrRemigio:
            "~Me?~ He laughs, a little surprised. ~I am... nobody. A man who
            walk very far.~ He wipes his hands on his habit. ~I find this
            place, they let me stay. I work hard. Is enough, no?~";
          Pax:
            "~Ah, la gatta! Frate Wilfred, he love her much. She good mouser.
            Always hungry.~";
        }

        wn = consult_from;
        switch (NextWord()) {
          'himself': <<Ask self self>>;
          'poison', 'murder': "~Assassinio?~ He looks terrified.";
          'priory': "~It is safe here.~";
          'tuscany', 'tuscana', 'italy':
            "~Toscana.~ He is quiet for a moment, his eyes distant.
            ~Is... how to say... the hills, they are gold in summer.
            The sun, she is warm. Not like here.~ He glances at the grey
            stone walls around him. ~I not speak of it. Is better not to.~";
          'basil', 'basilico': "~Ah, it makes me happy.~";
        }
        "Brother Remigio listens with a puzzled expression.";

      Give:
        if (BrMartin in Kitchen)
          "You shouldn't try to give Brother Remigio anything with
          Brother Martin here.";

        if (noun == Basil) {
          QuoteBoxSimple(quote_stranger);
          TaskDone(TASK_BRIBE_WITH_BASIL);
          remove Basil;
          give self general;
          print
            "Remigio's weathered face transforms. ~Basilico!~ he exclaims,
            taking the herb and breathing deeply. ~I not smell since Toscana.~
            His eyes glisten. ~Frate Aelred grew for me? He was brav'uomo,
            a good man.~";
          if (Kitchen has on) { ! tried going down stairs
            print
              "^^He gestures toward the stairs, his voice thick. ~Grazie mille,
              uh, thanks you. Go. I not see you";
            if (~~IndirectlyContains(player, MyCandle)) {
              move TallowCandle to player;
              update_moved = true;
              print "~. He produces a tallow candle from his robe and gives
              it to you. ~La luce";
            }
            ".~";
          }
          "^^He clasps your hand warmly. ~Grazie mille, uh, thanks you.
          You need to do something, Remigio let you. Yes?~";
        }
    ],
    before [;
      Smell: print_ret (The) self,
        " always smells a bit like the fire in the Kitchen.";
    ],
    history_text
      "Remigio (c.1308-). A lay brother from Tuscany, came to the priory
      1340 seeking refuge from troubles in his homeland. Works in the
      Kitchen and performs manual labour. Has not taken full vows.",
  has
  ;

Candle TallowCandle "tallow candle"                              ! >TallowCandle
  with
    adj_name 'tallow',
    description [;
      print "A poor-quality candle made of tallow";
      if (self has light) print ". It is lit";
      ".";
    ],
  has
    ;


! Always guards the library (he's excused from other services)
!
! PUZZLE: can put him to sleep with burning mandrake
!
! He'll have limited conversation w/PC in the library.

Constant MSG_WILFRED_DEEP_IN_SLEEP = "Brother Wilfred is fast asleep.";

Monk BrWilfred "Brother Wilfred"                                    ! >BrWilfred
  with
    name 'wilfred' 'librarian',
    simple_name "Wilfred",
    job_title "Librarian",
    description [;
      if (self hasnt awake)
        print_ret (string) MSG_WILFRED_DEEP_IN_SLEEP;
      else
        print
          "Brother Wilfred is the most venerated of the brethren, well
          over seventy. He's lean and wiry, with wisps of white hair shooting
          in all directions from his head. His fingers are stained with
          pigments, and his habit has bits of orange fluff or fur on it";
      if (Pax in self)
        print ".^^He currently has ", (the) Pax, " on his lap";
      ".";
    ],
    describe [;
      if (BrWilfred in Scriptorium) {
        print "^Brother Wilfred sits at the table, close to the south wall";
        if (BrWilfred hasnt awake) print ", snoring heavily";
        if (Pax in self) print ". Lying on his lap is Pax";
        ".";
      }
    ],
    possess 'wilfred^s' 'wilfreds',
    tired_count 0,  ! don't repeat messages
    home Scriptorium,
    walk_home Quire (s_to) (e_to) (s_to) (e_to),
    yawn [ ;
      if (BrWilfred hasnt awake || deadflag || f_ever_offered_confession)
        rfalse;
      self.tired_count++;
      switch (self.tired_count) {
        1: "^Brother Wilfred yawns sleepily.";
        2: "^The venerable Wilfred rubs his temples wearily.";
        3: "^Brother Wilfred blinks his eyes heavily.";
        4: "^Brother Wilfred rubs his eyes.";
        5: "^The venerable librarian stifles a yawn.";
        6: "^Brother Wilfred yawns sleepily.";
      }
    ],
    each_turn [ ;
      if (self in Scriptorium && random(10) > 5) self.yawn();
    ],
    life [;
      WakeOther:
        ! if (self hasnt awake) {
        !   print
        !     "You shake Brother Wilfred awake. ~Ah, young son, you'll have to
        !     pardon an old man his weakness.~ He blinks sleepily at you";
        !   if (Pax in self) {
        !     remove Pax;
        !     print ".^^", (The) Pax, " hops out of his lap and goes west";
        !   }
        !   ".";
        ! }
        "As you're about to shake Brother Wilfred, his eyes snap open.
        ~Dear child,~ he says, ~I was just resting my eyes.~";
      Ask:
        if (self hasnt awake) "Brother Wilfred is deep in sleep.";
        switch (second) {
          BrAelred:
            "~What a loss for our community. He would often bring me
            rosemary after he learned that was my mother's name.~";
          BrAnselm:
            "~Such a beautiful voice for one so young.~";
          BrAldwin:
            "~You? You're doing well, my child.~ His eyes twinkle.";
          BrBenedict:
            "~Brother Benedict makes me valerian tea to steady me.~
            He looks down at the small tremble in his hands.";
          BrCuthbert:
            "~Such a god-fearing man and so careful in his duties.~";
          BrHugh:
            "~A fine cellarer. In the past few months, he's been helping me
            in the Library.~";
          BrMartin:
            "~Brother Martin keeps us all well-fed, even in these lean times.
            A generous soul.~";
          BrOswald:
            "~He's done very well as prior. That was once my role, but---~
            He looks at you with tenderness. ~Age comes for us all, my son.~";
          BrRemigio:
            "~Brother Remigio? We speak little---his English, my Italian,
            neither sufficient.~ He chuckles. ~But we both love our little
            Pax, and that needs no words.~";
          BrWilfred:
            "~Me? I'm simply a child of God, like you, dear Aldwin.~";
          Pax:
            Pax.meet();
            "His eyes glisten a bit. ~Forgive an old Brother, but that cat
            has become very dear to me. I was the one who named her---'Pax',
            for the peace she brings to these old halls.~";
          Breviary:
            "~Do you like it? It's my latest work.~";
          StolenPsalter:
            "~I just don't understand how I've misplaced it.
            Brother Hugh even helped me look for it.~";
        }

        wn = consult_from;
        switch (NextWord()) {
          'himself': <<Ask self self>>;
          'poison', 'murder':
            "~Now, none of that kind of talk, dear child.~";
          'rosemary', 'mother':
            "His eyes mist, but he says nothing.";
          'fluff', 'fur':
            print "~Oh.~ He looks almost abashed, and brushes at his habit.";
            if (Pax has proper)
              " ~Dear old Pax.~";
        }

        "Brother Wilfred hushes you kindly. ~Never mind that.~";

      Tell:
        if (self has awake)
          "Brother Wilfred listens sleepily without response.";
        print_ret (string) MSG_WILFRED_DEEP_IN_SLEEP;
      Give:
        if (noun == Rosemary && self has awake) {
          remove Rosemary;
          "Brother Wilfred accepts the rosemary. ~Thank you.
          My favorite.~";
        }
      default:
        if (self hasnt awake) {
          print_ret (string) MSG_WILFRED_DEEP_IN_SLEEP;
        }
    ],
    before [;
      Confess:
        if (BrWilfred hasnt awake)
          print_ret (string) MSG_WILFRED_DEEP_IN_SLEEP;
        if (enough_evidence) {
            SceneConfession.scene_start();
            rtrue;
        }
    ],
    history_text
      "Wilfred (1273-). Entered 1290 from a scholarly family in Norwich.
      Elected Prior 1310, serving until 1338 when he stepped down due to
      age and failing sight. Now serves as Librarian and master illuminator,
      though his hands tremble with the years. The oldest brother in living
      memory, he has seen the priory through plague, famine, and decline.^^
      You note that this entry was written by Brother Wilfred himself, but in
      his way, he tried to maintain a scholarly and truthful tone.",
  has transparent topicky
  ;

Object -> LibraryKey "silver key"                               ! >LibraryKey
  class AdjObject,
  with
    adj_name 'library' 'silver',
    noun_name 'key',
    description
      "A simple silver key, tarnished with age. Brother Wilfred guards
      it jealously---it's his responsibility as librarian to control
      access to the priory's precious books.",
    before [;
      Take:
        if (self in BrWilfred && BrWilfred has awake) ! awake
          "Brother Wilfred's eyes snap up just as your hand reaches for it.
          ~Ah-ah,~ he says kindly but firmly, stifling a yawn. ~Not without
          the prior's leave, young Brother Aldwin.~";
        if (self in BrWilfred) {
          ! TODO: needs to check result of TryToTakeNoun
          move self to location;
          if (TryToTakeNoun(noun) ~= 1) {
            "Being as quiet as you can, you take the key from the table.";
          } else {
            move self to BrWilfred;
            rtrue;
          };
        }
    ],

  has ;

! - perhaps a check theft:
!   - hugh discovers open barrels: NO, he wouldn't want outside help
!   - wilfred discovers open door; missing key: YES
!   - open chests: NO, no one goes up during the day
!   - benedict discovers open cabinet: YES
!   - prior discovers open solar door: YES
!   - cuthbert discovers open bell chest: YES
!   - oswald discovers open drawer or chest: YES
!   - open west gate: NO, not important
!   - open church door: NO, not important

[ CheckCareless yes ;
  if (BrBenedict in Infirmary && InfirmaryCabinet has open) {
    yes = 3;
    print "^Brother Benedict found the infirmary cabinet open";
  }
  if (BrOswald in CloisterNW && PriorDoor has open) {
    print "^Brother Oswald found his solar door open";
    yes = 10;
  }
  if (BrCuthbert in BellTower && BellTowerChest has open) {
    print
      "^Brother Cuthbert discovered you had been exploring his bell tool chest";
      yes = 3;
  }
  if (BrOswald in PriorsSolar &&
      (PriorsChest has open || PriorDrawer has open)) {
      yes = 10;
      print "^Brother Oswald found evidence you had been in his solar";
  }
  if (BrWilfred in Scriptorium && BrWilfred has awake) {
    if (LibraryDoor has open) {
      yes = 6;
      print "^Brother Wilfred discovered the library door was open";
    }
    if (LibraryKey notin BrWilfred) {
      yes = 6;
      print
        "^Brother Wilfred discovered that the library key wasn't on the table
        where he keeps it";
     }
  }
  if (yes) {
    print "---you've been caught.
    ^^For violating a serious rule of the priory, you are sentenced
    to bread and water for ", (LanguageNumber) yes, " days.";
    #IfDef DEBUG;
      print "^*** NOT KILLING YOU during debugging^";
      ! KillOff();
    #IfNot;
      KillOff();
      rtrue;
    #EndIf;
  }
  rfalse;
];

Object BrAldwin "you"                                                ! >BrAldwin
	with
		name 'me' 'myself' 'self',
		short_name  [;
			if(caps_mode) { print "You"; rtrue; }
			print "yourself";
			rtrue;
		],
    description
      "You're a novice in your first year, younger than all of the professed
      monks. Your black habit marks you as Benedictine, though you haven't yet
      taken your final vows. Your head remains untonsured---that will come only
      if you complete your novitiate and join the community fully.",
		capacity MAX_CARRIED,
    react_after [;
      Go:
        if (location == thedark) {
          NowInDark();
          #IfDef DEBUG; f_found_darkness = true; #EndIf;
        }
    ],
    history_text
      "Aldwin (1326-). Joined us in 1346, coming from a servant family
      serving the Lord of Thornbury. Educated by that Lord. Mother died young.
      Interested in gardening, so he's being mentored by Brother Aelred.",
	has concealed animate proper transparent;


! general: happy with you (you can pick up)

Object Pax                                                                ! >Pax
  class AdjObject
  with
    article "an",
    adj_name 'orange',
    noun_name 'cat' 'pax',
    short_name "orange cat",
    meet [;
      give self proper;
      self.short_name = "Pax";
    ],
    description [;
      print "She is small and lean";
      if (self has general) print ", and purrs when she sees you";
      else print " with hunger";
      ".";
    ],
    orders [;
      print_ret "She only mews in response.";
    ],
    life [;
      Give:
        if (noun == Fish) {
          remove Fish;
          give self general;
          update_moved = true;
          print_ret
            (The) self,
              " eats the fish hungrily then rubs against you, purring.";
        }
        if (noun has toxic) {
          "Surely you don't want to poison this innocent creature of God?";
        }
        "She turns up her nose at your offer.";
    ],
    before [ ;
      Confess:
        print_ret
          (The) Pax, " listens attentively, then mews sadly in response.";
      Attack:
        remove self;
        print_ret
          "She flees into the Garth at your movement toward her.";
      Kiss:
        if (self hasnt general)
          "Cats usually need to be bribed to let you touch them.";
        print_ret
          "She allows a small head kiss.";
      Take:
        if (self hasnt general)
          "You dare not. She hisses as you start to try.";
      Smell:
        "Warm wool and wood smoke, with a faint undercurrent of mouse.";
    ],
    after [;
      Take:
        "She allows you to pick her up.";
      Drop:
        remove self;
        "She scampers away.";
    ],
    each_turn [;
      if (location == Scriptorium || waittime_waiting) rfalse;
      if (self in player) {
        if (location ~= Garth && ~~location ofclass Cloister) {
          remove Pax;
          "^", (The) self, " wriggles out of your arms and escapes.";
        }
        "^", (The) self, " purrs contentedly in your arms.";
      }

      switch (random(12)) {
        1: "^", (The) self, " rubs against the Cloister wall.";
        2: "^", (The) self, " twitches, sensing movement somewhere.";
        3: "^", (The) self, " chases after an insect.";
        4: "^", (The) self, " sits and licks a paw contentedly.";
      }
    ],
    history_text
      "In the margin, you find a note: ~Pax: She was first spotted in 1342
      by Brother Remigio. She's an excellent ratter and conversationalist,
      though her Latin is poor.~",
  has
    female animate ok_carry;



! ======================================================================= SCENES

! Mostly here for adding debugging onto it and listing all in loops

Class Scene                                                             ! >Scene
  with
    time_left 0,
    scene_start [;
      self.time_left = 0;
      give self general;
      ! scenes are in the robe ()
      move self to MyRobe;
      update_moved = true;
      ! scope_modified = true;
      StartDaemon(self);
      #IfDef FULL_DEBUG;
      print "*** SCENE START ", (the) self, " at ", (RealTimeSub) nothing,  "^";
      #EndIf;
    ],
    scene_stop [;
      give self ~general;
      give self ~on;  ! some scenes use this to show someone leading it
      give self visited;
      remove self;
      StopDaemon(self);
      scope_modified = true;
      #IfDef FULL_DEBUG;
      print "*** SCENE STOP ", (the) self, " at ", (RealTimeSub) nothing,  "^";
      #EndIf;
    ]
  has proper scenery ;

! This is the period after lauds but before the players run into Remigio

Scene SceneWandering "SceneWandering"                          ! >SceneWandering
  with
    name 'wandering',
    time_left 0,
    daemon [;
      self.time_left++;
      switch(self.time_left) {
        8:
          "^Brother Aelred will be waiting for you in the gardens.";
        14:
          "^You feel that you should really get to the gardens. You don't
          want to keep Brother Aelred waiting.";
        20:
          print
            "^By the time Brother Remigio finds you, you're too late to see
            the death of your mentor. You regret spending so much time
            wandering before going to the gardens.";
          deadflag = 3;
      }
    ],
    react_after [;
      Go:
        if (location ~= Nave or Quire or HighAltarArea or LadyChapel
              or TowerStairs or BellTower or NightStairs or Garth or DayStairs
              && ~~location ofclass Cloister)
          print
            "While you enjoy exploring the church, you should go to the
            Garden and begin your daily labours with Brother Aelred.^";
        if (location == CloisterNE or CloisterE or CloisterSE) {
          self.scene_stop();
          SceneFollowRemigio.scene_start();
        }
    ],
  has ;


Scene SceneFollowRemigio "SceneFollowRemigio"              ! >SceneFollowRemigio
  with
    name 'follow',
    time_left 0,
    add_to_scope BrRemigio,
    react_before [;
      Tell, Ask, AskFor, Order:
        switch (random(3)) {
          1:
            "Brother Remigio practically shouts: ~La urgenza---uh,
            fastly~ and points toward the Slype.";
          2:
            "Brother Remigio just tugs at his hair in frustration.";
          3:
            "Looking frantic, Remigio says something in his native tongue.";
        }
      Go:
        if ((location == CloisterNE && selected_direction ~= s_to)
            || (location == CloisterE && selected_direction ~= s_to )
            || (location == CloisterSE && selected_direction ~= e_to) ) {
            print "Brother Remigio really wants you to follow him ";
            if (location == CloisterSE) print "east"; else print "south";
            " to the Slype.";
        }
    ],
    daemon [;
      self.time_left++;
      if (self.time_left == 1) {
        PronounNotice(BrRemigio);
        print
          "^The lay monk, Brother Remigio, runs up to you, his face ashen. ~You!~
          he cries, grabbing your sleeve. ~Come---Frate Aelred, l'erborista, he
          is---~ He cannot find the words. His eyes say everything. He
          urgently points ";
        if (location == CloisterSE) print "east";
        else print "south";
        " toward the Slype.";
      }
      if (self.time_left == 8) {
        ! IDEA: maybe don't end game, but see less of the death scene?
        print
          "^Unfortunately, you arrive at the Slype too late. Brother Aelred
          died by the time you got there, and you missed his final words.
          You'll never forgive yourself for not comforting him at his end.";
        deadflag = 3;
        return;
      }
      if (action ~= ##Go) "^Brother Remigio implores you to move quickly.";
    ],
    react_after [;
      Go:
        print "You follow Brother Remigio.^";
        if (location == Slype) {
          self.scene_stop();
          SceneDeathInSlype.scene_start();
        }
    ];


Scene SceneDeathInSlype "SceneDeath"                        ! >SceneDeathInSlype
  with
    name 'death',
    time_left 0,
    scene_stop [;
      self.Scene::scene_stop();
      the_time = the_time + 20;
    ],
    add_to_scope BrRemigio BrAelredDying BrAelredEyes BrAelredHabit,
    daemon [;
      self.time_left++;
      switch (self.time_left) {
        1:
          PronounNotice(BrAelredDying);
          "^Brother Aelred is here, but clearly unwell. His movements are
          frantic and his eyes look unusual.";
        2:
          "^Aelred seems gripped with delirium. ~My son...~
          he whispers. ~Gathering... he was always gathering... I wanted
          to know why...~";
        3:
          "^Aelred's hand jerks, trembling, gesturing north toward the
          bushes lining the Slype and the Scriptorium behind.
          His lips move. ~The letter... the letter told me everything...~";
        4:
          "^Aelred convulses wildly. The end of his earthly time cannot
          be far.";
        5:
          give BrAelredDying ~animate;
          "^A strange peace crosses Aelred's face. He finds your hand and
          holds it with surprising strength. ~One life for two, my friend.~
          He smiles, looking towards Heaven---and is gone.";
        6:
          self.scene_stop();
          StoryPause();
          print
            "^Prior Oswald arrives and, upon seeing the wide and still
            eyes of Brother Aelred, makes the sign of the cross and whispers
            a prayer. The other brothers, having heard Remigio's cries,
            come to the Slype. Brother Benedict, the infirmarer, is called upon
            to determine if Aelred is dead, and does so.
            Brothers Benedict and Anselm carry Aelred's body to the
            Infirmary.

            ^^You find yourself in the garden without quite knowing how you got
            there, standing among Aelred's carefully tended beds. Your friend.
            Your mentor. The pangs of loneliness that have eaten at you on long
            nights return cruelly.

            ^^Brother Wilfred, the venerable librarian, finds you in the Garden
            and tries to offer tender words of consolation: ~My child~, he says,
            ~you will always have a friend in me. Brother Aelred lived a joyful
            and reverent life, and we can carry on in his spirit with your
            help.~ He gestures to the gardens that you have grown to love so
            much.

            ^^You are told by others that there is a meeting in the Chapter
            House. You dry your eyes and make your way there.^";
          StoryPause();
          new_line;
          SceneMeeting.scene_start();
      }
    ],
    react_before [;
      Go:
        "You wouldn't dare abandon Brother Aelred.";
    ],
  ;


Scene SceneMeeting "SceneMeeting"                                ! >SceneMeeting
  with
    name 'meeting',
    time_left 0,
    scene_start [ m ;
      self.Scene::scene_start();
      give self on;  ! oswald talking
      objectloop (m ofclass Monk)
        if (m ~= BrAelred) move m to ChapterHouse;
      PlayerTo(ChapterHouse);
    ],
    daemon [ m ;
      self.time_left++;
      switch (self.time_left) {
        1:
          "^The brothers gathered here begin to find seats.";
        2:
          objectloop (m ofclass Monk)
            if (m ~= BrAelred) move m to ChapterBenches;
          if (player notin ChapterBenches) {
            print "^You sit on a bench.^";
            move player to ChapterBenches;
            ! update_moved = true;
          }
          "^~Brothers,~ starts Brother Prior Oswald, ~this is a terrible day
          for our community: the loss of our herbalist, Brother Aelred.~";
        3:
          "^Brother Oswald pauses. ~Brother Aelred's passing was... sudden.
          He did have a weak heart. Let us thank God that his passing
          was quick.~";
        4:
          "^Brother Oswald continues: ~Brother Benedict has placed him in
          the Infirmary Chapel. You may pay visits to our dear brother there.~";
        5:
          "^Brother Oswald continues: ~Our novice~---he gestures toward
          you---~is doing adequately in his
          role, and will spend today cataloging the state of the gardens
          so that he and I can meet after the burial to decide how to proceed
          without our herbalist.~
          ^^You flinch inwardly at being described as ~adequate~, but remember
          your pledge of modesty and service.";
        6:
          "^Brother Oswald continues: ~Of course, we will continue to hold the
          rest of our Divine Offices today---however, given the circumstances,
          I expect many of you may need to skip some offices today. To this, I
          give my blessing.~";
        7:
          objectloop (m ofclass Monk)
            if (m ~= BrAelred) move m to location;
          the_time = the_time + 15;
          give self ~on;
          "^The meeting draws to a close and the brethren stand and prepare to
          leave.";
        8:
          BrWilfred.yawn();
          move BrOswald to BrOswald.home;
          move BrBenedict to BrBenedict.home;
          move BrRemigio to BrRemigio.home;
          move BrCuthbert to BrCuthbert.home;
          move BrHugh to BrHugh.home;
          if (location == ChapterHouse)
            "^Brothers Oswald, Hugh, Benedict, Cuthbert, and Remigio leave.";
        9:
          move BrWilfred to BrWilfred.home;
          move BrMartin to BrMartin.home;
          move BrAnselm to BrAnselm.home;
          if (location == ChapterHouse)
            print
              "^Brothers Wilfred, Martin, and Anselm depart, leaving you
              alone.^";
          "^You feel a deep sense of obligation to Brother Aelred. Something
          about this death doesn't feel right or natural. You decide you have
          to spend today trying to discover what happened and why.
          You're not quite sure where to begin, but examining his body in
          the Infirmary Chapel or searching his Herbarium might be good
          places to begin.
          ^^Of course, this investigation is unsanctioned by the Prior.
          You'll have to cover your tracks carefully.";
        12:
          self.scene_stop();
          if (~~f_show_time_command) {
            f_show_time_command = true;
            "^(There is no clock here, but between the bells ringing for
            offices and your own internal sense, you decide that it is
            very approximately ",
            (ReallyRoughTime) the_time,
            ". You can check this sense any time with the command TIME).";
          }
      }
    ],
    react_before [;
      Examine, Look, Wait, Think, Offices, Time,
        WaitHours, WaitMinutes, WaitUntil, WaitMoves: ;
      Go:
        if (self has on)
          "You shouldn't leave during the meeting.";
      Listen:
        if (self has on) "You listen intently to Brother Oswald.";
      Ask, Tell, Show, AskFor, AskTo, Wave:
        if (self has on)
          "Brother Anselm, sitting beside you, rebukes you kindly:
          ~We should listen to what our prior tells us.~";
      default:
        if (self has on)
          "You dare not disturb the meeting with any action such as this.";
    ],
  ;


Scene SceneLibraryMandrake "SceneMandrake"               ! >SceneLibraryMandrake
  with
    name 'smoke',
    react_before [;
      WakeOther:
        if (BrWilfred hasnt awake) {
          give BrWilfred awake;
          print
            "You shake Brother Wilfred awake. ~Ah, young son, you'll have to
            pardon an old man his weakness.~ He blinks sleepily at you.^";
          self.scene_stop();
        }
    ],
    #IfDef DEBUG;
    scene_start [;
      self.Scene::scene_start();
      if (location ~= Scriptorium) PlayerTo(Scriptorium);
      move MandrakeRoot to Fireplace;
      update_moved = true;
    ],
    #EndIf;
    scene_stop [;
      self.Scene::scene_stop();
      give BrWilfred awake;
      remove MandrakeRoot;
    ],
    daemon [;
      self.time_left++;
      switch (self.time_left) {
        1:
          if (player notin Scriptorium) return;
          "^An unpleasant, acrid stench starts to fill the room. To be
          cautious, you move to the north side of the room, far from the
          fireplace.";
        2:
          give BrWilfred ~awake;
          if (player notin Scriptorium) return;
          print
            "^Now under the influence of the burning mandrake, Brother Wilfred
            starts to snore.^";
          QuoteBoxSimple(quote_sleep);
        3:
          if (player in Scriptorium && BrWilfred hasnt awake)
            "^Brother Wilfred seems deeply asleep.";
        5:
          remove MandrakeRoot;
          if (player notin Scriptorium) return;
            print "^The mandrake root has burned, and the air starts to clear.";
          if (BrWilfred hasnt awake)
            print " Wilfred is still deep in sleep, and will be for a while.";
          new_line;
        15:
          if (player in Library)
            "^You can hear noises from the Scriptorium, suggesting Wilfred
            is starting to waken.";

          if (player in Scriptorium)
              "^Brother Wilfred starts to stir.";
        17:
          if (player in Scriptorium)
            print "^Brother Wilfred seems groggily awake now.^";
          self.scene_stop();
      }
    ],
  ;


Scene SceneLibraryCat "SceneCatnap"                           ! >SceneLibraryCat
  with
    name 'catnap',
    react_before [ ;
      Kiss, Take, Attack:
        if (noun == Pax && BrWilfred hasnt awake) {
          give BrWilfred awake;
          remove Pax;
          self.scene_stop();
          print_ret
            (The) Pax, " is surprised by your touch, hops up and flees
            the room, waking Brother Wilfred with a start.";
        }
      WakeOther:
        if (BrWilfred hasnt awake) {
          give BrWilfred awake;
          print
            "You shake Brother Wilfred awake, which causes ", (the) Pax,
            " to flee from
            his lap and out of the room. ~Ah, young son, you'll have to
            pardon an old man his weakness.~ He blinks sleepily at you.^";
          self.scene_stop();
          rtrue;
        }
    ],
    #IfDef DEBUG;
    scene_start [;
      self.Scene::scene_start();
      if (location ~= Scriptorium) PlayerTo(Scriptorium);
      move Pax to player;
    ],
    #EndIf;
    scene_stop [;
      self.Scene::scene_stop();
      give BrWilfred awake;
      remove Pax;

      if (LibraryKey notin BrWilfred) { ! && ~~deadflag) {
        print
          "^Brother Wilfred discovers that the key is missing from the
          table---you're caught.

          For violating such a serious rule of the priory, you are sentenced
          to bread and water for a week.";
        KillOff();
      }
    ],
    daemon [;
      self.time_left++;
      switch (self.time_left) {
        1:
          move Pax to BrWilfred;
          if (player notin Scriptorium) return;
          "^A smile crosses Brother Wilfred's lined face as he sees ",
          (the) Pax, ".
          ~Ah, Pax~, he murmurs, ~come to check on an old man?~ ",
          (The) Pax, " leaps into his lap and settles there. His hand moves
          to stroke her, and his eyes grow heavy almost at once.";
        2:
          give BrWilfred ~awake;
          if (player notin Scriptorium) return;
          print
            "^As ", (the) Pax, " continues to rest in his lap,
            Brother Wilfred begins to snore.^";
          QuoteBoxSimple(quote_sleep);
        3:
          if (player in Scriptorium && BrWilfred hasnt awake)
            "^Brother Wilfred seems deeply asleep.";
        15:
          remove Pax;
          if (player in Library)
            "^You can hear noises from the Scriptorium, suggesting Wilfred
            is starting to waken.";
          if (player in Scriptorium)
             "^", (The) Pax, " suddenly hops off of Wilfred's lap and runs
              out to the Cloister, causing him to start to stir.";
        17:
          give BrWilfred awake;
          if (player in Scriptorium)
            print "^Brother Wilfred seems groggily awake now.^";
          self.scene_stop();
      }
    ],
  has ;


Scene SceneUndercroft "SceneUndercroft"                       ! >SceneUndercroft
  with
    name 'undercroft',
    react_after [;
      Go:
        if (selected_direction == u_to or e_to) self.scene_stop();
    ],
    caught [ o ;
      print
        "Brother Hugh catches you here. ~You!~ he snarls, ~What are you doing
        here?~ ";

      if (BrHugh has general) {
        print "You've been caught here before. ";
        return self.die();
      }
      give BrHugh general;

      objectloop(o ofclass Barrel)
        if (o has open) {
          print "He sees ", (the) o, ", obviously open. ";
          return self.die();
        }

      objectloop (o in Undercroft)
        if (o has evidence) {
          print  "Looking around the room,";
          return self.die(o);
        }
      objectloop (o in player)
        if (o has evidence) {
          print "Searching you,";
          return self.die(o);
        }

      if (Basket in player or Undercroft)
        objectloop (o in Basket)
          if (o has evidence) {
            print "Searching the basket,";
            return self.die(o);
          }

      objectloop (o in MyHood)
        if (o has evidence) {
          print "Searching your hood,";
          return self.die(o);
        }

      print
        "^^He opens the wide door to the east and pushes you out, closing
        the door after.^^";
      PlayerTo(PassageSouth);
      self.scene_stop();
    ],
    die [ item ;
      if (item) print " he finds ", (the) item, ". ";
      print
        "~So, Brother Novice,~ he says quietly, his voice cold.
        ~You've been meddling where you shouldn't.~";
      if (PrayerMat has general) {
        give PrayerMat ~general;
        ev_hugh_attempt = true;
        print
          "^^You see Brother Hugh swing to hit your head, but he stumbles
          and you dodge aside. You manage to escape through the door.
          ^^St. Jude has answered your desperate prayer with a miracle.^^";
        self.scene_stop();
        PlayerTo(PassageSouth);
        rfalse;
      }
      deadflag = 1;
      print
        "^^You feel a hard object smash against the back of your head. You fall
        to the ground, gasping.
        ^^You feel yourself being stuffed into an empty barrel, and can hear
        him hammering the lid shut. You pass out---perhaps mercifully---so you
        don't feel yourself being rolled off the cliffs and into the dark sea.";
      rtrue;
    ],
    scene_start [;
      self.Scene::scene_start();
      if (BrHugh in Undercroft) if (self.caught()) return;
    ],
    time_left 0,
    daemon [;
      self.time_left++;
      if (BrHugh in Undercroft) if (self.caught()) return;
    ],
  ;


Scene SceneCrypt "SceneCrypt"                                      ! >SceneCrypt
  with
    name 'crypt',
    check [ ;
      ! check and kill off player
      if (BrCuthbert in HighAltarArea && location == HighAltarArea)
        print
          "^Brother Cuthbert looks at you with suspicion. ~Brother Aldwin?
          Were you just in the crypt?~";
      else if (BrCuthbert in location && TombEzra hasnt general)
        print
          "^Brother Cuthbert stops short. ~Brother Aldwin? What brings you to
          the crypt?~";
      else if (BrCuthbert in Crypt && FitzAlanPanel has open)
        print
          "^~The panel is open? Someone must have been robbing that old family
          crypt?~";
      else if (real_location == FitzAlanCrypt) rfalse;
      else if (BrCuthbert in Crypt or CryptVestry && IsCarryingLit())
        print
          "^~Who's there?~ Brother Cuthbert calls out, spotting your light.
          ~Brother Aldwin? You shouldn't be down here alone.~";
      else rfalse;
      print
        "^^When this is reported to Brother Oswald, you are summoned
        before him. ~Why would you be wandering the crypt?~ he asks unkindly.
        You are sentenced to confined prayer for a week.";
      KillOff();
      rtrue;
  ],
  noises [ ;
    if (real_location ~= FitzAlanCrypt or Crypt or CryptVestry
        or CryptStairs or HighAltarArea or Quire or Sacristy or LadyChapel)
        rfalse;  ! far away, can't hear
    print "^";
    if (real_location == FitzAlanCrypt) {
      if (FitzAlanPanel has open) print "Through the opening,";
      else print "Behind the panel,";
    }
    else if (real_location == parent(BrCuthbert)) print "Very close,";
    else if (real_location == CryptStairs or HighAltarArea or Quire
            or Sacristy or LadyChapel)
      print "Faintly,";
    else if (BrCuthbert in CryptStairs or Nave or HighAltarArea)
      print "Above,";
    else if (BrCuthbert in Crypt) print "To the north,";
    else if (BrCuthbert in CryptVestry) print "To the south,";
    #Ifv5;
    else print "*** noises: REPORT BUG";
    #EndIf;
    print " you hear ";
    rtrue;
  ],
  daemon [ ;
    self.time_left++;
    give self on;

    ! check for discovery (may also do again after moving cuthbert below)
    if (self.check()) return;

    if (self has on && location == Sacristy or LadyChapel or Quire
          && ~~task_done->TASK_ESCAPE_CRYPT) {
      TaskDone(TASK_ESCAPE_CRYPT);
      give self ~on;
      print
        "^It appears the danger has passed, and you escaped the Crypt
        without being discovered.^";
    }

    switch (self.time_left) {
      1:
      2:
        move BrCuthbert to Nave;
        give CryptGate open;
        if (self.check()) return;
        "^You can hear a key turning in the gate above.
        If you get caught here, you'll be in serious trouble.";
      3:
        move BrCuthbert to CryptStairs;
        if (self.check()) return;
        "^You can hear footsteps coming down the crypt stairs.";
      4:
        give Crypt light;
        give CryptVestry light;
        scope_modified = true;
        if (self.check()) return;
        if (real_location == Crypt or CryptVestry)
          "^The footsteps are closer, and you can see some light coming
          from the stairs.";
        "^The footsteps sound closer.";
      5:
        move BrCuthbert to Crypt;
        if (self.check()) return;
        if (real_location == Crypt or CryptVestry)
          "^Someone has entered the crypt bearing a light.";
        "^You can hear someone in the crypt.";
      6:
        if (self.noises())
          "~Is someone down here?~ You recognise the voice as
          Brother Cuthbert's.";
      7:
        if (self.noises())
          "~Helloooo?~";
      8:
        move BrCuthbert to CryptVestry;
        if (self.check()) return;
        if (real_location == Crypt) {
          print
            "^The light moves to the south and you sense Brother Cuthbert
            is now searching ";
          if (CryptVestry has visited) print "the Crypt Vestry";
          else print "the room south of the Crypt";
          ".";
        }
        if (self.noises())
          "footsteps going south, away from the crypt stairs.";
      9:
        if (self.noises()) "~Is someone in the Vestry?~";
      10:
        if (self.noises()) "~Helloooo?~";
      11:
        if (self.noises()) "rustling noises.";
      12:
        if (self.noises())
          "~Must have been a draft from the church above.~ (You hear him
          muttering a brief prayer.)";
      13:
        move BrCuthbert to Crypt;
        if (self.check()) return;
        if (real_location == Crypt)
          "^The light becomes stronger here and you hear footsteps walking
          back to the stairs.";
        if (self.noises()) "the footsteps now walking back to the stairs.";
      14:
        give CryptVestry ~light;
        give Crypt ~light;
        scope_modified = true;
        move BrCuthbert to CryptStairs;
        if (self.check()) return;
        if (real_location == Crypt)
          "^The light dims as you hear footsteps on the stairs.";
      15:
        give CryptBell ~general;
        give CryptGate locked;
        move BrCuthbert to HighAltarArea;
        if (self.check()) return;
        if (location == HighAltarArea)
          "^You see Brother Cuthbert at the gate and see him shut the gate.";
        if (self.noises()) "the gate being shut.";
      16:
        move BrCuthbert to BrCuthbert.home;
        self.scene_stop();
        if (real_location == Crypt or FitzAlanCrypt or CryptVestry)
          "^You managed to avoid detection, but you're still stuck here.
          Now how will you get out?";
    }
  ],
  react_after [;
    Go:
      if (location == HighAltarArea && self has on) {
        give self ~on;
        print "You slip through the open gate.^";
      }
  ],
  has ;


[ JusticeOrMercy ;
  print "Do you choose justice or mercy? > ";
  for (::) {
    read buffer parse;
    wn = 1;
    switch (NextWord()) {
      'justice': rtrue;
      'mercy':   rfalse;
      default:
        print "Please type ~justice~ or ~mercy~. > ";
    }
  }
];


Scene SceneConfession "SceneConfession"                       ! >SceneConfession
  with
    name 'confession',
    scene_start [;
      self.Scene::scene_start();
      print
        "^^Wilfred listens as you explain your discovery, and great sadness
        crosses his lined face.

        ^^~My son,~ he begins, then pauses. ~No. 'Aldwin'. You are no longer a
        child.~

        ^^He sighs deeply. ~I have grown more forgiving in my old age. I no
        longer feel it is my place to judge others' sins---only to hear them
        and offer what comfort I can.

        ^^~But you... you have chosen this life. And if you are to be a true
        brother here, you must be capable of making great and terrible choices.~

        ^^He looks at you steadily. ~So I leave this to you, Aldwin. Will you
        bring these accusations to our Prior? If you do, Hugh will surely hang.
        Or will you forgive him, even knowing justice may demand otherwise?

        ^^~This is your choice. Choose wisely, and choose with prayer.~^^";

      if (JusticeOrMercy()) Ending(DEAD_JUSTICE);
      else Ending(DEAD_MERCY);
    ],
  has ;

! general = active (adds to scope, is equal to daemon-active)
! visited = has already happened
! on = service is underway (ie, PC should be sat and singing)

Scene SceneGoHome "SceneGoHome"                                   ! >SceneGoHome
  with
    scene_start [ o ;
      self.Scene::scene_start();
      objectloop (o ofclass Monk) {
        o.walk_start = 0;
      }
      BrAnselm.walk_start = -3;
      BrWilfred.walk_start = -3;
    ],
    daemon [ m dir now_at going_to fake_dir any_moved newline ;
      ! print "HERE";
      objectloop (m ofclass Monk) {
        if (m.walk_start < 0) {
          m.walk_start++;
          continue;
        }
        now_at = parent(m);
        if (now_at == nothing) continue;  ! aelred is dead

        if (m.home == now_at) {
          continue;
        }

        dir = m.&walk_home-->m.walk_start;
        m.walk_start++;
        fake_dir = (dir ~= n_to or s_to or w_to or e_to or u_to or d_to);

        if (dir == 0) continue; ! pausing

        if (fake_dir) going_to = dir;
        else going_to = now_at.(dir);

        ! show departing ms
        if (now_at == location) {
        if (now_at ~= Stalls) {
          print "^", (the) m, " heads ";
          if (fake_dir) print "to ", (the) going_to, ".";
          else print (DirName) dir, ".";
          newline = true;
        }
        }

        move m to going_to;

        ! arriving/sitting ms
        if (going_to == location) {
          if (location == Quire or Stalls) {
            print "^", (The) m, " stands.";
          }
          else {
            print "^", (the) m, " arrives from ";
            if (fake_dir) print (the) now_at, ".";
            else print (OppDirName) dir, ".";
          }
          newline = true;
        }

        any_moved = true;
      }
      if (newline) new_line;

      if (BrOswald in PriorsSolar) {
        objectloop (m ofclass DoorButton)
        give m ~on;
        PriorDoor.pressed_count = 0;
      }

      if (~~any_moved) self.scene_stop();
      self.time_left++;
    ],
  has ;


Class SceneService                                               ! >SceneService
  class Scene,
  with
    num_present 0,
    ! Remigio and obviously Aelred don't attend most offices
    req_monks BrAnselm BrCuthbert BrHugh BrMartin BrOswald BrWilfred BrBenedict,
    time_left 0,
    number 0,          ! hour of this service (0 for non-aut-start first)
    has_sung false,    ! has player sung during the actual service?
    service_rounds 0,  ! what "round" of the active-singing is this?
    service_length 35, ! how many turns do they get?
    aldwin_joining false,   ! is aldwin joining in?
    actually_attending 0,
      ! if so, he has to do the right things
      ! he'll be auto-joined for the first one (Lauds), but not for the others
    scene_start [ i monk ;
      ! start the daemon, set to general (active), simplify quire description.
      ! if this isn't the first service (the bell happens just pre-game),
      ! note that the hear the bell.
      self.Scene::scene_start();

      ! Monks that aren't in their home won't attend service
      ! (Wilfred sleeping, Cuthbert in Crypt)
      for (i = 0: i < self.#req_monks / 2: i++) {
        monk = self.&req_monks-->i;
        if (
          (monk == BrWilfred && BrWilfred hasnt awake) ||
          (monk == BrCuthbert && BrCuthbert notin BrCuthbert.home) ) {
            self.&req_monks-->i = 0;
          } else {
            self.actually_attending++;
          }
      }

      current_service = self;
      give Stalls concealed;
      if (self.number) {
        print "^~";
        #Ifv5; @set_text_style 2; #EndIf;
        for (i = 1: i <= self.number : i++) {
          print "RING!";
          if (i ~= self.number) print " ";
        }
        #Ifv5; @set_text_style 0; #EndIf;
        print
          "~ You hear the bell ring ", (LanguageNumber) self.number,
          " times to call the Brothers to ", (the) self, ".";
      }
      if (self.aldwin_joining == 0)
        print
          " You've been excused from this Office, but you know the choir
          monks will be in the Quire for the next thirty minutes or so.";
      new_line;

      f_offered_shout = false;
      ! #IfDef DEBUG;
      ! print "Attending ", self.actually_attending, " out of ",
      !       self.#req_monks/2, "^";;
      ! for (i = 0 : i < self.#req_monks / 2 : i++) {
      !   monk = self.&req_monks-->i;
      !   if (monk == 0) print "missing^";
      !   else print (name) monk, "^";
      ! }
      ! #EndIf;
    ],
    scene_stop [ o ;
      self.Scene::scene_stop();
      current_service = 0;
      give Stalls ~concealed;
      ! Only say this if Aldwin in the quire
      if (location == Quire) {
        StoryPause();
        print
          "^The office ends.^";
      }

      if (self.number > 0) {
        ! normal service: they wander home
        SceneGoHome.scene_start();
      } else {
        ! first service: they jump home, since aldwin hangs out in quire
        objectloop(o ofclass Monk) {
          ! when he's dead, aelread will be nowhere
          if (o.home == nothing) remove o;
          else move o to o.home;
          if (parent(o) ~= nothing) move o to o.home;
        }
      }

      ! the first service is special; it leads immediately to corralling
      ! the player to the slype, and it's after this service that the
      ! game "starts"
      current_service = 0;
      ! but don't change the "moves", this wasn't a player choice
      the_time = self.time_start + self.service_length + 5; ! add travel time
    ],
    react_before [ dir ;
      ! if aldwin isn't joining this service, he skips the consequences
      if (self.aldwin_joining == false && location ~= Quire) rfalse;
      Sing:
        if (location ~= Quire) rfalse;
        if (player notin Stalls)
          "You should sing from the stalls. Seat yourself.";
        if (self hasnt on)
          "The service hasn't started yet.";
        if (self.has_sung)
          "(You're already singing and will continue to do so throughout the
          service. If you'd like to perform other allowed actions during
          the service, you may. If you want to fast-forward to end of the
          service, just WAIT)";
        if (self.has_sung == 0) {
          self.has_sung = 1;
          if (self.number == 0) {
            QuoteBoxSimple(quote_song);
            TaskDone(TASK_COMPLETED_OFFICE);
          }
        }
        print
          "You join the others in song.^";
        rtrue;
      Shout:
        if (enough_evidence) {
          if (self hasnt on)
            "Wait until they're all here.";
          print
          "You shout loudly. Every face turns to you---shocked, confused,
          some afraid.
          ^^Slowly, you begin to speak.";
          if (task_done->TASK_EVIDENCE_COINS)
            print " The coins hidden among the dead.";
          if (task_done->TASK_EVIDENCE_PSALTER)
            print " The discovered stolen psalter.";
          if (task_done->TASK_EVIDENCE_HENBANE_DECOCT)
            print " The murderous henbane decoction.";
          if (task_done->TASK_EVIDENCE_LETTER)
            print " The note showing the sale of priory manuscripts.";
          if (task_done->TASK_ROSE_LETTERS)
            print " The letters to Rose, showing previous payment.";
          if (ev_hugh_attempt)
            print " And, most damning, the attempt on your life by Hugh.";

          print
            "^^Brother Hugh's face goes very still.
            ^^~Brother Aldwin,~ says Prior Oswald carefully, ~what are you
            saying?~
            ^^~I am saying,~ you answer, ~that Brother Aelred did not die of
            a weak heart.~
            You summon your courage. ~He was murdered by Brother Hugh.~^";

          Ending(DEAD_JUSTICE);
          rtrue;
        }
        "You dare not interrupt the Divine Office.";
      Go:
        if (parent(player) == Stalls && self has on) {
          "Surely, you wouldn't leave your stall now.";
        }
        if (location == Quire && self has on) {
          "Surely, you wouldn't leave the office.";
        }
        if (~~self.aldwin_joining) rfalse;
        if (location == Quire)
          "Stay here for the service.";

        dir = MoveMonkToService(player, location);
        if (dir > 1 && dir ~= selected_direction) {
          "Going ", (DirName) selected_direction,
          " isn't the right direction for the Divine Office.
          You want to head ", (DirName) dir, ".";
        }
      Exit:
        if (noun == Stalls) "Not during office, surely!";
      Ask, Tell, Give, AskFor, AskTo, ShoutAt:
        if (noun == BrAelred && self hasnt on) rfalse;
        "Absolute silence is the rule when called to Divine Office.";
      Wait:
        if (self.has_sung) {
          self.service_rounds = 100;  ! they're bored, end service
          "(skipping to end of service)";
        }
    ],
    move_to_service [ i monk now_at going_to dir newline num_ready fake_dir ;
        ! Service hasn't started yet; move monks to sitting in quire
        for (i = 0: i < self.#req_monks / 2: i++) {
          monk = self.&req_monks-->i;
          if (monk == 0) continue;
          now_at = parent(monk);
          dir = MoveMonkToService(monk, now_at);
          fake_dir = (dir ~= n_to or s_to or w_to or e_to or u_to or d_to);

          if (dir == -1) { num_ready++; continue; }
          if (dir == 0) continue;

          if (fake_dir) going_to = dir;
          else going_to = now_at.(dir);

          ! show departing monks
          if (now_at ~= Quire && now_at == location) {
            print "^", (the) monk;
            if (now_at == Scriptorium && monk == BrWilfred)
              print " gets ", (the) LibraryKey, " from the table and";
            print " heads ";
            if (fake_dir) print "to ", (the) going_to, ".";
            else print (DirName) dir, ".";
            newline = true;
          }

          move monk to going_to;

          ! arriving/sitting monks
          if (going_to == location) {
            print "^", (the) monk, " arrives from ";
            if (fake_dir) print (the) now_at, ".";
            else print (OppDirName) dir, ".";
            newline = true;
          }
          else if (going_to == Stalls && location == Quire) {
            print "^", (the) monk, " sits.";
            newline = true;
          }

        }
        if (newline) print "^";

        if (num_ready == self.actually_attending) {
          give self on;  ! all the monks are in the right place now
          rtrue;
        }
        ! Don't check singing until service starts
        rfalse;
    ],

    daemon [  distant ;
      self.time_left++;

      ! don't do anything until everyone has moved
      if (~~self.move_to_service()) rfalse;

      if (location == Quire && self has on && enough_evidence
            && ~~f_offered_shout) {
        f_offered_shout = true;
        print
          "^You know this may be your best chance to make the accusation and
          help catch the killer. If you'd like to do so, SHOUT to interrupt
          the Divine Office.^";
      }

      distant = (location ==
            Crypt or CryptStairs or LadyChapel or StJudeChapel or CloisterN
            or FitzAlanChantry or NightStairs or Nave or HighAltarArea);

      f_singing_mentioned = false;

      if (self.service_rounds == 0) {
        if (location == Quire)
          print "^Brother Anselm begins to lead the brethren in song.^";
        else if (distant) {
          f_singing_mentioned = true;
          print "^In the distance, you can hear singing as the office starts.^";
        }
      }

      ! service is underway
      self.service_rounds++;

      if (self.aldwin_joining && location ~= Quire) {
        print
          "^Brother Cuthbert finds you, exasperated. ~Why aren't you
          singing with the other brothers in the Quire?~^";
        self.failed();
        return;
      }

      if (player in Quire) {
        if (self.service_rounds == 1 || ~~self.aldwin_joining)
          print
            "^The other monks look at you, puzzled. Why aren't you
            seated with them?^";
        else if (self.service_rounds > 2) {
          self.failed();
          return;
        }
      }

      if (location == Quire) {
        if (self.has_sung == false) {
          if (self.service_rounds > 1 || ~~self.aldwin_joining) {
            print
              "^Brother Anselm looks at you pointedly.
              Why aren't you singing?^";
          }
          else if (self.service_rounds > 3) {
            self.failed();
            return;
          }
        } else {
          if (~~waittime_waiting)
            print "^You continue to sing with the others.^";
        }
      }

      if (self.service_rounds >= self.service_length) {
        if (distant) {
          f_singing_mentioned = true;
          print "^The singing from the Quire stops.^";
        }
        self.scene_stop();
      }

      if (distant && ~~f_singing_mentioned)
          print "^From a distance, you can hear the singing continue.^";

    ],
    failed [;
      StoryPause();
      print
        "^After the service, Brother Oswald confronts you about your
        behaviour. ~Where was your mind, Brother Aldwin? Part of being
        a monk is joining in song.~ You are confined to silent prayer
        for three days.";
      KillOff();
      return;
    ],
  has ~proper concealed;



SceneService SceneMatins "Matins office"                          ! >SceneMatins
  with
    name 'matins',
    number 0,
    time_start 3 * 60,
    aldwin_joining true,
    req_monks
        ! override to add remigio and aelred
        BrAnselm BrCuthbert BrHugh BrMartin BrOswald BrWilfred
      BrAelred BrRemigio BrBenedict,
    scene_stop [;
      self.SceneService::scene_stop();
      SceneWandering.scene_start();
      if (~~f_aelred_mentioned_meeting)
        print "^Brother Aelred touches your shoulder. ~Son, take your time
        here. When you're ready, come meet me in the gardens.~^";
      print
        "^You spend several minutes reflecting on your life
        now: ritual, timing, prayer, silence. It feels both comforting and
        confining. You're not sure which feeling is prevailing.^^";
      Banner();
    ],
  has
  ;


SceneService SceneLauds "Lauds office"                           ! >SceneLauds
  with
    name 'lauds',
    number 2,
    time_start 5 * 60,
  has ;

SceneService ScenePrime "Prime office"                           ! >ScenePrime
  with
    name 'prime',
    number 3,
    time_start 6 * 60,
  has ;

SceneService SceneTerce "Terce office"                             ! >SceneTerce
  with
    name 'terce',
    number 4,
    time_start 9 * 60,
  has ;

SceneService SceneSext "Sext office"                                ! >SceneSext
  with
    name 'sext',
    number 5,
    time_start 12 * 60,
  has ;

SceneService SceneNone "None office"                                ! >SceneNone
  with
    name 'none',
    number 6,
    time_start 15 * 60,
  has ;

SceneService SceneVespers "Vespers office"                       ! >SceneVespers
  with
    name 'vespers',
    number 7,
    time_start 18 * 60,
  has ;

SceneService SceneCompline "Compline office"                    ! >SceneCompline
  with
    name 'compline',
    number 8,
    time_start 19 * 60,
    scene_stop [;
      self.SceneService::scene_stop();
      StoryPause();
      print
        "^With the end of Compline, it is the end of the day for you
        and your brothers.^";
        if (f_ever_offered_confession) Ending(DEAD_INACTION);
        else Ending(DEAD_UNSOLVED);
    ]
  has ;

! ======================================================== 2.0 CHURCH
! 2.0.1 Entrance
! 2.0.2 Nave
! 2.0.3 Tower
! 2.0.4 Quire
! 2.0.5 High Altar Area
! 2.0.6 Sacristy
! 2.0.7 FitzAlan chantry
! 2.0.8 Lady Chapel
! 2.0.9 St Jude Chapel


! --------------------------------------------------- 2.0.1 Entrance
! West Porch, door




Constant MSG_CANT_LEAVE
  "As a novice, you're not allowed to leave the priory grounds without
  permission.";

Room Passage "Passage (North End)"                                    ! >Passage
  with
    description
      "A narrow covered walkway that runs along the west edge of the priory.
      The stones underfoot are set carefully to make this a clear path.
      ^^You can go north to the West Porch, east to the West gate, or south
      to the lower end of the Passage.",
    n_to WestPorch,
    e_to WestGate,
    s_to PassageSouth,
    in_to WestGate,
    out_to MSG_CANT_LEAVE,
    w_to MSG_CANT_LEAVE,
    cheap_scenery
      'roof' 'covering' "Simple wooden beams supporting a slanted roof."
      'stones' 'floor' "Worn smooth by countless footsteps."
      3 'path' 'passage' 'walkway' "A sheltered path for the brothers."
    ;


Constant DOOR_BLOCKED "The door blocks the way.";

Room PassageSouth "Passage (South End)"                          ! >PassageSouth
  with
    description
      "The narrow walkway ends here. This part seems less travelled, with small
      weeds growing from between the stones underfoot. To the east, the
      ground slopes down to a wide door.",
    n_to Passage,
    e_to DOOR_BLOCKED,
    in_to DOOR_BLOCKED,
    s_to MSG_CANT_LEAVE,
    w_to MSG_CANT_LEAVE,
    out_to MSG_CANT_LEAVE,
    cheap_scenery
      'roof' 'covering' "Simple wooden beams supporting a slanted roof."
      'stones' 'floor' "Cracked stones, used to bearing heavy weight."
      3 'path' 'passage' 'walkway' "A sheltered path for the brothers."
      CS_THEM 1 'weeds' "Just small weeds."
      1 'door' [;
        Examine:
          "It's a large wooden door, leading to the Undercroft stores.
           You can't open it---in fact, there
          isn't even a handle on this side to open it.";
        Take: "You can't take the door.";
        Unlock: "There's no apparent way to unlock this.";
        Turn, Pull, Push, Open: "You try to pull it open, but have no success.";
      ]
    ,
  ;


Room WestPorch "West Porch"                                         ! >WestPorch
  class AdjObject,
  with
    adj_name 'west',
    noun_name  'porch' 'entrance',
    description
      "This covered entrance protects the west door from the winds that come
      across the sea to the east. Villagers used to gather here before
      services, but the number who do so has been declining for years.
      ^^A covered walkway the brothers call the ~Passage~ leads south.",
    e_to WestDoor,
    in_to WestDoor,
    s_to Passage,
    n_to MSG_CANT_LEAVE,
    w_to MSG_CANT_LEAVE,
    out_to Passage,
    cheap_scenery
      1 'villagers' "You certainly don't see any here now."
      1 'nave' "The Nave is to the east, inside the church."
      3 'path' 'passage' 'walkway' "It's a covered passage leading south."
    ,
  ;


! PUZZLE: one way to find the founding date is on the door

Object WestDoor "west door"                                          ! >WestDoor
  class AdjObject,
  with
    adj_name 'west' 'great',
    noun_name 'door' 'carving',
    found_in WestPorch Nave,
    door_dir (e_to) (w_to),
    when_closed [;
      print "The great door to the ";
      if (location == Nave) print "west"; else print "east";
      " is closed.";
    ],
    when_open [;
      print "The great door is open, revealing the ";
      if (location == WestPorch) "Nave to the east."; "West Porch to the west.";
    ],
    description [;
      if (location == WestPorch && self hasnt open) {
        TaskDone(TASK_LEARNED_FOUNDING_DATE);
        "Carved deeply into the door's face:^
        ^  NOSTRA DOMINA SPINARUM (~Our Lady of Thorns~)
        ^  FUNDATUM ANNO DOMINI MCLII^^
        Almost two hundred years of wind and rain have worn the letters
        down.";
      }
      print "A large and solid oaken door. It is ";
      if (self has open) "open."; "closed.";
    ],
    after [;
      Close:
        print "You close the west door";
        if (location == WestPorch) print ", revealing a carving on the face";
        ".";
    ],
  has
    static door openable ~open;

! --------------------------------------------------- 2.0.2 Nave
! Nave and rood screen and cross

! PUZZLE: stained glass reveal one of the Gordian's themes for the solar door

Constant CS_WINDOW 100;

Room Nave "Nave"                                                         ! >Nave
  with
    name 'nave',
    description [;
      print
        "The public space, where villagers stand for Mass weekly. The stone
        floor is worn smooth by centuries of feet. Detailed stained glass
        admits ";
        DescribeLight();
        ". The Quire lies to the east, separated by a screen.
        A doorway in the north wall leads to the Bell Tower Stairs.";
    ],
    e_to Quire,
    w_to WestDoor,
    out_to WestDoor,
    u_to TowerStairs,
    n_to TowerStairs,
    before [;
      ThrowAt:
        if (second == CheapScenery && cs_match_id == CS_WINDOW)
          "You dare not break this. It's much too beautiful.";
    ],
    cheap_scenery
      'outside' 'porch' "The porch is to the west, beyond the door."
      1 'quire' "You should go east to see it better."
      CS_WINDOW 3 'stained' 'glass' 'window' [;
        Examine:
          "You remember the first time you saw this glass, on the second day of
          your novitiate. Unlike some other things in the priory that show sign
          of decay, these still shine brightly on sunny days. The centre pane,
          the largest, has a golden hammer labelled ~II: LABOR OMNIA VINCIT~
          (~Work Conquers All~), a reminder of the mission of monks.";
        Attack:
          "You dare not break this---nor could you even reach it.";
      ]
    ,
  has ;


Object RoodScreen "rood screen"                                    ! >RoodScreen
  with
    name 'rood' 'screen',
    found_in Nave Quire,
    description
      "A wooden rood screen separates the Nave from the Quire, dividing the
      public space from the sacred. A simple carved cross tops the
      screen---the ~rood~ that gives it its name. The wood is dark with
      candle smoke.",
    before [;
      Climb, Enter: "It's far too narrow to climb on.";
    ]
  has
    transparent  ! so can see cross "contained" in it
    scenery;


Object -> RoodCross "rood cross"                                    ! >RoodCross
  class AdjObject,
  with
    adj_name 'rood',
    noun_name 'cross',
    description "Simply carved and without ornamentation.",
  has
    static;


!---------------------------------------------------- 2.0.3 Tower
! Tower stairs, tower, bell, and views


Room TowerStairs "Tower Stairs"                                   ! >TowerStairs
  with
    description [;
      "A spiral staircase winds upward. The stone steps are narrow
      and treacherously steep. Cold air and ", (DescribeLight) self,
      " flows down from above.";
    ],
    d_to Nave,
    s_to Nave,
    u_to BellTower,
    cant_go MSG_STAIRS_UP_DOWN_ONLY,
    cheap_scenery
      3 'stone' 'steps' 'stairs' "The steps lead upward."
    ,
  has ;


Room BellTower "Bell Tower"                                         ! >BellTower
  with
    description
      "The bell chamber. Wind whistles through the open arches on all four
      sides. The great bell hangs overhead. A rope from it hangs to within your
      reach. From here, you have clear views in all four directions.",
    d_to TowerStairs,
    before [;
      Examine:
        switch (selected_direction) {
          n_to:
            "To the north, you can see rough coast and cliffs,
            dotted with small farms.";
          s_to:
            "South of here, you see the Cloister surrounding the Garth,
            the priory's roofs, and the Garden. How you've learned to love
            that garden.";
          w_to:
            "West lies the village nestled down in the vale. You can also see
            a small path from the west door to the gate for the priory.";
          e_to:
            "East, you can see the Infirmary and its chapel near the cliffs.";
          u_to:
            "The great bell hangs above you, dark against the ",
            (DescribeLight) self, ".";
          d_to:
            "You see the stone floor of the Bell Tower, and through the
            opening, the stairs descending.
            ^^If you want to look in a particular direction, say so.";
        }
    ],
    cheap_scenery
      21 'great' 'bronze' 'bell' [;
        Examine:
          "A bronze bell, green with age. Cast nearly two centuries ago,
          you recall Brother Cuthbert once telling you it was cast by the
          priory founder, Brother Gordian, and bears the
          inscription ~I: FIDES~---a reminder that our primary task is faith.";
        default:
          "The bell is far above you. You can only reach the rope.";
      ]
    ,
  has ;


Object -> BellRope "bell rope"                                       ! >BellRope
  class AdjObject,
  with
    adj_name 'bell',
    noun_name 'rope' 'cord',
    describe 0,
    description
      "The cord reaches up to the bell, far above. Ringing the bell yourself
      would earn severe punishment. That duty does not belong to novices.",
    before [;
      Take:
        "It's tied far above you, so you can't take it.";
      Climb, Tie, Pull, Turn:
        if (BrCuthbert in location)
          print_ret (string) MSG_DARE_NOT_ANOTHER_BROTHER;
        StartTimer(self, 4);
        "Grabbing the cord causes the bell to toll, echoing across the priory.
        Instinctively you let go of the cord.";
    ],
    time_left,
    time_out [;
      if (location ~= BellTower or TowerStairs or Nave) {
        "You can hear footsteps in the Nave, going up to the Bell Tower, and
        then returning. It seems very fortunate that you have avoided the
        wrath of Brother Cuthbert.";
      }
      print
        "^Brother Cuthbert finds you here, his face dark with anger.
        ^^~What madness is this? Ringing the bells without cause?
        The entire village will think we're under attack!~
        ^^You are confined to your cell with bread and water for a fortnight.";
      KillOff();
    ],
  has ;


Object -> BellTowerChest "wooden chest"                        ! >BellTowerChest
  class AdjObject,
  with
    adj_name 'wooden' 'old' 'weathered',
    noun_name 'chest' 'box',
    description [;
      print
        "An old wooden chest, weathered by years of wind and rain blowing
        through the open tower. The lid bears an engraved inscription:
        ~VOCA POPULUM AD PRECES~";
      if (self has open)
        PrintContents(". The chest stands open, revealing ", self);
      ".";
    ],
    before [;
      Open:
        if (BrCuthbert in location)
          print_ret (string) MSG_DARE_NOT_ANOTHER_BROTHER;
      Push, Pull, LookUnder, Search:
        if (BrCuthbert in location)
          print_ret (string) MSG_DARE_NOT_ANOTHER_BROTHER;
        if (ScribbledNote hasnt moved) {
          move ScribbledNote to location;
          ! update_moved = true;
          PronounNotice(ScribbledNote);
          "Moving the chest reveals a note that was hidden under it.";
        }
        "Nothing else is found under it.";
      Take:
        print_ret (The) self, " is much too large to carry.";
    ],
  has
    container openable ~open static;


Object -> -> BellTools "bell-repairing tools"                       ! >BellTools
  with
    article "some",
    name 'tools' 'oil' 'wedges' 'items',
    description
        "Some maintenance items: a small vial of oil and some wooden wedges.
        All the practical things needed to keep the great bell ringing true.",
    before [;
      Examine: ;
      Smell: "Oil and wood.";
      Take, Remove, Insert:
        "Leave them be---you have no need of bell-making tools, and Brother
        Cuthbert will want these left here.";
      Search:
        "You find nothing else among the tools.";
      default:
        "Leave the tools be, Brother.";
    ],
  has pluralname;


Object ScribbledNote "scribbled note"                           ! >ScribbledNote
  class AdjObject,
  with
    adj_name 'scribbled',
    noun_name 'note' 'letter',
    description
      "It's just a folded scrap of paper, written in an educated hand. It reads:
      ~The manuscript was exquisite---the illumination work exceptional. Should
      another such work become available, I remain most interested. Leave word
      at our usual place.~ It is unsigned.",
    after [;
      Examine:
        ev_note = true;
    ],
  has
    evidence ;


!---------------------------------------------------- 2.0.4 Quire
! Quire, lectern, and stalls


! Object to manage logic of the first-service and other ones
!
! PUZZLE: need to perform first service
! PUZZLE: if wander through area during service, will get sucked into it


Room Quire "Quire"                                                      ! >Quire
  with
    description [;
      if (current_service)
        print
          "The Quire is the centre of the church. Two long stalls face each
          other.^";
      else
        print
          "The Quire is the heart of monastic worship and the centre of the
          church. Two stalls face each other across the narrow gap, where
          the brothers gather to chant the Divine Offices. The stalls are plain
          but worn smooth by generations of use. The high altar rises to the
          east. The Nave lies west, beyond the screen. The Night Stairs ascend
          north to the Dorm, and a hall leads south to the Cloister.^";
      WhoSub(true);
    ],
    out_to CloisterN,
    s_to CloisterN,
    e_to HighAltarArea,
    w_to Nave,
    n_to NightStairs,
    u_to NightStairs,
    cheap_scenery
      'high' 'altar'
        "You can see the altar from here, but you should head east for a
        closer look.",
    before [;
      SitAny: <<Enter Stalls>>;
      Sing:
        "But there's no Divine Office going on at the moment.";
    ],
  has
    ;


Chair -> Stalls "stalls"                                              ! >Stalls
  class AdjObject,
  with
    article "two",
    adj_name 'wooden',
    noun_name 'stalls' 'stall' 'bench' 'benches',
    description [;
      print
        "You've sat on these for months now during Divine Offices.
        While sacred to you, the carpentry is unremarkable";
      PrintContents(". On them ", self, ISARE_BIT);
      ".";
    ],
    after [;
      Enter:
        if (BrAelred in self)
          "You sit on a stall next to your mentor, the herbalist Brother
          Aelred.";
        "You sit on a stall with a certain sense of familiarity.";
    ],
  has
     pluralname;


!----------------------------------------------------- 2.0.5 High Altar Area
! HighAltar, crypt stairs


Room HighAltarArea "High Altar Area"                            ! >HighAltarArea
  with
    description [;
      print
        "A domed ceiling rises above this, where Prior Oswald leads public Mass.
        A chapel stands in shadow to the east. The Sacristy lies south. ";
        if (CryptGate hasnt open)
          "A closed gate bars the narrow stairs descending to the Crypt.";
        "The crypt gate is open.";
    ],
    w_to Quire,
    e_to LadyChapel,
    d_to CryptGate,
    s_to SacristyDoor,
    cheap_scenery
      1 'chapel'
        "From here, you can see an altar and a statue. You can go east to
         explore it."
      11 'domed' 'ceiling'
        "It's lovely---and also far above you."
    ,
  has;


Altar -> HighAltar                                                  ! >HighAltar
  with
    short_name "High Altar",
    article "the",
    adj_name 'high',
    add_to_scope AltarCross,   ! don't want them to be listed on
    description
      "The poverty of the priory is evident in the simplicity of the altar,
      a stone structure supporting a cross.",
    before [;
      Smell: "It smells like dust and faint incense.";
      Take, Push, Pull, Turn: "It's much too heavy for that.";
    ],
  has ~supporter ~enterable ;


Object AltarCross "altar cross"                              ! >AltarCross
  class AdjObject
  with
    article "the",
    adj_name 'simple' 'wooden' 'altar',
    noun_name 'cross',
    description
      "A simple wooden cross---no gold, no jewels---firmly attached
      to the altar.",
    before [;
      Examine, Touch: ;
      Smell: <<Smell HighAltar>>;
      Attack: "Heaven forfend.";
      Push, Turn, Pull, Take: ;
      Search: ;
      default:
        "Thinking of how outraged Brother Cuthbert would be, you think better
        of this act.";
    ],
  has scenery;


! -------------------------------------------------------------

! PUZZLE: how to get into the crypt?
!  It isn't the key; that's a red herring and player will never get it.
!  It can be entered throught the secret FitzAlanCrypt
! PUZZLE: how to leave the crypt?
!  - can pray to st jude for impossible help
!  - can ring the bell, hide, wait for cuthbert to search, then run
!    upstairs when he goes to crypt vestry

Object CryptGate "crypt gate"                                       ! >CryptGate
  class AdjObject,
  with
    adj_name 'crypt',
    noun_name 'gate' 'stairs',
    description [;
      #ifDef HAS_HINTS; HintReady(Hint_gate); #EndIf;
      print
        "The gate is made of sturdy iron and has a heavy lock built into it";
      if (self has open) print ". It is open"; else print ". It is closed";
      ".";
    ],
    with_key DummyKey,
    found_in HighAltarArea CryptStairs,
    door_dir (u_to) (d_to),
  has
    scenery door locked lockable ~open openable;


Room CryptStairs "Crypt Stairs"                                   ! >CryptStairs
  with
    description [;
      print
        "At the midpoint of these stairs, you can sense the damp
        below. A thin veil of ", (DescribeLight) self,
        " comes from the altar area above";
      if (_LookForLightInObj(Crypt, Crypt))
        ", and weak candlelight from the Crypt below.";
      ", but the path down descends into darkness.";
    ],
    s_to CryptGate,
    cant_go MSG_STAIRS_UP_DOWN_ONLY,
    u_to [;
      if (PrayerMat has general && CryptGate hasnt open) {
        give CryptGate open;
        give PrayerMat hasnt general;
        TaskDone(TASK_ESCAPE_CRYPT);
        print
          "As you approach the crypt door, you hear the soft click of an unseen
          bolt sliding back. Your prayer has been answered.^^";
      }
      return CryptGate;
    ],
    d_to Crypt,
    before [;
      Smell: if (noun == nothing) "Musty and damp.";
      Close:
        if (BrCuthbert in CryptStairs or Crypt or CryptVestry)
          "Surely, you don't want to trap Brother Cuthbert in the Crypt?";
    ],
    cheap_scenery
      1 'crypt' "You can't see it from here, but it's below."
    ,
  has
    ;


! --------------------------------------------------- 2.0.6 Sacristy


Object SacristyDoor "sacristy door"                              ! >SacristyDoor
  class AdjObject,
  with
    adj_name 'sacristy',
    noun_name 'door',
    description "The Sacristy door is narrow and without any lock.",
    found_in HighAltarArea Sacristy,
    door_dir (n_to) (s_to),
    before [;
      Examine:
        if (location == thedark)
          "Have faith, Brother. You can't see it, but you know it's there.";
    ],
    after [;
        Open:
          give Sacristy light;
          "You open the door, revealing the ", (DescribeLight) self,
          " from the High Altar Area.";
          ! scope_modified = true;
        Close:
          give Sacristy ~light;
          ! scope_modified = true;
    ],
  has
    static scenery door openable ~open;


! PUZZLE: can only get the candle if has proven it's needed
! PUZZLE: has to hide candle as its contraband

Room Sacristy "Sacristy"                                             ! >Sacristy
  with
    name 'sacristy' 'vestry',
    description [;
      print
        "A small room where vestments and sacred vessels are kept. Shelves hold
        neatly folded linens, precious chalices, and other miscellaneous vestry
        items. The smell of beeswax and old incense lingers. Brother Cuthbert
        maintains this space with meticulous care";
      if (SacristyDoor has open)
        print
        "^^Through the open door, ", (DescribeLight) self, " spills in
        from the High Altar Area";
      ".";
    ],
    out_to SacristyDoor,
    n_to SacristyDoor,
    cheap_scenery
      'shelf' 'shelves' [;
        Search, Examine:
          "You find linens, chalices, and other miscellaneous vestry items
          useful for services.";
        Receive:
          "Brother Cuthbert keeps this very organised. Don't add things to
          these shelves.";
        Empty:
          "You dare not.";
        Take:
          "The shelves are built into the wall.";
        Smell:
          "The scent of beeswax is stronger here.";
      ]
      CS_THEM 'linen' 'linens' [;
        Examine: "The linens are worn but clean.";
        Search: "You find nothing among the linens.";
        Take, Insert: "You dare not. These are precious sacred items.";
        default: "Leave the linens alone.";
      ]
      CS_THEM 4 'vessel' 'vessels' 'chalice' 'chalices' [;
        Examine: "The chalices are used for sacred purpose during Mass.";
        Take, Insert: "You dare not. These are precious and would be missed.";
        default: "Leave the chalices alone.";
      ]
      1 'incense' [;
        Examine, Take: "You can smell it faintly, but can't find any here.";
        Smell: "It's a lingering aroma of sage.";
        default: "It's just a lingering aroma, that's all.";
      ]
      CS_THEM 'vestry' 'items' [;
        Examine:
          "Among the miscellany: some candles, a pewter platter, and a piece
          of cloth.";
        default: "You should address these items individually.";
      ]
      1 'cloth' [;
        Examine: "Just a plain scrap.";
        default: "Leave it be.";
      ]
      11 'pewter' 'platter' [;
        Examine: "Used to hold items during Mass.";
        Take, Insert: "Brother Cuthbert would be outraged if you took this.";
        default: "Brother Cuthbert would be outraged if you messed with this.";
      ]
    ,
    before [;
      Smell:
        if (noun) rfalse;
        if (location == thedark)
          "You smell wax and old incense in the darkness.";
        "Dusty and fragrant with wax and wood.";
      Go:
        if (location == thedark)
          "You shouldn't stumble around in the dark.
          You might damage something.";
    ],
  has
    ;


Object -> Candles "candles"                                           ! >Candles
  class AdjObject,
  with
    adj_name 'beeswax' 'bees' 'wax',
    noun_name 'candles',
    describe 0,
    description
      "There are a few candles here, finer than the more common ones made of
      tallow. These candles are used to light the church.",
    before [;
      Burn: "Burning all of these candles would be madness.";
      Extinguish: "They're not lit.";
      Take:
        if (MyCandle.dont_need()) rtrue;
        "The theft of all of the candles would be quickly discovered.";
    ],
    add_to_scope MyCandle,
  has pluralname;


Candle MyCandle "beeswax candle"                                     ! >MyCandle
  with
    adj_name 'beeswax' 'wax',
    description [;
      print "Good quality, made from beeswax from the priory's own bees";
      if (self has light) print ". It is lit";
      ".";
    ],
    before [;
      Smell: "Waxy and slightly sweet.";
      Taste: "Gingerly, you taste it. Waxy.";
      Take:
        ! haven't solved lion/crypt: don't let them take
        if (MyCandle.dont_need()) rtrue;
        ! if there's already a candle in room or player, they get this one
        if (IndirectlyContains(location, self)) rfalse;
        ! if it's been removed from the game (destroyed), they get another
        if (parent(MyCandle) == nothing) {
          if (TryToTakeNoun(true) ~= 1) {
            if (self has moved)
              "Feeling even more guilt, you take another candle.";
            "You take a single candle, feeling the weight of this
            small theft.";
          } else {
            rtrue;
          }
        }
        "Surely, one stolen candle must be enough.";
    ],
  has
    ;


! --------------------------------------------------- 2.0.7 FitzAlan Chantry

! PUZZLE: find hidden ladder to FA Crypt
! PUZZLE: how to get out of that area, since ladder is one-way

Room FitzAlanChantry "FitzAlan Chantry"                       ! >FitzAlanChantry
  with
    name 'chantry',
    description [;
      if (player in FitzAlanAltar)
        "From here you can see the arms closely.";
      print
        "The FitzAlan family chantry, endowed long ago for masses. But the
        FitzAlans are gone now---their line ended in the pestilence---and no
        masses are said here anymore";
      if (FitzAlanAltar has open) {
        print ".^^An opening in the floor reveals a ladder leading down";
        if (~~IsLit(FitzAlanCrypt))
          print " into darkness";
      }
      ".";
    ],
    on_first_entry [;
      #IfDef HAS_HINTS; HintReady(Hint_chantry); #EndIf;
    ],
    s_to LadyChapel,
    d_to [;
      if (FitzAlanAltar has open) {
        if (~~(IsLit(FitzAlanCrypt)() || IsCarryingLit())) {
          print
            "Do you want to descend into darkness without a source of light? ";
          if (YesOrNo() == 0) "You think better of it.";
          #IfDef HAS_HINTS; HintReady(Hint_FALight); #EndIf;
        }
        print
          "^You climb down the ladder. As you step off the bottom rung,
          a counterweight somewhere in the mechanism snaps the ladder
          back to the ceiling, far out of reach.^^";
        move Ladder to FitzAlanCrypt;
        return FitzAlanCrypt;
      }
    ],
    cheap_scenery
      1 'floor' "These almost look like scrapes from moving the altar."
      'gouge' 'gouges//p'
        "You're not sure what caused them---perhaps the altar was moved?"
      1 'motto'
        "~LEO VIAM CUSTODIT~. They certainly thought highly of themselves."
      1 'stone' "It's just ordinary stone."
    ,
  has
    ;


! open = open, can climb down
! moved = ever been opened

Altar -> FitzAlanAltar                                          ! >FitzAlanAltar
  class AdjObject,
  with
    adj_name 'fitzalan' 'stone',
    describe [;
      print "^A stone altar is set against the east wall";
      PrintContents(". On it ", self, ISARE_BIT);
      ".";
    ],
    description [;
      print "A heavy-looking block of white stone";
      if (self has open) {
        print " that has been pushed away from the wall, revealing a ladder";
        if (~~IsLit(FitzAlanCrypt)()) print " descending into darkness";
        ".";
      }
      print
        " on the floor. Gouges in the floor by the altar testify to its weight.
        Above the altar, carved into the wall, are the FitzAlan arms and motto";
      PrintContents(". On the altar ", self, ISARE_BIT);
      ".";
    ],
    after [;
      Enter:
        print "You climb onto the altar";
        if (FitzAlanLion hasnt moved)
          ". From here you can reach the carved arms above.";
        ".";
    ],
    before [;
      Take:
        if (FitzAlanLion hasnt moved) rfalse;
        "Even trying, you can't lift it.";
      Search:
        if (self hasnt open)
          "You find nothing hidden about the altar itself, but those gouges
          in the floor are intriguing.";
        "The altar is swung open, revealing a ladder downwards.";
      Push, Turn, Pull:
        if (player in self)
          "You can't move the altar while standing on it.";
        if (self has open) {
          give self ~open;
          give FitzAlanLion ~moved;
          remove Ladder;
          "You push the altar back against the wall and hear a solid click as
          it settles against the wall.";
        }
        if (FitzAlanLion has moved) {
          print
            "You push against the altar and it swings away from the wall,
            revealing an opening in the floor. ";
          if (self hasnt moved) {
            QuoteBoxSimple(quote_stone);
            TaskDone(TASK_FA_CRYPT);
          }
          give self open;  ! now open
          give self moved; ! ever opened
          move Ladder to FitzAlanChantry;
          print "The opening reveals a ladder descending";
          if (~~IsLit(FitzAlanCrypt)()) print " into darkness";
          ".";
        }
        if (self has moved)
          "It seems you can no longer push it.";
        "While it seems that the altar isn't built into the floor, it
        also doesn't budge when you try to move it.";
    ],
  has
     ;


! moved = lion is pushed in now
! general = lion has ever been pushed in

Object -> FitzAlanLion "FitzAlan arms"                           ! >FitzAlanLion
  class AdjObject,
  with
    describe 0,
    adj_name 'fitzalan' 'family' 'brass' 'rampant',
    noun_name 'lion' 'arms',
    description [;
      if (player notin FitzAlanAltar)
        "A lion, perhaps? It's a bit too far up to see clearly.";
      if (self has moved) "The lion is now flush against the stone.";
      "A finely-detailed brass rampant lion standing out from the stone.";
    ],
    before [;
      if (player notin FitzAlanAltar && action ~= ##Examine)
        "The arms are set high in the wall, well above you.";
      Push, Turn:
        if (self has moved) "Nothing new happens.";
        f_found_darkness = true;
        give self moved;
        if (self has general)
          "Again, you push against the lion, and hear the same deep click.";
        give self general;
        "You push against the lion and, surprisingly, it moves
        inward slightly. A deep click is heard in the wall.";
      Touch:
        "The arms are fine to the touch and, curiously, the lion feels like it
        could move.";
    ],
  has
    ~moved static pluralname;


!---------------------------------------------------- 2.0.8 Lady Chapel
! Chapel and statue

Room LadyChapel "Lady Chapel"                                      ! >LadyChapel
  with
    description
      "The largest of the three chapels, dedicated to the Blessed Virgin.
      This chapel sees more use than the others---the brothers pray here
      for the priory's patroness, Our Lady of Thorns. To the west is the
      High Altar Area. Small doorways lead north and south to smaller chapels.

      ^^A statue of Mary stands in a niche and a stone altar is next to her.",
    w_to HighAltarArea,
    n_to FitzAlanChantry,
    s_to StJudeChapel,
    cheap_scenery
      1 'niche' "It's just a spot for the statue, with nothing else in it."
      1 'lady' "The ~Lady~ here refers to the Virgin Mother."
      11 'carved' 'face' "It's the face on the statue."
      11 'stone' 'hands' "It's just a feature of the statue."
    ,
  has
    ;


Statue -> MaryStatue "statue"                                      ! >MaryStatue
  with
    name 'mary' 'virgin' 'blessed',
    describe 0,
    description
      "A stone statue of the Blessed Virgin Mary. Her stone hands are
      open in a gesture of welcome and mercy. Her carved face is serene.^^
      Carved on the base:^
      ^  BEATAE MARIAE MATRIS DEI
      ^  (Blessed Mary, Mother of God)",
    react_before [;
      Pray: "You make the sign of the cross and murmur an Ave Maria.";
    ],
  has
    female;


Altar -> MaryAltar                                                  ! >MaryAltar
  class AdjObject,
  with
    describe 0,
  ;

! --------------------------------------------------- 2.0.9 St Jude Chapel
! Chapel, mat, statue, altar, rosehips

! PUZZLE: can pray to st jude for later help in crypt
! PUZZLE: identify the rosehips

Room StJudeChapel "St Jude Chapel"                               ! >StJudeChapel
  with
    description
      "A small chapel dedicated to St Jude, patron of desperate causes. The
      stone floor is worn down---many desperate souls have knelt here over
      the generations, praying for urgent escape from terrible situations. A
      doorway leads north to the Lady Chapel.
      ^^A painted statue of the saint is in a corner. Near it is
      a stone altar with a prayer mat laid before it.",
    n_to LadyChapel,
    #IfDef HAS_HINTS;
      on_first_entry [;
        HintReady(hint_jude);
      ],
    #EndIf;
    cheap_scenery
      1 'staff' "The staff is just a painted part of the statue."
      1 'eyes' "While evocative, the eyes of the statue are merely paint."
      1 'chapel' "This room is the chapel."
    ,
  has
    ;


! general = has a prayer
! moved = ever had a prayer (can't get a second)

Object -> PrayerMat "prayer mat"                                    ! >PrayerMat
  class AdjObject,
  with
    adj_name 'prayer',
    noun_name 'mat',
    describe 0,
    description
      "A rough flax mat before the altar, worn thin by countless hours
      of kneeling. Someone has been using it recently---very recently.",
    before [;
      Take, Push, Pull: "You are deeply certain it belongs here.";
      Turn, Search, LookUnder: "Nothing below it but a worn stone floor.";
      Receive:
        "It feels sacrilegious to put anything on this sacred mat.";
    ],
    after [;
      Enter: "You kneel on the worn mat, as many others have done before.";
    ],
    react_before [;
      Pray:
        if (player in PrayerMat) {
          if (self hasnt general) {
            give self moved;   ! ever got a prayer
            give PrayerMat general;
            "You feel a powerful sense of hope that Saint Jude will help you in
            crisis.";
          }
          "You feel that the Saint has already heard your plea.";
        }
    ],
  has
    static supporter enterable;


Altar -> JudeAltar                                                  ! >JudeAltar
  with
    describe 0,
    description [;
      print "A simple stone altar";
      if (RoseHips hasnt moved) {
        give RoseHips ~concealed;
        print ". Someone has left an offering of ";
        if (RoseHips has general) print "rosehips";
        else print "small red berries";
        " on it.";
      } else {
        PrintContents(". On it ", self, ISARE_BIT);
      }
      ".";
    ],
  has
    ;


! The berries are initially known only as "berries", but they become known
! as rosehips after smell/tasting them. They're initially concealed, but are
! revealed after examining the altar (otherwise, they'd get listed in the
! initial room description, and I want people to have to look at the altar
! to notice them).

Object -> -> RoseHips  ! "berries" or "rosehips"                     ! >RoseHips
  with
    short_name "berries",
    invent [;
      print "some offering ", (name) self; rtrue;
    ],
    parse_name [ w wn ;
      while (true) {
        w = NextWord();
        if (w == 'red' or 'offering' or 'berry' or 'berries') wn++;
        else if (self has general &&
            w == 'offering' or 'rose' or 'hip' or 'hips' or 'rosehip'
                or 'rosehips') wn++;
        else return wn;
      }
    ],
    description [;
      if (self hasnt general) print "Small seed pods. ";
      "Someone carefully gathered these as an offering.
      They're fresh and fragrant, picked within the last day or two.";
    ],
    before [;
      Eat:
        "You shouldn't eat an offering left to a saint. If you just want to
        taste them, say so.";
      Taste, Smell:
        if (action == ##Taste)
          print "You nibble at one: a sweet, tangy flavour";
        if (action == ##Smell)
          print "A faint, floral scent";
        if (self hasnt general) {
          print ".";
          give self general;
          self.short_name = "rosehips";
          if (ev_rosehips == false) {
            ev_rosehips = true;
            QuoteBoxSimple(quote_rose);
            "This action brings back a memory from summer: Aelred in the physic
            garden, showing you a red rose in full bloom. ~Beautiful now, Brother,
            but its true gift comes later. These petals fall, and by autumn the
            hip swells with seed---tart and rich. We gather them after the first
            frost for winter cordials.~ He'd smiled. ~The rose serves us twice:
            beauty in summer, medicine in autumn.~ He pauses, then continues:
            ~For some, though, they portend painful loss or diminishment.~";
          }
        }
        ", reminiscent of roses and of loss.";
      Touch:
        print "Firm.";
        if (self hasnt general) print " Perhaps you should check their scent?";
        "";
    ],
  has
    pluralname edible concealed ok_carry;


Statue -> JudeStatue "St. Jude"                                    ! >JudeStatue
  with
    name 'saint' 'st' 'jude',
    describe 0,
    description
      "A wooden statue of St Jude, simply carved and crudely painted.
      The saint holds a staff in one hand. His painted eyes seem to
      gaze down at those who kneel before him in desperation.",
    react_before [;
      Pray: "You murmur a brief prayer to St Jude.";
    ];


! ======================================================== 2.1 CLOISTER
! NW N NE W E SW S SE Garth


class Cloister                                                       ! >Cloister
  with
    name 'cloister' 'arcade',
    description [;
      if (~~f_been_on_cloister) {
        f_been_on_cloister = true;
        print
            "You emerge on the ";
        if (location == CloisterN)
          print "northern edge of the";
        else if (location == CloisterSW)
          print "southwestern corner of the";
        print
            " Cloister walk, the covered stone arcade at the centre
            of the priory. It's a continuous square path surrounding the Garth,
            a large open yard. Various rooms and passageways come off of
            each section of it.^^";
      }
      print "Arched openings admit ";
      switch (RoughTime()) {
        CLOCK_NIGHT: print "cold night air and pale moonlight";
        CLOCK_MORNING: print "fresh morning breeze";
        CLOCK_AFTERNOON: print "slanted autumn sun";
        default: print "dim evening light";
      }
      print ".^^";
      self.cloister_detail();
    ],
    cant_go "The walls of the Cloister block that direction.",
    d_to
      "The Garth is only one step down from the Cloister. To enter it,
      just walk in that direction through an opening.",
    before [;
      Climb:
        "You eye the effort it would take to scale the walls
        and think better of it.";
      Smell:
        if (noun == nothing)
          "You can faintly smell the gardens and the grass in the Garth.";
    ],
  has
    light;

! ----------------------------------------------------------------- Cloister NW


Class DoorButton                                                   ! >DoorButton
  with
    describe 0,
    parse_name [ w1 w2;
      w1 = NextWord();
      w2 = NextWord();
      if (w1 == 'button') {
        if (w2 == 0) return 1;
        if (w2 == self.&name-->0) return 2;
      }
      if (w1 == self.&name-->0) {
        if (w2 == 0 or 'button') return 1 + (w2 ~= 0);
      }
      return 0;
    ],
    before [;
      Examine:
        print "A brass button engraved with ";
        print (string) self.simple_name;
        if (self has on)
          print ". It is currently pressed in";
        ".";
      Push, SwitchOn:
        if (NarcInRoom())
          "You dare not mess with the door, as any brother in the Cloister walk
          could see you.";
        if (self has on)
          "That button is already pressed in.";
        give self on;
        PriorDoor.&pressed-->PriorDoor.pressed_count = self;
        PriorDoor.pressed_count++;
        print "You press the button and feel it click into place.^";
        PriorDoor.check_combination();
        rtrue;
      Pull, SwitchOff:
          if (NarcInRoom())
            "You dare not mess with the door, as any brother in the Cloister
            walk could see you.";
        if (self hasnt on)
          "That button is not currently pressed.";
        "You cannot pull the button back out.";
      Take:
        "The button is part of the door.";
    ],
  has
    static;


Cloister CloisterNW "Cloister Northwest"                           ! >CloisterNW
  with
    cloister_detail
      "The high walls of the church rise imposingly to the north,
      and a curious door lies to the west.",
    s_to CloisterW,
    e_to CloisterN,
    w_to PriorDoor,
    in_to PriorDoor,
    #IfDef HAS_HINTS;
    on_first_entry [;
        HintReady(Hint_SolarDoor);
        HintReady(Hint_WhatIsSolar);
    ],
    #EndIf;
    cheap_scenery
      1 'buttons' "There are seven buttons on the door. You'll have to
        specify which one you want.";


DoorButton -> CompassButton "compass button"                   ! >CompassButton
  with
    name 'compass',
    simple_name "a compass, labelled ~RATIO~",
  has;

DoorButton -> HammerButton "hammer button"                      ! >HammerButton
  with
    name 'hammer',
    simple_name "a hammer, labelled ~LABOR~",
  has;

DoorButton -> ScrollButton "scroll button"                       ! >ScrollButton
  with
    name 'scroll',
    simple_name "an unfurled scroll, labelled ~SAPIENTIA~",
  has;

DoorButton -> CrossButton "cross button"                          ! >CrossButton
  with
    name 'cross',
    simple_name "a cross, labelled ~FIDES~",
  has;

DoorButton -> KeyButton "key button"                                ! >KeyButton
  with
    name 'key',
    simple_name "a key, labelled ~CUSTODIA~",
  has;

DoorButton -> LampButton "lamp button"                             ! >LampButton
  with
    name 'lamp',
    simple_name "a lamp, labelled ~LUX~",
  has;

DoorButton -> WheatButton "wheat button"                          ! >WheatButton
  with
    name 'wheat' 'sheaves',
    simple_name "wheat sheaves, labelled ~PROVIDENTIA~",
  has;


Cloister CloisterN "Cloister North"                                 ! >CloisterN
  with
    cloister_detail
      "The wall of the Nave rises imposingly to the north. A passageway into
      it leads to the Quire. You can also go west to the northwest corner,
      east to the northeastern corner, or south into the Garth.",
    in_to Quire,
    w_to CloisterNW,
    s_to Garth,
    n_to Quire,
    e_to CloisterNE;


Cloister CloisterNE "Cloister Northeast"                           ! >CloisterNE
  with
    cloister_detail
      "The Chapter House is to the east, and the Day Stairs to the upper floor
      head upward from here. You can also go west to the northern end of the
      Cloister or south to the eastern end.",
    e_to ChapterHouse,
    w_to CloisterN,
    u_to DayStairs,
    s_to CloisterE,
    after [;
      ! Look: if (self hasnt visited) SceneFollowRemigio.scene_start();
    ]
  ;


Cloister CloisterW "Cloister West"                                  ! >CloisterW
  with
    cloister_detail
      "The Locutory lies to the west. You can also go north to the northwestern
      corner of the Cloister, south to the southwestern corner, or east into
      the Garth.",
    s_to CloisterSW,
    e_to Garth,
    w_to Locutory,
    in_to Locutory,
    n_to CloisterNW,
  ;


Cloister CloisterE "Cloister East"                                  ! >CloisterE
  with
    cloister_detail
      "To the east is the entrance to the Scriptorium. You can also go north
      to the northeastern corner, south to the southeastern corner, or west
      into the Garth.",
    n_to CloisterNE,
    e_to Scriptorium,
    in_to Scriptorium,
    w_to Garth,
    s_to CloisterSE,
  ;


Object WestGate "West Gate"                                          ! >WestGate
  class AdjObject,
  with
    adj_name 'west',
    noun_name 'gate' 'door',
    description [;
      print
        "A wooden door whivch is the entrance for brothers into the Cloister";
      if (location == CloisterSW) {
        print ". The bar is ";
        if (self has locked) print "lowered, locking the gate";
        else print "raised, unlocking the gate";
      }
      print ". The gate is ";
      if (self has open) "open."; "closed.";
    ],
    before [;
      Pull:
        if (location == Passage && self has locked)
          "The gate won't open. It must be barred.";
      Push:
        if (location == CloisterSW) <<Open self>>;
      Turn:
        if (self has locked) <<Unlock self>>; <<Lock self>>;
      Unlock:
        if (location ~= CloisterSW) rfalse;
        if (self hasnt locked) "The bar is already raised.";
        give self ~locked;
        "You raise the bar, unlocking the gate.";
      Open:
        if (location == CloisterSW && self has locked) {
          <Unlock self>; new_line;
        }
      Lock:
        if (location ~= CloisterSW) rfalse;
        if (self has locked) "The bar is already lowered, locking the gate.";
        if (self has open) print "You close the gate and";
        else print "You";
        give self locked;
        give self ~open;
        " lower the bar, locking the gate.";
    ],
    found_in Passage CloisterSW,
    door_dir (w_to) (e_to),
  has
    scenery door locked openable ~open;


Cloister CloisterSW "Cloister Southwest"                           ! >CloisterSW
  with
    cloister_detail
      "The West Gate lies to the west. A small alcove, the Lavatorium,
       is to the south. You can also go north to the western edge, or
       east to the southern edge.",
    s_to Lavatorium,
    e_to CloisterS,
    w_to WestGate,
    n_to CloisterW,
    out_to WestGate,
  ;


Cloister CloisterS "Cloister South"                                 ! >CloisterS
  with
    cloister_detail
      "The Refectory lies to the south. You can also go west to the southwestern
      corner of the Cloister, east to the southeastern corner, or north to the
      Garth.",
    n_to Garth,
    w_to CloisterSW,
    e_to CloisterSE,
    s_to Refectory,
    in_to Refectory,
  ;


Cloister CloisterSE "Cloister Southeast"                           ! >CloisterSE
  with
    cloister_detail
      "The long Slype, leading to the Infirmary and the Herbarium, lies to the
      east. You can also go north to the eastern end of the Cloister, and
      west to the southern end.",
    n_to CloisterE,
    e_to Slype,
    w_to CloisterS,
    cheap_scenery
      2 'long' 'slype'
        "The Slype is a covered passageway to the east.",
  ;


Room Garth "Garth"                                                      ! >Garth
  with
    name 'garth' 'square',
    description [;
      "The Garth---the small grass courtyard at the heart of the Cloister.
      The covered Cloister walk surrounds it on all sides, its arches
      framing the sky above with its ", (DescribeLight) self,
      ".^^This is the monastery's heart, open to rain and sun, enclosed
      by the daily circuit of monastic life. In the centre is a sundial and a
      stone well.";
    ],
    n_to CloisterN,
    w_to CloisterW,
    s_to CloisterS,
    e_to CloisterE,
    u_to
      "The Cloister walk is raised only a single step. You're already
      at ground level. Just walk in the direction you want to enter it.",
    cheap_scenery
      'grass' 'courtyard' [;
        Examine:
          "Sparse grass and a few stubborn herbs. The Garth was probably
          more carefully tended in better times.";
        Enter:
          <<SitAny location>>;
      ]
      1 'herbs' "Poorly cared for. This wasn't Brother Aelred's domain."
      1 'water'
        "Presumably there's water in the well, but it's much too
        far for you to reach."
      13 'sun' 'sundial' 'dial' 'clock' [;
        Examine:
          if (the_time < 300 || the_time > 1260)
            "The sundial isn't casting a discernible shadow without sunlight.";
          "The sundial casts a shadow showing that the approximate time is ",
          (SundialTime) the_time, ".";
        Take: "It's much too heavy.";
        default: "There is nothing you can do with the grass.";
      ]
    ,
    before [;
      SitAny:
        the_time = the_time + 2;
        "You sit on the grass and try to clear your head. However, given the
        events so far, you cannot bear to spend time doing this. You get back
        up.";
      Listen:
        "You can hear only the quiet peace of the Garth.";
      Smell:
        "You can smell the grass and the nearby herbs.";
    ],
  has
    ;


Object -> GarthWell "well"                                          ! >GarthWell
  class AdjObject,
  with
    adj_name 'stone' 'old',
    noun_name 'well',
    description
      "An old stone well, its edges worn down by centuries of drawing
      water.",
    before [;
      Enter, Climb:
        "The well is deep and dark. You're not that desperate.";
      Search:
        if (Stick in player)
          "You put the stick into the well and fish around, but it seems the
          water is too far for the stick to reach.";
        "It's too dark to see the bottom.";
      Receive:
        if (NarcInRoom())
          "You dare not, since a brother on the Cloister walk would witness
          this act.";
        remove noun;
        print_ret
          (The) noun, " lands far below with a splash.
          You hope you didn't need that.";
    ],
  has
    scenery container open;


! ======================================================== 2.2 WEST WING
! 2.2.1 Prior's Solar
! 2.2.2 Locutory
! 2.2.3 Lavatorium

! --------------------------------------------------- 2.2.1 Prior's Solar


Object PriorDoor "prior door"                                       ! >PriorDoor
  class AdjObject,
  with
    adj_name 'prior' 'solar' 'solar^s',
    noun_name 'door',
    description [;
      print "A heavy door made of fine cedar";
      if (location == CloisterNW)
        print
          ", upon which a large brass plate
          is set. There are seven buttons on it, each bearing a symbol:
          a compass, a hammer, a scroll, a cross, a key, a lamp, and wheat. Below
          them, an inscription in elegant Latin script:
            ^^  HIS TRIBUS FUNDATA EST DOMUS MEA
             ^       --- GORDIANUS, PRIMUS PRIOR
            ^^You read that as ~On these three my house is founded ---
            Gordian, First Prior~";
      print ". The door is currently ";
      if (self hasnt open) "closed."; "open.";
    ],
    door_dir (e_to) (w_to),
    found_in CloisterNW PriorsSolar,
    pressed_count 0,
    pressed 0 0 0,
    check_combination [ obj;
      ! Check if three buttons pressed
      if (self.pressed_count ~= 3) rfalse;
      objectloop (obj ofclass DoorButton)
        give obj ~on;
      self.pressed_count = 0;

      ! Check combination: Cross (FIDES), Hammer (LABOR), Book (SAPIENTIA)
      if (self.&pressed-->0 == CrossButton
          && self.&pressed-->1 == HammerButton
          && self.&pressed-->2 == ScrollButton) {
        give self ~locked;
        TaskDone(TASK_SOLAR_DOOR);
        "^You hear a satisfying series of clicks from within the door.
        The lock disengages.";
      } else {
        ! Wrong combination - reset all buttons
        "^You hear a dull click from within the door. All the buttons
        spring back out. Perhaps you pressed the wrong combination?";
      }
    ],
    before [;
      Open:
        if (location == PriorsSolar) {
          give self open;
          give self ~locked;
          "You open the door.";
        }
      Knock:
        if (BrOswald in PriorsSolar && current_service == nothing)
          "Prior Oswald opens the door. ~Ah, Brother Novice. I'm
          busy. We can talk tomorrow.~ He closes the door firmly.";
    ],
    after [;
      Open:
        print "You open the door";
        if (parent(BrOswald) == PriorsSolar) {
          if (self has general) { ! already tried once
            print
              ". Brother Oswald stands up in the room, visibly angered.
              ~How dare you defy me?~ he bellows. You are sentenced to
              bread and water for a week.";
              KillOff();
              rtrue;
          }
          give self general;
          give self locked;
          give self ~open;
          #IfDef HAS_HINTS; HintReady(Hint_PriorGone); #EndIf;
          print
            ". Brother Oswald looks shocked from inside.
            ~Brother Aldwin, what are you doing, trying to gain entrance
            to my private quarters?~ He closes the door on you and you
            hear the lock click";
        }
        ".";
      Close:
        give self locked;
        "You close the door and hear clicks from inside the mechanism.
        The door must have locked itself.";
    ]
  has
    scenery door openable ~open locked;


Room PriorsSolar "Prior's Solar"                                  ! >PriorsSolar
  with
    description
      "Prior Oswald's private chamber. A narrow bed stands against one wall.
      A writing desk sits next to it. A wooden chest sits at the foot of the
      bed. The room is austere but private---a privilege of rank in a
      community that otherwise shares everything.",
    e_to PriorDoor,
    out_to PriorDoor,
    #IfDef HAS_HINTS;
    on_first_entry [;
      HintReady(Hint_InSolar);
    ],
    #EndIf;
    each_turn [;
      if (BrOswald in self) {
        print
          "^Prior Oswald catches you here. ~What are you doing in my private
          space?~ he bellows. You are sentenced to a week of bread and water.";
        KillOff();
      }
    ],
    before [;
      Sleep:
        "If the prior were to catch you in his bed, you'd be expelled.
        You think better of it.";
    ],
    cheap_scenery
      31 'prior' 'priors' 'prior^s' 'solar'
        "'Solar' is just the name for this kind of private chamber."
      42 'narrow' 'prior^s' 'prior' 'priors' 'bed' 'cot' [;
        Examine:
          "A simple bed, better than the straw pallets in the Dorm,
          but hardly luxurious.";
        Enter:
          <<Sleep>>;
        Search, LookUnder, Push, Pull, Turn:
          "Under it is nothing but dust.";
      ]
    ,
  has
    ;

Object -> PriorsDesk "desk"                                        ! >PriorsDesk
  class AdjObject,
  with
    adj_name 'writing',
    noun_name 'desk' 'table',
    description [;
      print "A fine wooden desk with a single drawer";
      if (PriorDrawer has open) print " (which is open)";
      PrintContents(". On it is ", self, ISARE_BIT);
      ".";
    ],
    before [;
      Enter, Climb:
        "You dare not climb on the Prior's desk.";
      Open: <<Open PriorDrawer>>;
      Unlock: <<Unlock PriorDrawer>>;
      Close: <<Close PriorDrawer>>;
      Search:
        PrintContents("On it ", self, ISARE_BIT);
        if (PriorDrawer has open) ". The drawer for it is open";
        ".";
    ],
  has
    scenery static supporter;


Object -> -> PriorCross "cross"                                    ! >PriorCross
  class AdjObject,
  with
    adj_name 'small' 'brass',
    noun_name 'cross' 'base',
    description
      "A finely detailed cross in dark wood. The brass base bears a small
      inscription: ~CONVERTIMINI~---~Turn to me~.",
    before [;
      Take: "It seems affixed to the desk.";
      Pull: "Tugging on it does nothing.";
      Push: "Pushing down on it does nothing.";
      Turn:
        give PriorDrawer open;
        "Turning the cross on its base, you hear a click within.
        The drawer opens, and the cross snaps back to its original place.";
    ],
  has static;


Object -> PriorDrawer "desk drawer"                               ! >PriorDrawer
  class AdjObject,
  with
    describe 0,
    adj_name 'desk',
    noun_name 'drawer',
    description [;
      print "A simple wooden drawer. It is ";
      if (self has open) {
        print "open";
        PrintContents(", revealing ", self);
      }
      else print "closed";
      ".";
    ],
    before [;
      Open:
        if (self has locked)
          "Though you don't see a lock on the drawer, it won't open.";
      Unlock:
        "You don't see any lock on it.";
      Take:
        "You can't remove the drawer from the desk.";
    ],
    after [;
      Close:
        give self locked;
        "It closes and you hear a click inside when it locks.";
    ],
  has
    static openable locked container;


! general = read

Object -> -> Chronicle "Chronicle"                                  ! >Chronicle
  with
    article "the",
    name 'chronicle',
    description
      "The Chronicle is the Prior's record of daily business.",
    before [;
      Examine:
        if (verb_word == 'read') {
          ev_chronicle = true;
          print
            "The Chronicle contains the Prior's notes on daily affairs.
            The recent entries:^^";
          #Ifv5; @set_text_style 2; #EndIf;
          print
            "15 June 1346:";
          #Ifv5; @set_text_style 0; #EndIf;
          #Ifv5; @set_text_style 4; #EndIf;
          print
            " Brother Martin reports the grain stores
            are adequate for winter, though we had to purchase an additional
            sack of flour from the village due to poor harvest. The cost
            continues to strain our resources.^^";
          #Ifv5; @set_text_style 0; #EndIf;
          #Ifv5; @set_text_style 2; #EndIf;
          print "6 July 1346:";
          #Ifv5; @set_text_style 0; #EndIf;
          #Ifv5; @set_text_style 4; #EndIf;
          print
           " Brother Hugh informs me that the sale of our
            honey and beeswax brought less income than anticipated. Several
            benefactors who once supported us have redirected their charity
            elsewhere. Our revenues have declined steadily these past three
            years.^^";
          #Ifv5; @set_text_style 0; #EndIf;
          #Ifv5; @set_text_style 2; #EndIf;
          print "28 July 1346:";
          #Ifv5; @set_text_style 0; #EndIf;
          #Ifv5; @set_text_style 4; #EndIf;
          print
            " Brother Wilfred has misplaced his latest work---a small psalter
            with illuminations of remarkable quality. He recalls completing the
            opening of Beatus vir with azure and gold, but cannot remember
            where he shelved it. At his age, such lapses grow more
            frequent---this is the second time in this season he's misplaced a
            work. This is causing a significant loss of income for us.^^";
          #Ifv5; @set_text_style 0; #EndIf;
          #Ifv5; @set_text_style 2; #EndIf;
          print "3 August 1346:";
          #Ifv5; @set_text_style 0; #EndIf;
          #Ifv5; @set_text_style 4; #EndIf;
          print " The roof above the Refectory shows signs of damage
            from the autumn storms. Brother Anselm inspected it and says it will
            require material and builders to repair---funds we can ill afford.
            I have written to the Bishop requesting assistance, but hold
            little hope of reply.";
          #Ifv5; @set_text_style 0; #EndIf;
          "";
        }
      Take:
        if (~~ev_chronicle) "
          Perhaps you should examine it first, rather than
          stealing from the Prior.";
    ],
    after [;
      Take:
        "You're uncertain if taking the prior's property is the right thing to
        do---but, under the circumstances, you do so.";
    ],
  has evidence;


Object -> PriorsChest "wooden chest"                              ! >PriorsChest
  with
    name 'wooden' 'chest' 'box',
    description [;
      print "A sturdy wooden chest";
      if (self has open) print ". It is open";
      ".";
    ],
    before [;
      Turn, Push, Pull, LookUnder:
        "You move it enough to establish that there's nothing under it,
        and return it to its location.";
    ]
  has
    scenery container openable ~open;



! ---------------------------------------------------  2.2.2 Locutory

Room Locutory "Locutory"                                             ! >Locutory
  with
    description [;
      if (self hasnt visited) QuoteBoxSimple(quote_locutory);
      "The Locutory---the speaking room. A plain wooden table is in the centre,
      surrounded by two benches. The walls are bare stone. This is where the
      prior meets with merchants, where brothers discuss monastery business,
      where the silence of the Rule may be broken for practical needs.";
    ],
    e_to CloisterW,
    out_to CloisterW,
    before [;
      SitAny: <<Enter LocutoryBenches>>;
    ],
    cheap_scenery
      1 'walls' "You see nothing special about them."
    ,
  has
    ;


Object -> LocutoryTable "table"                                 ! >LocutoryTable
  class AdjObject,
  with
    adj_name 'wooden',
    noun_name 'table',
    description
      "A plain wooden table where necessary business is conducted.",
    before [;
      Climb, Enter: "You dare not.";
    ],
  has
    scenery supporter;


Chair -> LocutoryBenches "benches"                            ! >LocutoryBenches
  with
    adj_name 'wooden',
    noun_name 'bench' 'benches',
    description
      "Simple wooden benches flanking the table.",
  has
    scenery pluralname;


! --------------------------------------------------- 2.2.3 Lavatorium

Room Lavatorium "Lavatorium"                                       ! >Lavatorium
  with
    name 'lavatorium',
