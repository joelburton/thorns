! --------------------------------------------------- Dorm

Room Dorm "Dorm"                                                         ! >Dorm
  with
    ! we wake up here, and won't initially show the room name and description
    ! short_name [;
    !   if (turns == -1) rtrue;
    ! ],
    description [;
      if (turns ~= -1) {
        ! On first turn of game, don't overwhelm player with room descrip ---
        ! there's already so much text. Just list the monks.
        print
          "This great room is used by all the choir monks except Brother Prior.
          It could easily provide rest for twenty brothers, but there are only
          eight cots in here now. Each cot has a chest at its foot for any
          meagre possessions the brother has. ^^A window high up reflects ";
        DescribeLight();
        print " on the floor.^^A doorway leads south to the Dorter";
        if (self hasnt general) {
          print " (a kind of hallway connecting this Dorm and another)";
          give self general;
        }
        print
          ". Narrow stairs descend to the Quire, where offices are held.";
        print "^";
      }
      ! ListMonks();
      rtrue;
    ],
    s_to Dorter,
    d_to NightStairs,
    cheap_scenery
      'window' 'windows'
        [;
          Examine: "Just an opening in the stone and much too far to reach.";
          default: "The window is too high to do anything with it.";
        ]
    ,
  has
    ;


! This is kind of a frankenobject; it pretends to be "my cot", each of the
! NPC monks cots, and all offerings clarifying questions when no cot is
! given, like "cot" or "cots" by themselves. This saves 8 individual objects
! plus a class, and reduces the numbers of objects in scope.

Object -> AllMonkCots "cot"                                       ! >AllMonkCots
  with
    parsed_monk 0,
    parse_name [ w mk words_consumed;
      ! words_consumed = 0;
      w = NextWord();
      words_consumed++;

      ! Check for "my" cot
      if (w == 'my') {
        self.parsed_monk = player;
        w = NextWord();
        if (w == 0) return 0;
        if (w == 'cot' or 'bed') return 2;
        return 0;
      }

      ! Check for generic "cot" or "cots" or "bed"
      if (w == 'cot' or 'cots' or 'bed' or 'beds' or 'mattress'
            or 'mattresses') {
        if (NextWord() == 0) {
          self.parsed_monk = 0;
          return 1;
        }
      }

      ! Check for "Brother", ignore it
      if (w == 'brother') {
        w = NextWord();
        words_consumed++;
        if (w == 0) return 0;
      }

      ! Match monk name
      if (w == 'aelred' or 'aelreds' or 'aelred^s') mk = BrAelred;
      else if (w == 'hugh' or 'hughs' or 'hugh^s') mk = BrHugh;
      else if (w == 'martin' or 'martins' or 'martin^s') mk = BrMartin;
      else if (w == 'benedict' or 'benedicts' or 'benedict^s') mk = BrBenedict;
      else if (w == 'cuthbert' or 'cuthberts' or 'cuthbert^s') mk = BrCuthbert;
      else if (w == 'anselm' or 'anselms' or 'anselm^s') mk = BrAnselm;
      else if (w == 'wilfred' or 'wilfreds' or 'wilfred^s') mk = BrWilfred;
      else return 0;

      self.parsed_monk = mk;

      ! Check for what comes next---must be noun like "cot" or "bed"
      w = NextWord();
      if (w == 0) return 0;

      words_consumed++;
      if (w == 'cot' or 'bed' or 'mattress') return words_consumed;

      return 0;
    ],
    react_before [;
      Go:
        if (parent(player) == self) {
          print "(first getting up from your cot)^";
          move player to location;
        }
    ],
    short_name [;
      if (self.parsed_monk == player || self.parsed_monk == 0) {
        if (caps_mode) print "Y";
        else print "y";
        print "our ";
      }
      else print (the) self.parsed_monk, "'s ";
      print "cot";
      rtrue;
    ],
    description [;
      if (self.parsed_monk == 0)
        "The cots are simple straw mattresses on wooden frames,
        all identical. You'd need to specify which monk's cot.";
      print
        (The) self, " is like all the others---a simple straw mattress";
      if (self.parsed_monk == BrWilfred)
        print ". A faint scent of rosemary lingers";
      ".";
    ],
    before [;
      if (action ~= ##Examine or ##Exit && self.parsed_monk == 0)
        "Which monk's cot do you mean?";
      Search, LookUnder:
        if (suspicion_level == 0)
          print_ret (string) MSG_ANOTHER_BROTHERS_PROPERTY_WRONG;
      Smell:
        if (self.parsed_monk == BrWilfred)
            "Definitely rosemary. He must sleep with it sometimes.";
      Push, Pull, Turn:
        "You shouldn't rearrange the cots here. Leave them be.";
      Enter:
        if (self.parsed_monk == player)
          "The Rule discourages sloth. You've already risen for the day.";
        "That's ", (the) self, ". You shouldn't sleep there.";
    ],
    after [;
      Exit: "You leave your cot.";
    ]
  has
    scenery supporter enterable proper;


Object -> Chests "chests"                                              ! >Chests
  with
    name 'chests',
    description "The chests are simple wooden boxes with lids.",
    before [;
      Examine: ;
      default:
        "(If you want to do something to a chest,
        specify which one.)";
    ],
  has
    scenery pluralname;


Object -> MyChest "your chest"                                        ! >MyChest
  class AdjObject,
  with
    adj_name 'my',
    noun_name 'chest' 'box',
    description [;
      print
        "Your chest is just like all of the other brothers' chests:
        A simple wooden box with a lid";
      if (self has open) print ". It is open";
      ".";
    ]
  has
    proper scenery ~open openable container;


Chest -> ChestCuthbert                                          ! >ChestCuthbert
 with amonk BrCuthbert;

Chest -> ChestHugh                                                  ! >ChestHugh
  with amonk BrHugh;

Object -> -> Letters "letters"                                        ! >Letters
  class AdjObject,
  with
    adj_name 'rose',
    noun_name 'letters' 'letter',
    description "A set of letters on rough paper.",
    invent [;
      print "some letters";
      if (self has general) print " from Rose";
      rtrue;
    ],
    before [;
      Examine:
        ev_rose_letters = true;
        print "The first letter reads:^^";

        #Ifv5; @set_text_style 4; #EndIf;  ! bold
        print
          "Dearest Brother Hugh,

          ^^I write to you in desperation, though it shames me to beg.
          The harvest failed again this year, and what little we had
          has gone to the lord's rent. My William can barely stand now---his
          leg has worsened terribly since Candlemas.
          The wound festers and will not heal.

          ^^It must be cut, else the poison will spread to his heart.
          There is a surgeon in Norwich, but the cost---Hugh, it is
          three shillings. We have not three pence.

          ^^I have sold all I can: the good kettle, even the winter blankets.

          ^^I know the Rule forbids monks from keeping wealth.
          I know you have given all to God. But if there is any way,
          any kindness you might ask of your abbot, any alms the monastery
          might spare for Christian charity. My William will die without it.

          ^^Your sister in Christ and in blood,
          ^Rose";
        #Ifv5; @set_text_style 0; #EndIf;  ! roman (back to normal)

        print "^^The second letter reads:^^";

        #Ifv5; @set_text_style 4; #EndIf;  ! bold
        print
          "Dearest Hugh,

          ^^May God bless you a thousand times for your mercy.
          The two shillings came just as William could no longer
          rise from bed.

          ^^We took William to the surgeon. He cut the leg below the knee.
          It was terrible, Hugh, but necessary. William lives, praise God,
          though he is weak yet.

          ^^But the surgeon demands another shilling and sixpence still owed.
          He will not wait past Michaelmas. And now William cannot work at
          all---he who used to haul timber is now fit only to sit and weave
          baskets, if his strength returns.

          ^^I hate to ask again after your generosity. The shame burns in me.
          But Hugh, they will take our cottage for the debt. We
          have nowhere. Starvation comes.

          ^^If there is anything more you can do---any favour you might ask---I
          swear by Our Lady I will never ask again.
          One more shilling would save us.

          ^^Your grateful sister,
          ^Rose";
        #Ifv5; @set_text_style 0; #EndIf;  ! bold
        "";
    ],
  has
    pluralname evidence;


